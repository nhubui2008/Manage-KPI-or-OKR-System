@model Manage_KPI_or_OKR_System.Models.BonusRule
@{
    ViewData["Title"] = "Thêm Quy tắc thưởng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var ranks = ViewBag.AllRanks as List<Manage_KPI_or_OKR_System.Models.GradingRank> ?? new List<Manage_KPI_or_OKR_System.Models.GradingRank>();
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-dark fw-bold">
                <i class="bi bi-gift-fill me-2"></i>Thêm Quy tắc thưởng Mới
            </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-dark text-decoration-none opacity-75">Quy tắc thưởng</a></li>
                    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Thêm mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="content-card rounded-3">
                <div class="card-header-custom bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-star me-2"></i>Thông tin Quy tắc</h5>
                </div>
                <div class="card-body-custom p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="RankId" class="form-label fw-bold text-dark">Xếp loại áp dụng <span class="text-danger">*</span></label>
                            <select asp-for="RankId" class="form-select" required>
                                <option value="">-- Chọn mức xếp loại --</option>
                                @foreach (var r in ranks)
                                {
                                    <option value="@r.Id">@r.RankCode (@r.Description)</option>
                                }
                            </select>
                            <span asp-validation-for="RankId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="BonusPercentage" class="form-label fw-bold text-dark">Tỷ lệ thưởng (%) <span class="text-danger">*</span></label>
                            <input asp-for="BonusPercentage" type="number" step="0.1" class="form-control" placeholder="VD: 5.0, 10..." required />
                            <span asp-validation-for="BonusPercentage" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="FixedAmount" class="form-label fw-bold text-dark">Số tiền thưởng cố định (VNĐ)</label>
                            <input asp-for="FixedAmount" type="number" step="0.01" class="form-control" placeholder="Để trống nếu chỉ dùng tỷ lệ %" />
                            <span asp-validation-for="FixedAmount" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2 pt-3 border-top">
                            <a asp-action="Index" class="btn-outline-custom px-4">Hủy bỏ</a>
                            <button type="submit" class="btn-primary-custom px-4">
                                <i class="bi bi-save me-1"></i> Lưu Quy tắc
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
