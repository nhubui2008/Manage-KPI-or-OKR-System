@model List<Manage_KPI_or_OKR_System.Models.BonusRule>
@{
    ViewData["Title"] = "Chính sách Thưởng/Phạt";
    var ranks = ViewBag.Ranks as Dictionary<int, string> ?? new Dictionary<int, string>();
    var rankDescriptions = ViewBag.RankDescriptions as Dictionary<int, string> ?? new Dictionary<int, string>();
    var allRanks = ViewBag.AllRanks as List<Manage_KPI_or_OKR_System.Models.GradingRank> ?? new List<Manage_KPI_or_OKR_System.Models.GradingRank>();
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
        <div class="d-flex align-items-center">
            <i class="bi bi-check-circle-fill me-2 fs-5"></i>
            <div>@TempData["SuccessMessage"]</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container-fluid px-0">
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 font-weight-bold mb-1">Quy định Thưởng & Phạt KPI</h1>
            <div class="page-breadcrumb">
                <a href="/">Trang chủ</a><i class="bi bi-chevron-right separator"></i>
                <span>Chính sách thưởng/phạt</span>
            </div>
        </div>
        @if (!User.IsInRole("Employee") && !User.IsInRole("employee"))
        {
            <div class="d-flex justify-content-end gap-2">
                <button class="btn-primary-custom d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#createModal">
                    <i class="bi bi-plus-lg me-1"></i> Thêm quy định mới
                </button>
            </div>
        }
    </div>

    <div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100 shadow-sm border-0">
                <div class="card-body-custom p-0">
                    <div class="table-responsive w-100">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">Xếp loại áp dụng</th>
                                    <th>% Thưởng</th>
                                    <th>Số tiền cố định (VNĐ)</th>
                                    @if (!User.IsInRole("Employee") && !User.IsInRole("employee"))
                                    {
                                        <th class="text-end pe-4">Thao tác</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var r in Model)
                                    {
                                        var rankCode = r.RankId.HasValue && ranks.ContainsKey(r.RankId.Value) ? ranks[r.RankId.Value] : "N/A";
                                        var rankDesc = r.RankId.HasValue && rankDescriptions.ContainsKey(r.RankId.Value) ? rankDescriptions[r.RankId.Value] : "";
                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold text-dark">Xếp loại @rankCode</div>
                                                <div class="text-muted small">@rankDesc</div>
                                            </td>
                                            <td>
                                                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">
                                                    @(r.BonusPercentage?.ToString("0.##") ?? "0")%
                                                </span>
                                            </td>
                                            <td class="fw-bold text-primary">
                                                @(r.FixedAmount?.ToString("N0") ?? "0") <span class="small fw-normal text-muted">VNĐ</span>
                                            </td>
                                            @if (!User.IsInRole("Employee") && !User.IsInRole("employee"))
                                            {
                                                <td class="text-end pe-4">
                                                    <div class="d-flex justify-content-end gap-2">
                                                        <button type="button" class="btn btn-sm btn-outline-info rounded-circle" 
                                                                title="Chỉnh sửa" 
                                                                onclick="showEditModal('@r.Id', '@r.RankId', '@(r.BonusPercentage?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")', '@(r.FixedAmount?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")')">
                                                            <i class="bi bi-pencil-square"></i>
                                                        </button>
                                                        <form asp-action="Delete" method="post" class="m-0" onsubmit="return confirm('Bạn có chắc muốn xóa quy tắc thưởng này?');">
                                                            <input type="hidden" name="id" value="@r.Id" />
                                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle" title="Xóa">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </td>
                                            }
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-5">
                                            <i class="bi bi-inbox display-4 text-light mb-3 d-block"></i>
                                            <p class="mb-0">Chưa có quy tắc thưởng nào được định nghĩa.</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Thêm Mới -->
<div class="modal fade" id="createModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-cash-coin text-primary me-2"></i>Thêm Quy tắc Thưởng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted text-uppercase">Xếp hạng áp dụng</label>
                        <select name="RankId" class="form-select shadow-none" required>
                            <option value="">-- Chọn xếp hạng --</option>
                            @foreach (var rk in allRanks)
                            {
                                <option value="@rk.Id">@rk.RankCode - @rk.Description</option>
                            }
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted text-uppercase">Phần trăm thưởng (%)</label>
                            <div class="input-group">
                                <input type="number" name="BonusPercentage" class="form-control shadow-none" step="0.01" placeholder="0.00" />
                                <span class="input-group-text bg-light border-start-0">%</span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted text-uppercase">Số tiền cố định</label>
                            <div class="input-group">
                                <input type="text" name="FixedAmount" class="form-control shadow-none number-format" placeholder="0" />
                                <span class="input-group-text bg-light border-start-0">VNĐ</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0 px-4 pb-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn-primary-custom rounded-pill px-4">Tạo mới</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Chỉnh sửa -->
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square text-info me-2"></i>Chỉnh sửa Quy tắc</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Edit" method="post">
                <input type="hidden" name="Id" id="editId" />
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted text-uppercase">Xếp hạng áp dụng</label>
                        <select name="RankId" id="editRankId" class="form-select shadow-none" required>
                            <option value="">-- Chọn xếp hạng --</option>
                            @foreach (var rk in allRanks)
                            {
                                <option value="@rk.Id">@rk.RankCode - @rk.Description</option>
                            }
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted text-uppercase">Phần trăm thưởng (%)</label>
                            <div class="input-group">
                                <input type="number" name="BonusPercentage" id="editBonusPercentage" class="form-control shadow-none" step="0.01" />
                                <span class="input-group-text bg-light border-start-0">%</span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted text-uppercase">Số tiền cố định</label>
                            <div class="input-group">
                                <input type="text" name="FixedAmount" id="editFixedAmount" class="form-control shadow-none number-format" />
                                <span class="input-group-text bg-light border-start-0">VNĐ</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0 px-4 pb-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showEditModal(id, rankId, bonus, amount) {
            $('#editId').val(id);
            $('#editRankId').val(rankId);
            
            // Format bonus
            $('#editBonusPercentage').val(bonus ? parseFloat(bonus).toString() : '');
            
            // Format amount with dots for display
            let formattedAmount = amount ? amount.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".") : '';
            $('#editFixedAmount').val(formattedAmount);
            
            const modal = new bootstrap.Modal(document.getElementById('editModal'));
            modal.show();
        }

        $(document).ready(function() {
            // Thousands separator formatting in real-time
            $(document).on('input', '.number-format', function() {
                // Get raw value (digits only)
                let val = $(this).val().replace(/\D/g, '');
                // Format with dots
                $(this).val(val.replace(/\B(?=(\d{3})+(?!\d))/g, "."));
            });

            // Strip dots before any form submit on this page
            $('form').on('submit', function() {
                $(this).find('.number-format').each(function() {
                    let rawValue = $(this).val().replace(/\./g, '');
                    $(this).val(rawValue);
                });
            });
        });
    </script>
}