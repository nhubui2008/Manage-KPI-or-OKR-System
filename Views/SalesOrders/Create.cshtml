@model Manage_KPI_or_OKR_System.Models.SalesOrder
@{
    ViewData["Title"] = "Tạo Đơn bán hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var customers = ViewBag.Customers as List<Manage_KPI_or_OKR_System.Models.Customer> ?? new List<Manage_KPI_or_OKR_System.Models.Customer>();
    var employees = ViewBag.Employees as List<Manage_KPI_or_OKR_System.Models.Employee> ?? new List<Manage_KPI_or_OKR_System.Models.Employee>();
    var orderStatuses = ViewBag.OrderStatuses as List<string> ?? new List<string> { " Draft", "Confirmed", "Shipping", "Completed" };
}

<div class="page-content">
    <div class="page-header d-flex align-items-center justify-content-between mb-4 animate__animated animate__fadeIn">
        <div>
            <h1 class="mb-2 fw-800">Tạo Đơn bán hàng Mới</h1>
            <div class="page-breadcrumb">
                <a href="/">Trang chủ</a>
                <span class="separator">/</span>
                <a asp-action="Index">Quản lý Đơn hàng</a>
                <span class="separator">/</span>
                <span class="text-muted">Tạo mới</span>
            </div>
        </div>
        <div>
            <a asp-action="Index" class="btn-outline-custom shadow-sm">
                <i class="bi bi-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- FORM COLUMN -->
        <div class="col-xl-8 animate__animated animate__fadeInLeft">
            <div class="content-card border-0 shadow-lg" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">
                <div class="card-header-custom border-bottom bg-transparent py-4">
                    <h5 class="fw-bold fs-5 mb-0"><i class="bi bi-cart-plus-fill text-primary me-2"></i> Thông tin Đơn hàng</h5>
                </div>

                <div class="card-body-custom p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <!-- SECTION 1: THÔNG TIN ĐƠN -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-primary text-white me-3 d-flex align-items-center justify-content-center shadow" style="width: 38px; height: 38px; border-radius: 12px;">
                                <span class="fw-bold">1</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Thông tin đơn hàng</h6>
                        </div>

                        <div class="row g-4 mb-5 p-3 rounded-4 bg-light bg-opacity-50 border border-white">
                            <div class="col-md-5">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Mã đơn hàng <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-hash"></i>
                                        <input asp-for="OrderCode" class="form-control shadow-sm" placeholder="VD: DH2024001..." required />
                                    </div>
                                    <span asp-validation-for="OrderCode" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-7">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Khách hàng <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-person-fill"></i>
                                        <select asp-for="CustomerId" class="form-select shadow-sm" required>
                                            <option value="">-- Chọn khách hàng --</option>
                                            @foreach (var c in customers)
                                            {
                                                <option value="@c.Id">@c.CustomerName (@c.CustomerCode)</option>
                                            }
                                        </select>
                                    </div>
                                    <span asp-validation-for="CustomerId" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <!-- SECTION 2: CHI TIẾT -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-success text-white me-3 d-flex align-items-center justify-content-center shadow" style="width: 38px; height: 38px; border-radius: 12px;">
                                <span class="fw-bold">2</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Chi tiết & giao hàng</h6>
                        </div>

                        <div class="row g-4 p-3 rounded-4 bg-light bg-opacity-50 border border-white mb-4">
                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Nhân viên bán hàng</label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-person-badge"></i>
                                        <select asp-for="SalesStaffId" class="form-select shadow-sm">
                                            <option value="">-- Chọn nhân viên --</option>
                                            @foreach (var e in employees)
                                            {
                                                <option value="@e.Id">@e.FullName (@e.EmployeeCode)</option>
                                            }
                                        </select>
                                    </div>
                                    <span asp-validation-for="SalesStaffId" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Tổng giá trị đơn (VNĐ) <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-cash-stack"></i>
                                        <input asp-for="TotalAmount" type="number" step="0.01" class="form-control shadow-sm" id="totalAmountInput" placeholder="0.00" required />
                                    </div>
                                    <span asp-validation-for="TotalAmount" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-12">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Địa chỉ giao hàng</label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-geo-alt"></i>
                                        <input asp-for="ShippingAddress" class="form-control shadow-sm" placeholder="Nhập địa chỉ giao hàng cụ thể" />
                                    </div>
                                    <span asp-validation-for="ShippingAddress" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Ngày giao dự kiến</label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-calendar-check"></i>
                                        <input asp-for="ExpectedDeliveryDate" type="date" class="form-control shadow-sm" />
                                    </div>
                                    <span asp-validation-for="ExpectedDeliveryDate" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Trạng thái</label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-toggle-on"></i>
                                        <select asp-for="Status" class="form-select shadow-sm">
                                            @foreach (var stText in orderStatuses)
                                            {
                                                <option value="@stText">@stText</option>
                                            }
                                        </select>
                                    </div>
                                    <span asp-validation-for="Status" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                            <a asp-action="Index" class="btn-outline-custom">
                                <i class="bi bi-x-lg me-2"></i> Hủy thao tác
                            </a>
                            <button type="submit" class="btn-primary-custom" style="padding: 12px 40px; border-radius: 12px;">
                                <i class="bi bi-check-lg fs-5 me-2"></i> Tạo Đơn hàng
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- SIDEBAR COLUMN -->
        <div class="col-xl-4 animate__animated animate__fadeInRight">
            <div class="sticky-top" style="top: 100px;">
                <div class="content-card border-0 shadow-lg text-white mb-4" style="background: linear-gradient(135deg, #1a73e8, #1557b0); border-radius: 24px;">
                    <div class="card-body-custom p-4">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-white bg-opacity-20 p-3 rounded-4 me-3">
                                <i class="bi bi-cart-check fs-3 text-white"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 opacity-75 fw-bold text-uppercase small">Tổng giá trị</h6>
                                <h3 class="mb-0 fw-800" id="previewTotal">--</h3>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="small opacity-75 fw-bold text-uppercase mb-1">Mã đơn hàng</div>
                            <div class="fw-bold fs-6" id="previewCode" style="min-height: 24px;">--</div>
                        </div>
                        <div class="row g-3 mt-1">
                            <div class="col-6">
                                <div class="bg-white bg-opacity-10 p-3 rounded-4">
                                    <div class="small opacity-75 mb-1">Khách hàng</div>
                                    <div class="fw-bold small" id="previewCustomer">--</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-white bg-opacity-10 p-3 rounded-4">
                                    <div class="small opacity-75 mb-1">Trạng thái</div>
                                    <div class="fw-bold small" id="previewStatus">--</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="content-card border-0 shadow-sm rounded-4 bg-white p-4">
                    <h6 class="fw-bold text-dark mb-3"><i class="bi bi-info-circle text-primary me-2"></i> Lưu ý</h6>
                    <ul class="list-unstyled mb-0 small text-muted" style="line-height: 1.8;">
                        <li class="mb-2"><i class="bi bi-patch-check-fill text-success me-2"></i> Mã đơn phải là duy nhất trong hệ thống.</li>
                        <li class="mb-2"><i class="bi bi-patch-check-fill text-success me-2"></i> Chỉ đơn "Đã xác nhận" mới được tạo phiếu giao.</li>
                        <li><i class="bi bi-patch-check-fill text-success me-2"></i> Nhân viên bán hàng dùng để tính KPI doanh số.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    .letter-spacing-1 { letter-spacing: 0.1em; }
    .form-select, .form-control { border: 1.5px solid #edf2f7; padding-top: 12px; padding-bottom: 12px; }
    .form-select:focus, .form-control:focus { border-color: #a3c9f9; box-shadow: 0 0 0 4px rgba(163, 201, 249, 0.1); }
    .animate__animated { animation-duration: 0.8s; }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <script>
        const codeInput   = document.getElementById('OrderCode');
        const custSelect  = document.getElementById('CustomerId');
        const totalInput  = document.getElementById('totalAmountInput');
        const statusSelect= document.getElementById('Status');
        function updatePreview() {
            document.getElementById('previewCode').textContent = codeInput.value.trim().toUpperCase() || '--';
            const cOpt = custSelect.options[custSelect.selectedIndex];
            document.getElementById('previewCustomer').textContent = cOpt && cOpt.value ? cOpt.text : '--';
            document.getElementById('previewTotal').textContent = totalInput.value
                ? new Intl.NumberFormat('vi-VN').format(totalInput.value) + ' ₫' : '--';
            document.getElementById('previewStatus').textContent = statusSelect.options[statusSelect.selectedIndex]?.text || '--';
        }
        codeInput.addEventListener('input', updatePreview);
        totalInput.addEventListener('input', updatePreview);
        custSelect.addEventListener('change', updatePreview);
        statusSelect.addEventListener('change', updatePreview);
        window.addEventListener('DOMContentLoaded', updatePreview);
    </script>
}
