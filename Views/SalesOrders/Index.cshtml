@model List<Manage_KPI_or_OKR_System.Models.SalesOrder>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    var customers = ViewBag.Customers as Dictionary<int, string> ?? new Dictionary<int, string>();
    var employees = ViewBag.Employees as Dictionary<int, string> ?? new Dictionary<int, string>();
    var allCustomers = ViewBag.AllCustomers as List<Manage_KPI_or_OKR_System.Models.Customer> ?? new List<Manage_KPI_or_OKR_System.Models.Customer>();
    var allEmployees = ViewBag.AllEmployees as List<Manage_KPI_or_OKR_System.Models.Employee> ?? new List<Manage_KPI_or_OKR_System.Models.Employee>();
}
@if (TempData["SuccessMessage"] != null)
{<div class="alert alert-success alert-dismissible fade show" role="alert"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<style>
    /* Styling select2 for bootstrap consistency */
    .select2-container .select2-selection--single {
        height: 38px;
        border: 1px solid #ced4da;
        border-radius: 0.375rem;
    }
    .select2-container--default .select2-selection--single .select2-selection__rendered {
        line-height: 36px;
    }
    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 36px;
    }
</style>
<div class="page-header">
    <div><h1 class="h3 font-weight-bold mb-1">Đơn hàng Bán (Sales Orders)</h1><div class="page-breadcrumb"><a href="/">Trang chủ</a><i class="bi bi-chevron-right separator"></i><span>Bán hàng</span><i class="bi bi-chevron-right separator"></i><span>Đơn hàng</span></div></div>
    <div class="d-flex gap-2"><button class="btn-primary-custom" data-bs-toggle="modal" data-bs-target="#createModal"><i class="bi bi-plus-lg"></i> Tạo đơn hàng mới</button></div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3"><div class="stat-card p-3 border-start border-4 border-primary"><div class="text-muted" style="font-size:0.8rem;">Tổng đơn hàng</div><div class="fw-bold text-dark fs-4 mt-1">@(ViewBag.TotalOrders ?? 0)</div></div></div>
    <div class="col-md-3"><div class="stat-card p-3 border-start border-4 border-success"><div class="text-muted" style="font-size:0.8rem;">Đã hoàn thành</div><div class="fw-bold text-success fs-4 mt-1">@(ViewBag.CompletedOrders ?? 0)</div></div></div>
    <div class="col-md-3"><div class="stat-card p-3 border-start border-4 border-warning"><div class="text-muted" style="font-size:0.8rem;">Đang xử lý</div><div class="fw-bold text-warning fs-4 mt-1">@(ViewBag.ProcessingOrders ?? 0)</div></div></div>
    <div class="col-md-3"><div class="stat-card p-3 border-start border-4 border-danger"><div class="text-muted" style="font-size:0.8rem;">Đã hủy</div><div class="fw-bold text-danger fs-4 mt-1">@(ViewBag.CancelledOrders ?? 0)</div></div></div>
</div>

<div class="content-card"><div class="card-body-custom">
    <div class="toolbar"><div class="toolbar-left">
        <form method="get" class="d-flex gap-2"><div class="toolbar-search"><i class="bi bi-search"></i><input type="text" name="searchString" value="@ViewBag.CurrentSearch" placeholder="Tìm theo mã đơn..."></div>
        <select name="status" class="filter-select"><option value="">Tất cả trạng thái</option><option value="Chờ xác nhận">Chờ xác nhận</option><option value="Đang xử lý">Đang xử lý</option><option value="Đang giao">Đang giao</option><option value="Hoàn thành">Hoàn thành</option><option value="Đã hủy">Đã hủy</option></select>
        <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-funnel"></i></button></form>
    </div></div>

    <div class="table-responsive"><table class="data-table">
        <thead><tr><th>Mã Đơn</th><th>Ngày tạo</th><th>Khách hàng</th><th>Nhân viên</th><th class="text-end">Tổng tiền (VNĐ)</th><th>Trạng thái</th><th class="text-end">Thao tác</th></tr></thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var s in Model)
                {
                    var custName = s.CustomerId.HasValue && customers.ContainsKey(s.CustomerId.Value) ? customers[s.CustomerId.Value] : "N/A";
                    var empName = s.SalesStaffId.HasValue && employees.ContainsKey(s.SalesStaffId.Value) ? employees[s.SalesStaffId.Value] : "N/A";
                    var statusClass = s.Status == "Hoàn thành" ? "bg-success text-white" : s.Status == "Đã hủy" ? "bg-danger bg-opacity-10 text-danger" : s.Status == "Đang giao" ? "bg-info text-white" : "bg-warning text-dark";
                    <tr>
                        <td><span class="fw-bold text-primary">@s.OrderCode</span></td>
                        <td><div class="fw-medium text-dark">@(s.CreatedAt?.ToString("dd/MM/yyyy") ?? "")</div><div class="text-muted" style="font-size:0.75rem;">@(s.CreatedAt?.ToString("HH:mm") ?? "")</div></td>
                        <td class="fw-semibold text-dark">@custName</td>
                        <td class="text-dark" style="font-size:0.85rem;">@empName</td>
                        <td class="text-end fw-semibold @(s.Status == "Đã hủy" ? "text-muted text-decoration-line-through" : "")">@(s.TotalAmount?.ToString("N0") ?? "0")</td>
                        <td><span class="badge @statusClass px-2 py-1 rounded-pill">@(s.Status ?? "N/A")</span></td>
                        <td><div class="action-btns justify-content-end">
                            <form asp-action="Delete" method="post" style="display:inline;"><input type="hidden" name="id" value="@s.Id" /><button type="submit" class="action-btn danger" title="Xóa" onclick="return confirm('Vô hiệu hóa đơn hàng?')"><i class="bi bi-trash"></i></button></form>
                        </div></td>
                    </tr>
                }
            }
            else
            {<tr><td colspan="7" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;"></i><p class="mt-2">Chưa có đơn hàng nào</p></td></tr>}
        </tbody>
    </table></div>
</div></div>

<div class="modal fade" id="createModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content border-0 shadow">
    <div class="modal-header border-0"><h5 class="modal-title fw-bold"><i class="bi bi-cart-plus me-2"></i>Tạo Đơn hàng</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form asp-action="Create" method="post"><div class="modal-body">
        <div class="mb-3"><label class="form-label fw-semibold">Mã đơn hàng</label><input type="text" name="OrderCode" class="form-control" required placeholder="VD: SO-2603-0001" /></div>
        <div class="mb-3"><label class="form-label fw-semibold">Khách hàng</label><select name="CustomerId" class="form-select select2-sales" required>
            <option value="">-- Chọn khách hàng --</option>@foreach(var c in allCustomers){<option value="@c.Id">@c.CustomerName (@c.CustomerCode)</option>}</select></div>
        <div class="mb-3"><label class="form-label fw-semibold">Nhân viên phụ trách</label><select name="SalesStaffId" class="form-select select2-sales">
            <option value="">-- Chọn nhân viên --</option>@foreach(var e in allEmployees){<option value="@e.Id">@e.FullName</option>}</select></div>
        <div class="mb-3"><label class="form-label fw-semibold">Địa chỉ giao hàng</label><textarea name="ShippingAddress" class="form-control" rows="2"></textarea></div>
        <div class="row"><div class="col-6 mb-3"><label class="form-label fw-semibold">Tổng tiền (VNĐ)</label><input type="number" name="TotalAmount" class="form-control" step="1000" /></div>
        <div class="col-6 mb-3"><label class="form-label fw-semibold">Ngày giao dự kiến</label><input type="date" name="ExpectedDeliveryDate" class="form-control" /></div></div>
    </div>
    <div class="modal-footer border-0"><button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn-primary-custom">Tạo đơn hàng</button></div></form>
</div></div></div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.select2-sales').select2({
                dropdownParent: $('#createModal'),
                width: '100%',
                placeholder: 'Tìm kiếm hoặc chọn...',
                allowClear: true
            });
        });
    </script>
}
