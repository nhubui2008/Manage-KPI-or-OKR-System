@{
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<div class="page-header">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Đơn hàng Bán (Sales Orders)</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Bán hàng</span>
            <i class="bi bi-chevron-right separator"></i>
            <span>Đơn hàng</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn-outline-custom">
            <i class="bi bi-file-earmark-arrow-up"></i> Xuất Excel
        </button>
        <button class="btn-primary-custom">
            <i class="bi bi-plus-lg"></i> Tạo đơn hàng mới
        </button>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="stat-card p-3 border-start border-4 border-primary">
            <div class="text-muted" style="font-size: 0.8rem;">Tổng đơn hàng (Tháng này)</div>
            <div class="fw-bold text-dark fs-4 mt-1">1,245</div>
            <div class="text-success mt-2" style="font-size: 0.75rem;"><i class="bi bi-arrow-up-right"></i> +12% so với tháng trước</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card p-3 border-start border-4 border-success">
            <div class="text-muted" style="font-size: 0.8rem;">Đã hoàn thành</div>
            <div class="fw-bold text-success fs-4 mt-1">980</div>
            <div class="text-muted mt-2" style="font-size: 0.75rem;">Chiếm 78.7% tổng số đơn</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card p-3 border-start border-4 border-warning">
            <div class="text-muted" style="font-size: 0.8rem;">Đang xử lý</div>
            <div class="fw-bold text-warning fs-4 mt-1">215</div>
            <div class="text-muted mt-2" style="font-size: 0.75rem;">15 đơn cần xử lý gấp</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card p-3 border-start border-4 border-danger">
            <div class="text-muted" style="font-size: 0.8rem;">Khách hàng hủy</div>
            <div class="fw-bold text-danger fs-4 mt-1">50</div>
            <div class="text-danger mt-2" style="font-size: 0.75rem;"><i class="bi bi-arrow-up-right"></i> Tăng 5% so với tháng trước</div>
        </div>
    </div>
</div>

<div class="content-card">
    <div class="card-body-custom">
        <div class="toolbar">
            <div class="toolbar-left">
                <div class="toolbar-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Tìm theo mã đơn, khách hàng...">
                </div>
                <div class="d-flex align-items-center gap-2 border rounded px-2 bg-light bg-opacity-50">
                    <i class="bi bi-calendar3 text-muted"></i>
                    <input type="date" class="form-control form-control-sm border-0 bg-transparent shadow-none w-auto" value="2026-02-01">
                    <span class="text-muted">-</span>
                    <input type="date" class="form-control form-control-sm border-0 bg-transparent shadow-none w-auto" value="2026-02-28">
                </div>
                <select class="filter-select">
                    <option value="">Trạng thái</option>
                    <option value="pending">Chờ xác nhận</option>
                    <option value="processing">Đang xử lý</option>
                    <option value="shipping">Đang giao</option>
                    <option value="completed">Hoàn thành</option>
                    <option value="cancelled">Đã hủy</option>
                </select>
            </div>
            <div class="toolbar-right">
                <button class="btn btn-sm btn-outline-secondary border-0"><i class="bi bi-gear"></i> Setup cột</button>
            </div>
        </div>

