@model List<Manage_KPI_or_OKR_System.Models.SalesOrder>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    var customers = ViewBag.Customers as Dictionary<int, string> ?? new Dictionary<int, string>();
    var employees = ViewBag.Employees as Dictionary<int, string> ?? new Dictionary<int, string>();
    var allCustomers = ViewBag.AllCustomers as List<Manage_KPI_or_OKR_System.Models.Customer> ?? new List<Manage_KPI_or_OKR_System.Models.Customer>();
    var allEmployees = ViewBag.AllEmployees as List<Manage_KPI_or_OKR_System.Models.Employee> ?? new List<Manage_KPI_or_OKR_System.Models.Employee>();
}
@if (TempData["SuccessMessage"] != null)
{<div class="alert alert-success alert-dismissible fade show" role="alert"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="h3 font-weight-bold mb-1">Đơn hàng Bán (Sales Orders)</h1><div class="page-breadcrumb"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a><i class="bi bi-chevron-right separator"></i><span class="text-dark opacity-75">Bán hàng</span><i class="bi bi-chevron-right separator"></i><span class="text-dark fw-bold">Đơn hàng</span></div></div>
    <div class="d-flex justify-content-end gap-2"><a asp-action="Create" class="btn-primary-custom d-flex align-items-center text-decoration-none"><i class="bi bi-plus-lg me-1"></i> Tạo đơn hàng mới</a></div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3"><div class="stat-card p-3 border-start border-4 border-primary"><div class="text-muted" style="font-size:0.8rem;">Tổng đơn hàng</div><div class="fw-bold text-dark fs-4 mt-1">@(ViewBag.TotalOrders ?? 0)</div></div></div>
    <div class="col-md-3"><div class="stat-card p-3 border-start border-4 border-success"><div class="text-muted" style="font-size:0.8rem;">Đã hoàn thành</div><div class="fw-bold text-success fs-4 mt-1">@(ViewBag.CompletedOrders ?? 0)</div></div></div>
    <div class="col-md-3"><div class="stat-card p-3 border-start border-4 border-warning"><div class="text-muted" style="font-size:0.8rem;">Đang xử lý</div><div class="fw-bold text-warning fs-4 mt-1">@(ViewBag.ProcessingOrders ?? 0)</div></div></div>
    <div class="col-md-3"><div class="stat-card p-3 border-start border-4 border-danger"><div class="text-muted" style="font-size:0.8rem;">Đã hủy</div><div class="fw-bold text-danger fs-4 mt-1">@(ViewBag.CancelledOrders ?? 0)</div></div></div>
</div>

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100"><div class="card-body-custom">
    <form method="get" class="toolbar">
        <div class="toolbar-left d-flex gap-3 flex-wrap flex-grow-1">
            <div class="search-wrapper-premium" style="max-width: 350px;">
                <i class="bi bi-search"></i>
                <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="search-input-premium" placeholder="Tìm theo mã đơn...">
            </div>
            
            <div class="premium-select-wrapper" style="min-width: 200px;">
                <span class="select-label">Trạng thái</span>
                <i class="bi bi-truck lead-icon"></i>
                <select name="status">
                    <option value="">Tất cả trạng thái</option>
                    <option value="Chờ xác nhận">Chờ xác nhận</option>
                    <option value="Đang xử lý">Đang xử lý</option>
                    <option value="Đang giao">Đang giao</option>
                    <option value="Hoàn thành">Hoàn thành</option>
                    <option value="Đã hủy">Đã hủy</option>
                </select>
            </div>
        </div>
        <div class="toolbar-right d-flex gap-2 align-items-center">
            <button type="submit" class="btn-filter-premium">
                <i class="bi bi-funnel-fill"></i> Lọc
            </button>
            <a asp-action="Index" class="btn-refresh-premium" title="Làm mới">
                <i class="bi bi-arrow-clockwise fs-5"></i>
            </a>
        </div>
    </form>

    <div class="table-responsive w-100"><table class="data-table w-100">
        <thead><tr><th>Mã Đơn</th><th>Ngày tạo</th><th>Khách hàng</th><th>Nhân viên</th><th class="text-end">Tổng tiền (VNĐ)</th><th>Trạng thái</th><th class="text-end">Thao tác</th></tr></thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var s in Model)
                {
                    var custName = s.CustomerId.HasValue && customers.ContainsKey(s.CustomerId.Value) ? customers[s.CustomerId.Value] : "N/A";
                    var empName = s.SalesStaffId.HasValue && employees.ContainsKey(s.SalesStaffId.Value) ? employees[s.SalesStaffId.Value] : "N/A";
                    var statusClass = s.Status == "Hoàn thành" ? "bg-success text-white" : s.Status == "Đã hủy" ? "bg-danger bg-opacity-10 text-danger" : s.Status == "Đang giao" ? "bg-info text-white" : "bg-warning text-dark";
                    <tr>
                        <td><span class="fw-bold text-dark">@s.OrderCode</span></td>
                        <td><div class="fw-medium text-dark">@(s.CreatedAt?.ToString("dd/MM/yyyy") ?? "")</div><div class="text-muted" style="font-size:0.75rem;">@(s.CreatedAt?.ToString("HH:mm") ?? "")</div></td>
                        <td class="fw-semibold text-dark">@custName</td>
                        <td class="text-dark" style="font-size:0.85rem;">@empName</td>
                        <td class="text-end fw-semibold @(s.Status == "Đã hủy" ? "text-muted text-decoration-line-through" : "")">@(s.TotalAmount?.ToString("N0") ?? "0")</td>
                        <td><span class="badge @statusClass px-2 py-1 rounded-pill">@(s.Status ?? "N/A")</span></td>
                        <td><div class="action-btns justify-content-end">
                            <button type="button" class="action-btn" title="Sửa" onclick="showComingSoonToast('Chỉnh sửa Đơn hàng')"><i class="bi bi-pencil-square"></i></button>
                            <form asp-action="Delete" method="post" style="display:inline;"><input type="hidden" name="id" value="@s.Id" /><button type="submit" class="action-btn danger" title="Xóa" onclick="return confirm('Vô hiệu hóa đơn hàng?')"><i class="bi bi-trash"></i></button></form>
                        </div></td>
                    </tr>
                }
            }
            else
            {<tr><td colspan="7" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;"></i><p class="mt-2">Chưa có đơn hàng nào</p></td></tr>}
        </tbody>
    </table></div>
</div></div>


        </div>
    </div>
</div>