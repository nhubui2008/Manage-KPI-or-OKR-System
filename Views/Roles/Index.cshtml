@model IEnumerable<Manage_KPI_or_OKR_System.Models.Role>
@{
    ViewData["Title"] = "Quản lý Vai trò (Roles)";
    
    string GetRoleColor(string roleName) 
    {
        roleName = roleName?.ToLower() ?? "";
        if (roleName.Contains("admin")) return "dark";
        if (roleName.Contains("manager")) return "secondary";
        return "dark";
    }
    
    string GetRoleIcon(string roleName) 
    {
        roleName = roleName?.ToLower() ?? "";
        if (roleName.Contains("admin")) return "shield-lock-fill";
        if (roleName.Contains("manager")) return "person-badge-fill";
        return "person-fill";
    }
}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Phân quyền Hệ thống</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Hệ thống</span>
            <i class="bi bi-chevron-right separator"></i>
            <span>Quản lý roles</span>
        </div>
    </div>
    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Create" class="btn-primary-custom d-flex align-items-center">
            <i class="bi bi-shield-plus me-1"></i> Tạo Role mới
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success shadow-sm border-0 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger shadow-sm border-0 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
    </div>
}

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="row g-4 w-100">
    @if (Model != null && Model.Any())
    {
        foreach (var role in Model)
        {
            var roleName = role.RoleName ?? "";
            var color = GetRoleColor(roleName);
            var icon = GetRoleIcon(roleName);

            <div class="col-md-4">
                <div class="content-card h-100 position-relative">
                    @if (color == "danger")
                    {
                        <div class="position-absolute top-0 end-0 p-3">
                            <span class="badge bg-danger rounded-pill"><i class="bi bi-star-fill me-1"></i>Toàn quyền</span>
                        </div>
                    }
                    <div class="card-body-custom p-4">
                        <div class="d-inline-flex align-items-center justify-content-center bg-@color bg-opacity-10 text-@color rounded-circle mb-3 border border-@color border-opacity-25" style="width: 48px; height: 48px; font-size: 1.25rem;">
                            <i class="bi bi-@icon"></i>
                        </div>
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h5 class="fw-bold text-dark mb-0">@role.RoleName</h5>
                        </div>
                        <p class="text-muted mb-4 mt-2" style="font-size: 0.85rem; height: 40px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                            @(string.IsNullOrEmpty(role.Description) ? "Không có mô tả..." : role.Description)
                        </p>
                        
                        <div class="d-flex align-items-center gap-2 mb-3 pb-3 border-bottom">
                            <div class="user-avatar bg-dark text-white" style="width: 24px; height: 24px; font-size: 0.6rem;">
                                <i class="bi bi-people"></i>
                            </div>
                            <span class="fw-medium text-muted" style="font-size: 0.85rem;">Phân quyền người dùng</span>
                        </div>
                        
                        <div class="d-flex justify-content-end gap-2">
                            <button class="btn btn-sm btn-outline-@color flex-grow-1" onclick="showComingSoonToast('Cấu hình chi tiết quyền')">Cấu hình chi tiết</button>
                            <form asp-action="Delete" asp-route-id="@role.Id" method="post" class="m-0" onsubmit="return confirm('Bạn có chắc chắn muốn xóa quyền này?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa role" @(color == "danger" ? "disabled" : "")>
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-secondary border-0 shadow-sm text-center p-5 bg-light">
                <i class="bi bi-shield-x display-4 text-muted mb-3 d-block"></i>
                <h5 class="text-dark fw-bold">Chưa có nhóm quyền nào</h5>
                <p class="text-muted mb-4">Bạn cần tạo mới các nhóm quyền để có thể phân loại người dùng trong hệ thống.</p>
                <a asp-action="Create" class="btn-primary-custom px-4 rounded-pill">Tạo Role đầu tiên</a>
            </div>
        </div>
    }
</div>


        </div>
    </div>
</div>