@model Manage_KPI_or_OKR_System.Models.Role
@{
    ViewData["Title"] = "Tạo Nhóm Quyền Mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-content py-4 container-fluid px-4">
    <!-- HEADER -->
    <div class="page-header d-flex align-items-center justify-content-between mb-4 animate__animated animate__fadeIn">
        <div>
            <h1 class="mb-2 fw-800 text-dark text-gradient">Tạo Nhóm Quyền Mới</h1>
            <div class="page-breadcrumb">
                <a href="/" class="text-decoration-none opacity-75">Trang chủ</a>
                <span class="separator mx-2 text-muted">/</span>
                <a asp-action="Index" class="text-decoration-none opacity-75">Phân quyền Hệ thống</a>
                <span class="separator mx-2 text-muted">/</span>
                <span class="text-primary fw-bold">Tạo mới</span>
            </div>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-light shadow-sm border-0 bg-white px-4 py-2" style="border-radius: 12px; font-weight: 600; color: #475569; transition: all 0.3s;">
                <i class="bi bi-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- ======== FORM COLUMN ======== -->
        <div class="col-xl-8 animate__animated animate__fadeInLeft">
            <div class="content-card border-0 shadow-lg overflow-visible" style="background: rgba(255,255,255,0.97); backdrop-filter: blur(20px); border-radius: 24px;">
                <!-- Card Header -->
                <div class="card-header-custom border-bottom bg-white bg-opacity-50 py-4 px-4" style="border-radius: 24px 24px 0 0;">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary bg-opacity-10 p-3 rounded-4 me-3">
                            <i class="bi bi-shield-plus-fill text-primary fs-4"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold fs-5 mb-0 text-dark">Định nghĩa Nhóm Quyền</h5>
                            <p class="text-muted small mb-0">Thiết lập tên và mô tả chi tiết cho nhóm quyền truy cập mới</p>
                        </div>
                    </div>
                </div>

                <!-- Card Body -->
                <div class="card-body-custom p-4 p-md-5">
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 rounded-4 mb-4" role="alert">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-exclamation-octagon-fill fs-4 me-3"></i>
                                <div>
                                    <strong>Lỗi!</strong> @ViewBag.ErrorMessage
                                </div>
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Create" method="post" id="createRoleForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <!-- SECTION 1: ĐỊNH NGHĨA QUYỀN -->
                        <div class="form-section mb-4">
                            <div class="d-flex align-items-center mb-4">
                                <span class="badge bg-primary me-2" style="width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:0.85rem;">1</span>
                                <h6 class="text-uppercase fw-800 text-muted small mb-0 tracking-wider">Thông tin nhận diện</h6>
                            </div>

                            <div class="row g-4">
                                <!-- Tên nhóm quyền -->
                                <div class="col-md-12">
                                    <div class="form-icon-group text-dark">
                                        <label class="form-label small fw-bold text-secondary">
                                            Tên nhóm quyền <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-wrapper shadow-sm rounded-3 overflow-hidden border">
                                            <i class="bi bi-shield"></i>
                                            <input type="text"
                                                   id="roleName"
                                                   name="roleName"
                                                   class="form-control border-0"
                                                   placeholder="VD: HRManager, AccountingLead, SalesStaff..."
                                                   required
                                                   autocomplete="off"
                                                   style="padding-left: 45px; height: 50px;" />
                                        </div>
                                        <div class="form-text mt-2 small text-muted">
                                            <i class="bi bi-info-circle me-1"></i>
                                            Dùng tên tiếng Anh, không dấu, viết liền (VD: <strong>HRManager</strong>, <strong>SalesLead</strong>). Tên phải là duy nhất trong hệ thống.
                                        </div>
                                    </div>
                                </div>

                                <!-- Mô tả -->
                                <div class="col-md-12">
                                    <div class="form-icon-group text-dark">
                                        <label class="form-label small fw-bold text-secondary">Mô tả chức năng & phạm vi quyền hạn</label>
                                        <div class="input-wrapper shadow-sm rounded-3 overflow-hidden border" style="height: auto;">
                                            <i class="bi bi-textarea-t" style="top: 22px; transform: none;"></i>
                                            <textarea id="description"
                                                      name="description"
                                                      class="form-control border-0"
                                                      rows="5"
                                                      placeholder="Mô tả chi tiết các chức năng mà nhóm quyền này có thể thực hiện trong hệ thống..."
                                                      style="padding-left: 45px; border-radius: 12px; resize: none;"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SECTION 2: CẤU HÌNH BỔ SUNG -->
                        <div class="form-section mb-4">
                            <div class="d-flex align-items-center mb-4">
                                <span class="badge bg-success me-2" style="width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:0.85rem;">2</span>
                                <h6 class="text-uppercase fw-800 text-muted small mb-0 tracking-wider">Cấu hình trạng thái</h6>
                            </div>

                            <div class="row g-4 align-items-center">
                                <div class="col-md-12">
                                    <div class="d-flex align-items-center gap-3 p-3 bg-success bg-opacity-10 rounded-4 border border-success border-opacity-10">
                                        <div class="form-check form-switch fs-5 mb-0">
                                            <input type="checkbox"
                                                   class="form-check-input"
                                                   id="isActiveSwitch"
                                                   name="IsActive"
                                                   value="true"
                                                   checked />
                                        </div>
                                        <div>
                                            <label class="form-check-label fw-bold text-dark d-block" for="isActiveSwitch">
                                                Kích hoạt nhóm quyền ngay
                                            </label>
                                            <span class="small text-muted">Nhóm quyền sẽ có hiệu lực ngay sau khi được tạo và có thể gán cho tài khoản người dùng.</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-12">
                                    <div class="d-flex align-items-start gap-3 p-3 bg-warning bg-opacity-10 rounded-4 border border-warning border-opacity-10">
                                        <i class="bi bi-lightbulb-fill text-warning fs-4 mt-1 flex-shrink-0"></i>
                                        <div class="small text-muted">
                                            <strong class="text-dark">Bước tiếp theo:</strong> Sau khi tạo nhóm quyền, bạn có thể vào <strong>"Cấu hình Quyền chi tiết"</strong> để gán các mã quyền cụ thể (Permission Codes) cho nhóm này, kiểm soát chính xác từng tính năng mà nhóm được phép truy cập.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ACTIONS -->
                        <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 12px; font-weight: 600; border: 1.5px solid #e2e8f0;">
                                <i class="bi bi-x-lg me-2"></i> Hủy bỏ
                            </a>
                            <button type="submit" class="btn btn-primary px-5 py-2 shadow-lg" style="border-radius: 12px; font-weight: 700; background: linear-gradient(135deg, #0078d4 0%, #005a9e 100%); border: none;">
                                <i class="bi bi-shield-plus me-2"></i> Tạo Nhóm Quyền
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- ======== SIDEBAR COLUMN ======== -->
        <div class="col-xl-4 animate__animated animate__fadeInRight">
            <div class="sticky-top" style="top: 100px;">

                <!-- LIVE PREVIEW CARD -->
                <div class="content-card border-0 shadow-lg text-white mb-4 position-relative overflow-hidden"
                     style="background: linear-gradient(135deg, #0078d4, #005a9e); border-radius: 24px;">
                    <!-- Decorative blobs -->
                    <div style="position:absolute;top:-30px;right:-30px;width:120px;height:120px;background:rgba(255,255,255,0.07);border-radius:50%;"></div>
                    <div style="position:absolute;bottom:-20px;left:-20px;width:80px;height:80px;background:rgba(255,255,255,0.05);border-radius:50%;"></div>

                    <div class="card-body-custom p-4 position-relative">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-white bg-opacity-20 p-3 rounded-4 me-3">
                                <i class="bi bi-shield-check fs-3 text-white"></i>
                            </div>
                            <div>
                                <div class="small opacity-75 fw-bold text-uppercase">Xem trước</div>
                                <h4 class="mb-0 fw-800" id="previewName" style="transition: all 0.3s ease;">--</h4>
                            </div>
                        </div>

                        <div class="bg-white bg-opacity-10 p-3 rounded-4 mb-3">
                            <div class="small opacity-75 mb-1"><i class="bi bi-text-paragraph me-1"></i> Mô tả</div>
                            <div class="fw-500 small" id="previewDesc" style="min-height: 24px; line-height: 1.6; transition: all 0.3s ease;">--</div>
                        </div>

                        <div class="d-flex gap-2">
                            <div class="bg-white bg-opacity-10 px-3 py-2 rounded-3 flex-fill text-center">
                                <div class="small opacity-75">Trạng thái</div>
                                <div class="fw-bold small" id="previewStatus">
                                    <i class="bi bi-check-circle-fill text-warning"></i> Hoạt động
                                </div>
                            </div>
                            <div class="bg-white bg-opacity-10 px-3 py-2 rounded-3 flex-fill text-center">
                                <div class="small opacity-75">Quyền hạn</div>
                                <div class="fw-bold small">
                                    <i class="bi bi-lock text-warning"></i> Chưa cấu hình
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- INFO / NOTES CARD -->
                <div class="content-card border-0 shadow-sm rounded-4 bg-white p-4 mb-4">
                    <h6 class="fw-bold text-dark mb-4">
                        <i class="bi bi-info-circle text-primary me-2"></i> Lưu ý quan trọng
                    </h6>
                    <div class="list-group list-group-flush">
                        <div class="list-group-item px-0 py-3 border-0">
                            <div class="d-flex align-items-start">
                                <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 me-3 flex-shrink-0">
                                    <i class="bi bi-keyboard"></i>
                                </div>
                                <p class="small text-muted mb-0">
                                    <strong>Tên nhóm quyền</strong> phải là duy nhất — không được trùng với nhóm quyền đã có trong hệ thống.
                                </p>
                            </div>
                        </div>
                        <div class="list-group-item px-0 py-3 border-0">
                            <div class="d-flex align-items-start">
                                <div class="bg-success bg-opacity-10 text-success p-2 rounded-3 me-3 flex-shrink-0">
                                    <i class="bi bi-translate"></i>
                                </div>
                                <p class="small text-muted mb-0">
                                    <strong>Dùng tiếng Anh</strong>, viết liền, không dấu, không khoảng trắng (VD: <code>HRManager</code>).
                                </p>
                            </div>
                        </div>
                        <div class="list-group-item px-0 py-3 border-0">
                            <div class="d-flex align-items-start">
                                <div class="bg-warning bg-opacity-10 text-warning p-2 rounded-3 me-3 flex-shrink-0">
                                    <i class="bi bi-people"></i>
                                </div>
                                <p class="small text-muted mb-0">
                                    Quyền này sẽ được <strong>gán cho Tài khoản Người dùng</strong> để kiểm soát quyền truy cập vào từng tính năng.
                                </p>
                            </div>
                        </div>
                        <div class="list-group-item px-0 py-3 border-0">
                            <div class="d-flex align-items-start">
                                <div class="bg-info bg-opacity-10 text-info p-2 rounded-3 me-3 flex-shrink-0">
                                    <i class="bi bi-gear"></i>
                                </div>
                                <p class="small text-muted mb-0">
                                    Sau khi tạo, vào <strong>"Cấu hình Quyền"</strong> để thiết lập chi tiết các permission code.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- QUICK ROLES REFERENCE -->
                <div class="content-card border-0 shadow-sm rounded-4 bg-white p-4">
                    <h6 class="fw-bold text-dark mb-3">
                        <i class="bi bi-bookmark-star text-warning me-2"></i> Gợi ý tên phổ biến
                    </h6>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var role in new[] { "Admin", "HRManager", "SalesStaff", "Accountant", "Warehouse", "DeliveryStaff", "Manager", "Director" })
                        {
                            <span class="badge rounded-pill px-3 py-2 role-suggestion"
                                  style="background: #f1f5f9; color: #475569; font-size: 0.78rem; cursor: pointer; border: 1px solid #e2e8f0; transition: all 0.2s;"
                                  data-role="@role">
                                @role
                            </span>
                        }
                    </div>
                    <div class="form-text mt-2 small text-muted">
                        <i class="bi bi-hand-index me-1"></i> Click để điền vào ô nhập tên.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* ======== TYPOGRAPHY ======== */
    .fw-800 { font-weight: 800; }
    .fw-500 { font-weight: 500; }
    .tracking-wider { letter-spacing: 0.06em; }
    .text-gradient {
        background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* ======== FORM SECTIONS ======== */
    .form-section {
        background: rgba(248, 250, 252, 0.6);
        padding: 22px 20px;
        border-radius: 16px;
        border: 1px solid #f1f5f9;
        transition: all 0.3s ease;
    }
    .form-section:hover {
        background: rgba(248, 250, 252, 0.9);
        border-color: #e2e8f0;
        box-shadow: 0 4px 15px rgba(0,0,0,0.04);
    }

    /* ======== ICON INPUT GROUPS ======== */
    .form-icon-group { position: relative; }

    .form-icon-group .input-wrapper {
        position: relative;
        transition: all 0.3s ease;
        background: #fff;
    }
    .form-icon-group .input-wrapper:focus-within {
        border-color: #0078d4 !important;
        box-shadow: 0 8px 15px -5px rgba(0,120,212,0.15) !important;
        transform: translateY(-1px);
    }
    .form-icon-group .input-wrapper i {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: 1.1rem;
        z-index: 10;
        transition: color 0.3s;
        pointer-events: none;
    }
    .form-icon-group .input-wrapper:focus-within i {
        color: #0078d4;
    }
    .form-control:focus, .form-select:focus {
        box-shadow: none !important;
        color: #1e293b;
        background-color: transparent;
    }

    /* ======== TEXTAREA ICON FIX ======== */
    .form-icon-group .input-wrapper.textarea-wrapper i {
        top: 18px;
        transform: none;
    }

    /* ======== ROLE SUGGESTION BADGE HOVER ======== */
    .role-suggestion:hover {
        background: #0078d4 !important;
        color: #fff !important;
        border-color: #0078d4 !important;
        transform: translateY(-1px);
        box-shadow: 0 4px 10px rgba(0,120,212,0.2);
    }

    /* ======== ANIMATION ======== */
    .animate__animated { animation-duration: 0.75s; }

    /* ======== FORM SWITCH ======== */
    .form-check-input[type="checkbox"] {
        width: 3em;
        height: 1.6em;
        cursor: pointer;
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <script>
        // ===== LIVE PREVIEW =====
        const nameInput   = document.getElementById('roleName');
        const descInput   = document.getElementById('description');
        const switchInput = document.getElementById('isActiveSwitch');
        const previewName   = document.getElementById('previewName');
        const previewDesc   = document.getElementById('previewDesc');
        const previewStatus = document.getElementById('previewStatus');

        function updatePreview() {
            const name = nameInput.value.trim();
            const desc = descInput.value.trim();
            const active = switchInput.checked;

            // Animate name change
            previewName.style.opacity = '0';
            setTimeout(() => {
                previewName.textContent = name || '--';
                previewName.style.opacity = '1';
            }, 150);

            previewDesc.textContent = desc || '--';

            if (active) {
                previewStatus.innerHTML = '<i class="bi bi-check-circle-fill text-warning"></i> Hoạt động';
            } else {
                previewStatus.innerHTML = '<i class="bi bi-pause-circle-fill" style="color:#fca5a5"></i> Tạm khóa';
            }
        }

        nameInput.addEventListener('input', updatePreview);
        descInput.addEventListener('input', updatePreview);
        switchInput.addEventListener('change', updatePreview);

        // ===== ROLE SUGGESTION CHIPS =====
        document.querySelectorAll('.role-suggestion').forEach(chip => {
            chip.addEventListener('click', () => {
                nameInput.value = chip.dataset.role;
                nameInput.dispatchEvent(new Event('input'));
                nameInput.focus();
            });
        });

        // ===== TEXTAREA ICON POSITION FIX =====
        const textareaWrapper = document.querySelector('textarea').closest('.input-wrapper');
        const textareaIcon = textareaWrapper.querySelector('i');
        textareaWrapper.addEventListener('focusin', () => { textareaIcon.style.top = '18px'; textareaIcon.style.transform = 'none'; });

        // Init
        window.addEventListener('DOMContentLoaded', updatePreview);
    </script>
}
