@model Manage_KPI_or_OKR_System.Models.Role

@{
    ViewData["Title"] = "Tạo Nhóm Quyền Mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-dark fw-bold">
                <i class="bi bi-shield-plus me-2"></i>Tạo Nhóm Quyền Mới
            </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-dark text-decoration-none opacity-75">Phân quyền Hệ thống</a></li>
                    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Tạo mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="content-card rounded-3">
        <div class="card-body-custom p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label for="roleName" class="form-label fw-bold text-dark">Tên nhóm quyền <span class="text-danger">*</span></label>
                        <input type="text" id="roleName" name="roleName" class="form-control" placeholder="Vd: Manager, Accountant..." required>
                        <div class="form-text mt-2 text-muted"><i class="bi bi-info-circle me-1"></i> Tên nhóm quyền tiếng Anh, viết liền (VD: HRManager)</div>
                    </div>

                    <div class="col-md-12">
                        <label for="description" class="form-label fw-bold text-dark">Mô tả quyền hạn</label>
                        <textarea id="description" name="description" class="form-control" rows="4" placeholder="Nhập mô tả các chức năng mà nhóm quyền này có thể thao tác..."></textarea>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-5 border-top pt-4">
                    <a asp-action="Index" class="btn-outline-custom px-4">
                        <i class="bi bi-x-circle me-1"></i> Hủy bỏ
                    </a>
                    <button type="submit" class="btn-primary-custom px-4">
                        <i class="bi bi-save me-2"></i> Tạo mới
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
