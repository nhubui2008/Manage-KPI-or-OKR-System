</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('permissionForm');
            const searchInput = document.getElementById('permissionSearch');
            const groupButtons = Array.from(document.querySelectorAll('.select-all-group'));
            const checkboxes = Array.from(document.querySelectorAll('.permission-checkbox'));
            const permissionItems = Array.from(document.querySelectorAll('[data-permission-item]'));
            const groupColumns = Array.from(document.querySelectorAll('[data-group-column]'));
            const selectVisibleButton = document.getElementById('selectVisiblePermissions');
            const clearAllButton = document.getElementById('clearAllPermissions');
            const selectedPermissionCount = document.getElementById('selectedPermissionCount');
            const selectedPermissionFooter = document.getElementById('selectedPermissionFooter');
            const selectedPermissionHero = document.getElementById('selectedPermissionHero');
            const selectedGroupCount = document.getElementById('selectedGroupCount');
            const selectedPermissionHeroBar = document.getElementById('selectedPermissionHeroBar');
            const selectedPermissionFooterBar = document.getElementById('selectedPermissionFooterBar');
            const totalPermissions = checkboxes.length;

            function getGroupCheckboxes(groupKey) {
                return checkboxes.filter(function (checkbox) {
                    return checkbox.dataset.groupKey === groupKey;
                });
            }

            function getVisibleGroupCheckboxes(groupKey) {
                const visible = getGroupCheckboxes(groupKey).filter(function (checkbox) {
                    return !checkbox.closest('[data-permission-item]').hidden;
                });

                return visible.length > 0 ? visible : getGroupCheckboxes(groupKey);
            }

            function updatePermissionItemState(checkbox) {
                const item = checkbox.closest('[data-permission-item]');
                if (!item) {
                    return;
                }

                item.classList.toggle('is-checked', checkbox.checked);
            }

            function updateGroupState(groupKey) {
                const groupCheckboxes = getGroupCheckboxes(groupKey);
                const checkedCount = groupCheckboxes.filter(function (checkbox) { return checkbox.checked; }).length;
                const counter = document.getElementById('group-counter-' + groupKey);
                const button = groupButtons.find(function (groupButton) {
                    return groupButton.dataset.group === groupKey;
                });

                if (counter) {
                    counter.textContent = checkedCount + '/' + groupCheckboxes.length + ' đã chọn';
                }

                if (button) {
                    button.textContent = checkedCount === groupCheckboxes.length && groupCheckboxes.length > 0
                        ? 'Bỏ chọn tất cả'
                        : 'Chọn tất cả';
                }
            }

            function updateSummary() {
                const checkedCount = checkboxes.filter(function (checkbox) { return checkbox.checked; }).length;
                const activeGroups = groupColumns.filter(function (column) {
                    const groupKey = column.dataset.groupColumn;
                    return getGroupCheckboxes(groupKey).some(function (checkbox) { return checkbox.checked; });
                }).length;
                const percentage = totalPermissions === 0 ? 0 : Math.round((checkedCount * 100) / totalPermissions);

                selectedPermissionCount.textContent = checkedCount;
                selectedPermissionFooter.textContent = checkedCount;
                selectedPermissionHero.textContent = checkedCount;
                selectedGroupCount.textContent = activeGroups;
                selectedPermissionHeroBar.style.width = percentage + '%';
                selectedPermissionFooterBar.style.width = percentage + '%';
            }

            function updateAllStates() {
                checkboxes.forEach(updatePermissionItemState);
                groupColumns.forEach(function (column) {
                    updateGroupState(column.dataset.groupColumn);
                });
                updateSummary();
            }

            function applyFilter() {
                const keyword = (searchInput.value || '').trim().toLowerCase();

                permissionItems.forEach(function (item) {
                    const haystack = item.dataset.filterText || '';
                    item.hidden = keyword.length > 0 && !haystack.includes(keyword);
                });

                groupColumns.forEach(function (column) {
                    const groupKey = column.dataset.groupColumn;
                    const hasVisibleItems = permissionItems.some(function (item) {
                        return item.dataset.groupKey === groupKey && !item.hidden;
                    });

                    column.hidden = !hasVisibleItems;
                });
            }

            checkboxes.forEach(function (checkbox) {
                checkbox.addEventListener('change', function () {
                    updatePermissionItemState(checkbox);
                    updateGroupState(checkbox.dataset.groupKey);
                    updateSummary();
                });
            });

            groupButtons.forEach(function (button) {
                button.addEventListener('click', function () {
                    const groupKey = button.dataset.group;
                    const targetCheckboxes = getVisibleGroupCheckboxes(groupKey);
                    const shouldCheck = targetCheckboxes.some(function (checkbox) { return !checkbox.checked; });

                    targetCheckboxes.forEach(function (checkbox) {
                        checkbox.checked = shouldCheck;
                        updatePermissionItemState(checkbox);
                    });

                    updateGroupState(groupKey);
                    updateSummary();
                });
            });

            searchInput.addEventListener('input', applyFilter);

            selectVisibleButton.addEventListener('click', function () {
                permissionItems
                    .filter(function (item) { return !item.hidden; })
                    .forEach(function (item) {
                        const checkbox = item.querySelector('.permission-checkbox');
                        checkbox.checked = true;
                        updatePermissionItemState(checkbox);
                    });

                updateAllStates();
            });

            clearAllButton.addEventListener('click', function () {
                checkboxes.forEach(function (checkbox) {
                    checkbox.checked = false;
                    updatePermissionItemState(checkbox);
                });

                updateAllStates();
            });

            form.addEventListener('reset', function () {
                window.requestAnimationFrame(function () {
                    updateAllStates();
                    applyFilter();
                });
            });

            updateAllStates();
            applyFilter();
        });
    </script>
}
