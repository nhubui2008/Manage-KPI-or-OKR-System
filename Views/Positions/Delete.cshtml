@model Manage_KPI_or_OKR_System.Models.Position
@{
    ViewData["Title"] = "Xóa Chức vụ - " + Model.PositionName;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var positionInitial = Model.PositionName?[0].ToString().ToUpper() ?? "P";
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
        border-radius: 1.5rem;
        overflow: hidden;
    }
    .page-header-danger {
        background: url('data:image/svg+xml;utf8,<svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(220,53,69,0.04)" stroke-width="1"/></pattern></defs><rect width="100%" height="100%" fill="url(%23grid)" /></svg>'), linear-gradient(to right, #fff5f5, #ffffff);
        border: 1px solid rgba(220, 53, 69, 0.15) !important;
    }
    .warning-box {
        background: linear-gradient(to right, rgba(255, 193, 7, 0.08), rgba(255, 193, 7, 0.02));
        border-left: 4px solid #ffc107;
        border-radius: 0.75rem;
    }
    .btn-danger-gradient {
        background: linear-gradient(135deg, #dc3545 0%, #b02a37 100%);
        color: white;
        border: none;
        transition: all 0.3s ease;
    }
    .btn-danger-gradient:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(220, 53, 69, 0.25);
        color: white;
    }
    .position-info-card {
        background: rgba(0,0,0,0.02);
        border-radius: 1rem;
        border: 1px dashed rgba(0,0,0,0.1);
        transition: all 0.3s ease;
    }
    .position-info-card:hover {
        background: rgba(0,0,0,0.04);
        border-color: rgba(0,0,0,0.2);
    }
    .detail-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px dashed rgba(0,0,0,0.06);
    }
    .detail-row:last-child { border-bottom: none; }
    .detail-icon {
        width: 34px; height: 34px;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0; font-size: 0.9rem;
    }
    .detail-label {
        font-size: 0.7rem; font-weight: 600;
        color: #6c757d; text-transform: uppercase; letter-spacing: 0.5px;
    }
    .detail-value {
        font-size: 0.95rem; font-weight: 700; color: #1a1a2e;
    }
</style>

<div class="container-fluid px-0">
    <div class="page-header d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-4 p-4 rounded-4 shadow-sm page-header-danger">
        <div class="d-flex align-items-center mb-0">
            <div class="bg-danger bg-opacity-10 text-danger p-3 rounded-3 me-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 50px; height: 50px;">
                <i class="bi bi-exclamation-triangle-fill fs-4"></i>
            </div>
            <div>
                <h1 class="h4 font-weight-bold mb-1 text-danger" style="letter-spacing: -0.5px;">Xóa Chức Vụ</h1>
                <p class="text-danger opacity-75 small mb-0 fw-medium">Hành động này KHÔNG THỂ hoàn tác!</p>
            </div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8 col-xl-7">
            <div class="glass-card mb-5">
                <div class="card-body p-4 p-md-5">

                    <div class="warning-box p-4 mb-5">
                        <div class="d-flex align-items-start">
                            <i class="bi bi-info-circle-fill fs-4 text-warning me-3 mt-1" style="filter: drop-shadow(0 2px 4px rgba(255,193,7,0.3));"></i>
                            <div>
                                <h6 class="fw-bold text-dark mb-2">Cảnh báo tính toàn vẹn dữ liệu</h6>
                                <p class="text-muted small mb-0" style="line-height: 1.6;">
                                    Ngay cả khi bạn xác nhận xóa, hệ thống sẽ <strong>TỪ CHỐI XÓA</strong> nếu chức vụ này đang được gán cho nhân viên hoặc có dữ liệu liên kết trong hệ thống.<br>
                                    <span class="d-inline-block mt-2 px-2 py-1 bg-warning bg-opacity-10 text-dark rounded-2">
                                        💡 <em class="fw-medium">Khuyến nghị: Kiểm tra danh sách nhân viên trước khi xóa chức vụ này.</em>
                                    </span>
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="position-info-card p-4 text-center mt-5 mb-5 position-relative">
                        <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3 shadow-sm fw-bold" style="width: 68px; height: 68px; font-size: 1.8rem; margin-top: -3.5rem; border: 4px solid #fff;">
                            @positionInitial
                        </div>
                        <h4 class="fw-bold text-dark mb-1">@Model.PositionName</h4>
                        <div class="px-3 py-2 mt-3 text-start">
                            <div class="detail-row">
                                <div class="detail-icon bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-hash"></i></div>
                                <div>
                                    <div class="detail-label">Mã chức vụ</div>
                                    <div class="detail-value">@Model.PositionCode</div>
                                </div>
                            </div>
                            <div class="detail-row">
                                <div class="detail-icon bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-reception-3"></i></div>
                                <div>
                                    <div class="detail-label">Cấp bậc chuyên môn</div>
                                    <div class="detail-value">@(Model.RankLevel != null ? "Cấp " + Model.RankLevel : "—")</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center mt-2 border-top border-secondary border-opacity-10 pt-4">
                            <a asp-action="Index" class="btn btn-light btn-lg rounded-pill fw-medium px-4 shadow-sm border order-2 order-sm-1 flex-grow-1 flex-sm-grow-0" style="transition: all 0.2s ease;">
                                <i class="bi bi-arrow-left me-1"></i> Hủy & Quay lại an toàn
                            </a>
                            <button type="submit" class="btn btn-danger-gradient btn-lg rounded-pill fw-bold px-4 shadow-sm order-1 order-sm-2 flex-grow-1 flex-sm-grow-0">
                                Xác nhận XÓA <i class="bi bi-trash3-fill ms-1"></i>
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>


