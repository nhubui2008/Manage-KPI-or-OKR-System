@model Manage_KPI_or_OKR_System.Models.Position
@{
    ViewData["Title"] = "Thêm Chức vụ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-dark fw-bold">
                <i class="bi bi-person-plus me-2"></i>Thêm Chức vụ Mới
            </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-dark text-decoration-none opacity-75">Danh mục Chức vụ</a></li>
                    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Thêm mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="content-card rounded-3">
                <div class="card-header-custom bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-person-plus me-2"></i>Thông tin Chức vụ</h5>
                </div>
                <div class="card-body-custom p-4">
                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label asp-for="PositionCode" class="form-label fw-bold text-dark">Mã chức vụ (VD: CV01, MGR) <span class="text-danger">*</span></label>
                            <input asp-for="PositionCode" class="form-control" placeholder="Nhập mã chức vụ..." required />
                            <span asp-validation-for="PositionCode" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PositionName" class="form-label fw-bold text-dark">Tên chức vụ <span class="text-danger">*</span></label>
                            <input asp-for="PositionName" class="form-control" placeholder="Nhập tên chức vụ (VD: Trưởng phòng, Nhân viên)..." required />
                            <span asp-validation-for="PositionName" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="RankLevel" class="form-label fw-bold text-dark">Cấp bậc (Số càng nhỏ cấp càng cao)</label>
                            <input asp-for="RankLevel" type="number" class="form-control" placeholder="VD: 1, 2, 3..." />
                            <span asp-validation-for="RankLevel" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2 pt-3 border-top">
                            <a asp-action="Index" class="btn-outline-custom px-4">Hủy bỏ</a>
                            <button type="submit" class="btn-primary-custom px-4"><i class="bi bi-save me-2"></i>Lưu thông tin</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>