@model Manage_KPI_or_OKR_System.Models.Position
@{
    ViewData["Title"] = "Thêm Chức vụ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-content py-4 container-fluid px-4">
    <div class="page-header d-flex align-items-center justify-content-between mb-4 animate__animated animate__fadeIn">
        <div>
            <h1 class="mb-2 fw-800 text-dark text-gradient">Thêm Chức vụ Mới</h1>
            <div class="page-breadcrumb">
                <a href="/" class="text-decoration-none opacity-75">Trang chủ</a>
                <span class="separator mx-2 text-muted">/</span>
                <a asp-action="Index" class="text-decoration-none opacity-75">Danh mục Chức vụ</a>
                <span class="separator mx-2 text-muted">/</span>
                <span class="text-primary fw-bold">Thêm mới</span>
            </div>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-light shadow-sm border-0 bg-white px-4 py-2" style="border-radius: 12px; font-weight: 600; color: #475569; transition: all 0.3s;">
                <i class="bi bi-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-8 animate__animated animate__fadeInLeft">
            <div class="content-card border-0 shadow-lg overflow-visible" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(20px); border-radius: 24px;">
                <div class="card-header-custom border-bottom bg-white bg-opacity-50 py-4 px-4" style="border-radius: 24px 24px 0 0;">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary bg-opacity-10 p-3 rounded-4 me-3">
                            <i class="bi bi-person-badge text-primary fs-4"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold fs-5 mb-0 text-dark">Thông tin Chức vụ</h5>
                            <p class="text-muted small mb-0">Định nghĩa chức danh và cấp bậc trong cơ cấu nhân sự</p>
                        </div>
                    </div>
                </div>

                <div class="card-body-custom p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-primary text-white me-3 d-flex align-items-center justify-content-center shadow" style="width: 38px; height: 38px; border-radius: 12px;">
                                <span class="fw-bold">1</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Thông tin định danh</h6>
                        </div>

                        <div class="row g-4 mb-5 p-3 rounded-4 bg-light bg-opacity-50 border border-white">
                            <div class="col-md-4">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Mã chức vụ <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-hash"></i>
                                        <input asp-for="PositionCode" class="form-control shadow-sm" placeholder="VD: CV01, MGR..." required />
                                    </div>
                                    <span asp-validation-for="PositionCode" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-8">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Tên chức vụ <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-person-workspace"></i>
                                        <input asp-for="PositionName" class="form-control shadow-sm" placeholder="VD: Trưởng phòng, Nhân viên..." required />
                                    </div>
                                    <span asp-validation-for="PositionName" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-success text-white me-3 d-flex align-items-center justify-content-center shadow" style="width: 38px; height: 38px; border-radius: 12px;">
                                <span class="fw-bold">2</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Thứ bậc</h6>
                        </div>

                        <div class="row g-4 p-3 rounded-4 bg-light bg-opacity-50 border border-white mb-4">
                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Cấp bậc (Số càng nhỏ cấp càng cao)</label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-sort-numeric-up"></i>
                                        <input asp-for="RankLevel" type="number" class="form-control shadow-sm" placeholder="VD: 1, 2, 3..." />
                                    </div>
                                    <span asp-validation-for="RankLevel" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                            <a asp-action="Index" class="btn-outline-custom">
                                <i class="bi bi-x-lg me-2"></i> Hủy thao tác
                            </a>
                            <button type="submit" class="btn-primary-custom" style="padding: 12px 40px; border-radius: 12px;">
                                <i class="bi bi-check-lg fs-5 me-2"></i> Lưu Chức vụ
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-xl-4 animate__animated animate__fadeInRight">
            <div class="sticky-top" style="top: 100px;">
                <div class="content-card border-0 shadow-lg text-white mb-4 position-relative overflow-hidden" style="background: linear-gradient(135deg, #0078d4, #005a9e); border-radius: 24px;">
                    <div style="position:absolute;top:-30px;right:-30px;width:120px;height:120px;background:rgba(255,255,255,0.07);border-radius:50%;"></div>
                    <div style="position:absolute;bottom:-20px;left:-20px;width:80px;height:80px;background:rgba(255,255,255,0.05);border-radius:50%;"></div>
                    <div class="card-body-custom p-4 position-relative">
                        <div class="d-flex align-items-center mb-4">
                            <div class="me-3 flex-shrink-0" style="width:56px;height:56px;background:linear-gradient(135deg,#8b5cf6,#6d28d9);border-radius:16px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 15px rgba(139,92,246,0.4);">
                                <i class="bi bi-person-badge fs-3 text-white"></i>
                            </div>
                            <div>
                                <div class="small fw-bold text-uppercase" style="opacity:0.8;letter-spacing:0.08em;">Mã chức vụ</div>
                                <h4 class="mb-0 fw-800" id="previewCode">--</h4>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="small opacity-75 fw-bold text-uppercase mb-1">Tên chức vụ</div>
                            <div class="fw-bold fs-6" id="previewName" style="min-height: 28px;">--</div>
                        </div>
                        <div class="bg-white bg-opacity-10 p-3 rounded-4">
                            <div class="small opacity-75 mb-1">Cấp bậc</div>
                            <div class="fw-bold" id="previewRank">--</div>
                        </div>
                    </div>
                </div>

                <div class="content-card border-0 shadow-sm rounded-4 bg-white p-4">
                    <h6 class="fw-bold text-dark mb-3"><i class="bi bi-info-circle text-primary me-2"></i> Lưu ý</h6>
                    <ul class="list-unstyled mb-0 small text-muted" style="line-height: 1.8;">
                        <li class="mb-2"><i class="bi bi-patch-check-fill text-success me-2"></i> Mã chức vụ nên viết tắt, viết hoa.</li>
                        <li class="mb-2"><i class="bi bi-patch-check-fill text-success me-2"></i> Cấp bậc 1 là cao nhất trong hệ thống.</li>
                        <li><i class="bi bi-patch-check-fill text-success me-2"></i> Chức vụ được dùng khi phân công nhân viên.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    .text-gradient { background: linear-gradient(135deg, #1e293b 0%, #334155 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .letter-spacing-1 { letter-spacing: 0.1em; }
    .form-icon-group { position: relative; }
    .form-icon-group .input-wrapper { position: relative; transition: all 0.3s ease; background: #fff; }
    .form-icon-group .input-wrapper:focus-within { border-color: #0078d4 !important; box-shadow: 0 8px 15px -5px rgba(0,120,212,0.15) !important; transform: translateY(-1px); }
    .form-icon-group .input-wrapper i { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 1.1rem; z-index: 10; transition: color 0.3s; pointer-events: none; }
    .form-icon-group .input-wrapper:focus-within i { color: #0078d4; }
    .form-control:focus, .form-select:focus { box-shadow: none !important; color: #1e293b; background-color: transparent; }
    .animate__animated { animation-duration: 0.8s; }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <script>
        const codeInput = document.getElementById('PositionCode');
        const nameInput = document.getElementById('PositionName');
        const rankInput = document.getElementById('RankLevel');
        function updatePreview() {
            document.getElementById('previewCode').textContent = codeInput.value.trim().toUpperCase() || '--';
            document.getElementById('previewName').textContent = nameInput.value.trim() || '--';
            document.getElementById('previewRank').textContent = rankInput.value ? 'Cấp ' + rankInput.value : '--';
        }
        [codeInput, nameInput, rankInput].forEach(el => el.addEventListener('input', updatePreview));
        window.addEventListener('DOMContentLoaded', updatePreview);
    </script>
}