@model Manage_KPI_or_OKR_System.Models.Position
@{
    ViewData["Title"] = "Thêm Chức vụ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-success"><i class="bi bi-plus-circle me-2"></i>Thêm chức vụ mới</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label asp-for="PositionCode" class="form-label fw-semibold text-muted">Mã chức vụ (VD: CV01, MGR)</label>
                            <input asp-for="PositionCode" class="form-control form-control-lg bg-light" placeholder="Nhập mã chức vụ..." />
                            <span asp-validation-for="PositionCode" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PositionName" class="form-label fw-semibold text-muted">Tên chức vụ <span class="text-danger">*</span></label>
                            <input asp-for="PositionName" class="form-control form-control-lg" placeholder="Nhập tên chức vụ (VD: Trưởng phòng, Nhân viên)..." required />
                            <span asp-validation-for="PositionName" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="RankLevel" class="form-label fw-semibold text-muted">Cấp bậc (Số càng nhỏ cấp càng cao)</label>
                            <input asp-for="RankLevel" type="number" class="form-control form-control-lg" placeholder="VD: 1, 2, 3..." />
                            <span asp-validation-for="RankLevel" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light border px-4">Hủy bỏ</a>
                            <button type="submit" class="btn btn-success fw-bold px-4"><i class="bi bi-floppy me-2"></i>Lưu thông tin</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>