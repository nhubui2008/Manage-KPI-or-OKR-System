@{
    ViewData["Title"] = "Danh mục Chức vụ";
}

<div class="page-header">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Chức vụ & Vị trí</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Chức vụ</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn-primary-custom">
            <i class="bi bi-plus-lg"></i> Thêm chức vụ
        </button>
    </div>
</div>

<div class="content-card">
    <div class="card-body-custom">
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 80px;">Mã CV</th>
                        <th>Tên chức vụ</th>
                        <th>Cấp bậc (Rank)</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="fw-semibold">GD</td>
                        <td class="fw-bold text-dark">Giám đốc</td>
                        <td><span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3">Cấp 1</span></td>
                        <td><span class="status-badge active"><span class="status-dot"></span> Đang sử dụng</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="Chỉnh sửa"><i class="bi bi-pencil"></i></button>
                                <button class="action-btn danger" title="Xóa"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-semibold">PGD</td>
                        <td class="fw-bold text-dark">Phó Giám đốc</td>
                        <td><span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3">Cấp 2</span></td>
                        <td><span class="status-badge active"><span class="status-dot"></span> Đang sử dụng</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="Chỉnh sửa"><i class="bi bi-pencil"></i></button>
                                <button class="action-btn danger" title="Xóa"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-semibold">TP</td>
                        <td class="fw-bold text-dark">Trưởng phòng</td>
                        <td><span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3">Cấp 3</span></td>
                        <td><span class="status-badge active"><span class="status-dot"></span> Đang sử dụng</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="Chỉnh sửa"><i class="bi bi-pencil"></i></button>
                                <button class="action-btn danger" title="Xóa"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-semibold">PP</td>
                        <td class="fw-bold text-dark">Phó phòng</td>
                        <td><span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3">Cấp 4</span></td>
                        <td><span class="status-badge active"><span class="status-dot"></span> Đang sử dụng</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="Chỉnh sửa"><i class="bi bi-pencil"></i></button>
                                <button class="action-btn danger" title="Xóa"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-semibold">NV</td>
                        <td class="fw-bold text-dark">Nhân viên</td>
                        <td><span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">Cấp 5</span></td>
                        <td><span class="status-badge active"><span class="status-dot"></span> Đang sử dụng</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="Chỉnh sửa"><i class="bi bi-pencil"></i></button>
                                <button class="action-btn danger" title="Xóa"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
