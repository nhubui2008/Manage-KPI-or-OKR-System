@model IEnumerable<Manage_KPI_or_OKR_System.Models.Position>
@{
    ViewData["Title"] = "Danh mục Chức vụ";
}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Chức vụ & Vị trí</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Chức vụ</span>
        </div>
    </div>
    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Create" class="btn-primary-custom d-flex align-items-center">
            <i class="bi bi-plus-lg me-1"></i> Thêm chức vụ
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert" style="background-color: var(--success-bg); color: var(--text-primary); border-radius: var(--radius-md); border-left: 4px solid var(--success) !important;">
        <div class="d-flex align-items-center">
            <i class="bi bi-check-circle-fill me-3 fs-5" style="color: var(--success);"></i>
            <div class="fw-medium">@TempData["SuccessMessage"]</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mb-4" role="alert" style="background-color: var(--danger-bg); color: var(--text-primary); border-radius: var(--radius-md); border-left: 4px solid var(--danger) !important;">
        <div class="d-flex align-items-center">
            <i class="bi bi-exclamation-triangle-fill me-3 fs-5" style="color: var(--danger);"></i>
            <div class="fw-medium">@TempData["ErrorMessage"]</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100">
    <div class="card-body-custom">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Danh sách chức vụ (@Model.Count())</h5>
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Tìm kiếm chức vụ..." style="width: 250px;" />
                <button type="submit" class="btn btn-outline-primary"><i class="bi bi-search"></i></button>
            </form>
        </div>
        
        <div class="table-responsive w-100">
            <table class="data-table w-100">
                <thead>
                    <tr>
                        <th style="width: 80px;">Mã CV</th>
                        <th>Tên chức vụ</th>
                        <th>Cấp bậc (Rank)</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var position in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@position.PositionCode</td>
                                <td class="fw-bold text-dark">@position.PositionName</td>
                                <td>
                                    @if (position.RankLevel.HasValue)
                                    {
                                        <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3">Cấp @position.RankLevel</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <span class="status-badge active">
                                        <span class="status-dot"></span> Đang sử dụng
                                    </span>
                                </td>
                                <td>
                                    <div class="action-btns justify-content-end">
                                        <a asp-action="Details" asp-route-id="@position.Id" class="action-btn" title="Chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@position.Id" class="action-btn" title="Chỉnh sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@position.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('Bạn có chắc chắn muốn xóa chức vụ này?')">
                                            <button type="submit" class="action-btn danger" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="bi bi-info-circle me-2"></i>
                                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"] as string))
                                {
                                    <span>Không tìm thấy chức vụ nào phù hợp với từ khóa "@ViewData["CurrentFilter"]"</span>
                                }
                                else
                                {
                                    <span>Chưa có chức vụ nào được tạo.</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

        </div>
    </div>
</div>