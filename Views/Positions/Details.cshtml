@model Manage_KPI_or_OKR_System.Models.Position
@{
    ViewData["Title"] = "Chi tiết Chức vụ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-content">
    <!-- HEADER -->
    <div class="page-header d-flex align-items-center justify-content-between mb-4 animate__animated animate__fadeIn">
        <div>
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge bg-info bg-opacity-10 text-info px-3 py-2 rounded-pill border border-info border-opacity-25">
                    <i class="bi bi-eye me-1"></i> Chế độ xem
                </span>
                <span class="text-muted small">Mã: <strong>@Model.PositionCode</strong></span>
            </div>
            <h1 class="fw-800 text-dark mb-1">@Model.PositionName</h1>
            <div class="page-breadcrumb">
                <a href="/" class="text-decoration-none opacity-75">Trang chủ</a>
                <span class="separator">/</span>
                <a asp-action="Index" class="text-decoration-none opacity-75">Danh mục Chức vụ</a>
                <span class="separator">/</span>
                <span class="text-primary fw-bold">Chi tiết</span>
            </div>
        </div>
        <div class="d-flex gap-2 mt-3 mt-md-0">
            <a asp-action="Index" class="btn-outline-custom shadow-sm">
                <i class="bi bi-arrow-left me-2"></i> Quay lại
            </a>
            <a asp-action="Edit" asp-route-code="@Model.PositionCode" class="btn-primary-custom shadow-sm">
                <i class="bi bi-pencil me-2"></i> Chỉnh sửa
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- DETAILS COLUMN -->
        <div class="col-xl-8 animate__animated animate__fadeInLeft">
            <div class="content-card border-0 shadow-lg" style="background: rgba(255,255,255,0.95); backdrop-filter: blur(10px);">
                <div class="card-header-custom border-bottom bg-transparent py-4">
                    <h5 class="fw-bold fs-5 mb-0">
                        <i class="bi bi-person-badge text-primary me-2"></i> Thông tin Chi tiết
                    </h5>
                </div>

                <div class="card-body-custom p-4">
                    <!-- SECTION 1: ĐỊNH DANH -->
                    <div class="d-flex align-items-center mb-4">
                        <div class="icon-circle bg-primary text-white me-3 d-flex align-items-center justify-content-center shadow"
                             style="width: 38px; height: 38px; border-radius: 12px; flex-shrink: 0;">
                            <span class="fw-bold">1</span>
                        </div>
                        <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Thông tin định danh</h6>
                    </div>

                    <div class="row g-4 mb-5 p-3 rounded-4 bg-light bg-opacity-50 border border-white">
                        <div class="col-md-4">
                            <div class="mb-0">
                                <label class="form-label small text-muted text-uppercase fw-800 mb-1">Mã chức vụ</label>
                                <div class="d-flex align-items-center gap-2 mt-1">
                                    <i class="bi bi-hash text-primary fs-5"></i>
                                    <span class="fw-bold text-dark fs-6">@Model.PositionCode</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="mb-0">
                                <label class="form-label small text-muted text-uppercase fw-800 mb-1">Tên chức vụ</label>
                                <div class="d-flex align-items-center gap-2 mt-1">
                                    <i class="bi bi-person-workspace text-primary fs-5"></i>
                                    <span class="fw-bold text-dark fs-6">@Model.PositionName</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- SECTION 2: THỨ BẬC & TRẠNG THÁI -->
                    <div class="d-flex align-items-center mb-4">
                        <div class="icon-circle bg-success text-white me-3 d-flex align-items-center justify-content-center shadow"
                             style="width: 38px; height: 38px; border-radius: 12px; flex-shrink: 0;">
                            <span class="fw-bold">2</span>
                        </div>
                        <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Thứ bậc & Trạng thái</h6>
                    </div>

                    <div class="row g-4 p-3 rounded-4 bg-light bg-opacity-50 border border-white mb-4">
                        <div class="col-md-6">
                            <div class="mb-0">
                                <label class="form-label small text-muted text-uppercase fw-800 mb-1">Cấp bậc</label>
                                <div class="mt-2">
                                    @if (Model.RankLevel.HasValue)
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 fs-6 fw-bold">
                                            <i class="bi bi-sort-numeric-up me-1"></i> Cấp @Model.RankLevel
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Chưa xác định</span>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-0">
                                <label class="form-label small text-muted text-uppercase fw-800 mb-1">Trạng thái</label>
                                <div class="mt-2">
                                    <span class="status-badge active">
                                        <span class="status-dot"></span> Đang sử dụng
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-0">
                                <label class="form-label small text-muted text-uppercase fw-800 mb-1">ID hệ thống</label>
                                <div class="d-flex align-items-center gap-2 mt-1">
                                    <i class="bi bi-fingerprint text-muted fs-5"></i>
                                    <span class="text-muted fw-bold">#@Model.Id</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-5 pt-4 border-top">
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Bạn có chắc chắn muốn xóa chức vụ này?')">
                            <button type="submit" class="btn btn-outline-danger fw-bold px-4" style="border-radius: 12px;">
                                <i class="bi bi-trash me-2"></i> Xóa chức vụ
                            </button>
                        </form>
                        <div class="d-flex gap-2">
                            <a asp-action="Index" class="btn-outline-custom">
                                <i class="bi bi-arrow-left me-2"></i> Quay lại
                            </a>
                            <a asp-action="Edit" asp-route-code="@Model.PositionCode" class="btn-primary-custom" style="padding: 12px 32px; border-radius: 12px;">
                                <i class="bi bi-pencil me-2"></i> Chỉnh sửa
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SIDEBAR -->
        <div class="col-xl-4 animate__animated animate__fadeInRight">
            <div class="sticky-top" style="top: 100px;">
                <!-- Preview Card -->
                <div class="content-card border-0 shadow-lg text-white mb-4"
                     style="background: linear-gradient(135deg, #0078d4, #005a9e); border-radius: 24px;">
                    <div class="card-body-custom p-4">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-white bg-opacity-20 p-3 rounded-4 me-3">
                                <i class="bi bi-person-badge fs-3 text-white"></i>
                            </div>
                            <div>
                                <div class="small opacity-75 fw-bold text-uppercase">Mã chức vụ</div>
                                <h4 class="mb-0 fw-800">@Model.PositionCode</h4>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="small opacity-75 fw-bold text-uppercase mb-1">Tên chức vụ</div>
                            <div class="fw-bold fs-6">@Model.PositionName</div>
                        </div>
                        <div class="row g-2 mt-1">
                            <div class="col-6">
                                <div class="bg-white bg-opacity-10 p-3 rounded-4">
                                    <div class="small opacity-75 mb-1">Cấp bậc</div>
                                    <div class="fw-bold small">@(Model.RankLevel.HasValue ? "Cấp " + Model.RankLevel : "--")</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-white bg-opacity-10 p-3 rounded-4">
                                    <div class="small opacity-75 mb-1">Trạng thái</div>
                                    <div class="fw-bold small">
                                        <i class="bi bi-circle-fill text-success me-1" style="font-size: 0.6rem;"></i> Hoạt động
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Info Card -->
                <div class="content-card border-0 shadow-sm rounded-4 bg-white p-4">
                    <h6 class="fw-bold text-dark mb-3">
                        <i class="bi bi-info-circle text-primary me-2"></i> Thông tin hệ thống
                    </h6>
                    <ul class="list-unstyled mb-0 small text-muted" style="line-height: 1.8;">
                        <li class="mb-2"><i class="bi bi-patch-check-fill text-success me-2"></i> Chức vụ đang được sử dụng trong hệ thống.</li>
                        <li class="mb-2"><i class="bi bi-patch-check-fill text-primary me-2"></i> Cấp bậc 1 là cao nhất.</li>
                        <li><i class="bi bi-exclamation-triangle-fill text-warning me-2"></i> Xóa có thể ảnh hưởng đến nhân viên đang giữ chức vụ này.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    .letter-spacing-1 { letter-spacing: 0.1em; }
    .animate__animated { animation-duration: 0.8s; }
</style>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
}