@model Manage_KPI_or_OKR_System.Models.Position
@{
    ViewData["Title"] = "Chi tiết Chức vụ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-info"><i class="bi bi-info-circle me-2"></i>Chi tiết chức vụ</h5>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-pencil me-1"></i>Chỉnh sửa
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-arrow-left me-1"></i>Quay lại
                        </a>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-12">
                            <div class="border rounded-3 p-3 bg-light">
                                <div class="row">
                                    <div class="col-sm-4">
                                        <label class="form-label fw-semibold text-muted mb-1">Mã chức vụ</label>
                                        <p class="mb-0 fw-bold text-dark">@Model.PositionCode</p>
                                    </div>
                                    <div class="col-sm-4">
                                        <label class="form-label fw-semibold text-muted mb-1">Tên chức vụ</label>
                                        <p class="mb-0 fw-bold text-dark">@Model.PositionName</p>
                                    </div>
                                    <div class="col-sm-4">
                                        <label class="form-label fw-semibold text-muted mb-1">Cấp bậc</label>
                                        <p class="mb-0">
                                            @if (Model.RankLevel.HasValue)
                                            {
                                                <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3">Cấp @Model.RankLevel</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="border rounded-3 p-3 bg-light">
                                <div class="row">
                                    <div class="col-sm-6">
                                        <label class="form-label fw-semibold text-muted mb-1">Trạng thái</label>
                                        <p class="mb-0">
                                            <span class="status-badge active">
                                                <span class="status-dot"></span> Đang sử dụng
                                            </span>
                                        </p>
                                    </div>
                                    <div class="col-sm-6">
                                        <label class="form-label fw-semibold text-muted mb-1">ID</label>
                                        <p class="mb-0 fw-bold text-dark">@Model.Id</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 pt-4 border-top mt-4">
                        <a asp-action="Index" class="btn btn-light border px-4">Quay lại danh sách</a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary fw-bold px-4">
                            <i class="bi bi-pencil me-2"></i>Chỉnh sửa
                        </a>
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Bạn có chắc chắn muốn xóa chức vụ này?')">
                            <button type="submit" class="btn btn-danger fw-bold px-4">
                                <i class="bi bi-trash me-2"></i>Xóa
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>