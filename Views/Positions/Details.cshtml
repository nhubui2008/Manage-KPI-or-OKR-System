@model Manage_KPI_or_OKR_System.Models.Position
@{
    ViewData["Title"] = "Chi tiết Chức vụ - " + Model.PositionName;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-0">
    <!-- Page Header -->
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 font-weight-bold mb-1">Chi tiết Chức vụ</h1>
            <div class="page-breadcrumb">
                <a href="/">Trang chủ</a>
                <i class="bi bi-chevron-right separator"></i>
                <a asp-action="Index">Danh mục Chức vụ</a>
                <i class="bi bi-chevron-right separator"></i>
                <span>@Model.PositionName</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn-outline-custom d-flex align-items-center px-3 py-2" style="border-radius: 10px; text-decoration: none;">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
            <a asp-action="Edit" asp-route-code="@Model.PositionCode" class="btn-primary-custom d-flex align-items-center px-3 py-2" style="border-radius: 10px; text-decoration: none;">
                <i class="bi bi-pencil me-1"></i> Chỉnh sửa
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Position Banner -->
            <div class="content-card mb-4" style="overflow: hidden;">
                <div class="dept-banner">
                    <div class="dept-banner-bg"></div>
                    <div class="dept-banner-content">
                        <div class="dept-banner-icon">
                            <i class="bi bi-person-badge"></i>
                        </div>
                        <div class="dept-banner-info">
                            <h2 class="dept-banner-name">@Model.PositionName</h2>
                            <div class="dept-banner-meta">
                                <span class="dept-code-badge">@(Model.PositionCode ?? "—")</span>
                                @if (Model.RankLevel.HasValue)
                                {
                                    <span class="status-badge active ms-2"><span class="status-dot"></span> Cấp @Model.RankLevel</span>
                                }
                                else
                                {
                                    <span class="status-badge processing ms-2"><span class="status-dot"></span> Chưa xác định cấp</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Detailed Information -->
            <div class="content-card">
                <div class="card-header-custom border-bottom">
                    <h5 class="mb-0 fw-bold d-flex align-items-center">
                        <div class="header-icon-box">
                            <i class="bi bi-info-circle"></i>
                        </div>
                        Thông tin chi tiết
                    </h5>
                </div>
                <div class="card-body-custom p-0">
                    <div class="detail-info-list">
                        <div class="detail-info-row">
                            <div class="detail-info-icon"><i class="bi bi-hash"></i></div>
                            <div class="detail-info-body">
                                <div class="detail-info-label">ID Hệ thống</div>
                                <div class="detail-info-value">@Model.Id</div>
                            </div>
                        </div>
                        <div class="detail-info-row">
                            <div class="detail-info-icon"><i class="bi bi-qr-code"></i></div>
                            <div class="detail-info-body">
                                <div class="detail-info-label">Mã chức vụ</div>
                                <div class="detail-info-value">@(Model.PositionCode ?? "—")</div>
                            </div>
                        </div>
                        <div class="detail-info-row">
                            <div class="detail-info-icon"><i class="bi bi-tag"></i></div>
                            <div class="detail-info-body">
                                <div class="detail-info-label">Tên chức vụ</div>
                                <div class="detail-info-value">@(Model.PositionName ?? "—")</div>
                            </div>
                        </div>
                        <div class="detail-info-row">
                            <div class="detail-info-icon"><i class="bi bi-reception-3"></i></div>
                            <div class="detail-info-body">
                                <div class="detail-info-label">Cấp bậc chuyên môn</div>
                                <div class="detail-info-value">@(Model.RankLevel != null ? "Cấp " + Model.RankLevel : "—")</div>
                            </div>
                        </div>
                        <div class="detail-info-row">
                            <div class="detail-info-icon"><i class="bi bi-toggle-on"></i></div>
                            <div class="detail-info-body">
                                <div class="detail-info-label">Trạng thái</div>
                                <div class="detail-info-value">
                                    <span class="status-badge active"><span class="status-dot"></span> Đang sử dụng</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white border-top p-4">
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger fw-bold px-4 py-2 d-flex align-items-center" style="border-radius: 10px;">
                            <i class="bi bi-trash me-2"></i> Xóa chức vụ
                        </a>
                        <a asp-action="Edit" asp-route-code="@Model.PositionCode" class="btn-primary-custom px-4">
                            <i class="bi bi-pencil me-2"></i> Chỉnh sửa
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Reusing Office Blue layout styles */
    .header-icon-box {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: linear-gradient(135deg, #1a73e8, #4285f4);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 0.85rem;
        margin-right: 12px;
        flex-shrink: 0;
    }

    .dept-banner {
        position: relative;
        padding: 32px 28px;
        overflow: hidden;
    }
    .dept-banner-bg {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, #1a73e8 0%, #4285f4 40%, #669df6 100%);
        opacity: 0.95;
    }
    .dept-banner-bg::after {
        content: '';
        position: absolute;
        inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .dept-banner-content {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        gap: 20px;
    }
    .dept-banner-icon {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        color: #fff;
        flex-shrink: 0;
        border: 1px solid rgba(255, 255, 255, 0.25);
    }
    .dept-banner-name {
        font-size: 1.4rem;
        font-weight: 800;
        color: #fff;
        margin: 0 0 6px;
        text-shadow: 0 1px 2px rgba(0,0,0,0.1);
    }
    .dept-banner-meta {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .dept-code-badge {
        display: inline-flex;
        align-items: center;
        padding: 3px 12px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.2);
        color: #fff;
        font-size: 0.78rem;
        font-weight: 600;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .detail-info-list {
        padding: 0;
    }
    .detail-info-row {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 16px 24px;
        border-bottom: 1px solid var(--border-color, #e8eaed);
        transition: background 0.15s;
    }
    .detail-info-row:last-child {
        border-bottom: none;
    }
    .detail-info-row:hover {
        background: rgba(26, 115, 232, 0.02);
    }
    .detail-info-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: linear-gradient(135deg, #1a73e8, #4285f4);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 0.9rem;
        flex-shrink: 0;
    }
    .detail-info-body {
        flex: 1;
        min-width: 0;
    }
    .detail-info-label {
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--text-secondary, #5f6368);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 3px;
    }
    .detail-info-value {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text-primary, #1a1a2e);
    }

    .page-header h1 {
        font-size: 1.5rem;
        color: #1a1a2e;
    }
    .separator {
        opacity: 0.5;
        font-size: 0.8rem;
    }
</style>