@model Manage_KPI_or_OKR_System.Models.Position
@{
    ViewData["Title"] = "Chỉnh sửa Chức vụ - " + Model.PositionName;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
        border-radius: 1.5rem;
        overflow: hidden;
    }
    .page-header-modern {
        background: url('data:image/svg+xml;utf8,<svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(0,0,0,0.02)" stroke-width="1"/></pattern></defs><rect width="100%" height="100%" fill="url(%23grid)" /></svg>'), linear-gradient(to right, #ffffff, #fdfdfd);
        border: 1px solid rgba(0,0,0,0.05) !important;
    }
    .input-modern {
        height: 3.2rem;
        border-radius: 0.75rem;
        border: 1.5px solid rgba(0,0,0,0.08);
        padding-left: 2.8rem;
        font-size: 0.95rem;
        transition: all 0.25s ease;
        background-color: rgba(255,255,255,0.9);
    }
    .input-modern:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 4px rgba(13,110,253,0.12);
        background-color: #ffffff;
    }
    .input-wrapper {
        position: relative;
    }
    .input-wrapper i.input-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #0d6efd;
        font-size: 1.15rem;
        opacity: 0.7;
        z-index: 5;
        pointer-events: none;
    }
    .form-label-modern {
        font-weight: 600;
        font-size: 0.85rem;
        color: #495057;
        margin-bottom: 0.5rem;
        letter-spacing: 0.02em;
    }
    .btn-gradient {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        color: white;
        border: none;
        transition: all 0.3s ease;
    }
    .btn-gradient:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(13,110,253,0.25);
        color: white;
    }
    .hover-opacity:hover { opacity: 0.8; }
</style>

<div class="container-fluid px-0">
    <div class="page-header d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-4 p-4 rounded-4 shadow-sm page-header-modern">
        <div class="mb-3 mb-sm-0">
            <h1 class="h3 font-weight-bold mb-2 text-dark d-flex align-items-center">
                <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 me-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 44px; height: 44px;">
                    <i class="bi bi-person-badge"></i>
                </div>
                Chỉnh sửa Chức vụ
            </h1>
            <div class="page-breadcrumb text-muted" style="font-size: 0.85rem;">
                <a href="/" class="text-decoration-none text-muted hover-primary">Trang chủ</a>
                <i class="bi bi-chevron-right mx-2" style="font-size: 0.7rem;"></i>
                <a asp-action="Index" class="text-decoration-none text-muted hover-primary">Danh mục Chức vụ</a>
                <i class="bi bi-chevron-right mx-2" style="font-size: 0.7rem;"></i>
                <span class="text-primary fw-medium">@Model.PositionName</span>
            </div>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-white bg-white border rounded-pill px-4 shadow-sm d-flex align-items-center hover-opacity">
                <i class="bi bi-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
            <div class="glass-card mb-5">
                <div class="border-bottom px-4 py-3 bg-light bg-opacity-50">
                    <h5 class="mb-0 fw-bold text-dark d-flex align-items-center" style="font-size: 1.1rem;">
                        <i class="bi bi-pencil-square me-2 text-primary opacity-75"></i> Thông tin chức vụ
                    </h5>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 border-0 shadow-sm mb-4"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-4 mb-4">
                            <div class="col-md-5">
                                <div class="form-group">
                                    <label asp-for="PositionCode" class="form-label-modern">Mã chức vụ <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-hash input-icon"></i>
                                        <input asp-for="PositionCode" class="form-control input-modern" placeholder="VD: CV01, MGR..." required />
                                    </div>
                                    <span asp-validation-for="PositionCode" class="text-danger small mt-1 d-block ms-1"></span>
                                    <div class="form-text mt-1 ms-1 text-muted opacity-75" style="font-size: 0.75rem;">Mã nội bộ công ty.</div>
                                </div>
                            </div>
                            <div class="col-md-7">
                                <div class="form-group">
                                    <label asp-for="RankLevel" class="form-label-modern">Cấp bậc chuyên môn (Rank)</label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-reception-3 input-icon"></i>
                                        <input asp-for="RankLevel" type="number" class="form-control input-modern" placeholder="VD: 1, 2, 3..." />
                                    </div>
                                    <span asp-validation-for="RankLevel" class="text-danger small mt-1 d-block ms-1"></span>
                                    <div class="form-text mt-1 ms-1 text-muted opacity-75" style="font-size: 0.75rem;">Hệ số ưu tiên phân cấp (Số bé = chức to).</div>
                                </div>
                            </div>
                        </div>

                        <div class="form-group mb-5">
                            <label asp-for="PositionName" class="form-label-modern">Tên chức vụ <span class="text-danger">*</span></label>
                            <div class="input-wrapper">
                                <i class="bi bi-tag input-icon"></i>
                                <input asp-for="PositionName" class="form-control input-modern" placeholder="Nhập tên chức vụ đầy đủ..." required />
                            </div>
                            <span asp-validation-for="PositionName" class="text-danger small mt-1 d-block ms-1"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-3 pt-4 border-top border-secondary border-opacity-10">
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4 shadow-sm border fw-medium hover-opacity" style="transition: all 0.2s ease;">Hủy bỏ</a>
                            <button type="submit" class="btn btn-gradient rounded-pill px-5 shadow-sm fw-bold">
                                <i class="bi bi-floppy me-2"></i> Lưu Cập Nhật
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>