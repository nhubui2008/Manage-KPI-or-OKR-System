@model Manage_KPI_or_OKR_System.Models.Position
@{
    ViewData["Title"] = "Chỉnh sửa Chức vụ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-content">
    <div class="page-header d-flex align-items-center justify-content-between mb-4 animate__animated animate__fadeIn">
        <div>
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge bg-primary px-3 py-2 rounded-pill shadow-sm">
                    <i class="bi bi-pencil-square me-1"></i> Chế độ chỉnh sửa
                </span>
                <span class="text-muted small">Mã: <strong>@Model.PositionCode</strong></span>
            </div>
            <h1 class="fw-800 text-dark mb-1">@Model.PositionName</h1>
            <div class="page-breadcrumb">
                <a href="/" class="text-decoration-none opacity-75">Trang chủ</a>
                <span class="separator">/</span>
                <a asp-action="Index" class="text-decoration-none opacity-75">Danh mục Chức vụ</a>
                <span class="separator">/</span>
                <span class="text-primary fw-bold">Chỉnh sửa</span>
            </div>
        </div>
        <div class="d-flex gap-2 mt-3 mt-md-0">
            <a asp-action="Index" class="btn-outline-custom shadow-sm">
                <i class="bi bi-x-lg me-2"></i> Hủy bỏ
            </a>
            <button type="submit" form="editForm" class="btn-primary-custom shadow-sm">
                <i class="bi bi-floppy me-2"></i> Lưu thay đổi
            </button>
        </div>
    </div>

    <div class="row g-4">
        <!-- FORM COLUMN -->
        <div class="col-xl-8 animate__animated animate__fadeInLeft">
            <div class="content-card border-0 shadow-lg" style="background: rgba(255,255,255,0.95); backdrop-filter: blur(10px);">
                <div class="card-header-custom border-bottom bg-transparent py-4">
                    <h5 class="fw-bold fs-5 mb-0">
                        <i class="bi bi-person-badge text-primary me-2"></i> Thông tin Chức vụ
                    </h5>
                </div>

                <div class="card-body-custom p-4">
                    <form asp-action="Edit" method="post" id="editForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                        <input type="hidden" asp-for="Id" />

                        <!-- SECTION 1: ĐỊNH DANH -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-primary text-white me-3 d-flex align-items-center justify-content-center shadow"
                                 style="width: 38px; height: 38px; border-radius: 12px; flex-shrink: 0;">
                                <span class="fw-bold">1</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Thông tin định danh</h6>
                        </div>

                        <div class="row g-4 mb-5 p-3 rounded-4 bg-light bg-opacity-50 border border-white">
                            <div class="col-md-4">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">
                                        Mã chức vụ <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-hash"></i>
                                        <input asp-for="PositionCode" class="form-control shadow-sm" placeholder="VD: CV01, MGR..." required />
                                    </div>
                                    <span asp-validation-for="PositionCode" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-8">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">
                                        Tên chức vụ <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-person-workspace"></i>
                                        <input asp-for="PositionName" id="nameInput" class="form-control shadow-sm" placeholder="VD: Trưởng phòng, Nhân viên..." required />
                                    </div>
                                    <span asp-validation-for="PositionName" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <!-- SECTION 2: THỨ BẬC -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-success text-white me-3 d-flex align-items-center justify-content-center shadow"
                                 style="width: 38px; height: 38px; border-radius: 12px; flex-shrink: 0;">
                                <span class="fw-bold">2</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Thứ bậc</h6>
                        </div>

                        <div class="row g-4 p-3 rounded-4 bg-light bg-opacity-50 border border-white mb-4">
                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Cấp bậc (Số càng nhỏ cấp càng cao)</label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-sort-numeric-up"></i>
                                        <input asp-for="RankLevel" id="rankInput" type="number" class="form-control shadow-sm" placeholder="VD: 1, 2, 3..." />
                                    </div>
                                    <span asp-validation-for="RankLevel" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                            <a asp-action="Index" class="btn-outline-custom">
                                <i class="bi bi-x-lg me-2"></i> Hủy thao tác
                            </a>
                            <button type="submit" class="btn-primary-custom" style="padding: 12px 40px; border-radius: 12px;">
                                <i class="bi bi-floppy fs-5 me-2"></i> Cập nhật Chức vụ
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- SIDEBAR COLUMN -->
        <div class="col-xl-4 animate__animated animate__fadeInRight">
            <div class="sticky-top" style="top: 100px;">
                <!-- Preview Card -->
                <div class="content-card border-0 shadow-lg text-white mb-4"
                     style="background: linear-gradient(135deg, #0078d4, #005a9e); border-radius: 24px;">
                    <div class="card-body-custom p-4">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-white bg-opacity-20 p-3 rounded-4 me-3">
                                <i class="bi bi-person-badge fs-3 text-white"></i>
                            </div>
                            <div>
                                <div class="small opacity-75 fw-bold text-uppercase">Mã chức vụ</div>
                                <h4 class="mb-0 fw-800" id="previewCode">@Model.PositionCode</h4>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="small opacity-75 fw-bold text-uppercase mb-1">Tên chức vụ</div>
                            <div class="fw-bold fs-6" id="previewName" style="min-height: 28px;">@Model.PositionName</div>
                        </div>
                        <div class="bg-white bg-opacity-10 p-3 rounded-4">
                            <div class="small opacity-75 mb-1">Cấp bậc</div>
                            <div class="fw-bold" id="previewRank">@(Model.RankLevel.HasValue ? "Cấp " + Model.RankLevel : "--")</div>
                        </div>
                    </div>
                </div>

                <!-- Tips Card -->
                <div class="content-card border-0 shadow-sm rounded-4 bg-white p-4">
                    <h6 class="fw-bold text-dark mb-3">
                        <i class="bi bi-info-circle text-primary me-2"></i> Lưu ý khi chỉnh sửa
                    </h6>
                    <ul class="list-unstyled mb-0 small text-muted" style="line-height: 1.8;">
                        <li class="mb-2"><i class="bi bi-patch-check-fill text-success me-2"></i> Mã chức vụ nên viết tắt, viết hoa.</li>
                        <li class="mb-2"><i class="bi bi-patch-check-fill text-warning me-2"></i> Thay đổi cấp bậc có thể ảnh hưởng đến bộ lọc nhân sự.</li>
                        <li><i class="bi bi-patch-check-fill text-success me-2"></i> Cấp bậc 1 là cao nhất trong hệ thống.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    .letter-spacing-1 { letter-spacing: 0.1em; }
    .form-select, .form-control { border: 1.5px solid #edf2f7; padding-top: 12px; padding-bottom: 12px; }
    .form-select:focus, .form-control:focus { border-color: #a3c9f9; box-shadow: 0 0 0 4px rgba(163, 201, 249, 0.1); }
    .animate__animated { animation-duration: 0.8s; }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <script>
        const codeInput = document.getElementById('PositionCode');
        const nameInput = document.getElementById('nameInput');
        const rankInput = document.getElementById('rankInput');
        function updatePreview() {
            document.getElementById('previewCode').textContent = codeInput.value.trim().toUpperCase() || '--';
            document.getElementById('previewName').textContent = nameInput.value.trim() || '--';
            document.getElementById('previewRank').textContent = rankInput.value ? 'Cấp ' + rankInput.value : '--';
        }
        [codeInput, nameInput, rankInput].forEach(el => el.addEventListener('input', updatePreview));
        window.addEventListener('DOMContentLoaded', updatePreview);
    </script>
}