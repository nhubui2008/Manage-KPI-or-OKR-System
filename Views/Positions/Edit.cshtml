@model Manage_KPI_or_OKR_System.Models.Position
@{
    ViewData["Title"] = "Chỉnh sửa Chức vụ - " + Model.PositionName;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-0">
    <!-- Page Header -->
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 font-weight-bold mb-1">Chỉnh sửa Chức vụ</h1>
            <div class="page-breadcrumb">
                <a href="/">Trang chủ</a>
                <i class="bi bi-chevron-right separator"></i>
                <a asp-action="Index">Danh mục Chức vụ</a>
                <i class="bi bi-chevron-right separator"></i>
                <a asp-action="Details" asp-route-code="@Model.PositionCode">@Model.PositionName</a>
                <i class="bi bi-chevron-right separator"></i>
                <span>Chỉnh sửa</span>
            </div>
        </div>
        <div>
            <a asp-action="Index" class="btn-outline-custom d-flex align-items-center px-3 py-2" style="border-radius: 10px; text-decoration: none;">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="content-card">
                <div class="card-header-custom border-bottom">
                    <h5 class="mb-0 fw-bold d-flex align-items-center">
                        <div class="header-icon-box">
                            <i class="bi bi-pencil-square"></i>
                        </div>
                        Cập nhật thông tin chức vụ
                    </h5>
                </div>
                <div class="card-body-custom p-4">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="form-icon-group mb-4">
                            <label asp-for="PositionCode" class="form-label">Mã chức vụ <span class="text-danger">*</span></label>
                            <div class="input-wrapper">
                                <i class="bi bi-hash"></i>
                                <input asp-for="PositionCode" class="form-control bs-input-custom" placeholder="Nhập mã chức vụ (VD: CV01, MGR)..." required />
                            </div>
                            <span asp-validation-for="PositionCode" class="text-danger small mt-1 d-block"></span>
                            <div class="form-text mt-1 text-muted" style="font-size: 0.75rem;">Mã gợi ý: CV + Số thứ tự hoặc viết tắt tên chức vụ.</div>
                        </div>

                        <div class="form-icon-group mb-4">
                            <label asp-for="PositionName" class="form-label">Tên chức vụ <span class="text-danger">*</span></label>
                            <div class="input-wrapper">
                                <i class="bi bi-tag"></i>
                                <input asp-for="PositionName" class="form-control bs-input-custom" placeholder="Nhập tên chức vụ..." required />
                            </div>
                            <span asp-validation-for="PositionName" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="form-icon-group mb-4">
                            <label asp-for="RankLevel" class="form-label">Cấp bậc chuyên môn (Rank)</label>
                            <div class="input-wrapper">
                                <i class="bi bi-reception-3"></i>
                                <input asp-for="RankLevel" type="number" class="form-control bs-input-custom" placeholder="Số càng nhỏ cấp càng cao (VD: 1, 2, 3)..." />
                            </div>
                            <span asp-validation-for="RankLevel" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2 pt-4 border-top">
                            <a asp-action="Index" class="btn-outline-custom px-4 py-2" style="border-radius: 10px;">Hủy bỏ</a>
                            <button type="submit" class="btn-primary-custom px-4 py-2" style="border-radius: 10px;">
                                <i class="bi bi-floppy me-2"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .header-icon-box {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: linear-gradient(135deg, #1a73e8, #4285f4);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 0.85rem;
        margin-right: 12px;
        flex-shrink: 0;
    }

    .form-icon-group label {
        font-weight: 700;
        font-size: 0.75rem;
        color: var(--text-secondary, #5f6368);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 8px;
        display: block;
    }

    .form-icon-group .input-wrapper {
        position: relative;
    }

    .form-icon-group .input-wrapper i {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #1a73e8;
        font-size: 1.1rem;
        opacity: 0.6;
        z-index: 5;
    }

    .bs-input-custom {
        height: 48px;
        border-radius: 12px;
        border: 1.5px solid #e1e8f0;
        padding-left: 48px;
        font-size: 0.9rem;
        transition: all 0.2s;
        background-color: #fcfdfe;
    }

    .bs-input-custom:focus {
        border-color: #1a73e8;
        box-shadow: 0 0 0 4px rgba(26, 115, 232, 0.1);
        background-color: #ffffff;
    }

    .page-header h1 {
        font-size: 1.5rem;
        color: #1a1a2e;
    }
    .separator {
        opacity: 0.5;
        font-size: 0.8rem;
    }
</style>