@model List<Manage_KPI_or_OKR_System.Models.Product>
@{
    ViewData["Title"] = "Danh mục Sản phẩm";
    var categoryNames = ViewBag.CategoryNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var categories = ViewBag.Categories as List<Manage_KPI_or_OKR_System.Models.ProductCategory> ?? new List<Manage_KPI_or_OKR_System.Models.ProductCategory>();
}
@if (TempData["SuccessMessage"] != null)
{<div class="alert alert-success alert-dismissible fade show" role="alert"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}
@if (TempData["ErrorMessage"] != null)
{<div class="alert alert-danger alert-dismissible fade show" role="alert"><i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="h3 font-weight-bold mb-1">Sản phẩm & Vật tư</h1><div class="page-breadcrumb"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a><i class="bi bi-chevron-right separator"></i><span class="text-dark opacity-75">Kho</span><i class="bi bi-chevron-right separator"></i><span class="text-dark fw-bold">Sản phẩm</span></div></div>
    <div class="d-flex justify-content-end gap-2"><a asp-action="Create" class="btn-primary-custom d-flex align-items-center text-decoration-none"><i class="bi bi-plus-lg me-1"></i> Thêm sản phẩm</a></div>
</div>

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100"><div class="card-body-custom">
    <div class="toolbar"><div class="toolbar-left">
        <form method="get" class="d-flex gap-2"><div class="toolbar-search"><i class="bi bi-search"></i><input type="text" name="searchString" value="@ViewBag.CurrentSearch" placeholder="Tìm kiếm theo mã, tên..."></div>
        <select name="categoryId" class="filter-select"><option value="">Tất cả danh mục</option>@foreach(var cat in categories){<option value="@cat.Id" selected="@(ViewBag.CurrentCategory != null && (int)ViewBag.CurrentCategory == cat.Id)">@cat.CategoryName</option>}</select>
        <button type="submit" class="btn-primary-custom" style="padding: 0 16px;"><i class="bi bi-funnel"></i></button></form>
    </div></div>

    <div class="table-responsive w-100"><table class="data-table w-100">
        <thead><tr><th>Thông tin sản phẩm</th><th>Phân loại</th><th>Ngày tạo</th><th class="text-end">Thao tác</th></tr></thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var p in Model)
                {
                    var catName = p.CategoryId.HasValue && categoryNames.ContainsKey(p.CategoryId.Value) ? categoryNames[p.CategoryId.Value] : "Chưa phân loại";
                    <tr>
                        <td><div class="fw-semibold text-dark">@p.ProductName</div><div class="text-muted" style="font-size:0.75rem;">Mã SP: @p.ProductCode</div></td>
                        <td><span class="badge bg-light text-dark border">@catName</span></td>
                        <td class="text-muted">@(p.CreatedAt?.ToString("dd/MM/yyyy") ?? "")</td>
                        <td><div class="action-btns justify-content-end">
                            <button type="button" class="action-btn" title="Sửa" onclick="showComingSoonToast('Chỉnh sửa Sản phẩm')"><i class="bi bi-pencil-square"></i></button>
                            <form asp-action="Delete" method="post" style="display:inline;"><input type="hidden" name="id" value="@p.Id" /><button type="submit" class="action-btn danger" title="Xóa" onclick="return confirm('Vô hiệu hóa sản phẩm?')"><i class="bi bi-trash"></i></button></form>
                        </div></td>
                    </tr>
                }
            }
            else
            {<tr><td colspan="4" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;"></i><p class="mt-2">Chưa có sản phẩm nào</p></td></tr>}
        </tbody>
    </table></div>
</div></div>


        </div>
    </div>
</div>