@model Manage_KPI_or_OKR_System.Models.Product
@{
    ViewData["Title"] = "Thêm Sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var categories = ViewBag.Categories as List<Manage_KPI_or_OKR_System.Models.ProductCategory> ?? new List<Manage_KPI_or_OKR_System.Models.ProductCategory>();
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-dark fw-bold">
                <i class="bi bi-box-seam-fill me-2"></i>Thêm Sản phẩm Mới
            </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-dark text-decoration-none opacity-75">Danh mục Sản phẩm</a></li>
                    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Thêm mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="content-card rounded-3">
                <div class="card-header-custom bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-tag me-2"></i>Thông tin Sản phẩm</h5>
                </div>
                <div class="card-body-custom p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="ProductCode" class="form-label fw-bold text-dark">Mã sản phẩm <span class="text-danger">*</span></label>
                                <input asp-for="ProductCode" class="form-control" placeholder="VD: PRD001, ITEM-01..." required />
                                <span asp-validation-for="ProductCode" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ProductName" class="form-label fw-bold text-dark">Tên sản phẩm <span class="text-danger">*</span></label>
                                <input asp-for="ProductName" class="form-control" placeholder="Nhập tên sản phẩm" required />
                                <span asp-validation-for="ProductName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="CategoryId" class="form-label fw-bold text-dark">Danh mục <span class="text-danger">*</span></label>
                                <select asp-for="CategoryId" class="form-select" required>
                                    <option value="">-- Chọn danh mục --</option>
                                    @foreach (var cat in categories)
                                    {
                                        <option value="@cat.Id">@cat.CategoryName</option>
                                    }
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 pt-3 mt-4 border-top">
                            <a asp-action="Index" class="btn-outline-custom px-4">Hủy bỏ</a>
                            <button type="submit" class="btn-primary-custom px-4">
                                <i class="bi bi-save me-1"></i> Lưu Sản phẩm
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
