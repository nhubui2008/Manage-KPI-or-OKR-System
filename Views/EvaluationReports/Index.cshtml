@model IEnumerable<Manage_KPI_or_OKR_System.Models.OKR_Employee_Allocation>
@using Manage_KPI_or_OKR_System.Helpers
@{
    ViewData["Title"] = "Báo cáo Đánh giá Chi tiết (Director's View)";
    var okrs = (ViewBag.OKRs as List<Manage_KPI_or_OKR_System.Models.OKR>) ?? new List<Manage_KPI_or_OKR_System.Models.OKR>();
    var krs = (ViewBag.KRs as List<Manage_KPI_or_OKR_System.Models.OKRKeyResult>) ?? new List<Manage_KPI_or_OKR_System.Models.OKRKeyResult>();
    var employees = (ViewBag.Employees as Dictionary<int, Manage_KPI_or_OKR_System.Models.Employee>) ?? new Dictionary<int, Manage_KPI_or_OKR_System.Models.Employee>();
    var failReasons = (ViewBag.FailReasons as Dictionary<int, string>) ?? new Dictionary<int, string>();
    var departments = (ViewBag.Departments as List<Manage_KPI_or_OKR_System.Models.Department>) ?? new List<Manage_KPI_or_OKR_System.Models.Department>();
}

<div class="container-fluid px-0">
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 font-weight-bold mb-1">Báo cáo Phân bổ & Đánh giá Chỉ tiêu</h1>
            <div class="page-breadcrumb">
                <a href="/">Trang chủ</a>
                <i class="bi bi-chevron-right separator"></i>
                <span class="text-primary fw-medium">@ViewBag.CurrentDeptName</span>
                <i class="bi bi-chevron-right separator"></i>
                <span class="text-muted small">Chu kỳ: @ViewBag.CurrentCycle</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-custom" onclick="window.print()"><i class="bi bi-printer me-1"></i> In báo cáo</button>
            <a asp-action="ExportExcel" asp-route-departmentId="@ViewBag.CurrentDeptId" asp-route-cycle="@ViewBag.CurrentCycle" class="btn-primary-custom text-decoration-none">
                <i class="bi bi-file-earmark-excel me-1"></i> Xuất Excel
            </a>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="content-card mb-4 shadow-sm border-0">
        <div class="card-body-custom">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Phòng ban</label>
                    <select name="departmentId" class="form-select">
                        @foreach(var d in departments){
                            <option value="@d.Id" selected="@(ViewBag.CurrentDeptId == d.Id ? "selected" : null)">@d.DepartmentName</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Chu kỳ (Quý/Năm)</label>
                    <select name="cycle" class="form-select">
                        @if (ViewBag.Cycles != null)
                        {
                            foreach (var c in (List<string>)ViewBag.Cycles)
                            {
                                <option value="@c" selected="@(ViewBag.CurrentCycle == c ? "selected" : null)">@c</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary-custom w-100">Lọc dữ liệu</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Report Table -->
    <div class="content-card shadow-sm border-0">
        <div class="table-responsive">
            <table class="data-table w-100">
                <thead class="bg-light">
                    <tr>
                        <th>Bộ phận / Mục tiêu</th>
                        <th>Kết quả then chốt</th>
                        <th>Người phụ trách</th>
                        <th class="text-end">Chỉ tiêu riêng</th>
                        <th class="text-end">Thực tế đạt</th>
                        <th class="text-center">Hoàn thành</th>
                        <th class="text-center">Đánh giá</th>
                        <th>Lý do (Nếu chưa đạt)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var okr in okrs)
                    {
                        var okrKrs = krs.Where(k => k.OKRId == okr.Id).ToList();
                        foreach (var kr in okrKrs)
                        {
                            var krAllocations = Model.Where(a => a.OKRId == okr.Id).ToList(); // Simplifying allocation link
                            bool first = true;
                            foreach (var alloc in krAllocations)
                            {
                                var emp = employees.ContainsKey(alloc.EmployeeId) ? employees[alloc.EmployeeId] : null;
                                // In a real system, the allocation might link to the KR specifically. 
                                // Here we use the KR's CurrentValue for demonstration of the logic.
                                decimal progress = ProgressHelper.CalculateProgress(kr.CurrentValue ?? 0, alloc.AllocatedValue ?? 1, kr.IsInverse);
                                string status = ProgressHelper.GetResultStatus(progress);
                                string statusColor = ProgressHelper.GetProgressTextColorClass(progress);
                                string statusBgColor = ProgressHelper.GetProgressColorClass(progress);
                                
                                <tr>
                                    @if(first){ <td rowspan="@krAllocations.Count" class="fw-bold align-middle">@okr.ObjectiveName</td> }
                                    @if(first){ <td rowspan="@krAllocations.Count" class="align-middle">@kr.KeyResultName</td> }
                                    <td>@(emp?.FullName ?? "N/A")</td>
                                    <td class="text-end">@String.Format("{0:N0}", alloc.AllocatedValue) @kr.Unit</td>
                                    <td class="text-end fw-bold">@String.Format("{0:N1}", kr.CurrentValue) @kr.Unit</td>
                                    <td class="text-center">
                                        <div class="d-flex align-items-center gap-2 justify-content-center">
                                            <span class="fw-bold @statusColor">@((int)progress)%</span>
                                            <div class="progress" style="width: 50px; height: 5px;">
                                                <div class="progress-bar @statusBgColor" style="width: @((int)progress)%"></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center"><span class="badge @statusBgColor bg-opacity-10 @statusColor px-3">@status</span></td>
                                    <td class="text-muted small">@(kr.FailReasonId.HasValue && failReasons.ContainsKey(kr.FailReasonId.Value) ? failReasons[kr.FailReasonId.Value] : (progress < 100 ? "Chưa rõ lý do / Đang cập nhật" : "-"))</td>
                                </tr>
                                first = false;
                            }
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Director's Summative Analysis Section -->
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="content-card">
                <div class="card-header-custom"><i class="bi bi-chat-left-text me-2"></i>Tổng hợp của Giám đốc</div>
                <div class="card-body-custom">
                    <textarea id="directorSummaryText" class="form-control" rows="4" placeholder="Nhập nhận định chung về tình hình thực hiện OKR/KPI của Sale Q1...">@ViewBag.DirectorSummary</textarea>
                    <div class="d-flex justify-content-end mt-3">
                        <button id="btnSaveSummary" class="btn-primary-custom"><i class="bi bi-save me-1"></i> Lưu nhận xét</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="content-card h-100">
                <div class="card-header-custom"><i class="bi bi-exclamation-triangle me-2"></i>Các rủi ro vận hành (P.S.)</div>
                <div class="card-body-custom">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><span class="badge bg-danger rounded-pill me-2">!</span>Sự cố cúp điện 2h (Tháng 2) - Ảnh hưởng 15% năng suất KPI sản xuất.</li>
                        <li class="mb-2"><span class="badge bg-warning rounded-pill me-2">!</span>Biến động tỷ giá - Ảnh hưởng chỉ tiêu chi phí/lợi nhuận.</li>
                        <li onclick="addIncident()" style="cursor: pointer;" class="text-primary hover-opacity"><i class="bi bi-plus-circle me-2"></i> Thêm sự cố vận hành năm nay</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function addIncident() {
            Swal.fire({
                title: 'Thêm sự cố vận hành',
                input: 'textarea',
                inputPlaceholder: 'Nhập chi tiết sự cố và mức độ ảnh hưởng...',
                showCancelButton: true,
                confirmButtonText: 'Lưu',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire('Đã lưu!', 'Sự cố đã được ghi nhận.', 'success');
                }
            });
        }

        document.getElementById('btnSaveSummary')?.addEventListener('click', async function() {
            const btn = this;
            const textarea = document.getElementById('directorSummaryText');
            const content = textarea.value;
            const departmentId = '@ViewBag.CurrentDeptId';
            const cycle = '@ViewBag.CurrentCycle';

            if (!content.trim()) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Thông báo',
                    text: 'Vui lòng nhập nội dung nhận xét trước khi lưu.'
                });
                return;
            }

            // Show loading state
            btn.disabled = true;
            const originalContent = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Đang lưu...';

            try {
                const formData = new URLSearchParams();
                formData.append('departmentId', departmentId);
                formData.append('cycle', cycle);
                formData.append('content', content);

                const response = await fetch('/EvaluationReports/SaveDirectorSummary', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: formData
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Thành công',
                        text: result.message || 'Lưu nhận xét của Giám đốc thành công!',
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    throw new Error(result.message || 'Có lỗi xảy ra từ máy chủ.');
                }
            } catch (error) {
                console.error('Error saving summary:', error);
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi',
                    text: 'Không thể kết nối đến máy chủ hoặc có lỗi xảy ra. Vui lòng thử lại.'
                });
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalContent;
            }
        });
    </script>
}
