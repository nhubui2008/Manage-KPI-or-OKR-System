@model IEnumerable<Manage_KPI_or_OKR_System.Models.OKR_Employee_Allocation>
@using Manage_KPI_or_OKR_System.Helpers
@{
    ViewData["Title"] = "Báo cáo hiệu suất Sale Q1";
    var okrs = ViewBag.OKRs as List<Manage_KPI_or_OKR_System.Models.OKR> ?? new List<Manage_KPI_or_OKR_System.Models.OKR>();
    var employees = ViewBag.Employees as Dictionary<int, Manage_KPI_or_OKR_System.Models.Employee> ?? new Dictionary<int, Manage_KPI_or_OKR_System.Models.Employee>();
    var failReasons = ViewBag.FailReasons as Dictionary<int, string> ?? new Dictionary<int, string>();
    var saleDept = ViewBag.SaleDept as Manage_KPI_or_OKR_System.Models.Department;
    
    // Tính toán tổng hiệu suất bộ phận
    double deptTotalProgress = okrs.Any() ? okrs.Average(o => (double)o.TotalProgress) : 0;
}

<div class="container-fluid px-0">
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 font-weight-bold mb-1">Hiệu suất bộ phận Sale - @ViewBag.CurrentCycle</h1>
            <div class="page-breadcrumb">
                <a href="/">Trang chủ</a>
                <i class="bi bi-chevron-right separator"></i>
                <a asp-action="Index">Báo cáo</a>
                <i class="bi bi-chevron-right separator"></i>
                <span>Sale Q1 Analysis</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn-outline-custom" onclick="window.print()"><i class="bi bi-printer me-1"></i> In báo cáo</button>
            <button class="btn-primary-custom" onclick="location.reload()"><i class="bi bi-arrow-clockwise me-1"></i> Làm mới</button>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 bg-primary text-white p-4 h-100">
                <h6 class="text-white-50 small text-uppercase fw-bold mb-3">Hiệu suất bộ phận Sale</h6>
                <div class="d-flex align-items-center justify-content-between">
                    <h2 class="display-6 fw-bold mb-0">@deptTotalProgress.ToString("N1")%</h2>
                    <div class="bg-white bg-opacity-20 rounded-circle p-3">
                        <i class="bi bi-graph-up-arrow fs-3"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <span class="badge @(deptTotalProgress >= 100 ? "bg-success" : "bg-warning") text-white rounded-pill px-3">
                        @(deptTotalProgress >= 100 ? "Đạt chỉ tiêu chung" : "Chưa đạt chỉ tiêu chung")
                    </span>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <h6 class="text-muted small text-uppercase fw-bold mb-3">Phân tích mục tiêu bộ phận (Director's View)</h6>
                <div class="row text-center border-top pt-3">
                    <div class="col-4 border-end">
                        <h4 class="fw-bold text-dark mb-1">@okrs.Count</h4>
                        <p class="text-muted small mb-0">Mục tiêu OKR</p>
                    </div>
                    <div class="col-4 border-end">
                        <h4 class="fw-bold text-success mb-1">@okrs.Count(o => o.TotalProgress >= 100)</h4>
                        <p class="text-muted small mb-0">OKR Hoàn thành</p>
                    </div>
                    <div class="col-4">
                        <h4 class="fw-bold text-danger mb-1">@okrs.Count(o => o.TotalProgress < 100)</h4>
                        <p class="text-muted small mb-0">OKR Cần tập trung</p>
                    </div>
                </div>
                <div class="mt-3">
                    <p class="small text-muted mb-0"><i class="bi bi-info-circle me-1"></i> Giám đốc có thể xem chi tiết lý do bên dưới để điều chỉnh chỉ tiêu cho năm kế tiếp.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Detailed Table -->
    <div class="row m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100">
                <div class="card-body-custom p-0">
                    <div class="p-3 bg-light border-bottom">
                        <h5 class="mb-0 fw-bold fs-6"><i class="bi bi-people-fill me-2 text-primary"></i>Chi tiết hiệu suất từng nhân sự</h5>
                    </div>
                    <div class="table-responsive w-100">
                        <table class="data-table w-100">
                            <thead>
                                <tr>
                                    <th>Nhân viên</th>
                                    <th>Mục tiêu phụ trách</th>
                                    <th>Phân bổ (Target)</th>
                                    <th>Đạt được (%)</th>
                                    <th>Bảng chi tiết (%)</th>
                                    <th>Đánh giá</th>
                                    <th>Lý do (Nếu chưa đủ)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        var emp = employees.ContainsKey(item.EmployeeId) ? employees[item.EmployeeId] : null;
                                        var okr = okrs.FirstOrDefault(o => o.Id == item.OKRId);
                                        if (emp == null || okr == null) continue;
                                        
                                        // Tiến độ thực tế của nhân viên (giả sử lấy theo tiến độ OKR chung nếu ko có chi tiết sub-KPI)
                                        decimal actualProgress = okr.TotalProgress;
                                        bool isMet = actualProgress >= 100;
                                        string statusClass = isMet ? "text-success bg-success-soft" : "text-danger bg-danger-soft";
                                        string statusText = isMet ? "ĐỦ" : "CHƯA ĐỦ";

                                        <tr>
                                            <td>
                                                <div class="fw-bold text-dark">@emp.FullName</div>
                                                <div class="text-muted small">@emp.EmployeeCode</div>
                                            </td>
                                            <td>
                                                <div class="text-dark fw-medium">@okr.ObjectiveName</div>
                                                <span class="badge bg-secondary-soft text-secondary small rounded-pill">@okr.Cycle</span>
                                            </td>
                                            <td class="fw-bold text-dark">@item.AllocatedValue.ToString("N0")</td>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="progress flex-grow-1" style="height: 6px; width: 60px;">
                                                        <div class="progress-bar @(isMet ? "bg-success" : "bg-danger")" style="width: @(Math.Min(actualProgress, 100))%"></div>
                                                    </div>
                                                    <span class="fw-bold @(actualProgress >= 100 ? "text-success" : "text-danger")">@actualProgress%</span>
                                                </div>
                                            </td>
                                            <td>@actualProgress% / 100%</td>
                                            <td>
                                                <span class="badge @(isMet ? "bg-success" : "bg-danger") px-3 rounded-pill" style="font-size: 0.7rem;">@statusText</span>
                                            </td>
                                            <td class="text-muted" style="min-width: 200px;">
                                                @if (!isMet)
                                                {
                                                    <i class="bi bi-chat-left-dots me-1"></i>
                                                    @if(okr.KeyResults.Any(k => k.FailReasonId.HasValue))
                                                    {
                                                        var reasonId = okr.KeyResults.First(k => k.FailReasonId.HasValue).FailReasonId.Value;
                                                        <span>@(failReasons.ContainsKey(reasonId) ? failReasons[reasonId] : "Lý do khác")</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="fst-italic">Chưa cập nhật lý do</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-success small"><i class="bi bi-check-circle-fill me-1"></i>Hoàn thành tốt</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-5 text-muted">Không có dữ liệu phân bổ Sale trong quý này.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Director's Decision Section -->
    <div class="row g-4 mt-2">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 p-4 border-start border-4 border-primary">
                <h6 class="fw-bold text-dark mb-3"><i class="bi bi-lightning-charge-fill text-warning me-2"></i>Tùy biến cho năm sau</h6>
                <p class="text-muted">Dựa trên hiệu suất quý 1, hệ thống gợi ý điều chỉnh chỉ tiêu Sale cho kỳ tiếp theo:</p>
                <div class="d-flex gap-3 mt-3">
                    <div class="bg-light p-3 rounded-3 flex-grow-1">
                        <small class="text-muted d-block">Phân phối thâm hụt (Cúp điện > 2h)</small>
                        <span class="fw-bold text-danger">-5.2% Kế hoạch Sale</span>
                    </div>
                    <div class="bg-light p-3 rounded-3 flex-grow-1">
                        <small class="text-muted d-block">Dự báo tăng trưởng dựa trên Q1</small>
                        <span class="fw-bold text-success">+12.5% Chỉ tiêu quý sau</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-success-soft { background-color: rgba(40, 167, 69, 0.1); }
    .bg-danger-soft { background-color: rgba(220, 53, 69, 0.1); }
    .bg-secondary-soft { background-color: rgba(108, 117, 125, 0.1); }
    .bg-light-primary { background-color: rgba(0, 123, 255, 0.05); }
    
    @@media print {
        .page-header, .btn-outline-custom, .btn-primary-custom { display: none; }
        .card { box-shadow: none !important; border: 1px solid #ddd !important; }
    }
</style>
