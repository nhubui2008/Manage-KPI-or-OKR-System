@model Manage_KPI_or_OKR_System.Models.DeliveryNote
@{
    ViewData["Title"] = "Tạo Phiếu giao hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var orders = ViewBag.AllOrders as List<Manage_KPI_or_OKR_System.Models.SalesOrder> ?? new List<Manage_KPI_or_OKR_System.Models.SalesOrder>();
    var partners = ViewBag.AllPartners as List<Manage_KPI_or_OKR_System.Models.ShippingPartner> ?? new List<Manage_KPI_or_OKR_System.Models.ShippingPartner>();
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-dark fw-bold">
                <i class="bi bi-truck me-2"></i>Tạo Phiếu giao hàng Mới
            </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-dark text-decoration-none opacity-75">Quản lý Giao hàng</a></li>
                    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Tạo mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="content-card rounded-3">
                <div class="card-header-custom bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-file-earmark-text me-2"></i>Thông tin Giao hàng</h5>
                </div>
                <div class="card-body-custom p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-12">
                                <label asp-for="OrderId" class="form-label fw-bold text-dark">Đơn hàng liên kết <span class="text-danger">*</span></label>
                                <select asp-for="OrderId" class="form-select" required>
                                    <option value="">-- Chọn đơn hàng --</option>
                                    @foreach (var o in orders)
                                    {
                                        <option value="@o.Id">@o.OrderCode</option>
                                    }
                                </select>
                                <span asp-validation-for="OrderId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PartnerId" class="form-label fw-bold text-dark">Đối tác vận chuyển</label>
                                <select asp-for="PartnerId" class="form-select">
                                    <option value="">-- Chọn đối tác --</option>
                                    @foreach (var p in partners)
                                    {
                                        <option value="@p.Id">@p.PartnerName</option>
                                    }
                                </select>
                                <span asp-validation-for="PartnerId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="TrackingCode" class="form-label fw-bold text-dark">Mã vận đơn (Tracking Code)</label>
                                <input asp-for="TrackingCode" class="form-control" placeholder="Nhập mã vận đơn" />
                                <span asp-validation-for="TrackingCode" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ShippingFee" class="form-label fw-bold text-dark">Phí vận chuyển (VNĐ)</label>
                                <input asp-for="ShippingFee" type="number" step="0.01" class="form-control" placeholder="0.00" />
                                <span asp-validation-for="ShippingFee" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="DispatchDate" class="form-label fw-bold text-dark">Ngày gửi hàng</label>
                                <input asp-for="DispatchDate" type="date" class="form-control" />
                                <span asp-validation-for="DispatchDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 pt-3 mt-4 border-top">
                            <a asp-action="Index" class="btn-outline-custom px-4">Hủy bỏ</a>
                            <button type="submit" class="btn-primary-custom px-4">
                                <i class="bi bi-save me-1"></i> Tạo Phiếu giao
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
