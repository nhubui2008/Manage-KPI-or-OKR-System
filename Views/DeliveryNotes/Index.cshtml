@model List<Manage_KPI_or_OKR_System.Models.DeliveryNote>
@{
    ViewData["Title"] = "Phiếu Giao hàng";
    var orders = ViewBag.Orders as Dictionary<int, string> ?? new Dictionary<int, string>();
    var partners = ViewBag.Partners as Dictionary<int, string> ?? new Dictionary<int, string>();
    var methods = ViewBag.Methods as Dictionary<int, string> ?? new Dictionary<int, string>();
    var allOrders = ViewBag.AllOrders as List<Manage_KPI_or_OKR_System.Models.SalesOrder> ?? new List<Manage_KPI_or_OKR_System.Models.SalesOrder>();
    var allPartners = ViewBag.AllPartners as List<Manage_KPI_or_OKR_System.Models.ShippingPartner> ?? new List<Manage_KPI_or_OKR_System.Models.ShippingPartner>();
}
@if (TempData["SuccessMessage"] != null)
{<div class="alert alert-success alert-dismissible fade show" role="alert"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="h3 font-weight-bold mb-1">Phiếu Giao hàng</h1><div class="page-breadcrumb"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a><i class="bi bi-chevron-right separator"></i><span class="text-dark opacity-75">Vận chuyển</span><i class="bi bi-chevron-right separator"></i><span class="text-dark fw-bold">Phiếu giao hàng</span></div></div>
    @if (!User.IsInRole("Warehouse") && !User.IsInRole("warehouse"))
    {
        <div class="d-flex justify-content-end gap-2"><a asp-action="Create" class="btn-primary-custom d-flex align-items-center text-decoration-none"><i class="bi bi-plus-lg me-1"></i> Tạo phiếu giao</a></div>
    }
</div>

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100"><div class="card-body-custom">
    <div class="table-responsive w-100"><table class="data-table w-100">
        <thead><tr><th>Tracking Code</th><th>Đơn hàng</th><th>Đối tác VC</th><th>Ngày xuất</th><th>Hạn giao</th><th class="text-end">Phí ship (VNĐ)</th><th class="text-end">Thao tác</th></tr></thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var dn in Model)
                {
                    var orderCode = dn.OrderId.HasValue && orders.ContainsKey(dn.OrderId.Value) ? orders[dn.OrderId.Value] : "N/A";
                    var partnerName = dn.PartnerId.HasValue && partners.ContainsKey(dn.PartnerId.Value) ? partners[dn.PartnerId.Value] : "N/A";
                    <tr>
                        <td class="fw-bold text-dark">@dn.TrackingCode</td>
                        <td class="text-muted">@orderCode</td>
                        <td><span class="badge bg-light text-dark border">@partnerName</span></td>
                        <td class="text-muted">@(dn.DispatchDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td class="text-muted">@(dn.Deadline?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td class="text-end fw-medium">@(dn.ShippingFee?.ToString("N0") ?? "0")</td>
                        @if (!User.IsInRole("Warehouse") && !User.IsInRole("warehouse"))
                        {
                            <td><div class="action-btns justify-content-end">
                                <button type="button" class="action-btn" title="Sửa" onclick="showComingSoonToast('Chỉnh sửa Phiếu Giao hàng')"><i class="bi bi-pencil-square"></i></button>
                                <form asp-action="Delete" method="post" style="display:inline;"><input type="hidden" name="id" value="@dn.Id" /><button type="submit" class="action-btn danger" title="Xóa" onclick="return confirm('Vô hiệu hóa phiếu giao?')"><i class="bi bi-trash"></i></button></form>
                            </div></td>
                        }
                    </tr>
                }
            }
            else
            {<tr><td colspan="@(User.IsInRole("Warehouse") || User.IsInRole("warehouse") ? "6" : "7")" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;"></i><p class="mt-2">Chưa có phiếu giao hàng nào</p></td></tr>}
        </tbody>
    </table></div>
</div></div>


        </div>
    </div>
</div>