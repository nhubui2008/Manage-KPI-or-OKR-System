@{
    ViewData["Title"] = "Quản lý Giao hàng";
}

<div class="page-header">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Phiếu Giao hàng</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Giao nhận & Vận chuyển</span>
            <i class="bi bi-chevron-right separator"></i>
            <span>Phiếu giao hàng</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn-primary-custom">
            <i class="bi bi-plus-lg"></i> Tạo phiếu giao
        </button>
    </div>
</div>

<div class="content-card">
    <div class="card-body-custom">
        <div class="toolbar">
            <div class="toolbar-left">
                <div class="toolbar-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Tìm mã phiếu, mã đơn hàng...">
                </div>
                <div class="d-flex align-items-center gap-2 border rounded px-2 bg-light bg-opacity-50">
                    <i class="bi bi-calendar3 text-muted"></i>
                    <input type="date" class="form-control form-control-sm border-0 bg-transparent shadow-none w-auto" value="2026-02-01">
                    <span class="text-muted">-</span>
                    <input type="date" class="form-control form-control-sm border-0 bg-transparent shadow-none w-auto" value="2026-02-28">
                </div>
                <select class="filter-select">
                    <option value="">Đơn vị vận chuyển</option>
                    <option value="internal">Đội xe nội bộ</option>
                    <option value="viettel">Viettel Post</option>
                    <option value="ghtk">GHTK</option>
                </select>
                <select class="filter-select">
                    <option value="">Trạng thái</option>
                    <option value="processing">Chờ lấy hàng</option>
                    <option value="delivering">Đang giao</option>
                    <option value="delivered">Đã giao thành công</option>
                    <option value="returned">Hoàn hàng</option>
                </select>
            </div>
            <div class="toolbar-right">
                <button class="btn btn-sm btn-outline-secondary border-0 text-primary fw-medium"><i class="bi bi-truck me-1"></i> Theo dõi lộ trình</button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 40px;"><input type="checkbox" class="form-check-input"></th>
                        <th>Thông tin giao hàng</th>
                        <th>Đơn hàng</th>
                        <th>Đơn vị vận chuyển</th>
                        <th>Bảng giá (VNĐ)</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="fw-bold text-dark">DO-2602-085</div>
                            <div class="text-muted" style="font-size: 0.75rem;"><i class="bi bi-calendar-event me-1"></i>Hôm nay, 10:30 AM</div>
                        </td>
                        <td>
                            <a href="#" class="fw-semibold text-primary text-decoration-none">SO-2602-0050</a>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="bg-light border rounded px-2 py-1" style="font-size: 0.75rem; font-weight: 600;">Viettel Post</div>
                                <span class="text-muted" style="font-size: 0.75rem;">VT-992812</span>
                            </div>
                        </td>
                        <td class="fw-medium">45,000</td>
                        <td><span class="badge bg-info text-white px-2 py-1 rounded-pill"><i class="bi bi-truck me-1"></i>Đang giao</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="In vận đơn"><i class="bi bi-printer"></i></button>
                                <button class="action-btn" title="Xem chi tiết"><i class="bi bi-eye"></i></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="fw-bold text-dark">DO-2602-084</div>
                            <div class="text-muted" style="font-size: 0.75rem;"><i class="bi bi-calendar-event me-1"></i>Hôm qua, 15:00 PM</div>
                        </td>
                        <td>
                            <a href="#" class="fw-semibold text-primary text-decoration-none">SO-2602-0049</a>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="bg-primary text-white rounded px-2 py-1" style="font-size: 0.75rem; font-weight: 600;">Đội xe nội bộ</div>
                                <span class="text-muted" style="font-size: 0.75rem;">Tài xế: Minh (59C-12345)</span>
                            </div>
                        </td>
                        <td class="fw-medium text-muted">N/A</td>
                        <td><span class="status-badge active"><span class="status-dot"></span> Đã giao thành công</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="In vận đơn"><i class="bi bi-printer"></i></button>
                                <button class="action-btn" title="Xem chi tiết"><i class="bi bi-eye"></i></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="fw-bold text-dark">DO-2602-083</div>
                            <div class="text-muted" style="font-size: 0.75rem;"><i class="bi bi-calendar-event me-1"></i>18/02/2026, 09:15 AM</div>
                        </td>
                        <td>
                            <a href="#" class="fw-semibold text-primary text-decoration-none">SO-2602-0045</a>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="bg-success text-white rounded px-2 py-1" style="font-size: 0.75rem; font-weight: 600;">GHTK</div>
                                <span class="text-muted" style="font-size: 0.75rem;">S123.456.789</span>
                            </div>
                        </td>
                        <td class="fw-medium">35,000</td>
                        <td><span class="badge bg-warning text-dark px-2 py-1 rounded-pill"><i class="bi bi-box-seam me-1"></i>Chờ lấy hàng</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="In vận đơn"><i class="bi bi-printer"></i></button>
                                <button class="action-btn" title="Xem chi tiết"><i class="bi bi-eye"></i></button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
