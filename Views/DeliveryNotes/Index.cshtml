@model List<Manage_KPI_or_OKR_System.Models.DeliveryNote>
@{
    ViewData["Title"] = "Phiếu Giao hàng";
    var orders = ViewBag.Orders as Dictionary<int, string> ?? new Dictionary<int, string>();
    var partners = ViewBag.Partners as Dictionary<int, string> ?? new Dictionary<int, string>();
    var methods = ViewBag.Methods as Dictionary<int, string> ?? new Dictionary<int, string>();
    var allOrders = ViewBag.AllOrders as List<Manage_KPI_or_OKR_System.Models.SalesOrder> ?? new List<Manage_KPI_or_OKR_System.Models.SalesOrder>();
    var allPartners = ViewBag.AllPartners as List<Manage_KPI_or_OKR_System.Models.ShippingPartner> ?? new List<Manage_KPI_or_OKR_System.Models.ShippingPartner>();
}
@if (TempData["SuccessMessage"] != null)
{<div class="alert alert-success alert-dismissible fade show" role="alert"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="h3 font-weight-bold mb-1">Phiếu Giao hàng</h1><div class="page-breadcrumb"><a href="/">Trang chủ</a><i class="bi bi-chevron-right separator"></i><span>Vận chuyển</span><i class="bi bi-chevron-right separator"></i><span>Phiếu giao hàng</span></div></div>
    <div class="d-flex justify-content-end gap-2"><button class="btn-primary-custom d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#createModal"><i class="bi bi-plus-lg me-1"></i> Tạo phiếu giao</button></div>
</div>

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100"><div class="card-body-custom">
    <div class="table-responsive w-100"><table class="data-table w-100">
        <thead><tr><th>Tracking Code</th><th>Đơn hàng</th><th>Đối tác VC</th><th>Ngày xuất</th><th>Hạn giao</th><th class="text-end">Phí ship (VNĐ)</th><th class="text-end">Thao tác</th></tr></thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var dn in Model)
                {
                    var orderCode = dn.OrderId.HasValue && orders.ContainsKey(dn.OrderId.Value) ? orders[dn.OrderId.Value] : "N/A";
                    var partnerName = dn.PartnerId.HasValue && partners.ContainsKey(dn.PartnerId.Value) ? partners[dn.PartnerId.Value] : "N/A";
                    <tr>
                        <td class="fw-bold text-primary">@dn.TrackingCode</td>
                        <td class="text-muted">@orderCode</td>
                        <td><span class="badge bg-light text-dark border">@partnerName</span></td>
                        <td class="text-muted">@(dn.DispatchDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td class="text-muted">@(dn.Deadline?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td class="text-end fw-medium">@(dn.ShippingFee?.ToString("N0") ?? "0")</td>
                        <td><div class="action-btns justify-content-end">
                            <form asp-action="Delete" method="post" style="display:inline;"><input type="hidden" name="id" value="@dn.Id" /><button type="submit" class="action-btn danger" title="Xóa" onclick="return confirm('Vô hiệu hóa phiếu giao?')"><i class="bi bi-trash"></i></button></form>
                        </div></td>
                    </tr>
                }
            }
            else
            {<tr><td colspan="7" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;"></i><p class="mt-2">Chưa có phiếu giao hàng nào</p></td></tr>}
        </tbody>
    </table></div>
</div></div>

<div class="modal fade" id="createModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content border-0 shadow">
    <div class="modal-header border-0"><h5 class="modal-title fw-bold"><i class="bi bi-truck me-2"></i>Tạo Phiếu Giao hàng</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form asp-action="Create" method="post"><div class="modal-body">
        <div class="mb-3"><label class="form-label fw-semibold">Mã tracking</label><input type="text" name="TrackingCode" class="form-control" required placeholder="VD: GH-2603-001" /></div>
        <div class="mb-3"><label class="form-label fw-semibold">Đơn hàng</label><select name="OrderId" class="form-select" required>
            <option value="">-- Chọn đơn --</option>@foreach(var o in allOrders){<option value="@o.Id">@o.OrderCode</option>}</select></div>
        <div class="mb-3"><label class="form-label fw-semibold">Đối tác vận chuyển</label><select name="PartnerId" class="form-select">
            <option value="">-- Chọn đối tác --</option>@foreach(var p in allPartners){<option value="@p.Id">@p.PartnerName</option>}</select></div>
        <div class="row"><div class="col-6 mb-3"><label class="form-label fw-semibold">Ngày xuất hàng</label><input type="date" name="DispatchDate" class="form-control" /></div>
        <div class="col-6 mb-3"><label class="form-label fw-semibold">Hạn giao</label><input type="date" name="Deadline" class="form-control" /></div></div>
        <div class="mb-3"><label class="form-label fw-semibold">Phí vận chuyển (VNĐ)</label><input type="number" name="ShippingFee" class="form-control" step="1000" /></div>
    </div>
    <div class="modal-footer border-0"><button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn-primary-custom d-flex align-items-center">Tạo phiếu</button></div></form>
</div></div></div>

        </div>
    </div>
</div>