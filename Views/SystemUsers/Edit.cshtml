@model Manage_KPI_or_OKR_System.Models.SystemUser

@{
    ViewData["Title"] = "Chỉnh sửa tài khoản";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var roles = ViewBag.Roles as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="page-content">
    <div class="page-header d-flex align-items-center justify-content-between mb-4 animate__animated animate__fadeIn">
        <div>
            <h1 class="mb-2 fw-800">Cập Nhật Tài khoản</h1>
            <div class="page-breadcrumb">
                <a href="/">Trang chủ</a>
                <span class="separator">/</span>
                <a asp-action="Index">Tài khoản Hệ thống</a>
                <span class="separator">/</span>
                <span class="text-muted">Chỉnh sửa</span>
            </div>
        </div>
        <div>
            <a asp-action="Index" class="btn-outline-custom shadow-sm">
                <i class="bi bi-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- FORM COLUMN -->
        <div class="col-xl-8 animate__animated animate__fadeInLeft">
            <div class="content-card border-0 shadow-lg" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">
                <div class="card-header-custom border-bottom bg-transparent py-4">
                    <h5 class="fw-bold fs-5 mb-0"><i class="bi bi-person-lines-fill me-2"></i> Chỉnh sửa Thông tin</h5>
                </div>

                <div class="card-body-custom p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <!-- SECTION 1: CƠ BẢN -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-primary text-white me-3 d-flex align-items-center justify-content-center shadow" style="width: 38px; height: 38px; border-radius: 12px;">
                                <span class="fw-bold">1</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Thông tin cơ bản</h6>
                        </div>

                        <div class="row g-4 mb-5 p-3 rounded-4 bg-light bg-opacity-50 border border-white">
                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Tên đăng nhập <span class="fw-normal text-lowercase">(không đổi)</span></label>
                                    <div class="input-wrapper" style="background: #f8f9fa;">
                                        <i class="bi bi-person-circle"></i>
                                        <input asp-for="Username" class="form-control shadow-sm" readonly style="background: #f8f9fa; cursor: not-allowed;" />
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Địa chỉ Email <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-envelope"></i>
                                        <input asp-for="Email" type="email" class="form-control shadow-sm" required />
                                    </div>
                                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <!-- SECTION 2: PHÂN QUYỀN VÀ TRẠNG THÁI -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-success text-white me-3 d-flex align-items-center justify-content-center shadow" style="width: 38px; height: 38px; border-radius: 12px;">
                                <span class="fw-bold">2</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Phân quyền & Trạng thái</h6>
                        </div>

                        <div class="row g-4 mb-5 p-3 rounded-4 bg-light bg-opacity-50 border border-white">
                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Nhóm Quyền (Role) <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-shield-check"></i>
                                        <select asp-for="RoleId" class="form-select shadow-sm" required>
                                            <option value="">-- Chọn nhóm quyền --</option>
                                            @foreach (var role in roles)
                                            {
                                                <option value="@role.Key">@role.Value</option>
                                            }
                                        </select>
                                    </div>
                                    <span asp-validation-for="RoleId" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Tình trạng hoạt động</label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-activity"></i>
                                        <select asp-for="IsActive" class="form-select shadow-sm" required style="cursor: pointer;">
                                            <option value="true">Đang hoạt động</option>
                                            <option value="false">Ngưng hoạt động (Khóa)</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SECTION 3: BẢO MẬT -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-warning text-white me-3 d-flex align-items-center justify-content-center shadow" style="width: 38px; height: 38px; border-radius: 12px;">
                                <span class="fw-bold">3</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Đổi Mật Khẩu <span class="text-muted text-lowercase fw-normal">(Tùy chọn)</span></h6>
                        </div>

                        <div class="row g-4 p-3 rounded-4 bg-light bg-opacity-50 border border-warning border-opacity-25 mb-4">
                            <div class="col-md-12">
                                <p class="text-muted small mb-3">
                                    Để trống trường này nếu bạn không muốn thay đổi mật khẩu hiện tại.
                                </p>
                                <div class="form-icon-group mb-0">
                                    <div class="input-wrapper">
                                        <i class="bi bi-lock-fill"></i>
                                        <input name="newPassword" type="password" class="form-control shadow-sm" placeholder="Mật khẩu mới (ít nhất 6 ký tự)..." minlength="6" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                            <a asp-action="Index" class="btn-outline-custom">
                                <i class="bi bi-x-lg me-2"></i> Hủy thao tác
                            </a>
                            <button type="submit" class="btn-primary-custom" style="padding: 12px 40px; border-radius: 12px;">
                                <i class="bi bi-cloud-arrow-up-fill fs-5 me-2"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- SIDEBAR COLUMN -->
        <div class="col-xl-4 animate__animated animate__fadeInRight">
            <div class="sticky-top" style="top: 100px;">
                <div class="content-card border-0 shadow-lg text-white mb-4" id="previewCard" style="background: linear-gradient(135deg, #1a73e8, #1557b0); border-radius: 24px; transition: background 0.3s ease;">
                    <div class="card-body-custom p-4">
                        <div class="d-flex align-items-center mb-4">
                            <div class="position-relative me-4 ms-2 mt-2" style="margin-bottom: 0.5rem;">
                                <div class="avatar-custom-ui">
                                    @(Model != null && !string.IsNullOrEmpty(Model.Username) ? Model.Username.Substring(0, 1).ToUpper() : "U")
                                </div>
                                <span id="statusIndicator" class="position-absolute bottom-0 end-0 p-2 bg-success border border-2 border-white rounded-circle shadow-sm" style="transform: translate(20%, 20%); z-index: 2;" title="Đang hoạt động">
                                    <span class="visually-hidden">New alerts</span>
                                </span>
                            </div>
                            <div>
                                <div class="small opacity-75 fw-bold text-uppercase">Tài khoản</div>
                                <h4 class="mb-0 fw-800" id="previewUsername">--</h4>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="small opacity-75 fw-bold text-uppercase mb-1">Email</div>
                            <div class="fw-bold fs-6" id="previewEmail" style="min-height: 24px; word-break: break-all;">--</div>
                        </div>
                        <div class="bg-white bg-opacity-10 p-3 rounded-4 d-flex align-items-center">
                            <i class="bi bi-shield-check fs-4 me-3 opacity-75"></i>
                            <div>
                                <div class="small opacity-75 mb-1">Nhóm quyền</div>
                                <div class="fw-bold small" id="previewRole">--</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="content-card border-0 shadow-sm rounded-4 bg-white p-4">
                    <h6 class="fw-bold text-dark mb-3"><i class="bi bi-info-circle text-primary me-2"></i> Thông tin chỉnh sửa</h6>
                    <ul class="list-unstyled mb-0 small text-muted" style="line-height: 1.8;">
                        <li class="mb-2"><i class="bi bi-dot text-primary me-1 text-lg"></i> <strong class="text-dark">Tên đăng nhập:</strong> Không thể thay đổi sau khi khởi tạo.</li>
                        <li class="mb-2"><i class="bi bi-dot text-primary me-1 text-lg"></i> <strong class="text-dark">Mật khẩu:</strong> Chỉ nhập khi cần đặt lại mật khẩu mới.</li>
                        <li><i class="bi bi-dot text-primary me-1 text-lg"></i> <strong class="text-dark">Trạng thái:</strong> Khóa tài khoản sẽ chặn đăng nhập vào hệ thống.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    .letter-spacing-1 { letter-spacing: 0.1em; }
    .form-select, .form-control { border: 1.5px solid #edf2f7; padding-top: 12px; padding-bottom: 12px; }
    .form-select:focus, .form-control:focus { border-color: #a3c9f9; box-shadow: 0 0 0 4px rgba(163, 201, 249, 0.1); }
    .animate__animated { animation-duration: 0.8s; }
    
    .avatar-custom-ui {
        width: 68px; height: 68px;
        background: #ffffff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        font-weight: 800;
        color: #0d6efd;
        position: relative;
        z-index: 1;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }
    .avatar-custom-ui::before {
        content: '';
        position: absolute;
        top: -6px; right: -6px; bottom: -6px; left: -6px;
        border-radius: 50%;
        border: 2px dashed rgba(255, 192, 203, 0.7);
        box-shadow: 0 0 15px rgba(255, 192, 203, 0.2);
        z-index: -1;
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <script>
        const unInput   = document.getElementById('Username');
        const emInput   = document.getElementById('Email');
        const roleSelect= document.getElementById('RoleId');
        const activeSelect = document.getElementById('IsActive');
        
        function updatePreview() {
            document.getElementById('previewUsername').textContent = unInput.value.trim() || '--';
            document.getElementById('previewEmail').textContent    = emInput.value.trim() || '--';
            
            const rOpt = roleSelect.options[roleSelect.selectedIndex];
            document.getElementById('previewRole').textContent = rOpt && rOpt.value ? rOpt.text : '--';

            const statusIndicator = document.getElementById('statusIndicator');
            const previewCard = document.getElementById('previewCard');
            if (activeSelect.value.toLowerCase() === 'true') {
                statusIndicator.classList.remove('bg-danger');
                statusIndicator.classList.add('bg-success');
                statusIndicator.title = 'Đang hoạt động';
                previewCard.style.background = 'linear-gradient(135deg, #1a73e8, #1557b0)';
            } else {
                statusIndicator.classList.remove('bg-success');
                statusIndicator.classList.add('bg-danger');
                statusIndicator.title = 'Đã khóa';
                previewCard.style.background = 'linear-gradient(135deg, #6c757d, #343a40)';
            }
        }

        [emInput, roleSelect, activeSelect].forEach(el => el.addEventListener('change', updatePreview));
        [emInput].forEach(el => el.addEventListener('input', updatePreview));
        
        window.addEventListener('DOMContentLoaded', updatePreview);
    </script>
}
