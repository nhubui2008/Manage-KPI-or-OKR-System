@model Manage_KPI_or_OKR_System.Models.SystemUser

@{
    ViewData["Title"] = "Chỉnh sửa tài khoản";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var roles = ViewBag.Roles as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
        border-radius: 1.5rem;
    }
    .input-modern {
        border-radius: 0.75rem;
        border: 1px solid rgba(0,0,0,0.1);
        padding: 0.75rem 1rem;
        transition: all 0.2s ease;
        background: #fff;
    }
    .input-modern:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.15);
        transform: translateY(-2px);
    }
    .input-modern[readonly] {
        background: #f8f9fa;
        color: #6c757d;
        cursor: not-allowed;
    }
    .btn-gradient {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        color: white;
        border: none;
        transition: all 0.3s ease;
    }
    .btn-gradient:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(13, 110, 253, 0.2);
    }
    .page-header-modern {
        background: url('data:image/svg+xml;utf8,<svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(0,0,0,0.02)" stroke-width="1"/></pattern></defs><rect width="100%" height="100%" fill="url(%23grid)" /></svg>'), linear-gradient(to right, #ffffff, #fdfdfd);
    }
    .form-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 700;
        color: #6c757d;
        margin-bottom: 0.5rem;
    }
    .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #343a40;
        display: flex;
        align-items: center;
        margin-bottom: 1.5rem;
    }
    .section-title i {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: rgba(13, 110, 253, 0.1);
        color: #0d6efd;
        margin-right: 0.75rem;
        font-size: 1rem;
    }
</style>

<div class="container-fluid px-0">
    <div class="page-header d-flex justify-content-between align-items-center mb-4 p-4 rounded-4 shadow-sm border border-black border-opacity-10 page-header-modern">
        <div>
            <h1 class="h3 font-weight-bold mb-2 text-dark d-flex align-items-center">
                <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 me-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 44px; height: 44px;">
                    <i class="bi bi-person-lines-fill"></i>
                </div>
                Cập Nhật Tài Khoản
            </h1>
            <div class="page-breadcrumb text-muted" style="font-size: 0.85rem;">
                <a href="/" class="text-decoration-none text-muted hover-primary">Trang chủ</a>
                <i class="bi bi-chevron-right mx-2" style="font-size: 0.7rem;"></i>
                <a asp-action="Index" class="text-decoration-none text-muted hover-primary">Tài khoản Hệ thống</a>
                <i class="bi bi-chevron-right mx-2" style="font-size: 0.7rem;"></i>
                <span class="text-primary fw-medium">Chỉnh sửa</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-white bg-white border rounded-pill px-4 shadow-sm d-flex align-items-center" style="transition: all 0.2s ease;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                <i class="bi bi-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="glass-card mb-4">
        <div class="card-body p-4 p-lg-5">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 border-0 shadow-sm mb-4"></div>

                <div class="row g-5">
                    <!-- Basic Information -->
                    <div class="col-lg-6">
                        <div class="section-title">
                            <i class="bi bi-person-badge"></i> Thông Tin Cơ Bản
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label">Tên đăng nhập <span class="text-muted fw-normal text-lowercase">(không đổi)</span></label>
                            <input asp-for="Username" class="form-control input-modern" readonly />
                        </div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label">Địa chỉ Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control input-modern" required placeholder="Nhập địa chỉ email..." />
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <!-- Permissions & Status -->
                    <div class="col-lg-6">
                        <div class="section-title">
                            <i class="bi bi-shield-check"></i> Phân Quyền & Trạng Thái
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="RoleId" class="form-label">Nhóm Quyền (Role) <span class="text-danger">*</span></label>
                            <select asp-for="RoleId" class="form-select input-modern" required>
                                <option value="">-- Chọn nhóm quyền --</option>
                                @foreach (var role in roles)
                                {
                                    <option value="@role.Key">@role.Value</option>
                                }
                            </select>
                            <span asp-validation-for="RoleId" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="IsActive" class="form-label">Tình trạng hoạt động</label>
                            <select asp-for="IsActive" class="form-select input-modern" style="cursor: pointer;">
                                <option value="true">Đang hoạt động</option>
                                <option value="false">Ngưng hoạt động (Khóa)</option>
                            </select>
                        </div>
                    </div>

                    <!-- Security (Optional) -->
                    <div class="col-12 mt-2">
                        <div class="p-4 bg-light rounded-4 border border-secondary border-opacity-10 shadow-sm" style="background: linear-gradient(145deg, #f8f9fa, #ffffff);">
                            <div class="section-title mb-3">
                                <i class="bi bi-key" style="background: #fff; border: 1px solid rgba(0,0,0,0.05); color: #6c757d;"></i> Đổi Mật Khẩu (Tùy Chọn)
                            </div>
                            
                            <div class="row align-items-center">
                                <div class="col-md-6 mb-3 mb-md-0">
                                    <p class="text-muted small mb-0 pe-md-4" style="line-height: 1.6;">
                                        Trường hợp bạn cần thay đổi mật khẩu cho tài khoản này, vui lòng nhập mật khẩu mới vào ô bên cạnh. <br/>
                                        <strong class="text-dark">Nếu không đổi, hãy để trống trường này.</strong>
                                    </p>
                                </div>
                                <div class="col-md-6">
                                    <div class="input-group shadow-sm" style="border-radius: 0.75rem; overflow: hidden;">
                                        <span class="input-group-text bg-white border-0 text-secondary px-3">
                                            <i class="bi bi-lock-fill"></i>
                                        </span>
                                        <input name="newPassword" type="password" class="form-control border-0 px-2 py-3 bg-white" placeholder="Mật khẩu mới (ít nhất 6 ký tự)..." minlength="6" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="col-12 mt-5 pt-4 border-top border-secondary border-opacity-10">
                        <div class="d-flex justify-content-end gap-3">
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4 shadow-sm border" style="font-weight: 500;">Hủy Thao Tác</a>
                            <button type="submit" class="btn btn-gradient rounded-pill px-5 shadow-sm d-flex align-items-center" style="font-weight: 600;">
                                <i class="bi bi-cloud-arrow-up-fill me-2 fs-5"></i> Lưu Thay Đổi
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
