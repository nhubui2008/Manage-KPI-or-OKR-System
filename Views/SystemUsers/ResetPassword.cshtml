@model Manage_KPI_or_OKR_System.Models.SystemUser
@{
    ViewData["Title"] = "Làm mới mật khẩu - " + Model.Username;
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
        border-radius: 1.5rem;
    }
    .input-group-modern {
        border-radius: 1rem;
        border: 1px solid rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        background: #fff;
    }
    .input-group-modern:focus-within {
        border-color: #0d6efd;
        box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.15);
        transform: translateY(-2px);
    }
    .input-group-modern .input-group-text {
        background: transparent;
        border: none;
        color: #6c757d;
        padding-left: 1.25rem;
    }
    .input-group-modern .form-control {
        border: none;
        box-shadow: none;
        padding: 1rem;
        background: transparent;
    }
    .input-group-modern .btn {
        border: none;
        background: transparent;
        color: #6c757d;
    }
    .input-group-modern .btn:hover {
        color: #0d6efd;
    }
    .btn-gradient {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        color: white;
        border: none;
        transition: all 0.3s ease;
    }
    .btn-gradient:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 16px rgba(13, 110, 253, 0.2);
    }
    .btn-gradient:active {
        transform: translateY(-1px);
    }
    .page-header-modern {
        background: url('data:image/svg+xml;utf8,<svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(0,0,0,0.02)" stroke-width="1"/></pattern></defs><rect width="100%" height="100%" fill="url(%23grid)" /></svg>'), linear-gradient(to right, #ffffff, #fdfdfd);
    }
    .warning-box {
        background: linear-gradient(to right, rgba(255,193,7,0.1), rgba(255,193,7,0.02));
        border-left: 4px solid #ffc107;
    }
</style>

<div class="container-fluid px-0">
    <div class="page-header d-flex justify-content-between align-items-center mb-5 p-4 rounded-4 shadow-sm border border-black border-opacity-10 page-header-modern">
        <div>
            <h1 class="h3 font-weight-bold mb-2 text-dark d-flex align-items-center">
                <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 me-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 44px; height: 44px;">
                    <i class="bi bi-shield-lock"></i>
                </div>
                Làm mới mật khẩu
            </h1>
            <div class="page-breadcrumb text-muted" style="font-size: 0.85rem;">
                <a href="/" class="text-decoration-none text-muted hover-primary">Trang chủ</a>
                <i class="bi bi-chevron-right mx-2" style="font-size: 0.7rem;"></i>
                <a asp-action="Index" class="text-decoration-none text-muted hover-primary">Tài khoản hệ thống</a>
                <i class="bi bi-chevron-right mx-2" style="font-size: 0.7rem;"></i>
                <span class="text-primary fw-medium">Đổi mật khẩu</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-white bg-white border rounded-pill px-4 shadow-sm d-flex align-items-center" style="transition: all 0.2s ease;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                <i class="bi bi-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6 col-xl-5">
            <div class="glass-card">
                <div class="card-header bg-transparent border-0 pt-4 pb-2 text-center position-relative">
                    <div class="mx-auto bg-white shadow-sm rounded-circle d-flex align-items-center justify-content-center position-relative z-1" style="width: 84px; height: 84px; padding: 6px; margin-top: -15px;">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle w-100 h-100 d-flex align-items-center justify-content-center" style="font-size: 2.2rem;">
                            <i class="bi bi-person-fill-lock"></i>
                        </div>
                    </div>
                    
                    <div class="mt-4">
                        <h4 class="mb-1 fw-bold text-dark">Đặt lại mật khẩu</h4>
                        <p class="text-muted mb-0" style="font-size: 0.95rem;">Tài khoản đăng nhập: <strong class="text-primary">@Model.Username</strong></p>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5 pt-3">
                    <form asp-action="ResetPassword" method="post">
                        <input type="hidden" name="userId" value="@Model.Id" />
                        
                        <div class="mb-4 position-relative">
                            <label class="form-label fw-bold text-muted text-uppercase mb-3" style="font-size: 0.8rem; letter-spacing: 0.5px;">Thiết lập mật khẩu mới</label>
                            
                            <div class="input-group-modern d-flex align-items-center shadow-sm">
                                <span class="input-group-text text-primary">
                                    <i class="bi bi-key-fill fs-5"></i>
                                </span>
                                <input type="password" name="newPassword" class="form-control" placeholder="Nhập ít nhất 6 ký tự..." required minlength="6" id="passwordInput">
                                <button class="btn px-3" type="button" onclick="togglePassword()">
                                    <i class="bi bi-eye fs-5" id="toggleIcon"></i>
                                </button>
                            </div>
                            
                            <div class="mt-4 text-muted d-flex align-items-center" style="font-size: 0.86rem;"> 
                                <i class="bi bi-shield-check text-success me-2" style="font-size: 1.5rem; line-height: 1;"></i> 
                                <span class="text-start">Mật khẩu nên kết hợp chữ cái, số và ký tự đặc biệt để đảm bảo an toàn tối đa.</span>
                            </div>
                        </div>

                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-lg btn-gradient rounded-pill fw-bold shadow py-3">
                                <i class="bi bi-check-circle-fill me-2"></i> Xác Nhận Đổi Mật Khẩu
                            </button>
                            <a asp-action="Index" class="text-center text-muted text-decoration-none" style="font-size: 0.95rem; transition: color 0.2s;" onmouseover="this.classList.add('text-primary')" onmouseout="this.classList.remove('text-primary')">
                                Hủy bỏ thao tác
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="mt-4 p-4 rounded-4 shadow-sm warning-box">
                <div class="d-flex gap-3 align-items-start">
                    <i class="bi bi-exclamation-triangle-fill text-warning fs-3" style="filter: drop-shadow(0 2px 4px rgba(255,193,7,0.3));"></i>
                    <div>
                        <h6 class="fw-bold text-dark mb-1">Lưu ý bảo mật</h6>
                        <p class="text-muted mb-0" style="font-size: 0.85rem; line-height: 1.6;">
                            Việc đặt lại mật khẩu sẽ vô hiệu hóa phiên đăng nhập cũ. Hãy thông báo mật khẩu mới cho người dùng sau khi bạn thay đổi hoàn tất.
                        </p>
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</div>

<script>
    function togglePassword() {
        var input = document.getElementById("passwordInput");
        var icon = document.getElementById("toggleIcon");
        if (input.type === "password") {
            input.type = "text";
            icon.classList.remove("bi-eye");
            icon.classList.add("bi-eye-slash");
        } else {
            input.type = "password";
            icon.classList.remove("bi-eye-slash");
            icon.classList.add("bi-eye");
        }
    }
</script>
