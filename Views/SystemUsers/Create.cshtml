@model Manage_KPI_or_OKR_System.Models.SystemUser
@{
    ViewData["Title"] = "Tạo tài khoản mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var roles = ViewBag.Roles as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="page-content">
    <div class="page-header d-flex align-items-center justify-content-between mb-4 animate__animated animate__fadeIn">
        <div>
            <h1 class="mb-2 fw-800">Tạo Tài khoản Mới</h1>
            <div class="page-breadcrumb">
                <a href="/">Trang chủ</a>
                <span class="separator">/</span>
                <a asp-action="Index">Tài khoản Hệ thống</a>
                <span class="separator">/</span>
                <span class="text-muted">Tạo mới</span>
            </div>
        </div>
        <div>
            <a asp-action="Index" class="btn-outline-custom shadow-sm">
                <i class="bi bi-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- FORM COLUMN -->
        <div class="col-xl-8 animate__animated animate__fadeInLeft">
            <div class="content-card border-0 shadow-lg" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">
                <div class="card-header-custom border-bottom bg-transparent py-4">
                    <h5 class="fw-bold fs-5 mb-0 d-flex align-items-center gap-2">
                        <span class="d-inline-flex align-items-center justify-content-center bg-primary text-white shadow-sm" style="width:34px;height:34px;border-radius:10px;flex-shrink:0;">
                            <i class="bi bi-shield-lock" style="font-size:1rem;"></i>
                        </span>
                        Thông tin Tài khoản
                    </h5>
                </div>

                <div class="card-body-custom p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <!-- SECTION 1: ĐĂNG NHẬP -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-primary text-white me-3 d-flex align-items-center justify-content-center shadow" style="width: 38px; height: 38px; border-radius: 12px;">
                                <span class="fw-bold">1</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Thông tin đăng nhập</h6>
                        </div>

                        <div class="row g-4 mb-5 p-3 rounded-4 bg-light bg-opacity-50 border border-white">
                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Tên đăng nhập <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-person-circle"></i>
                                        <input asp-for="Username" class="form-control shadow-sm" placeholder="VD: admin_123" required />
                                    </div>
                                    <span asp-validation-for="Username" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Địa chỉ Email <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-envelope"></i>
                                        <input asp-for="Email" type="email" class="form-control shadow-sm" placeholder="VD: example@congty.com" required />
                                    </div>
                                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Mật khẩu <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-key"></i>
                                        <input name="PasswordHash" type="password" class="form-control shadow-sm" placeholder="Nhập ít nhất 6 ký tự" required minlength="6" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SECTION 2: PHÂN QUYỀN -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-success text-white me-3 d-flex align-items-center justify-content-center shadow" style="width: 38px; height: 38px; border-radius: 12px;">
                                <span class="fw-bold">2</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Phân quyền</h6>
                        </div>

                        <div class="row g-4 p-3 rounded-4 bg-light bg-opacity-50 border border-white mb-4">
                            <div class="col-md-12">
                                <div class="premium-select-wrapper">
                                    <span class="select-label">Nhóm Quyền (Role)</span>
                                    <i class="bi bi-shield-check lead-icon"></i>
                                    <select asp-for="RoleId" required>
                                        <option value="">-- Chọn nhóm quyền --</option>
                                        @foreach (var role in roles)
                                        {
                                            <option value="@role.Key">@role.Value</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                            <a asp-action="Index" class="btn-outline-custom" style="padding: 10px 24px; border-radius: 10px; font-size: 0.95rem;">
                                <i class="bi bi-x-lg me-2"></i> Hủy thao tác
                            </a>
                            <button type="submit" class="btn-primary-custom" style="padding: 10px 30px; border-radius: 10px; font-size: 0.95rem;">
                                <i class="bi bi-check-lg me-2"></i> Lưu tài khoản
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- SIDEBAR COLUMN -->
        <div class="col-xl-4 animate__animated animate__fadeInRight">
            <div class="sticky-top" style="top: 100px;">
                <div class="content-card border-0 shadow-lg text-white mb-4" style="background: linear-gradient(135deg, #0078d4, #005a9e); border-radius: 24px;">
                    <div class="card-body-custom p-4">
                        <div class="d-flex align-items-center mb-4">
                            <div class="me-3 d-flex align-items-center justify-content-center" style="width:56px;height:56px;border-radius:16px;background:rgba(255,255,255,0.15);border:2px solid rgba(255,255,255,0.35);backdrop-filter:blur(6px);box-shadow:0 4px 16px rgba(0,0,0,0.15);flex-shrink:0;">
                                <i class="bi bi-person-lock" style="font-size:1.6rem;color:#fff;text-shadow:0 2px 8px rgba(0,0,0,0.2);"></i>
                            </div>
                            <div>
                                <div class="small opacity-75 fw-bold text-uppercase">Tài khoản</div>
                                <h4 class="mb-0 fw-800" id="previewUsername">--</h4>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="small opacity-75 fw-bold text-uppercase mb-1">Email</div>
                            <div class="fw-bold fs-6" id="previewEmail" style="min-height: 24px; word-break: break-all;">--</div>
                        </div>
                        <div class="bg-white bg-opacity-10 p-3 rounded-4">
                            <div class="small opacity-75 mb-1">Nhóm quyền</div>
                            <div class="fw-bold small" id="previewRole">--</div>
                        </div>
                    </div>
                </div>

                <div class="content-card border-0 shadow-sm rounded-4 bg-white p-4">
                    <h6 class="fw-bold text-dark mb-3 d-flex align-items-center gap-2">
                        <span class="d-inline-flex align-items-center justify-content-center bg-primary text-white shadow-sm" style="width:30px;height:30px;border-radius:9px;flex-shrink:0;">
                            <i class="bi bi-info-lg" style="font-size:0.9rem;"></i>
                        </span>
                        Lưu ý bảo mật
                    </h6>
                    <ul class="list-unstyled mb-0 small text-muted" style="line-height: 1.8;">
                        <li class="mb-2"><i class="bi bi-patch-check-fill text-success me-2"></i> Tên đăng nhập phải là duy nhất trong hệ thống.</li>
                        <li class="mb-2"><i class="bi bi-patch-check-fill text-warning me-2"></i> Mật khẩu phải ít nhất 6 ký tự, gồm chữ và số.</li>
                        <li><i class="bi bi-patch-check-fill text-success me-2"></i> Quyền hạn quyết định các chức năng tài khoản được truy cập.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    .letter-spacing-1 { letter-spacing: 0.1em; }
    .form-select, .form-control { border: 1.5px solid #edf2f7; padding-top: 12px; padding-bottom: 12px; }
    .form-select:focus, .form-control:focus { border-color: #a3c9f9; box-shadow: 0 0 0 4px rgba(163, 201, 249, 0.1); }
    .animate__animated { animation-duration: 0.8s; }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <script>
        const unInput   = document.getElementById('Username');
        const emInput   = document.getElementById('Email');
        const roleSelect= document.getElementById('RoleId');
        function updatePreview() {
            document.getElementById('previewUsername').textContent = unInput.value.trim() || '--';
            document.getElementById('previewEmail').textContent    = emInput.value.trim() || '--';
            const rOpt = roleSelect.options[roleSelect.selectedIndex];
            document.getElementById('previewRole').textContent = rOpt && rOpt.value ? rOpt.text : '--';
        }
        [unInput, emInput].forEach(el => el.addEventListener('input', updatePreview));
        roleSelect.addEventListener('change', updatePreview);
        window.addEventListener('DOMContentLoaded', updatePreview);
    </script>
}
