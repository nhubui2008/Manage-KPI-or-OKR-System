@model Manage_KPI_or_OKR_System.Models.SystemUser

@{
    ViewData["Title"] = "Tạo tài khoản mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var roles = ViewBag.Roles as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-dark fw-bold"><i class="bi bi-person-plus-fill me-2"></i>Tạo tài khoản mới</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-dark text-decoration-none opacity-75">Tài khoản Hệ thống</a></li>
                    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Thêm mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="content-card rounded-3">
                <div class="card-header-custom bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-shield-lock me-2"></i>Thông tin Tài khoản</h5>
                </div>
                <div class="card-body-custom p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="Username" class="form-label fw-bold text-dark">Tên đăng nhập <span class="text-danger">*</span></label>
                                <input asp-for="Username" class="form-control" placeholder="VD: admin_123" required />
                                <span asp-validation-for="Username" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-bold text-dark">Địa chỉ Email <span class="text-danger">*</span></label>
                                <input asp-for="Email" type="email" class="form-control" placeholder="VD: example@congty.com" required />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PasswordHash" class="form-label fw-bold text-dark">Mật khẩu <span class="text-danger">*</span></label>
                                <input name="PasswordHash" type="password" class="form-control" placeholder="Nhập ít nhất 6 ký tự" required minlength="6"/>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="RoleId" class="form-label fw-bold text-dark">Nhóm Quyền (Role) <span class="text-danger">*</span></label>
                                <select asp-for="RoleId" class="form-select" required>
                                    <option value="">-- Chọn nhóm quyền --</option>
                                    @foreach (var role in roles)
                                    {
                                        <option value="@role.Key">@role.Value</option>
                                    }
                                </select>
                                <span asp-validation-for="RoleId" class="text-danger small"></span>
                            </div>

                            <div class="col-12 pt-3 mt-4 border-top">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Index" class="btn-outline-custom px-4 outline-none">Hủy bỏ</a>
                                    <button type="submit" class="btn-primary-custom px-4">
                                        <i class="bi bi-save me-1"></i> Lưu tài khoản
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
