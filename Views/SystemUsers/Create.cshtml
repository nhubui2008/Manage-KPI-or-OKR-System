@model Manage_KPI_or_OKR_System.Models.SystemUser

@{
    ViewData["Title"] = "Tạo tài khoản mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var roles = ViewBag.Roles as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-primary fw-bold"><i class="bi bi-person-plus-fill me-2"></i>Tạo tài khoản mới</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/Dashboard" class="text-decoration-none">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Tài khoản Hệ thống</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Thêm mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label asp-for="Username" class="form-label fw-semibold">Tên đăng nhập <span class="text-danger">*</span></label>
                        <input asp-for="Username" class="form-control" placeholder="VD: admin_123" required />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-semibold">Địa chỉ Email <span class="text-danger">*</span></label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="VD: example@congty.com" required />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="PasswordHash" class="form-label fw-semibold">Mật khẩu <span class="text-danger">*</span></label>
                        <input name="PasswordHash" type="password" class="form-control" placeholder="Nhập ít nhất 6 ký tự" required minlength="6"/>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="RoleId" class="form-label fw-semibold">Nhóm Quyền (Role) <span class="text-danger">*</span></label>
                        <select asp-for="RoleId" class="form-select" required>
                            <option value="">-- Chọn nhóm quyền --</option>
                            @foreach (var role in roles)
                            {
                                <option value="@role.Key">@role.Value</option>
                            }
                        </select>
                        <span asp-validation-for="RoleId" class="text-danger"></span>
                    </div>

                    <div class="col-12 mt-5">
                        <div class="d-flex justify-content-end gap-2 text-end border-top pt-3">
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4">Hủy thao tác</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4">
                                <i class="bi bi-save me-1"></i> Lưu tài khoản
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
