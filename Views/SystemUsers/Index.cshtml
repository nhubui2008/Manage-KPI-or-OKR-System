@using Manage_KPI_or_OKR_System.Models
@model IEnumerable<SystemUser>
@{
    ViewData["Title"] = "Tài khoản Hệ thống";
    var roles = ViewBag.Roles as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="page-header">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Tài khoản Hệ thống</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Hệ thống</span>
            <i class="bi bi-chevron-right separator"></i>
            <span>Tài khoản users</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a href="/Auth/Register" class="btn btn-primary-custom text-decoration-none">
            <i class="bi bi-person-plus-fill"></i> Tạo tài khoản mới
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success shadow-sm border-0 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
    </div>
}

<div class="content-card">
    <div class="card-body-custom">
        <div class="toolbar">
            <div class="toolbar-left">
                <div class="toolbar-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Tìm tên đăng nhập, email...">
                </div>
                <select class="filter-select">
                    <option value="">Phân quyền (Role)</option>
                    @foreach (var role in roles)
                    {
                        <option value="@role.Key">@role.Value</option>
                    }
                </select>
                <select class="filter-select">
                    <option value="">Trạng thái tài khoản</option>
                    <option value="active">Đang hoạt động</option>
                    <option value="locked">Bị khóa</option>
                </select>
            </div>
        </div>

        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Tài khoản</th>
                        <th>Thông tin Email</th>
                        <th>Phân quyền</th>
                        <th>Ngày tạo</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            var roleName = user.RoleId.HasValue && roles.ContainsKey(user.RoleId.Value) ? roles[user.RoleId.Value] : "N/A";
                            var statusClass = user.IsActive == true ? "active" : "pending";
                            var statusDot = user.IsActive == true ? "" : "text-danger bg-danger";
                            var statusText = user.IsActive == true ? "Kích hoạt" : "Bị khóa";
                            
                            <tr>
                                <td>
                                    <div class="fw-bold text-dark">@user.Username</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">ID: @user.Id</div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="user-avatar bg-primary text-white" style="width: 28px; height: 28px; font-size: 0.7rem;">
                                            @(user.Username?[0].ToString().ToUpper() ?? "U")
                                        </div>
                                        <div>
                                            <div class="text-muted" style="font-size: 0.85rem;">@user.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @{
                                        var badgeClass = roleName.ToLower() == "admin" ? "bg-danger text-white" : "bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25";
                                    }
                                    <span class="badge @badgeClass rounded-pill px-3">@roleName</span>
                                </td>
                                <td class="text-muted" style="font-size: 0.85rem;">@(user.CreatedAt?.ToString("dd/MM/yyyy HH:mm"))</td>
                                <td>
                                    <span class="status-badge @statusClass">
                                        <span class="status-dot @statusDot"></span> @statusText
                                    </span>
                                </td>
                                <td>
                                    <div class="action-btns justify-content-end">
                                        @if (user.IsActive == false)
                                        {
                                            <button class="action-btn" title="Mở khóa tài khoản"><i class="bi bi-unlock-fill text-success"></i></button>
                                        }
                                        else
                                        {
                                            <button class="action-btn danger" title="Khóa tài khoản"><i class="bi bi-lock-fill"></i></button>
                                        }
                                        <button class="action-btn" title="Đổi mật khẩu"><i class="bi bi-key"></i></button>
                                        <button class="action-btn" title="Phân quyền" data-bs-toggle="modal" data-bs-target="#assignRoleModal-@user.Id"><i class="bi bi-shield-lock"></i></button>
                                    </div>
                                </td>
                            </tr>

                            <!-- Modal Phân quyền -->
                            <div class="modal fade" id="assignRoleModal-@user.Id" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content border-0 shadow-lg">
                                        <div class="modal-header border-bottom-0 pb-0">
                                            <h5 class="modal-title fw-bold text-dark"><i class="bi bi-shield-lock text-primary me-2"></i>Phân quyền tài khoản</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body p-4">
                                            <p class="text-muted mb-4">Chọn nhóm quyền mới cho tài khoản <strong>@user.Username</strong> (@user.Email)</p>
                                            <form asp-controller="SystemUsers" asp-action="AssignRole" method="post">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <div class="mb-4">
                                                    <label class="form-label">Chọn Role</label>
                                                    <select name="roleId" class="form-select" required>
                                                        <option value="">-- Chọn nhóm quyền --</option>
                                                        @foreach (var role in roles)
                                                        {
                                                            if (user.RoleId == role.Key)
                                                            {
                                                                <option value="@role.Key" selected>@role.Value</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@role.Key">@role.Value</option>
                                                            }
                                                        }
                                                    </select>
                                                </div>
                                                <div class="d-flex justify-content-end gap-2">
                                                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                                                    <button type="submit" class="btn btn-primary rounded-pill px-4">Lưu cấu hình</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Không có dữ liệu tài khoản nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
