@using Manage_KPI_or_OKR_System.Models
@model IEnumerable<SystemUser>
@{
    ViewData["Title"] = "Tài khoản Hệ thống";
    var roles = ViewBag.Roles as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Tài khoản Hệ thống</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Hệ thống</span>
            <i class="bi bi-chevron-right separator"></i>
            <span>Tài khoản users</span>
        </div>
    </div>
    <div class="d-flex justify-content-end gap-2">
        <a href="/Auth/Register" class="btn-primary-custom text-decoration-none">
            <i class="bi bi-person-plus-fill"></i> Tạo tài khoản mới
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success shadow-sm border-0 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
    </div>
}

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100">
    <div class="card-body-custom">
        <form asp-action="Index" method="get" class="toolbar">
            <div class="toolbar-left">
                <div class="toolbar-search">
                    <i class="bi bi-search"></i>
                    <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Tìm tên đăng nhập, email..." />
                </div>
                <select name="roleId" class="filter-select">
                    <option value="">Phân quyền (Role)</option>
                    @foreach (var role in roles)
                    {
                        if (ViewBag.RoleId != null && ViewBag.RoleId == role.Key)
                        {
                            <option value="@role.Key" selected>@role.Value</option>
                        }
                        else
                        {
                            <option value="@role.Key">@role.Value</option>
                        }
                    }
                </select>
                <select name="status" class="filter-select">
                    <option value="">Trạng thái tài khoản</option>
                    @if(ViewBag.Status == "active") { <option value="active" selected>Đang hoạt động</option> } else { <option value="active">Đang hoạt động</option> }
                    @if(ViewBag.Status == "locked") { <option value="locked" selected>Bị khóa</option> } else { <option value="locked">Bị khóa</option> }
                </select>
            </div>
            <div class="toolbar-right">
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary border-0" title="Làm mới">
                    <i class="bi bi-arrow-clockwise"></i>
                </a>
                <button type="submit" class="btn btn-sm btn-outline-secondary border-0" title="Lọc kết quả">
                    <i class="bi bi-funnel"></i>
                </button>
            </div>
        </form>

        <div class="table-responsive w-100">
            <table class="data-table w-100">
                <thead>
                    <tr>
                        <th>Tài khoản</th>
                        <th>Thông tin Email</th>
                        <th>Phân quyền</th>
                        <th>Ngày tạo</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            var roleName = user.RoleId.HasValue && roles.ContainsKey(user.RoleId.Value) ? roles[user.RoleId.Value] : "N/A";
                            var statusClass = user.IsActive == true ? "active" : "pending";
                            var statusDot = user.IsActive == true ? "" : "text-danger bg-danger";
                            var statusText = user.IsActive == true ? "Kích hoạt" : "Bị khóa";
                            
                            <tr>
                                <td>
                                    <div class="fw-bold text-dark">@user.Username</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">ID: @user.Id</div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="user-avatar bg-primary text-white" style="width: 28px; height: 28px; font-size: 0.7rem;">
                                            @(user.Username?[0].ToString().ToUpper() ?? "U")
                                        </div>
                                        <div>
                                            <div class="text-muted" style="font-size: 0.85rem;">@user.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @{
                                        var badgeClass = roleName.ToLower() == "admin" ? "bg-danger text-white" : "bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25";
                                    }
                                    <span class="badge @badgeClass rounded-pill px-3">@roleName</span>
                                </td>
                                <td class="text-muted" style="font-size: 0.85rem;">@(user.CreatedAt?.ToString("dd/MM/yyyy HH:mm"))</td>
                                <td>
                                    <span class="status-badge @statusClass">
                                        <span class="status-dot @statusDot"></span> @statusText
                                    </span>
                                </td>
                                <td>
                                    <div class="action-btns justify-content-end">
                                        <a asp-action="Details" asp-route-id="@user.Id" class="action-btn" title="Xem chi tiết"><i class="bi bi-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@user.Id" class="action-btn" title="Chỉnh sửa"><i class="bi bi-pencil"></i></a>
                                        
                                        <form asp-action="ToggleLock" method="post" class="d-inline m-0">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            @if (user.IsActive == false)
                                            {
                                                <button type="submit" class="action-btn" title="Mở khóa tài khoản"><i class="bi bi-unlock-fill text-success"></i></button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="action-btn danger" title="Khóa tài khoản"><i class="bi bi-lock-fill"></i></button>
                                            }
                                        </form>

                                        <button class="action-btn" title="Đổi mật khẩu" data-bs-toggle="modal" data-bs-target="#resetPasswordModal-@user.Id"><i class="bi bi-key"></i></button>
                                        
                                        <a asp-action="Delete" asp-route-id="@user.Id" class="action-btn danger" title="Xóa tài khoản"><i class="bi bi-trash-fill text-danger"></i></a>
                                    </div>
                                </td>
                            </tr>

                            <!-- Modal Đổi mật khẩu -->
                            <div class="modal fade" id="resetPasswordModal-@user.Id" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content border-0 shadow-lg">
                                        <div class="modal-header border-bottom-0 pb-0">
                                            <h5 class="modal-title fw-bold text-dark"><i class="bi bi-key text-info me-2"></i>Làm mới mật khẩu</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body p-4">
                                            <form asp-controller="SystemUsers" asp-action="ResetPassword" method="post">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <div class="mb-4">
                                                    <label class="form-label">Mật khẩu mới cho <strong>@user.Username</strong></label>
                                                    <input type="password" name="newPassword" class="form-control" required minlength="6" placeholder="Nhập ít nhất 6 ký tự..." />
                                                </div>
                                                <div class="d-flex justify-content-end gap-2">
                                                    <button type="button" class="btn-outline-custom rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                                                    <button type="submit" class="btn-primary-custom rounded-pill px-4">Lưu cấu hình</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Không có dữ liệu tài khoản nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

        </div>
    </div>
</div>