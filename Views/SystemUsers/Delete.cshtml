@model Manage_KPI_or_OKR_System.Models.SystemUser

@{
    ViewData["Title"] = "Xóa Tài khoản";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var roles = ViewBag.Roles as Dictionary<int, string> ?? new Dictionary<int, string>();
    var roleName = Model.RoleId.HasValue && roles.ContainsKey(Model.RoleId.Value) ? roles[Model.RoleId.Value] : "Chưa phân quyền";
    var userInitial = Model.Username?[0].ToString().ToUpper() ?? "U";
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
        border-radius: 1.5rem;
        overflow: hidden;
    }
    .page-header-danger {
        background: url('data:image/svg+xml;utf8,<svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(220,53,69,0.04)" stroke-width="1"/></pattern></defs><rect width="100%" height="100%" fill="url(%23grid)" /></svg>'), linear-gradient(to right, #fff5f5, #ffffff);
        border: 1px solid rgba(220, 53, 69, 0.15) !important;
    }
    .warning-box {
        background: linear-gradient(to right, rgba(255, 193, 7, 0.08), rgba(255, 193, 7, 0.02));
        border-left: 4px solid #ffc107;
        border-radius: 0.75rem;
    }
    .btn-danger-gradient {
        background: linear-gradient(135deg, #dc3545 0%, #b02a37 100%);
        color: white;
        border: none;
        transition: all 0.3s ease;
    }
    .btn-danger-gradient:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(220, 53, 69, 0.25);
        color: white;
    }
    .user-info-card {
        background: rgba(0,0,0,0.02);
        border-radius: 1rem;
        border: 1px dashed rgba(0,0,0,0.1);
        transition: all 0.3s ease;
    }
    .user-info-card:hover {
        background: rgba(0,0,0,0.04);
        border-color: rgba(0,0,0,0.2);
    }
</style>

<div class="container-fluid px-0">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8 col-xl-7 mt-4">
            
            <div class="page-header d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-4 p-4 rounded-4 shadow-sm page-header-danger">
                <div class="d-flex align-items-center mb-0">
                    <div class="bg-danger bg-opacity-10 text-danger p-3 rounded-3 me-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 50px; height: 50px;">
                        <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                    </div>
                    <div>
                        <h1 class="h4 font-weight-bold mb-1 text-danger" style="letter-spacing: -0.5px;">Xóa Vĩnh Viễn Tài Khoản</h1>
                        <p class="text-danger opacity-75 small mb-0 fw-medium">Hành động dỡ bỏ hệ thống này KHÔNG THỂ hoàn tác!</p>
                    </div>
                </div>
            </div>

            <div class="glass-card mb-5">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="warning-box p-4 mb-5">
                        <div class="d-flex align-items-start">
                            <i class="bi bi-info-circle-fill fs-4 text-warning me-3 mt-1" style="filter: drop-shadow(0 2px 4px rgba(255,193,7,0.3));"></i>
                            <div>
                                <h6 class="fw-bold text-dark mb-2">Cảnh báo tính toàn vẹn dữ liệu</h6>
                                <p class="text-muted small mb-0" style="line-height: 1.6;">
                                    Ngay cả khi bạn xác nhận xóa, hệ thống sẽ <strong>TỪ CHỐI XÓA</strong> (báo lỗi bảo vệ ForeignKey) nếu tài khoản này đã từng duyệt KPI, được gán vào OKR, tạo báo cáo hoặc dính dữ liệu lịch sử.<br>
                                    <span class="d-inline-block mt-2 px-2 py-1 bg-warning bg-opacity-10 text-dark rounded-2">
                                        💡 <em class="fw-medium">Khuyến nghị an toàn: Thay vì xóa, hãy dùng chức năng <strong>Chỉnh sửa & Khóa tài khoản</strong> để vô hiệu hóa người dùng.</em>
                                    </span>
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="user-info-card p-4 text-center mt-5 mb-5 position-relative">
                        <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3 shadow-sm" style="width: 68px; height: 68px; font-size: 2rem; margin-top: -3.5rem; border: 4px solid #fff;">
                            @userInitial
                        </div>
                        <h4 class="fw-bold text-dark mb-1">@Model.Username</h4>
                        <div class="text-muted small mb-3"><i class="bi bi-envelope-at me-1"></i> @Model.Email</div>
                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-3 py-2 rounded-pill shadow-sm">
                            <i class="bi bi-shield-check me-1"></i> Vai trò: @roleName
                        </span>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center mt-2 border-top border-secondary border-opacity-10 pt-4">
                            <a asp-action="Index" class="btn btn-light btn-lg rounded-pill fw-medium px-4 shadow-sm border order-2 order-sm-1 flex-grow-1 flex-sm-grow-0 hover-opacity" style="transition: all 0.2s ease;">
                                <i class="bi bi-arrow-left me-1"></i> Hủy & Quay lại an toàn
                            </a>
                            <button type="submit" class="btn btn-danger-gradient btn-lg rounded-pill fw-bold px-4 shadow-sm order-1 order-sm-2 flex-grow-1 flex-sm-grow-0">
                                Xác nhận XÓA <i class="bi bi-trash3-fill ms-1"></i>
                            </button>
                        </div>
                    </form>

                </div>
            </div>
            
        </div>
    </div>
</div>
