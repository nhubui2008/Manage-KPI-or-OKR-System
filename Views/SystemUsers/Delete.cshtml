@model Manage_KPI_or_OKR_System.Models.SystemUser

@{
    ViewData["Title"] = "Xóa Tài khoản";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var roles = ViewBag.Roles as Dictionary<int, string> ?? new Dictionary<int, string>();
    var roleName = Model.RoleId.HasValue && roles.ContainsKey(Model.RoleId.Value) ? roles[Model.RoleId.Value] : "N/A";
}

<div class="container-fluid px-4 mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden mt-5">
                <div class="card-header bg-danger text-white py-4 d-flex flex-column align-items-center text-center">
                    <div class="bg-white text-danger rounded-circle d-flex justify-content-center align-items-center mb-3" style="width: 70px; height: 70px; font-size: 2rem;">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <h3 class="fw-bold mb-0">Xóa vĩnh viễn Hệ thống tài khoản?</h3>
                    <p class="mb-0 text-white-50 mt-1">Hành động này KHÔNG THỂ hoàn tác!</p>
                </div>
                <div class="card-body p-4 p-md-5">
                    <div class="alert alert-warning border-warning border-opacity-50 text-dark mb-4 p-3 rounded-3" role="alert">
                        <i class="bi bi-info-circle-fill me-2 text-warning"></i>
                        <strong>Cảnh báo:</strong> Ngay cả khi bạn xác nhận xóa, hệ thống sẽ <strong>CHỐNG XÓA</strong> (báo lỗi bảo vệ CSDL) nếu tài khoản này đã duyệt, tạo báo cáo hoặc dính dữ liệu lịch sử. <br>
                        <em>Khuyến nghị an toàn: Hãy quay lại và dùng chức năng <strong>Khóa tài khoản</strong>.</em>
                    </div>

                    <div class="border rounded-3 p-3 mb-4 bg-light text-center">
                        <h5 class="fw-bold mb-1">@Model.Username</h5>
                        <div class="text-muted small mb-2">@Model.Email</div>
                        <span class="badge bg-secondary rounded-pill px-3">Role: @roleName</span>
                    </div>

                    <form asp-action="Delete" method="post" class="mt-4">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex flex-column gap-3">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold w-100 shadow-sm hover-elevate">
                                <i class="bi bi-trash me-2"></i> Xác nhận XÓA VĨNH VIỄN
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill fw-bold w-100">
                                Quay lại Danh sách an toàn
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
