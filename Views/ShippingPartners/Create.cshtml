@model Manage_KPI_or_OKR_System.Models.ShippingPartner
@{
    ViewData["Title"] = "Thêm Đối tác vận chuyển";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-dark fw-bold">
                <i class="bi bi-truck me-2"></i>Thêm Đối tác vận chuyển Mới
            </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-dark text-decoration-none opacity-75">Đối tác vận chuyển</a></li>
                    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Thêm mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="content-card rounded-3">
                <div class="card-header-custom bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-briefcase me-2"></i>Thông tin Đối tác</h5>
                </div>
                <div class="card-body-custom p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="PartnerName" class="form-label fw-bold text-dark">Tên đối tác <span class="text-danger">*</span></label>
                            <input asp-for="PartnerName" class="form-control" placeholder="VD: Giao Hàng Tiết Kiệm, Viettel Post..." required />
                            <span asp-validation-for="PartnerName" class="text-danger small"></span>
                        </div>


                        <div class="d-flex justify-content-end gap-2 pt-3 border-top">
                            <a asp-action="Index" class="btn-outline-custom px-4">Hủy bỏ</a>
                            <button type="submit" class="btn-primary-custom px-4">
                                <i class="bi bi-save me-1"></i> Lưu Đối tác
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
