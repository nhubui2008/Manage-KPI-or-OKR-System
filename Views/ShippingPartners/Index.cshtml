@model List<Manage_KPI_or_OKR_System.Models.ShippingPartner>
@{ ViewData["Title"] = "Đối tác Vận chuyển"; }
@if (TempData["SuccessMessage"] != null)
{<div class="alert alert-success alert-dismissible fade show" role="alert"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="h3 font-weight-bold mb-1">Đối tác Vận chuyển</h1><div class="page-breadcrumb"><a href="/" class="text-dark text-decoration-none">Trang chủ</a><i class="bi bi-chevron-right separator"></i><span class="text-dark">Vận chuyển</span><i class="bi bi-chevron-right separator"></i><span class="text-dark fw-bold">Đối tác</span></div></div>
    @if (!User.IsInRole("Warehouse") && !User.IsInRole("warehouse"))
    {
        <div class="d-flex justify-content-end gap-2"><a asp-action="Create" class="btn btn-dark d-flex align-items-center text-decoration-none"><i class="bi bi-plus-lg me-1"></i> Thêm đối tác</a></div>
    }
</div>

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100"><div class="card-body-custom">
    <div class="table-responsive w-100"><table class="table table-hover align-middle">
        <thead><tr><th>Tên đối tác</th><th>API Endpoint</th><th>Trạng thái</th><th class="text-end">Thao tác</th></tr></thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var p in Model)
                {
                    <tr>
                        <td><div class="d-flex align-items-center gap-2"><div class="stat-icon dark" style="width:32px;height:32px;font-size:0.8rem;border-radius:8px; background: rgba(0,0,0,0.05); color: #000; display: flex; align-items: center; justify-content: center;"><i class="bi bi-truck"></i></div><span class="fw-semibold text-dark">@p.PartnerName</span></div></td>
                        <td class="text-muted" style="font-size:0.85rem;">@(p.APIEndpoint ?? "—")</td>
                        <td><span class="badge bg-light text-dark border">Hoạt động</span></td>
                        @if (!User.IsInRole("Warehouse") && !User.IsInRole("warehouse"))
                        {
                            <td><div class="d-flex justify-content-end gap-2">
                                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-dark" title="Sửa"><i class="bi bi-pencil-square"></i></a>
                                <form asp-action="Delete" method="post" style="display:inline;"><input type="hidden" name="id" value="@p.Id" /><button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa" onclick="return confirm('Vô hiệu hóa đối tác?')"><i class="bi bi-trash"></i></button></form>
                            </div></td>
                        }
                    </tr>
                }
            }
            else
            {<tr><td colspan="@(User.IsInRole("Warehouse") || User.IsInRole("warehouse") ? "3" : "4")" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;"></i><p class="mt-2">Chưa có đối tác nào</p></td></tr>}
        </tbody>
    </table></div>
</div></div>


        </div>
    </div>
</div>