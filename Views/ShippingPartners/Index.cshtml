@model List<Manage_KPI_or_OKR_System.Models.ShippingPartner>
@{ ViewData["Title"] = "Đối tác Vận chuyển"; }
@if (TempData["SuccessMessage"] != null)
{<div class="alert alert-success alert-dismissible fade show" role="alert"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="page-header">
    <div><h1 class="h3 font-weight-bold mb-1">Đối tác Vận chuyển</h1><div class="page-breadcrumb"><a href="/">Trang chủ</a><i class="bi bi-chevron-right separator"></i><span>Vận chuyển</span><i class="bi bi-chevron-right separator"></i><span>Đối tác</span></div></div>
    <div class="d-flex gap-2">
        @if (!User.IsInRole("Warehouse") && !User.IsInRole("warehouse"))
        {
            <button class="btn-primary-custom" data-bs-toggle="modal" data-bs-target="#createModal"><i class="bi bi-plus-lg"></i> Thêm đối tác</button>
        }
    </div>
</div>

<div class="content-card"><div class="card-body-custom">
    <div class="table-responsive"><table class="data-table">
        <thead><tr><th>Tên đối tác</th><th>API Endpoint</th><th>Trạng thái</th>
            @if (!User.IsInRole("Warehouse") && !User.IsInRole("warehouse")) { <th class="text-end">Thao tác</th> }
        </tr></thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var p in Model)
                {
                    <tr>
                        <td><div class="d-flex align-items-center gap-2"><div class="stat-icon blue" style="width:32px;height:32px;font-size:0.8rem;border-radius:8px;"><i class="bi bi-truck"></i></div><span class="fw-semibold text-dark">@p.PartnerName</span></div></td>
                        <td class="text-muted" style="font-size:0.85rem;">@(p.APIEndpoint ?? "—")</td>
                        <td><span class="status-badge active"><span class="status-dot"></span> Hoạt động</span></td>
                        @if (!User.IsInRole("Warehouse") && !User.IsInRole("warehouse"))
                        {
                            <td><div class="action-btns justify-content-end">
                                <form asp-action="Delete" method="post" style="display:inline;"><input type="hidden" name="id" value="@p.Id" /><button type="submit" class="action-btn danger" title="Xóa" onclick="return confirm('Vô hiệu hóa đối tác?')"><i class="bi bi-trash"></i></button></form>
                            </div></td>
                        }
                    </tr>
                }
            }
            else
            {<tr><td colspan="@(User.IsInRole("Warehouse") || User.IsInRole("warehouse") ? "3" : "4")" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;"></i><p class="mt-2">Chưa có đối tác nào</p></td></tr>}
        </tbody>
    </table></div>
</div></div>

<div class="modal fade" id="createModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content border-0 shadow">
    <div class="modal-header border-0"><h5 class="modal-title fw-bold"><i class="bi bi-truck me-2"></i>Thêm Đối tác</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form asp-action="Create" method="post"><div class="modal-body">
        <div class="mb-3"><label class="form-label fw-semibold">Tên đối tác</label><input type="text" name="PartnerName" class="form-control" required placeholder="VD: Giao Hàng Nhanh" /></div>
        <div class="mb-3"><label class="form-label fw-semibold">API Endpoint</label><input type="text" name="APIEndpoint" class="form-control" placeholder="https://api.partner.com/v1" /></div>
    </div>
    <div class="modal-footer border-0"><button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn-primary-custom">Tạo mới</button></div></form>
</div></div></div>
