@{
    ViewData["Title"] = "Đối tác Giao hàng";
}

<div class="page-header">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Đối tác Vận chuyển</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Giao nhận & Vận chuyển</span>
            <i class="bi bi-chevron-right separator"></i>
            <span>Đối tác</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn-primary-custom">
            <i class="bi bi-link-45deg"></i> Kết nối đối tác mới
        </button>
    </div>
</div>

<div class="row g-4">
    <!-- Partner 1 -->
    <div class="col-md-6 col-xl-4">
        <div class="content-card h-100 position-relative">
            <div class="position-absolute top-0 end-0 p-3">
                <span class="status-badge active"><span class="status-dot"></span> Đã kết nối</span>
            </div>
            <div class="card-body-custom p-4 text-center">
                <div class="d-inline-block bg-white border rounded shadow-sm p-3 mb-3">
                    <h3 class="fw-black text-danger mb-0" style="font-style: italic; letter-spacing: -1px;">Viettel<span class="text-dark">Post</span></h3>
                </div>
                <h5 class="fw-bold text-dark">Tổng Công ty CP Bưu chính Viettel</h5>
                <p class="text-muted mb-4" style="font-size: 0.85rem;">Phù hợp vận chuyển hàng nhẹ, liên tỉnh mạng lưới rộng khắp.</p>
                
                <div class="row g-2 mb-4 text-start">
                    <div class="col-6">
                        <div class="p-2 bg-light rounded border">
                            <div class="text-muted" style="font-size: 0.7rem;">Đơn hoàn thành</div>
                            <div class="fw-semibold text-dark">1,245</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-2 bg-light rounded border">
                            <div class="text-muted" style="font-size: 0.7rem;">Tỷ lệ giao công</div>
                            <div class="fw-semibold text-success">98.5%</div>
                        </div>
                    </div>
                </div>
                
                <button class="btn btn-outline-primary w-100">Cấu hình kết nối (API)</button>
            </div>
        </div>
    </div>

    <!-- Partner 2 -->
    <div class="col-md-6 col-xl-4">
        <div class="content-card h-100 position-relative">
            <div class="position-absolute top-0 end-0 p-3">
                <span class="status-badge active"><span class="status-dot"></span> Đã kết nối</span>
            </div>
            <div class="card-body-custom p-4 text-center">
                <div class="d-inline-block bg-success text-white border border-success rounded shadow-sm p-3 mb-3">
                    <h3 class="fw-bold mb-0" style="letter-spacing: 1px;">GHTK</h3>
                </div>
                <h5 class="fw-bold text-dark">Giao Hàng Tiết Kiệm</h5>
                <p class="text-muted mb-4" style="font-size: 0.85rem;">Tối ưu chi phí cho các đơn hàng khu vực nội thành, cận tỉnh.</p>
                
                <div class="row g-2 mb-4 text-start">
                    <div class="col-6">
                        <div class="p-2 bg-light rounded border">
                            <div class="text-muted" style="font-size: 0.7rem;">Đơn hoàn thành</div>
                            <div class="fw-semibold text-dark">850</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-2 bg-light rounded border">
                            <div class="text-muted" style="font-size: 0.7rem;">Tỷ lệ giao công</div>
                            <div class="fw-semibold text-success">96.2%</div>
                        </div>
                    </div>
                </div>
                
                <button class="btn btn-outline-primary w-100">Cấu hình kết nối (API)</button>
            </div>
        </div>
    </div>
    
    <!-- Internal Team -->
    <div class="col-md-6 col-xl-4">
        <div class="content-card h-100 position-relative bg-primary bg-opacity-10 border border-primary border-opacity-25">
            <div class="position-absolute top-0 end-0 p-3">
                <span class="badge bg-primary rounded-pill px-3">Nội bộ</span>
            </div>
            <div class="card-body-custom p-4 text-center">
                <div class="d-inline-flex align-items-center justify-content-center bg-white text-primary border border-primary rounded-circle shadow-sm mb-3" style="width: 70px; height: 70px; font-size: 2rem;">
                    <i class="bi bi-truck-front-fill"></i>
                </div>
                <h5 class="fw-bold text-primary">Đội xe công ty (Nội bộ)</h5>
                <p class="text-muted mb-4" style="font-size: 0.85rem;">Quản lý và điều phối các chuyến xe tải lớn giao hàng công nghiệp.</p>
                
                <div class="row g-2 mb-4 text-start">
                    <div class="col-6">
                        <div class="p-2 bg-white rounded border">
                            <div class="text-muted" style="font-size: 0.7rem;">Số lượng xe</div>
                            <div class="fw-semibold text-dark">5 xe tải</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-2 bg-white rounded border">
                            <div class="text-muted" style="font-size: 0.7rem;">Tài xế</div>
                            <div class="fw-semibold text-dark">8 nhân viên</div>
                        </div>
                    </div>
                </div>
                
                <button class="btn btn-primary w-100">Quản lý đội xe</button>
            </div>
        </div>
    </div>
</div>
