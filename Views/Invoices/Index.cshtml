@{
    ViewData["Title"] = "Quản lý Hóa đơn";
}

<div class="page-header">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Danh sách Hóa đơn</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Bán hàng</span>
            <i class="bi bi-chevron-right separator"></i>
            <span>Hóa đơn</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn-primary-custom">
            <i class="bi bi-plus-lg"></i> Tạo hóa đơn
        </button>
    </div>
</div>

<div class="content-card">
    <div class="card-body-custom">
        <div class="toolbar">
            <div class="toolbar-left">
                <div class="toolbar-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Tìm theo số HĐ, chứng từ...">
                </div>
                <div class="d-flex align-items-center gap-2 border rounded px-2 bg-light bg-opacity-50">
                    <i class="bi bi-calendar3 text-muted"></i>
                    <input type="date" class="form-control form-control-sm border-0 bg-transparent shadow-none w-auto" value="2026-02-01">
                    <span class="text-muted">-</span>
                    <input type="date" class="form-control form-control-sm border-0 bg-transparent shadow-none w-auto" value="2026-02-28">
                </div>
                <select class="filter-select">
                    <option value="">Trạng thái thanh toán</option>
                    <option value="paid">Đã thanh toán (100%)</option>
                    <option value="partial">Thanh toán một phần</option>
                    <option value="unpaid">Chưa thanh toán</option>
                </select>
            </div>
            <div class="toolbar-right">
                <button class="btn btn-sm btn-outline-secondary border-0 text-success"><i class="bi bi-file-earmark-excel"></i></button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 40px;"><input type="checkbox" class="form-check-input"></th>
                        <th>Số Hóa đơn</th>
                        <th>Ngày lập</th>
                        <th>Khách hàng</th>
                        <th class="text-end">Tổng tiền (VNĐ)</th>
                        <th>Trạng thái TT</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="fw-bold text-dark">INV-2602-159</div>
                            <div class="text-muted" style="font-size: 0.75rem;">Đơn: SO-2602-0049</div>
                        </td>
                        <td>
                            <div class="text-dark">18/02/2026</div>
                            <div class="text-danger" style="font-size: 0.75rem;"><i class="bi bi-exclamation-circle me-1"></i>Hạn: 25/02/2026</div>
                        </td>
                        <td>
                            <div class="fw-medium text-primary">Tập đoàn Alpha</div>
                        </td>
                        <td class="text-end fw-semibold">165,000,000</td>
                        <td><span class="status-badge inactive"><span class="status-dot"></span> Chưa thanh toán</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="Ghi nhận TT"><i class="bi bi-cash-coin text-success"></i></button>
                                <button class="action-btn" title="In HĐ"><i class="bi bi-printer"></i></button>
                                <button class="action-btn" title="Xem chi tiết"><i class="bi bi-eye"></i></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="fw-bold text-dark">INV-2602-158</div>
                            <div class="text-muted" style="font-size: 0.75rem;">Đơn: SO-2602-0045</div>
                        </td>
                        <td>
                            <div class="text-dark">15/02/2026</div>
                            <div class="text-muted" style="font-size: 0.75rem;">Hạn: 22/02/2026</div>
                        </td>
                        <td>
                            <div class="fw-medium text-primary">CTY XD Tân Tiến</div>
                        </td>
                        <td class="text-end fw-semibold">25,500,000</td>
                        <td>
                            <div><span class="badge bg-warning text-dark px-2 rounded-pill">Thanh toán 1 phần</span></div>
                            <div class="progress-custom mt-1" style="height: 4px;">
                                <div class="progress-bar-custom orange" style="width: 50%;"></div>
                            </div>
                        </td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="Ghi nhận TT"><i class="bi bi-cash-coin text-success"></i></button>
                                <button class="action-btn" title="In HĐ"><i class="bi bi-printer"></i></button>
                                <button class="action-btn" title="Xem chi tiết"><i class="bi bi-eye"></i></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="fw-bold text-dark">INV-2602-157</div>
                            <div class="text-muted" style="font-size: 0.75rem;">Đơn: SO-2602-0043</div>
                        </td>
                        <td>
                            <div class="text-dark">12/02/2026</div>
                            <div class="text-muted" style="font-size: 0.75rem;">Hạn: 12/02/2026</div>
                        </td>
                        <td>
                            <div class="fw-medium text-primary">Nguyễn Hải Nam</div>
                        </td>
                        <td class="text-end fw-semibold">12,000,000</td>
                        <td><span class="status-badge active"><span class="status-dot"></span> Đã thanh toán</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="Ghi nhận TT"><i class="bi bi-cash-coin text-success"></i></button>
                                <button class="action-btn" title="In HĐ"><i class="bi bi-printer"></i></button>
                                <button class="action-btn" title="Xem chi tiết"><i class="bi bi-eye"></i></button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
