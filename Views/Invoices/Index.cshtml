@model List<Manage_KPI_or_OKR_System.Models.Invoice>
@{
    ViewData["Title"] = "Quản lý Hóa đơn";
    var orders = ViewBag.Orders as Dictionary<int, string> ?? new Dictionary<int, string>();
    var allOrders = ViewBag.AllOrders as List<Manage_KPI_or_OKR_System.Models.SalesOrder> ?? new List<Manage_KPI_or_OKR_System.Models.SalesOrder>();
}
@if (TempData["SuccessMessage"] != null)
{<div class="alert alert-success alert-dismissible fade show" role="alert"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="h3 font-weight-bold mb-1">Hóa đơn (Invoices)</h1><div class="page-breadcrumb"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a><i class="bi bi-chevron-right separator"></i><span class="text-dark opacity-75">Bán hàng</span><i class="bi bi-chevron-right separator"></i><span class="text-dark fw-bold">Hóa đơn</span></div></div>
    <div class="d-flex justify-content-end gap-2"><a asp-action="Create" class="btn-primary-custom d-flex align-items-center text-decoration-none"><i class="bi bi-plus-lg me-1"></i> Tạo hóa đơn</a></div>
</div>

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100"><div class="card-body-custom">
    <div class="table-responsive w-100"><table class="data-table w-100">
        <thead><tr><th>Số hóa đơn</th><th>Đơn hàng</th><th>MST KH</th><th class="text-end">Tổng trước thuế</th><th class="text-end">VAT</th><th class="text-end">Tổng cộng</th><th>Thanh toán</th><th class="text-end">Thao tác</th></tr></thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var inv in Model)
                {
                    var orderCode = inv.OrderId.HasValue && orders.ContainsKey(inv.OrderId.Value) ? orders[inv.OrderId.Value] : "N/A";
                    <tr>
                        <td class="fw-bold text-dark">@inv.InvoiceNo</td>
                        <td class="text-muted">@orderCode</td>
                        <td class="text-muted">@(inv.CustomerTaxCode ?? "—")</td>
                        <td class="text-end">@(inv.SubTotal?.ToString("N0") ?? "0")</td>
                        <td class="text-end">@(inv.VATRate?.ToString("N0") ?? "0")%</td>
                        <td class="text-end fw-bold">@(inv.GrandTotal?.ToString("N0") ?? "0")</td>
                        <td><span class="badge bg-light text-dark border">@(inv.PaymentMethod ?? "N/A")</span></td>
                        <td><div class="action-btns justify-content-end">
                            <button type="button" class="action-btn" title="Sửa" onclick="showComingSoonToast('Chỉnh sửa Hóa đơn')"><i class="bi bi-pencil-square"></i></button>
                            <form asp-action="Delete" method="post" style="display:inline;"><input type="hidden" name="id" value="@inv.Id" /><button type="submit" class="action-btn danger" title="Xóa" onclick="return confirm('Vô hiệu hóa hóa đơn?')"><i class="bi bi-trash"></i></button></form>
                        </div></td>
                    </tr>
                }
            }
            else
            {<tr><td colspan="8" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;"></i><p class="mt-2">Chưa có hóa đơn nào</p></td></tr>}
        </tbody>
    </table></div>
</div></div>


        </div>
    </div>
</div>