@model Manage_KPI_or_OKR_System.Models.Invoice
@{
    ViewData["Title"] = "Tạo Hóa đơn";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var orders = ViewBag.AllOrders as List<Manage_KPI_or_OKR_System.Models.SalesOrder> ?? new List<Manage_KPI_or_OKR_System.Models.SalesOrder>();
}

<div class="page-content">
    <div class="page-header d-flex align-items-center justify-content-between mb-4 animate__animated animate__fadeIn">
        <div>
            <h1 class="mb-2 fw-800">Tạo Hóa đơn Mới</h1>
            <div class="page-breadcrumb">
                <a href="/">Trang chủ</a>
                <span class="separator">/</span>
                <a asp-action="Index">Quản lý Hóa đơn</a>
                <span class="separator">/</span>
                <span class="text-muted">Tạo mới</span>
            </div>
        </div>
        <div>
            <a asp-action="Index" class="btn-outline-custom shadow-sm">
                <i class="bi bi-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-8 animate__animated animate__fadeInLeft">
            <div class="content-card border-0 shadow-lg" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">
                <div class="card-header-custom border-bottom bg-transparent py-4">
                    <h5 class="fw-bold fs-5 mb-0"><i class="bi bi-receipt text-primary me-2"></i> Thông tin Hóa đơn</h5>
                </div>

                <div class="card-body-custom p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <!-- SECTION 1 -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-primary text-white me-3 d-flex align-items-center justify-content-center shadow" style="width: 38px; height: 38px; border-radius: 12px;">
                                <span class="fw-bold">1</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Thông tin hóa đơn</h6>
                        </div>

                        <div class="row g-4 mb-5 p-3 rounded-4 bg-light bg-opacity-50 border border-white">
                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Số hóa đơn <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-file-earmark-text"></i>
                                        <input asp-for="InvoiceNo" class="form-control shadow-sm" placeholder="VD: INV2024001, VAT-999..." required />
                                    </div>
                                    <span asp-validation-for="InvoiceNo" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Đơn hàng gốc <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-cart3"></i>
                                        <select asp-for="OrderId" class="form-select shadow-sm" required>
                                            <option value="">-- Chọn đơn hàng --</option>
                                            @foreach (var o in orders)
                                            {
                                                <option value="@o.Id">@o.OrderCode</option>
                                            }
                                        </select>
                                    </div>
                                    <span asp-validation-for="OrderId" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <!-- SECTION 2 -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-success text-white me-3 d-flex align-items-center justify-content-center shadow" style="width: 38px; height: 38px; border-radius: 12px;">
                                <span class="fw-bold">2</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Giá trị thanh toán</h6>
                        </div>

                        <div class="row g-4 p-3 rounded-4 bg-light bg-opacity-50 border border-white mb-4">
                            <div class="col-md-4">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Tạm tính (VNĐ)</label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-calculator"></i>
                                        <input asp-for="SubTotal" type="number" step="0.01" class="form-control shadow-sm" placeholder="0.00" id="subTotalInput" />
                                    </div>
                                    <span asp-validation-for="SubTotal" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Thuế suất VAT (%)</label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-percent"></i>
                                        <input asp-for="VATRate" type="number" step="0.01" class="form-control shadow-sm" placeholder="10.00" id="vatRateInput" />
                                    </div>
                                    <span asp-validation-for="VATRate" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Tổng thanh toán (VNĐ) <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-cash-stack"></i>
                                        <input asp-for="GrandTotal" type="number" step="0.01" class="form-control shadow-sm" placeholder="0.00" id="grandTotalInput" required />
                                    </div>
                                    <span asp-validation-for="GrandTotal" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                            <a asp-action="Index" class="btn-outline-custom">
                                <i class="bi bi-x-lg me-2"></i> Hủy thao tác
                            </a>
                            <button type="submit" class="btn-primary-custom" style="padding: 12px 40px; border-radius: 12px;">
                                <i class="bi bi-check-lg fs-5 me-2"></i> Xuất Hóa đơn
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-xl-4 animate__animated animate__fadeInRight">
            <div class="sticky-top" style="top: 100px;">
                <div class="content-card border-0 shadow-lg text-white mb-4" style="background: linear-gradient(135deg, #0078d4, #005a9e); border-radius: 24px;">
                    <div class="card-body-custom p-4">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-white bg-opacity-20 p-3 rounded-4 me-3">
                                <i class="bi bi-receipt fs-3 text-white"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 opacity-75 fw-bold text-uppercase small">Tổng thanh toán</h6>
                                <h3 class="mb-0 fw-800" id="previewGrand">--</h3>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="bg-white bg-opacity-10 p-3 rounded-4">
                                    <div class="small opacity-75 mb-1">Tạm tính</div>
                                    <div class="fw-bold small" id="previewSub">--</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-white bg-opacity-10 p-3 rounded-4">
                                    <div class="small opacity-75 mb-1">VAT</div>
                                    <div class="fw-bold small" id="previewVAT">--</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="content-card border-0 shadow-sm rounded-4 bg-white p-4">
                    <h6 class="fw-bold text-dark mb-3"><i class="bi bi-info-circle text-primary me-2"></i> Lưu ý</h6>
                    <ul class="list-unstyled mb-0 small text-muted" style="line-height: 1.8;">
                        <li class="mb-2"><i class="bi bi-patch-check-fill text-success me-2"></i> Hóa đơn phải liên kết với đơn hàng đã tồn tại.</li>
                        <li class="mb-2"><i class="bi bi-patch-check-fill text-success me-2"></i> Nhập đúng thuế suất VAT theo quy định.</li>
                        <li><i class="bi bi-patch-check-fill text-success me-2"></i> Tổng thanh toán = Tạm tính × (1 + VAT%).</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    .letter-spacing-1 { letter-spacing: 0.1em; }
    .form-select, .form-control { border: 1.5px solid #edf2f7; padding-top: 12px; padding-bottom: 12px; }
    .form-select:focus, .form-control:focus { border-color: #a3c9f9; box-shadow: 0 0 0 4px rgba(163, 201, 249, 0.1); }
    .animate__animated { animation-duration: 0.8s; }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <script>
        const subInput = document.getElementById('subTotalInput');
        const vatInput = document.getElementById('vatRateInput');
        const grandInput = document.getElementById('grandTotalInput');
        const fmt = (v) => v ? new Intl.NumberFormat('vi-VN').format(v) + ' ₫' : '--';
        function updatePreview() {
            document.getElementById('previewSub').textContent = fmt(subInput.value);
            document.getElementById('previewVAT').textContent = vatInput.value ? vatInput.value + '%' : '--';
            document.getElementById('previewGrand').textContent = fmt(grandInput.value);
            // Auto-calculate grand total
            if (subInput.value && vatInput.value && !grandInput.value) {
                const calc = parseFloat(subInput.value) * (1 + parseFloat(vatInput.value) / 100);
                grandInput.value = calc.toFixed(2);
                document.getElementById('previewGrand').textContent = fmt(calc.toFixed(2));
            }
        }
        [subInput, vatInput, grandInput].forEach(el => el.addEventListener('input', updatePreview));
        window.addEventListener('DOMContentLoaded', updatePreview);
    </script>
}
