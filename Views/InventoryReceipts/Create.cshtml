@model Manage_KPI_or_OKR_System.Models.InventoryReceipt
@{
    ViewData["Title"] = "Tạo Phiếu Nhập kho";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var warehouses = ViewBag.AllWarehouses as List<Manage_KPI_or_OKR_System.Models.Warehouse> ?? new List<Manage_KPI_or_OKR_System.Models.Warehouse>();
    var employees = ViewBag.AllEmployees as List<Manage_KPI_or_OKR_System.Models.Employee> ?? new List<Manage_KPI_or_OKR_System.Models.Employee>();
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-dark fw-bold">
                <i class="bi bi-box-arrow-in-down me-2"></i>Tạo Phiếu Nhập kho Mới
            </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-dark text-decoration-none opacity-75">Quản lý Nhập kho</a></li>
                    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Tạo mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="content-card rounded-3">
                <div class="card-header-custom bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-file-earmark-arrow-down me-2"></i>Thông tin Phiếu Nhập</h5>
                </div>
                <div class="card-body-custom p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="WarehouseId" class="form-label fw-bold text-dark">Kho hàng <span class="text-danger">*</span></label>
                                <select asp-for="WarehouseId" class="form-select" required>
                                    <option value="">-- Chọn kho hàng --</option>
                                    @foreach (var w in warehouses)
                                    {
                                        <option value="@w.Id">@w.WarehouseName (@w.WarehouseCode)</option>
                                    }
                                </select>
                                <span asp-validation-for="WarehouseId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="WarehouseStaffId" class="form-label fw-bold text-dark">Người nhận hàng (Nhân viên kho)</label>
                                <select asp-for="WarehouseStaffId" class="form-select">
                                    <option value="">-- Chọn nhân viên --</option>
                                    @foreach (var e in employees)
                                    {
                                        <option value="@e.Id">@e.FullName (@e.EmployeeCode)</option>
                                    }
                                </select>
                                <span asp-validation-for="WarehouseStaffId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="TotalAmount" class="form-label fw-bold text-dark">Tổng giá trị (VNĐ)</label>
                                <input asp-for="TotalAmount" type="number" step="0.01" class="form-control" placeholder="0.00" />
                                <span asp-validation-for="TotalAmount" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 pt-3 mt-4 border-top">
                            <a asp-action="Index" class="btn-outline-custom px-4">Hủy bỏ</a>
                            <button type="submit" class="btn-primary-custom px-4">
                                <i class="bi bi-save me-1"></i> Tạo Phiếu nhập
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
