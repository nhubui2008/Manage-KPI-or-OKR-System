@model List<Manage_KPI_or_OKR_System.Models.InventoryReceipt>
@{
    ViewData["Title"] = "Phiếu Nhập kho";
    var warehouses = ViewBag.Warehouses as Dictionary<int, string> ?? new Dictionary<int, string>();
    var employees = ViewBag.Employees as Dictionary<int, string> ?? new Dictionary<int, string>();
    var allWarehouses = ViewBag.AllWarehouses as List<Manage_KPI_or_OKR_System.Models.Warehouse> ?? new List<Manage_KPI_or_OKR_System.Models.Warehouse>();
    var allEmployees = ViewBag.AllEmployees as List<Manage_KPI_or_OKR_System.Models.Employee> ?? new List<Manage_KPI_or_OKR_System.Models.Employee>();
}
@if (TempData["SuccessMessage"] != null)
{<div class="alert alert-success alert-dismissible fade show" role="alert"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}
@if (TempData["ErrorMessage"] != null)
{<div class="alert alert-danger alert-dismissible fade show" role="alert"><i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="h3 font-weight-bold mb-1">Phiếu Nhập kho</h1><div class="page-breadcrumb"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a><i class="bi bi-chevron-right separator"></i><span class="text-dark opacity-75">Kho</span><i class="bi bi-chevron-right separator"></i><span class="text-dark fw-bold">Nhập kho</span></div></div>
    <div class="d-flex justify-content-end gap-2"><a asp-action="Create" class="btn-primary-custom d-flex align-items-center text-decoration-none"><i class="bi bi-plus-lg me-1"></i> Tạo phiếu nhập</a></div>
</div>

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100"><div class="card-body-custom">
    <div class="table-responsive w-100"><table class="data-table w-100">
        <thead><tr><th>Mã phiếu</th><th>Kho nhập</th><th>NV kho</th><th>Ngày nhập</th><th class="text-end">Tổng tiền (VNĐ)</th><th class="text-end">Thao tác</th></tr></thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var r in Model)
                {
                    var whName = r.WarehouseId.HasValue && warehouses.ContainsKey(r.WarehouseId.Value) ? warehouses[r.WarehouseId.Value] : "N/A";
                    var empName = r.WarehouseStaffId.HasValue && employees.ContainsKey(r.WarehouseStaffId.Value) ? employees[r.WarehouseStaffId.Value] : "N/A";
                    <tr>
                        <td class="fw-bold text-dark">PN-@r.Id.ToString("D5")</td>
                        <td class="fw-semibold text-dark">@whName</td>
                        <td class="text-muted">@empName</td>
                        <td class="text-muted">@(r.ReceiptDate?.ToString("dd/MM/yyyy") ?? "")</td>
                        <td class="text-end fw-semibold">@(r.TotalAmount?.ToString("N0") ?? "0")</td>
                        <td><div class="action-btns justify-content-end">
                            <a asp-action="Edit" asp-route-id="@r.Id" class="action-btn" title="Sửa">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <form asp-action="Delete" method="post" style="display:inline;"><input type="hidden" name="id" value="@r.Id" /><button type="submit" class="action-btn danger" title="Xóa" onclick="return confirm('Xóa phiếu nhập?')"><i class="bi bi-trash"></i></button></form>
                        </div></td>
                    </tr>
                }
            }
            else
            {<tr><td colspan="6" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;"></i><p class="mt-2">Chưa có phiếu nhập nào</p></td></tr>}
        </tbody>
    </table></div>
</div></div>


        </div>
    </div>
</div>