@{
    ViewData["Title"] = "Quản lý Phiếu Nhập kho";
}

<div class="page-header">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Phiếu Nhập kho</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Kho</span>
            <i class="bi bi-chevron-right separator"></i>
            <span>Phiếu Nhập kho</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn-primary-custom">
            <i class="bi bi-plus-lg"></i> Tạo phiếu nhập
        </button>
    </div>
</div>

<div class="content-card">
    <div class="card-body-custom">
        <div class="toolbar">
            <div class="toolbar-left">
                <div class="toolbar-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Tìm kiếm mã phiếu...">
                </div>
                <div class="d-flex align-items-center gap-2 border rounded px-2 bg-light bg-opacity-50">
                    <i class="bi bi-calendar3 text-muted"></i>
                    <input type="date" class="form-control form-control-sm border-0 bg-transparent shadow-none w-auto" value="2026-02-01">
                    <span class="text-muted">-</span>
                    <input type="date" class="form-control form-control-sm border-0 bg-transparent shadow-none w-auto" value="2026-02-28">
                </div>
                <select class="filter-select">
                    <option value="">Trạng thái</option>
                    <option value="draft">Bản nháp</option>
                    <option value="completed">Đã nhập</option>
                    <option value="cancelled">Đã hủy</option>
                </select>
            </div>
        </div>

        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 40px;"><input type="checkbox" class="form-check-input"></th>
                        <th>Mã Phiếu</th>
                        <th>Ngày nhập</th>
                        <th>Nhà cung cấp</th>
                        <th>Kho nhập</th>
                        <th class="text-end">Tổng tiền (VNĐ)</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="fw-bold text-primary">PN2602-001</div>
                        </td>
                        <td>
                            <div class="fw-medium text-dark">15/02/2026</div>
                            <div class="text-muted" style="font-size: 0.75rem;">08:30 AM</div>
                        </td>
                        <td><div class="text-dark">Công ty TNHH Cung cấp Thiết bị Kỹ thuật Á Châu</div></td>
                        <td><div class="badge bg-light border text-dark"><i class="bi bi-building me-1"></i>Kho Tổng Miền Nam</div></td>
                        <td class="text-end fw-semibold">120,500,000</td>
                        <td><span class="status-badge active"><span class="status-dot"></span> Đã nhập kho</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="In phiếu"><i class="bi bi-printer"></i></button>
                                <button class="action-btn" title="Xem chi tiết"><i class="bi bi-eye"></i></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="fw-bold text-primary">PN2602-002</div>
                        </td>
                        <td>
                            <div class="fw-medium text-dark">16/02/2026</div>
                            <div class="text-muted" style="font-size: 0.75rem;">14:15 PM</div>
                        </td>
                        <td><div class="text-dark">Nhà phân phối Vật tư Công nghiệp Long Phụng</div></td>
                        <td><div class="badge bg-light border text-dark"><i class="bi bi-building me-1"></i>Kho Miền Trung</div></td>
                        <td class="text-end fw-semibold">45,000,000</td>
                        <td><span class="status-badge active"><span class="status-dot"></span> Đã nhập kho</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="In phiếu"><i class="bi bi-printer"></i></button>
                                <button class="action-btn" title="Xem chi tiết"><i class="bi bi-eye"></i></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="fw-bold text-primary">PN2602-003</div>
                        </td>
                        <td>
                            <div class="fw-medium text-dark">20/02/2026</div>
                            <div class="text-muted" style="font-size: 0.75rem;">10:00 AM</div>
                        </td>
                        <td><div class="text-dark">Công ty Cổ phần Thương mại Dịch vụ Global Tech</div></td>
                        <td><div class="badge bg-light border text-dark"><i class="bi bi-building me-1"></i>Kho Tổng Miền Nam</div></td>
                        <td class="text-end fw-semibold">210,000,000</td>
                        <td><span class="status-badge pending"><span class="status-dot"></span> Bản nháp</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="Sửa phiếu"><i class="bi bi-pencil"></i></button>
                                <button class="action-btn danger" title="Hủy phiếu"><i class="bi bi-x-circle"></i></button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        
        <div class="pagination-custom mt-3">
            <div>Hiển thị 1-3 trong số 45 bản ghi</div>
            <div class="pagination-pages">
                <a href="#" class="page-btn"><i class="bi bi-chevron-left"></i></a>
                <a href="#" class="page-btn active">1</a>
                <a href="#" class="page-btn">2</a>
                <a href="#" class="page-btn">3</a>
                <a href="#" class="page-btn"><i class="bi bi-chevron-right"></i></a>
            </div>
        </div>
    </div>
</div>
