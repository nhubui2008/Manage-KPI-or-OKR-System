@model IEnumerable<Manage_KPI_or_OKR_System.Models.SystemParameter>
@{
    ViewData["Title"] = "Cài đặt thông số hệ thống";
}

<div class="container-fluid p-0">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center mb-3">
            <div>
                <h3 class="mb-1 fw-bold text-dark"><i class="bi bi-gear text-primary me-2"></i>Cài đặt hệ thống</h3>
                <p class="text-muted mb-0">Thiết lập các thông số tự động của hệ thống</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Mã cấu hình</th>
                                    <th>Mô tả</th>
                                    <th style="width: 250px;">Giá trị</th>
                                    <th class="text-end" style="width: 150px;">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td><span class="badge bg-secondary bg-opacity-10 text-secondary">@item.ParameterCode</span></td>
                                        <td class="text-muted">@item.Description</td>
                                        <td>
                                            <form asp-action="Update" method="post" id="form-@item.Id">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <div class="input-group">
                                                    <input type="text" name="value" class="form-control" value="@item.Value" form="form-@item.Id" required>
                                                </div>
                                            </form>
                                        </td>
                                        <td class="text-end">
                                            <button type="submit" form="form-@item.Id" class="btn btn-sm btn-primary rounded-pill px-3">
                                                <i class="bi bi-save me-1"></i> Lưu
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
