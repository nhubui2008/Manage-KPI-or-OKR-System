@model Manage_KPI_or_OKR_System.Models.Customer
@{
    ViewData["Title"] = "Thêm Khách hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-dark fw-bold">
                <i class="bi bi-people-fill me-2"></i>Thêm Khách hàng Mới
            </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-dark text-decoration-none opacity-75">Quản lý Khách hàng</a></li>
                    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Thêm mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="content-card rounded-3">
                <div class="card-header-custom bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-person-plus me-2"></i>Thông tin Khách hàng</h5>
                </div>
                <div class="card-body-custom p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="CustomerCode" class="form-label fw-bold text-dark">Mã khách hàng <span class="text-danger">*</span></label>
                                <input asp-for="CustomerCode" class="form-control" placeholder="VD: KH001, APPLE..." required />
                                <span asp-validation-for="CustomerCode" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="CustomerName" class="form-label fw-bold text-dark">Tên khách hàng <span class="text-danger">*</span></label>
                                <input asp-for="CustomerName" class="form-control" placeholder="Nhập tên khách hàng hoặc công ty" required />
                                <span asp-validation-for="CustomerName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label fw-bold text-dark">Số điện thoại</label>
                                <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại liên hệ" />
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-bold text-dark">Email</label>
                                <input asp-for="Email" type="email" class="form-control" placeholder="Nhập địa chỉ email" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="TaxCode" class="form-label fw-bold text-dark">Mã số thuế</label>
                                <input asp-for="TaxCode" class="form-control" placeholder="Nhập MST khách hàng" />
                                <span asp-validation-for="TaxCode" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="Address" class="form-label fw-bold text-dark">Địa chỉ</label>
                                <textarea asp-for="Address" class="form-control" rows="2" placeholder="Nhập địa chỉ văn phòng/nhà riêng"></textarea>
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 pt-3 mt-4 border-top">
                            <a asp-action="Index" class="btn-outline-custom px-4">Hủy bỏ</a>
                            <button type="submit" class="btn-primary-custom px-4">
                                <i class="bi bi-save me-1"></i> Lưu Khách hàng
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
