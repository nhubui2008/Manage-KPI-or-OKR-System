@model List<Manage_KPI_or_OKR_System.Models.Customer>
@{ ViewData["Title"] = "Quản lý Khách hàng"; }
@if (TempData["SuccessMessage"] != null)
{<div class="alert alert-success alert-dismissible fade show" role="alert"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="page-header">
    <div><h1 class="h3 font-weight-bold mb-1">Khách hàng & Đối tác</h1><div class="page-breadcrumb"><a href="/">Trang chủ</a><i class="bi bi-chevron-right separator"></i><span>Bán hàng</span><i class="bi bi-chevron-right separator"></i><span>Khách hàng</span></div></div>
    <div class="d-flex gap-2"><button class="btn-primary-custom" data-bs-toggle="modal" data-bs-target="#createModal"><i class="bi bi-person-plus-fill"></i> Thêm khách hàng mới</button></div>
</div>

<div class="content-card"><div class="card-body-custom">
    <div class="toolbar"><div class="toolbar-left">
        <form method="get" class="d-flex gap-2"><div class="toolbar-search"><i class="bi bi-search"></i><input type="text" name="searchString" value="@ViewBag.CurrentSearch" placeholder="Tìm theo tên, SĐT, Email, MST..."></div>
        <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-funnel"></i> Lọc</button></form>
    </div></div>

    <div class="table-responsive"><table class="data-table">
        <thead><tr><th>Thông tin Khách hàng</th><th>Liên hệ</th><th>Mã số thuế</th><th>Địa chỉ</th><th class="text-end">Thao tác</th></tr></thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var c in Model)
                {
                    <tr>
                        <td><div class="fw-semibold text-dark mb-1">@c.CustomerName</div><div class="text-muted" style="font-size:0.75rem;">Mã KH: @c.CustomerCode</div></td>
                        <td><div class="d-flex flex-column gap-1" style="font-size:0.8rem;">
                            @if (!string.IsNullOrEmpty(c.Phone)){<span><i class="bi bi-telephone text-muted me-1"></i>@c.Phone</span>}
                            @if (!string.IsNullOrEmpty(c.Email)){<span><i class="bi bi-envelope text-muted me-1"></i>@c.Email</span>}
                        </div></td>
                        <td class="text-muted">@(c.TaxCode ?? "—")</td>
                        <td class="text-muted" style="max-width:200px;"><div class="text-truncate">@(c.Address ?? "—")</div></td>
                        <td><div class="action-btns justify-content-end">
                            <form asp-action="Delete" method="post" style="display:inline;"><input type="hidden" name="id" value="@c.Id" /><button type="submit" class="action-btn danger" title="Xóa" onclick="return confirm('Vô hiệu hóa khách hàng này?')"><i class="bi bi-trash"></i></button></form>
                        </div></td>
                    </tr>
                }
            }
            else
            {<tr><td colspan="5" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;"></i><p class="mt-2">Chưa có khách hàng nào</p></td></tr>}
        </tbody>
    </table></div>
</div></div>

<div class="modal fade" id="createModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content border-0 shadow">
    <div class="modal-header border-0"><h5 class="modal-title fw-bold"><i class="bi bi-person-plus me-2"></i>Thêm Khách hàng</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form asp-action="Create" method="post"><div class="modal-body">
        <div class="mb-3"><label class="form-label fw-semibold">Mã khách hàng</label><input type="text" name="CustomerCode" class="form-control" required placeholder="VD: KH-00001" /></div>
        <div class="mb-3"><label class="form-label fw-semibold">Tên khách hàng</label><input type="text" name="CustomerName" class="form-control" required /></div>
        <div class="row"><div class="col-6 mb-3"><label class="form-label fw-semibold">Điện thoại</label><input type="text" name="Phone" class="form-control" /></div>
        <div class="col-6 mb-3"><label class="form-label fw-semibold">Email</label><input type="email" name="Email" class="form-control" /></div></div>
        <div class="mb-3"><label class="form-label fw-semibold">Mã số thuế</label><input type="text" name="TaxCode" class="form-control" /></div>
        <div class="mb-3"><label class="form-label fw-semibold">Địa chỉ</label><textarea name="Address" class="form-control" rows="2"></textarea></div>
    </div>
    <div class="modal-footer border-0"><button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn-primary-custom">Tạo mới</button></div></form>
</div></div></div>
