@model List<Manage_KPI_or_OKR_System.Models.Customer>
@{ ViewData["Title"] = "Quản lý Khách hàng"; }
@if (TempData["SuccessMessage"] != null)
{<div class="alert alert-success alert-dismissible fade show" role="alert"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="h3 font-weight-bold mb-1">Khách hàng & Đối tác</h1><div class="page-breadcrumb"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a><i class="bi bi-chevron-right separator"></i><span class="text-dark opacity-75">Bán hàng</span><i class="bi bi-chevron-right separator"></i><span class="text-dark fw-bold">Khách hàng</span></div></div>
    <div class="d-flex justify-content-end gap-2"><a asp-action="Create" class="btn-primary-custom d-flex align-items-center text-decoration-none"><i class="bi bi-person-plus-fill me-1"></i> Thêm khách hàng mới</a></div>
</div>

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100"><div class="card-body-custom">
    <form method="get" class="toolbar">
        <div class="toolbar-left">
            <div class="search-wrapper-premium" style="max-width: 350px;">
                <i class="bi bi-search"></i>
                <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="search-input-premium" placeholder="Tìm theo tên, SĐT, Email, MST...">
            </div>
        </div>
        <div class="toolbar-right d-flex gap-2 align-items-center">
            <button type="submit" class="btn-filter-premium">
                <i class="bi bi-funnel-fill"></i> Lọc dữ liệu
            </button>
            <a asp-action="Index" class="btn-refresh-premium" title="Làm mới">
                <i class="bi bi-arrow-clockwise fs-5"></i>
            </a>
        </div>
    </form>

    <div class="table-responsive w-100"><table class="data-table w-100">
        <thead><tr><th>Thông tin Khách hàng</th><th>Liên hệ</th><th>Mã số thuế</th><th>Địa chỉ</th><th class="text-end">Thao tác</th></tr></thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var c in Model)
                {
                    <tr>
                        <td><div class="fw-semibold text-dark mb-1">@c.CustomerName</div><div class="text-muted" style="font-size:0.75rem;">Mã KH: @c.CustomerCode</div></td>
                        <td><div class="d-flex flex-column gap-1" style="font-size:0.8rem;">
                            @if (!string.IsNullOrEmpty(c.Phone)){<span><i class="bi bi-telephone text-muted me-1"></i>@c.Phone</span>}
                            @if (!string.IsNullOrEmpty(c.Email)){<span><i class="bi bi-envelope text-muted me-1"></i>@c.Email</span>}
                        </div></td>
                        <td class="text-muted">@(c.TaxCode ?? "—")</td>
                        <td class="text-muted" style="max-width:200px;"><div class="text-truncate">@(c.Address ?? "—")</div></td>
                        <td><div class="action-btns justify-content-end">
                            <form asp-action="Delete" method="post" style="display:inline;"><input type="hidden" name="id" value="@c.Id" /><button type="submit" class="action-btn danger" title="Xóa" onclick="return confirm('Vô hiệu hóa khách hàng này?')"><i class="bi bi-trash"></i></button></form>
                        </div></td>
                    </tr>
                }
            }
            else
            {<tr><td colspan="5" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;"></i><p class="mt-2">Chưa có khách hàng nào</p></td></tr>}
        </tbody>
    </table></div>
</div></div>


        </div>
    </div>
</div>