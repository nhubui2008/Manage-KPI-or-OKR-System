@{
    ViewData["Title"] = "Tạo mật khẩu mới";
}
<style>
    body {
        background-color: #f8f9fa;
        font-family: 'Inter', sans-serif;
    }

    .auth-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }

    .btn-success {
        border: none;
        padding: 10px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-success:hover {
            transform: translateY(-1px);
        }

    .form-control {
        border-radius: 8px;
        padding: 10px 12px;
        border: 1px solid #dee2e6;
    }

        .form-control:focus {
            box-shadow: none;
            border-color: #dee2e6;
            background-color: #fff !important;
        }

    /* Đảm bảo khung input group đồng màu khi focus */
    .input-group:focus-within .input-group-text,
    .input-group:focus-within .form-control {
        border-color: #198754;
        background-color: #fff !important;
    }

    .input-group-text {
        border-radius: 8px 0 0 8px;
    }

    .toggle-password {
        border-radius: 0 8px 8px 0;
        transition: all 0.2s;
    }

        .toggle-password:hover i {
            color: #198754 !important; /* Đổi màu xanh lá khi hover */
        }

    .icon-box {
        width: 60px;
        height: 60px;
        background: rgba(25, 135, 84, 0.1);
        color: #198754;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 24px;
    }
</style>

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 80vh;">
        <div class="col-md-5 col-lg-4">
            <div class="card auth-card">
                <div class="card-body p-4 p-sm-5">
                    <div class="icon-box"><i class="bi bi-key-fill"></i></div>
                    <h3 class="text-center fw-bold mb-4">Tạo Mật Khẩu Mới</h3>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success d-flex align-items-center mb-4" style="font-size: 0.85rem; border-radius: 8px;">
                            <i class="bi bi-check-circle-fill me-2"></i><div>@TempData["SuccessMessage"]</div>
                        </div>
                    }

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-4" style="font-size: 0.85rem; border-radius: 8px;">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i><div>@ViewBag.Error</div>
                        </div>
                    }

                    <form asp-action="SetNewPassword" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold" style="font-size: 0.85rem;">Mật khẩu mới</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-muted"></i></span>
                                <input type="password" id="newPassword" name="newPassword" class="form-control border-start-0 border-end-0" required placeholder="Nhập mật khẩu mới" />
                                <span class="input-group-text bg-light border-start-0 toggle-password" data-target="newPassword" style="cursor: pointer;">
                                    <i class="bi bi-eye-slash text-muted"></i>
                                </span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold" style="font-size: 0.85rem;">Xác nhận mật khẩu</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-shield-check text-muted"></i></span>
                                <input type="password" id="confirmPassword" name="confirmPassword" class="form-control border-start-0 border-end-0" required placeholder="Nhập lại mật khẩu mới" />
                                <span class="input-group-text bg-light border-start-0 toggle-password" data-target="confirmPassword" style="cursor: pointer;">
                                    <i class="bi bi-eye-slash text-muted"></i>
                                </span>
                            </div>
                        </div>

                        <div class="d-grid mt-2">
                            <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-2"></i>Lưu mật khẩu mới</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const toggleButtons = document.querySelectorAll('.toggle-password');

        toggleButtons.forEach(button => {
            button.addEventListener('click', function () {
                const targetId = this.getAttribute('data-target');
                const passwordInput = document.getElementById(targetId);
                const icon = this.querySelector('i');

                if (passwordInput.type === "password") {
                    passwordInput.type = "text";
                    icon.classList.remove('bi-eye-slash');
                    icon.classList.add('bi-eye');
                    icon.style.color = '#198754'; // Màu xanh lá khi hiện pass
                } else {
                    passwordInput.type = "password";
                    icon.classList.remove('bi-eye');
                    icon.style.color = '';
                    icon.classList.add('bi-eye-slash');
                }
            });
        });
    });
</script>