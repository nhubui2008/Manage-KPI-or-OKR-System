@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="login-page">
    <div class="floating-shape"></div>
    <div class="floating-shape"></div>
    <div class="floating-shape"></div>

    <div class="login-card">
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-gradient text-white rounded-circle mb-3" style="width: 64px; height: 64px; font-size: 2rem;">
                <i class="bi bi-hexagon-fill"></i>
            </div>
            <h1 class="login-title">VietMach System</h1>
            <p class="login-subtitle">Hệ thống Quản lý KPI & OKR Doanh nghiệp</p>
        </div>

        <form asp-controller="Auth" asp-action="Login" method="post">
            <div class="mb-4">
                <label class="form-label" for="username">Tên đăng nhập</label>
                <div class="position-relative">
                    <input type="text" id="username" name="username" class="form-control" placeholder="Nhập tên tài khoản" required autocomplete="username">
                    <i class="bi bi-person position-absolute text-muted" style="top: 50%; right: 16px; transform: translateY(-50%);"></i>
                </div>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <label class="form-label mb-0" for="password">Mật khẩu</label>
                    <a href="#" class="text-primary text-decoration-none" style="font-size: 0.8125rem; font-weight: 500;">Quên mật khẩu?</a>
                </div>
                <div class="position-relative">
                    <input type="password" id="password" name="password" class="form-control" placeholder="Nhập mật khẩu" required autocomplete="current-password">
                    <i class="bi bi-lock position-absolute text-muted" style="top: 50%; right: 16px; transform: translateY(-50%);"></i>
                </div>
            </div>

            <div class="mb-4 d-flex align-items-center justify-content-between">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="rememberMe">
                    <label class="form-check-label text-muted" for="rememberMe" style="font-size: 0.875rem;">
                        Ghi nhớ đăng nhập
                    </label>
                </div>
            </div>

            <button type="submit" class="btn-login">
                Đăng Nhập <i class="bi bi-arrow-right-short ms-1 fs-5 align-middle"></i>
            </button>
        </form>

        <div class="text-center mt-5 mb-0 text-muted" style="font-size: 0.75rem;">
            &copy; 2026 VietMach ERP. Phiên bản 1.0.0
        </div>
    </div>
</div>
