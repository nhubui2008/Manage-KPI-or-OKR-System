@model Manage_KPI_or_OKR_System.Models.SystemUser
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    // Lấy thông tin nhân viên và quyền từ ViewBag
    var employee = ViewBag.EmployeeInfo as Manage_KPI_or_OKR_System.Models.Employee;
    var roleName = ViewBag.RoleName as string;
    
    // Tạo chữ cái đầu làm Avatar
    var avatarLetter = !string.IsNullOrEmpty(Model.Username) ? Model.Username[0].ToString().ToUpper() : "U";
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h3 class="fw-bold text-primary"><i class="bi bi-person-badge me-2"></i>Hồ sơ cá nhân</h3>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body text-center p-4">
                    <div class="bg-primary text-white d-inline-flex justify-content-center align-items-center mb-3 shadow-sm" 
                         style="width: 100px; height: 100px; border-radius: 50%; font-size: 2.5rem; font-weight: bold;">
                        @avatarLetter
                    </div>
                    <h4 class="fw-bold mb-1">@Model.Username</h4>
                    <p class="text-muted mb-3">@Model.Email</p>
                    <span class="badge bg-info text-dark px-3 py-2 rounded-pill shadow-sm mb-3">
                        <i class="bi bi-shield-lock-fill me-1"></i> Quyền: @roleName
                    </span>
                    <hr class="opacity-25" />
                    <div class="d-flex justify-content-between text-start mb-2 mt-3">
                        <span class="text-muted fw-semibold">Trạng thái:</span>
                        @if (Model.IsActive == true)
                        {
                            <span class="text-success fw-bold"><i class="bi bi-circle-fill small me-1"></i>Đang hoạt động</span>
                        }
                        else
                        {
                            <span class="text-danger fw-bold"><i class="bi bi-circle-fill small me-1"></i>Bị khóa</span>
                        }
                    </div>
                    <div class="d-flex justify-content-between text-start mb-2">
                        <span class="text-muted fw-semibold">Ngày tham gia:</span>
                        <span class="text-dark fw-medium">@(Model.CreatedAt?.ToString("dd/MM/yyyy"))</span>
                    </div>
                    
                    <a href="/Auth/ChangePassword" class="btn btn-outline-primary w-100 mt-4 rounded-pill fw-bold">
                        <i class="bi bi-key me-1"></i> Đổi mật khẩu
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-8 mb-4">
            <div class="card border-0 shadow-sm rounded-3 h-100">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-person-vcard text-primary me-2"></i>Thông tin hồ sơ nhân sự</h5>
                </div>
                <div class="card-body p-4">
                    @if (employee != null)
                    {
                        <div class="row g-4">
                            <div class="col-sm-6">
                                <label class="text-muted fw-semibold mb-1 d-block"><i class="bi bi-qr-code me-1"></i> Mã nhân viên</label>
                                <div class="fs-5 text-dark fw-bold">@employee.EmployeeCode</div>
                            </div>
                            <div class="col-sm-6">
                                <label class="text-muted fw-semibold mb-1 d-block"><i class="bi bi-person-bounding-box me-1"></i> Họ và tên</label>
                                <div class="fs-5 text-dark fw-bold">@employee.FullName</div>
                            </div>
                            <div class="col-sm-6">
                                <label class="text-muted fw-semibold mb-1 d-block"><i class="bi bi-telephone me-1"></i> Số điện thoại</label>
                                <div class="fs-5 text-dark fw-medium">@(string.IsNullOrEmpty(employee.Phone) ? "Chưa cập nhật" : employee.Phone)</div>
                            </div>
                            <div class="col-sm-6">
                                <label class="text-muted fw-semibold mb-1 d-block"><i class="bi bi-envelope-at me-1"></i> Email công việc</label>
                                <div class="fs-5 text-dark fw-medium">@(string.IsNullOrEmpty(employee.Email) ? "Chưa cập nhật" : employee.Email)</div>
                            </div>
                            <div class="col-sm-6">
                                <label class="text-muted fw-semibold mb-1 d-block"><i class="bi bi-calendar-event me-1"></i> Ngày sinh</label>
                                <div class="fs-5 text-dark fw-medium">@(employee.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</div>
                            </div>
                            <div class="col-sm-6">
                                <label class="text-muted fw-semibold mb-1 d-block"><i class="bi bi-building-check me-1"></i> Ngày vào làm</label>
                                <div class="fs-5 text-dark fw-medium">@(employee.JoinDate?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <div class="display-1 text-muted opacity-25 mb-3">
                                <i class="bi bi-person-exclamation"></i>
                            </div>
                            <h5 class="text-dark fw-bold mb-2">Chưa liên kết hồ sơ nhân viên</h5>
                            <p class="text-muted mb-0">Tài khoản này hiện chưa được gắn với bất kỳ hồ sơ nhân sự nào trên hệ thống.</p>
                            <p class="text-muted mt-2"><em>*Admin có thể cập nhật việc này trong phần "Quản lý nhân sự" -> "Sửa nhân viên" -> Chọn tài khoản ở mục "Liên kết".</em></p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>