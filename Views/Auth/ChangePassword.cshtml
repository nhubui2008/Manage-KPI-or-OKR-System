@{
    ViewData["Title"] = "Đổi Mật Khẩu";
}

<link rel="stylesheet" href="~/css/login.css" />

<div class="soft-background">
    <div class="floating-shapes">
        <div class="soft-blob blob-1"></div>
        <div class="soft-blob blob-2"></div>
        <div class="soft-blob blob-3"></div>
        <div class="soft-blob blob-4"></div>
    </div>
</div>

<div class="login-container">
    <div style="width: 100%; max-width: 440px;">
        <div class="soft-card" style="max-width: 100%;">
            <div class="comfort-header">
                <div class="gentle-logo">
                    <div class="logo-circle">
                        <div class="comfort-icon">
                            <i class="bi bi-shield-lock-fill" style="font-size: 26px;"></i>
                        </div>
                        <div class="gentle-glow"></div>
                    </div>
                </div>

                <h1 class="comfort-title" style="font-size: 1.8rem;">Reset Password</h1>
                <p class="gentle-subtitle" style="margin-top: 8px; line-height: 1.5;">
                    Please enter your current password and the new password to enhance the security of your account.
                </p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div style="text-align: center; margin-bottom: 20px;">
                    <span class="gentle-error" style="display: inline-block; background: #fff0f0; padding: 6px 16px; border-radius: 8px;">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i> @ViewBag.Error
                    </span>
                </div>
            }

            <form asp-action="ChangePassword" method="post" class="comfort-form" id="changePasswordForm">

                <div class="soft-field">
                    <div class="field-container">
                        <input type="password" id="oldPassword" name="oldPassword" required placeholder=" " />
                        <label for="oldPassword">Current Password</label>
                        <button type="button" class="gentle-toggle" data-target="oldPassword" aria-label="Toggle password visibility">
                            <div class="toggle-icon">
                                <svg class="eye-open" width="20" height="20" viewBox="0 0 20 20" fill="none">
                                    <path d="M10 3c-4.5 0-8.3 3.8-9 7 .7 3.2 4.5 7 9 7s8.3-3.8 9-7c-.7-3.2-4.5-7-9-7z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                    <circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                </svg>
                                <svg class="eye-closed" width="20" height="20" viewBox="0 0 20 20" fill="none">
                                    <path d="M3 3l14 14M8.5 8.5a3 3 0 004 4m2.5-2.5C15 10 12.5 7 10 7c-.5 0-1 .1-1.5.3M10 13c-2.5 0-4.5-2-5-3 .3-.6.7-1.2 1.2-1.7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </div>
                        </button>
                        <div class="field-accent"></div>
                    </div>
                </div>

                <div class="gentle-divider" style="margin: 8px 0;">
                    <div class="divider-line"></div>
                </div>

                <div class="soft-field">
                    <div class="field-container">
                        <input type="password" id="newPassword" name="newPassword" required placeholder=" " />
                        <label for="newPassword">New Password</label>
                        <button type="button" class="gentle-toggle" data-target="newPassword" aria-label="Toggle password visibility">
                            <div class="toggle-icon">
                                <svg class="eye-open" width="20" height="20" viewBox="0 0 20 20" fill="none">
                                    <path d="M10 3c-4.5 0-8.3 3.8-9 7 .7 3.2 4.5 7 9 7s8.3-3.8 9-7c-.7-3.2-4.5-7-9-7z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                    <circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                </svg>
                                <svg class="eye-closed" width="20" height="20" viewBox="0 0 20 20" fill="none">
                                    <path d="M3 3l14 14M8.5 8.5a3 3 0 004 4m2.5-2.5C15 10 12.5 7 10 7c-.5 0-1 .1-1.5.3M10 13c-2.5 0-4.5-2-5-3 .3-.6.7-1.2 1.2-1.7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </div>
                        </button>
                        <div class="field-accent"></div>
                    </div>
                </div>

                <div class="soft-field">
                    <div class="field-container">
                        <input type="password" id="confirmPassword" name="confirmPassword" required placeholder=" " />
                        <label for="confirmPassword">Confirm New Password</label>
                        <button type="button" class="gentle-toggle" data-target="confirmPassword" aria-label="Toggle password visibility">
                            <div class="toggle-icon">
                                <svg class="eye-open" width="20" height="20" viewBox="0 0 20 20" fill="none">
                                    <path d="M10 3c-4.5 0-8.3 3.8-9 7 .7 3.2 4.5 7 9 7s8.3-3.8 9-7c-.7-3.2-4.5-7-9-7z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                    <circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                </svg>
                                <svg class="eye-closed" width="20" height="20" viewBox="0 0 20 20" fill="none">
                                    <path d="M3 3l14 14M8.5 8.5a3 3 0 004 4m2.5-2.5C15 10 12.5 7 10 7c-.5 0-1 .1-1.5.3M10 13c-2.5 0-4.5-2-5-3 .3-.6.7-1.2 1.2-1.7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </div>
                        </button>
                        <div class="field-accent"></div>
                    </div>
                </div>

                <button type="submit" class="comfort-button" style="margin-top: 12px;">
                    <div class="button-background"></div>
                    <span class="button-text">
                        <i class="bi bi-check-circle-fill me-2"></i>Save Changes
                    </span>
                    <div class="button-loader">
                        <div class="gentle-spinner">
                            <div class="spinner-circle"></div>
                        </div>
                    </div>
                    <div class="button-glow"></div>
                </button>
            </form>

            <div class="text-center mt-4">
                <a asp-controller="Dashboard" asp-action="Index" class="comfort-link fw-medium" style="font-size: 0.95rem;">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại trang chủ
                </a>
            </div>
        </div>

        <p class="text-center text-muted mt-4 position-relative" style="font-size: 0.85rem; z-index: 1;">
            &copy; @DateTime.Now.Year VietMach System. All rights reserved.
        </p>
    </div>
</div>

<script>
    // Toggle password visibility cho tất cả các field
    document.querySelectorAll('.gentle-toggle').forEach(function(toggle) {
        toggle.addEventListener('click', function () {
            const targetId = this.getAttribute('data-target');
            const input = document.getElementById(targetId);
            if (!input) return;

            const isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            this.querySelector('.eye-open').style.display = isPassword ? 'none' : 'block';
            this.querySelector('.eye-closed').style.display = isPassword ? 'block' : 'none';
        });
    });

    // Spinner khi submit
    document.getElementById('changePasswordForm').addEventListener('submit', function(e) {
        const oldPw = document.getElementById('oldPassword').value.trim();
        const newPw = document.getElementById('newPassword').value.trim();
        const confirmPw = document.getElementById('confirmPassword').value.trim();

        if (oldPw && newPw && confirmPw) {
            const btn = this.querySelector('.comfort-button');
            btn.classList.add('loading');
            btn.querySelector('.button-text').style.opacity = '0';
        }
    });
</script>