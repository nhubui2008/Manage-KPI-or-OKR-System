@{
    ViewData["Title"] = "Đổi Mật Khẩu";
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-8 col-lg-5">
        <div class="card shadow-sm border-0" style="border-radius: 16px;">
            <div class="card-body p-4 p-md-5">

                <div class="text-center mb-4">
                    <div style="width: 64px; height: 64px; background: rgba(13, 110, 253, 0.1); color: #0d6efd; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px; font-size: 28px;">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <h3 class="fw-bold">Đổi Mật Khẩu</h3>
                    <p class="text-muted" style="font-size: 0.9rem;">
                        Vui lòng nhập mật khẩu hiện tại và mật khẩu mới để tăng cường bảo mật cho tài khoản của bạn.
                    </p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger d-flex align-items-center mb-4" style="font-size: 0.85rem; border-radius: 8px;">
                        <i class="bi bi-exclamation-triangle-fill me-2 text-danger"></i>
                        <div>@ViewBag.Error</div>
                    </div>
                }

                <form asp-action="ChangePassword" method="post">

                    <div class="mb-4">
                        <label class="form-label fw-semibold" style="font-size: 0.85rem;">Mật khẩu hiện tại</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-key text-muted"></i></span>
                            <input type="password" id="oldPassword" name="oldPassword" class="form-control border-start-0 border-end-0 bg-light focus-white" required placeholder="Nhập mật khẩu đang sử dụng" />
                            <span class="input-group-text bg-light border-start-0 toggle-password" data-target="oldPassword" style="cursor: pointer;">
                                <i class="bi bi-eye-slash text-muted"></i>
                            </span>
                        </div>
                    </div>

                    <hr class="text-muted opacity-25 mb-4">

                    <div class="mb-3">
                        <label class="form-label fw-semibold" style="font-size: 0.85rem;">Mật khẩu mới</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-muted"></i></span>
                            <input type="password" id="newPassword" name="newPassword" class="form-control border-start-0 border-end-0" required placeholder="Nhập mật khẩu mới" />
                            <span class="input-group-text bg-light border-start-0 toggle-password" data-target="newPassword" style="cursor: pointer;">
                                <i class="bi bi-eye-slash text-muted"></i>
                            </span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold" style="font-size: 0.85rem;">Xác nhận mật khẩu mới</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-shield-check text-muted"></i></span>
                            <input type="password" id="confirmPassword" name="confirmPassword" class="form-control border-start-0 border-end-0" required placeholder="Nhập lại mật khẩu mới" />
                            <span class="input-group-text bg-light border-start-0 toggle-password" data-target="confirmPassword" style="cursor: pointer;">
                                <i class="bi bi-eye-slash text-muted"></i>
                            </span>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary shadow-sm" style="border-radius: 8px; font-weight: 600; padding: 12px;">
                            <i class="bi bi-check-circle-fill me-2"></i> Lưu Thay Đổi
                        </button>
                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-light text-muted" style="border-radius: 8px; font-weight: 500; padding: 10px;">
                            Hủy bỏ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        box-shadow: none;
        border-color: #dee2e6;
        background-color: #fff !important;
    }
    /* Đảm bảo khung input group đồng màu khi focus */
    .input-group:focus-within .input-group-text,
    .input-group:focus-within .form-control {
        border-color: #86b7fe;
        background-color: #fff !important;
    }

    .input-group-text {
        border-radius: 8px 0 0 8px;
    }

    .toggle-password {
        border-radius: 0 8px 8px 0;
        transition: all 0.2s;
    }

        .toggle-password:hover i {
            color: #0d6efd !important;
        }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const toggleButtons = document.querySelectorAll('.toggle-password');

        toggleButtons.forEach(button => {
            button.addEventListener('click', function () {
                // Lấy ID của input tương ứng từ data-target
                const targetId = this.getAttribute('data-target');
                const passwordInput = document.getElementById(targetId);
                const icon = this.querySelector('i');

                // Chuyển đổi trạng thái Type và đổi icon con mắt
                if (passwordInput.type === "password") {
                    passwordInput.type = "text";
                    icon.classList.remove('bi-eye-slash');
                    icon.classList.add('bi-eye');
                    icon.classList.add('text-primary'); // Highlight lên màu xanh khi đang hiện pass
                } else {
                    passwordInput.type = "password";
                    icon.classList.remove('bi-eye');
                    icon.classList.remove('text-primary');
                    icon.classList.add('bi-eye-slash');
                }
            });
        });
    });
</script>