@{
    ViewData["Title"] = "Xác nhận mã OTP";
    ViewData["IsLoginPage"] = true;
}
<link rel="stylesheet" href="~/css/login.css" />

<div class="soft-background">
    <div class="floating-shapes">
        <div class="soft-blob blob-1"></div>
        <div class="soft-blob blob-2"></div>
        <div class="soft-blob blob-3"></div>
        <div class="soft-blob blob-4"></div>
    </div>
</div>

<div class="login-container">
    <div class="soft-card" style="text-align: center;">
        <div class="comfort-header">
            <div class="gentle-logo" style="margin-bottom: 24px;">
                <div class="logo-circle" style="width: 72px; height: 72px; margin: 0 auto;">
                    <div class="comfort-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                    </div>
                </div>
            </div>
            <h1 class="comfort-title">Xác nhận OTP</h1>
            <p class="gentle-subtitle mt-2">Mã 6 chữ số đã được gửi đến email của bạn</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="gentle-success active">
                <p class="success-desc">@TempData["SuccessMessage"]</p>
            </div>
        }

        @if (ViewBag.Error != null)
        {
            <span class="gentle-error" style="display: block; margin-bottom: 16px;">@ViewBag.Error</span>
        }

        <form asp-action="VerifyOTP" method="post" class="comfort-form">
            <div class="soft-field" style="margin-bottom: 24px;">
                <div class="field-container">
                    <input type="text" name="code" id="code" required autocomplete="off" placeholder=" " maxlength="6" style="letter-spacing: 12px; font-size: 1.5rem; text-align: center; font-weight: bold;" />
                    <label for="code" style="left:50%; transform:translateX(-50%); white-space:nowrap; top:-10px; font-size:0.85rem; color:#6b7fd7; background:#fff; padding:0 4px;">Nhập mã (6 số)</label>
                    <div class="field-accent"></div>
                </div>
            </div>
            
            <button type="submit" class="comfort-button mt-2">
                <div class="button-background"></div>
                <span class="button-text">Xác nhận mã</span>
                <div class="button-glow"></div>
            </button>
        </form>

        <div class="comfort-signup" style="margin-top: 24px;">
            <a asp-action="Login" class="comfort-link" style="color: #7a7e9a;">Hủy bỏ & Quay lại</a>
        </div>
    </div>
</div>