@model IEnumerable<Manage_KPI_or_OKR_System.Models.KPI>
@{
    ViewData["Title"] = "Danh mục KPI";

    var kpiDetails = ViewBag.KPIDetails as Dictionary<int, Manage_KPI_or_OKR_System.Models.KPIDetail> ?? new Dictionary<int, Manage_KPI_or_OKR_System.Models.KPIDetail>();
    var assignments = ViewBag.Assignments as Dictionary<int, List<Tuple<int, decimal>>> ?? new Dictionary<int, List<Tuple<int, decimal>>>();
    var departmentAssignments = ViewBag.DepartmentAssignments as Dictionary<int, List<int>> ?? new Dictionary<int, List<int>>();
    var employeesDict = ViewBag.Employees as Dictionary<int, string> ?? new Dictionary<int, string>();
    var departmentsDict = ViewBag.Departments as Dictionary<int, string> ?? new Dictionary<int, string>();
    var allEmployees = ViewBag.AllEmployees as List<Manage_KPI_or_OKR_System.Models.Employee> ?? new List<Manage_KPI_or_OKR_System.Models.Employee>();
    var allDepartments = ViewBag.AllDepartments as List<Manage_KPI_or_OKR_System.Models.Department> ?? new List<Manage_KPI_or_OKR_System.Models.Department>();
    var periodsDict = ViewBag.Periods as Dictionary<int, string> ?? new Dictionary<int, string>();
    var kpiTypesList = ViewBag.KPITypes as List<Manage_KPI_or_OKR_System.Models.KPIType> ?? new List<Manage_KPI_or_OKR_System.Models.KPIType>();
    var kpiTypesDict = kpiTypesList.ToDictionary(t => t.Id, t => t.TypeName ?? "N/A");
    var okrsList = ViewBag.OKRs as List<Manage_KPI_or_OKR_System.Models.OKR> ?? new List<Manage_KPI_or_OKR_System.Models.OKR>();
    var okrKeyResultsList = ViewBag.OKRKeyResults as List<Manage_KPI_or_OKR_System.Models.OKRKeyResult> ?? new List<Manage_KPI_or_OKR_System.Models.OKRKeyResult>();
    var okrNamesDict = ViewBag.OKRNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var okrKeyResultNamesDict = ViewBag.OKRKeyResultNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var latestProgress = ViewBag.LatestProgress as Dictionary<int, decimal> ?? new Dictionary<int, decimal>();
    var allocatedKpiCount = Model?.Count(k => assignments.ContainsKey(k.Id) || departmentAssignments.ContainsKey(k.Id)) ?? 0;
    var measurementUnits = new[] {
        new { Value = "%", Text = "% - Tỷ lệ phần trăm" },
        new { Value = "VNĐ", Text = "VNĐ - Tiền tệ" },
        new { Value = "Triệu VNĐ", Text = "Triệu VNĐ - Tiền tệ rút gọn" },
        new { Value = "Điểm", Text = "Điểm - Thang điểm" },
        new { Value = "Người", Text = "Người - Nhân sự" },
        new { Value = "Khách hàng", Text = "Khách hàng" },
        new { Value = "Cơ hội", Text = "Cơ hội bán hàng" },
        new { Value = "Hợp đồng", Text = "Hợp đồng" },
        new { Value = "Sản phẩm", Text = "Sản phẩm" },
        new { Value = "Lần", Text = "Lần" },
        new { Value = "Giờ", Text = "Giờ" },
        new { Value = "Ngày", Text = "Ngày" },
        new { Value = "Dự án", Text = "Dự án" },
        new { Value = "Công việc", Text = "Công việc" }
    };

    // Helper: Map StatusId to display info
    string GetStatusName(int? statusId, decimal? progress) {
        return statusId switch {
            0 or null => "Chờ duyệt",
            1 => progress.HasValue ? $"Đã duyệt ({progress:F0}%)" : "Đã duyệt",
            2 => "Từ chối",
            3 => $"Đang thực hiện ({progress ?? 0:F0}%)",
            4 => $"Hoàn thành ({progress ?? 100:F0}%)",
            5 => $"Gần đạt ({progress ?? 0:F0}%)",
            6 => $"Không đạt ({progress ?? 0:F0}%)",
            _ => "Không xác định"
        };
    }

    string GetStatusClass(int? statusId) {
        return statusId switch {
            0 or null => "bg-warning-subtle text-warning-emphasis",
            1 => "bg-info-subtle text-info-emphasis",
            2 => "bg-danger-subtle text-danger-emphasis",
            3 => "bg-primary-subtle text-primary-emphasis",
            4 => "bg-success-subtle text-success-emphasis",
            5 => "bg-success bg-opacity-10 text-success",
            6 => "bg-danger bg-opacity-10 text-danger",
            _ => "bg-secondary-subtle text-secondary-emphasis"
        };
    }

    string GetStatusIcon(int? statusId) {
        return statusId switch {
            0 or null => "bi-clock-fill",
            1 => "bi-check-circle-fill",
            2 => "bi-x-circle-fill",
            3 => "bi-arrow-repeat",
            4 => "bi-trophy-fill",
            5 => "bi-arrow-up-circle-fill",
            6 => "bi-exclamation-triangle-fill",
            _ => "bi-question-circle"
        };
    }

    string GetProgressColor(decimal progress) {
        if (progress >= 100) return "success";
        if (progress >= 70) return "primary";
        if (progress >= 40) return "warning";
        return "danger";
    }
}

<div class="container-fluid px-0">

    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Quản lý KPI</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Danh mục KPI</span>
        </div>
    </div>
        @if (!(User.IsInRole("Employee") || User.IsInRole("employee") ||
                User.IsInRole("Sales") || User.IsInRole("sales")))
        {
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-primary d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#aiKpiSuggestModal">
                    <i class="bi bi-stars me-1"></i> AI Gợi ý KPI
                </button>
                <button class="btn-primary-custom d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#createKpiModal">
                    <i class="bi bi-plus-lg me-1"></i> Thêm KPI mới
                </button>
            </div>
        }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success shadow-sm border-0 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
    </div>
}

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="stat-card p-3 border-start border-4 border-primary shadow-sm bg-white rounded-3">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <div class="text-muted fw-semibold" style="font-size: 0.85rem;">Tổng số KPI</div>
                <div class="icon-box bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;">
                    <i class="bi bi-target"></i>
                </div>
            </div>
            <div class="fw-bold text-dark fs-3">@(Model?.Count() ?? 0)</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card p-3 border-start border-4 border-success shadow-sm bg-white rounded-3">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <div class="text-muted fw-semibold" style="font-size: 0.85rem;">Đã phân bổ</div>
                <div class="icon-box bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;">
                    <i class="bi bi-people-fill"></i>
                </div>
            </div>
            <div class="fw-bold text-dark fs-3">@allocatedKpiCount</div>
        </div>
    </div>
</div>

<div class="content-card shadow-sm border-0">
    <div class="card-body-custom p-4">
        <form asp-action="Index" method="get" class="toolbar mb-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="toolbar-left d-flex gap-2 flex-wrap">
                <div class="toolbar-search position-relative">
                    <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control rounded-pill ps-5 border-light bg-light" placeholder="Tìm kiếm KPI..." style="width: 250px;">
                </div>
            </div>
            <div class="toolbar-right d-flex align-items-center gap-2">
                <div class="d-flex align-items-center gap-2 bg-white p-1 rounded shadow-sm border">
                    <span class="ps-2 text-muted small fw-bold text-uppercase" style="font-size: 0.7rem; white-space: nowrap;">Kỳ báo cáo:</span>
                    <select name="periodId" class="form-select form-select-sm border-0 fw-bold text-primary" style="width: 160px; outline: none; box-shadow: none;">
                        <option value="">Tất cả</option>
                        @foreach(var p in periodsDict)
                        {
                            if (ViewData["PeriodId"] is int selectedPeriodId && selectedPeriodId == p.Key)
                            {
                                <option value="@p.Key" selected>@p.Value</option>
                            }
                            else
                            {
                                <option value="@p.Key">@p.Value</option>
                            }
                        }
                    </select>
                </div>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary border-0 bg-white shadow-sm" title="Làm mới" style="padding: 0.35rem 0.6rem;">
                    <i class="bi bi-arrow-clockwise"></i>
                </a>
                <button type="submit" class="btn btn-sm btn-primary shadow-sm" title="Lọc kết quả" style="padding: 0.35rem 0.8rem;">
                    <i class="bi bi-funnel"></i> Lọc
                </button>
            </div>
        </form>

        <div class="table-responsive w-100">
            <table class="data-table w-100">
                <thead>
                    <tr>
                        <th class="fw-medium">Tên KPI</th>
                        <th class="fw-medium">Loại mục tiêu</th>
                        <th class="fw-medium">Chỉ tiêu (Target)</th>
                        <th class="fw-medium">Kỳ đánh giá</th>
                        <th class="fw-medium">Phân bổ cho</th>
                        <th class="border-0 text-muted small text-uppercase fw-bold" style="width: 100px;">Trạng thái</th>
                        <th class="border-0 text-muted small text-uppercase fw-bold" style="width: 100px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var kpi in Model)
                        {
                            var detail = kpiDetails.ContainsKey(kpi.Id) ? kpiDetails[kpi.Id] : null;
                            var assignedEmployees = assignments.ContainsKey(kpi.Id) ? assignments[kpi.Id] : new List<Tuple<int, decimal>>();
                            var assignedDepartmentIds = departmentAssignments.ContainsKey(kpi.Id) ? departmentAssignments[kpi.Id] : new List<int>();

                            // Use new dynamic status helpers
                            var kpiProgress = latestProgress.ContainsKey(kpi.Id) ? (decimal?)latestProgress[kpi.Id] : null;
                            string statusName = GetStatusName(kpi.StatusId, kpiProgress);
                            string statusClass = GetStatusClass(kpi.StatusId);
                            string statusIcon = GetStatusIcon(kpi.StatusId);

                            <tr class="bg-white">
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-primary bg-opacity-10 text-primary p-2 rounded">
                                            <i class="bi bi-graph-up-arrow fs-5"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark mb-1">@kpi.KPIName</div>
                                            @if (kpi.OKRId.HasValue && okrNamesDict.ContainsKey(kpi.OKRId.Value))
                                            {
                                                <div class="d-flex flex-wrap gap-1">
                                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-2 py-1">
                                                        <i class="bi bi-diagram-3 me-1"></i>@okrNamesDict[kpi.OKRId.Value]
                                                    </span>
                                                    @if (kpi.OKRKeyResultId.HasValue && okrKeyResultNamesDict.ContainsKey(kpi.OKRKeyResultId.Value))
                                                    {
                                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1">
                                                            <i class="bi bi-check2-circle me-1"></i>@okrKeyResultNamesDict[kpi.OKRKeyResultId.Value]
                                                        </span>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-muted border px-2 py-1">
                                                    <i class="bi bi-unlink me-1"></i>KPI độc lập
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="align-middle">
                                    <span class="badge bg-light text-secondary border px-2 py-1 fw-medium" style="font-size: 0.8rem;">
                                        @(kpi.KPITypeId.HasValue && kpiTypesDict.ContainsKey(kpi.KPITypeId.Value) ? kpiTypesDict[kpi.KPITypeId.Value] : "N/A")
                                    </span>
                                </td>
                                <td>
                                    @if(detail != null)
                                    {
                                        <div class="fw-bold text-success fs-6">@String.Format("{0:N0}", detail.TargetValue) @detail.MeasurementUnit</div>
                                        <div class="text-muted" style="font-size: 0.75rem;">Ngưỡng qua: @String.Format("{0:N0}", detail.PassThreshold)</div>
                                        <div class="text-muted" style="font-size: 0.75rem;">
                                            Deadline: @((detail.CheckInDeadlineTime ?? new TimeSpan(10, 0, 0)).ToString(@"hh\:mm")) / mỗi @(detail.CheckInFrequencyDays ?? 1) ngày
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Chưa thiết lập chỉ tiêu</span>
                                    }
                                </td>
                                <td>
                                    <div class="badge bg-info bg-opacity-10 text-info px-3 py-2 rounded-pill">
                                        <i class="bi bi-calendar-event me-1"></i> @(kpi.PeriodId.HasValue && periodsDict.ContainsKey(kpi.PeriodId.Value) ? periodsDict[kpi.PeriodId.Value] : "N/A")
                                    </div>
                                </td>
                                <td>
                                    @if (assignedEmployees.Any() || assignedDepartmentIds.Any())
                                    {
                                        <div class="d-flex flex-column gap-2">
                                            @if (assignedDepartmentIds.Any())
                                            {
                                                <div class="d-flex flex-wrap gap-1">
                                                    @foreach (var deptId in assignedDepartmentIds.Take(2))
                                                    {
                                                        var deptName = departmentsDict.ContainsKey(deptId) ? departmentsDict[deptId] : "Phòng ban";
                                                        <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-2 py-1">
                                                            <i class="bi bi-building me-1"></i>@deptName
                                                        </span>
                                                    }
                                                    @if (assignedDepartmentIds.Count > 2)
                                                    {
                                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border px-2 py-1">
                                                            +@(assignedDepartmentIds.Count - 2) phòng ban
                                                        </span>
                                                    }
                                                </div>
                                            }
                                            @if (assignedEmployees.Any())
                                            {
                                                <div class="d-flex align-items-center">
                                                    @foreach(var empObj in assignedEmployees.Take(3))
                                                    {
                                                        var empId = empObj.Item1;
                                                        var weight = empObj.Item2;
                                                        var name = employeesDict.ContainsKey(empId) ? employeesDict[empId] : "NV";
                                                        var initials = string.Join("", name.Split(' ').Where(n => !string.IsNullOrWhiteSpace(n)).Select(n => n[0])).ToUpper();
                                                        if (initials.Length > 2) initials = initials.Substring(0, 2);
                                                        if (initials.Length == 0) initials = "NV";

                                                        <div class="user-avatar bg-primary text-white border border-2 border-white position-relative rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 32px; height: 32px; font-size: 0.75rem; margin-right: -10px; z-index: 3;" title="@name">
                                                            @initials
                                                        </div>
                                                    }
                                                    @if (assignedEmployees.Count > 3)
                                                    {
                                                        <div class="user-avatar bg-secondary text-white border border-2 border-white position-relative rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 32px; height: 32px; font-size: 0.75rem; margin-right: -10px; z-index: 1;">
                                                            +@(assignedEmployees.Count - 3)
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning px-3 py-2 rounded-pill border border-warning border-opacity-25">
                                            <i class="bi bi-exclamation-circle me-1"></i> Chưa phân bổ
                                        </span>
                                    }
                                </td>
                                <td class="align-middle">
                                    <div class="d-flex flex-column gap-1">
                                        <span class="badge rounded-pill @statusClass py-2 px-3 fw-medium" style="font-size: 0.72rem;">
                                            <i class="bi @statusIcon me-1"></i>
                                            @statusName
                                        </span>
                                        @if (kpiProgress.HasValue && kpi.StatusId >= 3)
                                        {
                                            <div class="progress" style="height: 5px; border-radius: 3px; width: 100%;">
                                                <div class="progress-bar bg-@GetProgressColor(kpiProgress.Value)"
                                                     role="progressbar"
                                                     style="width: @(Math.Min((double)kpiProgress.Value, 100))%">
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </td>
                                <td class="align-middle text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-light rounded-circle shadow-sm" style="width: 32px; height: 32px;" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 animate__animated animate__fadeIn animate__faster" style="z-index: 1060; min-width: 180px;">
                                                 <li><a class="dropdown-item py-2" asp-action="Details" asp-route-id="@kpi.Id"><i class="bi bi-info-circle text-primary me-2"></i> Chi tiết</a></li>

                                                 @if (kpi.StatusId == 1 || kpi.StatusId >= 3)
                                                 {
                                                     <li><a class="dropdown-item py-2 text-success fw-bold" asp-controller="KPICheckIns" asp-action="Create" asp-route-kpiId="@kpi.Id"><i class="bi bi-calendar-check me-2"></i> Thực hiện Check-in</a></li>
                                                 }

                                                 @if (!(User.IsInRole("Employee") || User.IsInRole("employee") ||
                                                       User.IsInRole("Sales") || User.IsInRole("sales")))
                                                 {
                                                     <li><a class="dropdown-item py-2" asp-action="AllocatePersonnel" asp-route-id="@kpi.Id" data-legacy-onclick="openAssignPersonnelModal(@kpi.Id, '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(kpi.KPIName ?? ""))', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(assignedEmployees).Replace("\"", "&quot;")))"><i class="bi bi-people text-info-emphasis me-2"></i> Phân bổ phòng ban/nhân sự</a></li>
                                                 }

                                                 @if ((User.IsInRole("HR") || User.IsInRole("Admin") || User.IsInRole("Administrator") || User.IsInRole("Manager")) && (kpi.StatusId == 0 || kpi.StatusId == null))
                                                 {
                                                     <li><hr class="dropdown-divider"></li>
                                                     <li>
                                                         <form asp-action="Approve" method="post" class="d-inline">
                                                             <input type="hidden" name="id" value="@kpi.Id" />
                                                             <button type="submit" class="dropdown-item py-2 text-success"><i class="bi bi-check-circle me-2"></i> Duyệt KPI</button>
                                                         </form>
                                                     </li>
                                                     <li>
                                                         <form asp-action="Reject" method="post" class="d-inline">
                                                             <input type="hidden" name="id" value="@kpi.Id" />
                                                             <button type="submit" class="dropdown-item py-2 text-danger"><i class="bi bi-x-circle me-2"></i> Từ chối</button>
                                                         </form>
                                                     </li>
                                                 }

                                                 @if (!(User.IsInRole("Employee") || User.IsInRole("employee") ||
                                                      User.IsInRole("Sales") || User.IsInRole("sales")))
                                                 {
                                                     <li><hr class="dropdown-divider"></li>
                                                     <li>
                                                         <form asp-action="Delete" asp-route-id="@kpi.Id" method="post" class="m-0" onsubmit="return confirm('Xác nhận vô hiệu hóa KPI này?');">
                                                             <button type="submit" class="dropdown-item py-2 text-danger"><i class="bi bi-trash me-2"></i> Xóa KPI</button>
                                                         </form>
                                                     </li>
                                                 }
                                            </ul>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <div class="mb-3"><i class="bi bi-folder-x fs-1 opacity-50"></i></div>
                                <h5>Chưa có dữ liệu KPI</h5>
                                <p>Bắt đầu bằng cách thêm một KPI mới cho hệ thống.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Create KPI -->
<div class="modal fade" id="createKpiModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0 bg-light rounded-top p-4">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-plus-circle text-primary me-2"></i>Thêm KPI Mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-controller="KPIs" asp-action="Create" method="post">
                    <h6 class="fw-bold text-primary mb-3">Thông tin chung</h6>
                    <div class="row g-3 mb-4" data-okr-link-scope>
                        <div class="col-md-12">
                            <label class="form-label fw-semibold">Tên KPI <span class="text-danger">*</span></label>
                            <input type="text" name="kpi.KPIName" id="createKpiName" class="form-control" placeholder="VD: Doanh thu bán hàng tháng" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Phân loại KPI <span class="text-danger">*</span></label>
                            <select name="kpi.KPITypeId" class="form-select" required>
                                <option value="">-- Chọn loại KPI --</option>
                                @foreach (var t in kpiTypesList)
                                {
                                    <option value="@t.Id">@t.TypeName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Kỳ đánh giá <span class="text-danger">*</span></label>
                            <select name="kpi.PeriodId" id="createPeriodId" class="form-select" required>
                                @foreach(var kvp in periodsDict)
                                {
                                    <option value="@kvp.Key">@kvp.Value</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Liên kết OKR <span class="text-muted">(tùy chọn)</span></label>
                            <select name="kpi.OKRId" id="createOkrId" class="form-select js-okr-select">
                                <option value="">-- Không liên kết OKR --</option>
                                @foreach (var okr in okrsList)
                                {
                                    <option value="@okr.Id">@okr.ObjectiveName</option>
                                }
                            </select>
                            <div class="form-text">KPI có thể độc lập nếu không gắn với OKR cụ thể.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Key Result <span class="text-muted">(tùy chọn)</span></label>
                            <select name="kpi.OKRKeyResultId" id="createKrId" class="form-select js-kr-select">
                                <option value="">-- Không liên kết Key Result --</option>
                                @foreach (var kr in okrKeyResultsList)
                                {
                                    var parentOkrName = kr.OKRId.HasValue && okrNamesDict.ContainsKey(kr.OKRId.Value)
                                        ? okrNamesDict[kr.OKRId.Value]
                                        : "OKR";
                                    <option value="@kr.Id" data-okr-id="@kr.OKRId">@parentOkrName - @kr.KeyResultName</option>
                                }
                            </select>
                            <div class="form-text">Danh sách Key Result sẽ đổi theo OKR đã chọn.</div>
                        </div>
                    </div>

                    <h6 class="fw-bold text-primary mb-3"><i class="bi bi-sliders me-2"></i>Chi tiết Chỉ tiêu</h6>
                    <div class="row g-3 mb-4 bg-light p-3 rounded-3" data-measurement-scope>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Chỉ tiêu (Target) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="number" step="0.01" name="detail.TargetValue" id="createTarget" class="form-control measurement-value-input" data-measurement-role="target" placeholder="Nhập chỉ tiêu" required>
                                <span class="input-group-text measurement-unit-suffix">đơn vị</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Đơn vị đo lường <span class="text-danger">*</span></label>
                            <select name="detail.MeasurementUnit" id="createUnit" class="form-select measurement-unit-select" data-placeholder="-- Chọn đơn vị đo --" required>
                                <option value="">-- Chọn đơn vị đo --</option>
                                @foreach (var unit in measurementUnits)
                                {
                                    <option value="@unit.Value">@unit.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Ngưỡng đạt (Pass Threshold)</label>
                            <div class="input-group">
                                <input type="number" step="0.01" name="detail.PassThreshold" id="createPass" class="form-control measurement-value-input" data-measurement-role="pass" placeholder="Mức tối thiểu để Đạt">
                                <span class="input-group-text measurement-unit-suffix">đơn vị</span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold text-danger">Ngưỡng trượt (Fail Threshold)</label>
                            <div class="input-group">
                                <input type="number" step="0.01" name="detail.FailThreshold" id="createFail" class="form-control measurement-value-input" data-measurement-role="fail" placeholder="Mức xác định là Không đạt">
                                <span class="input-group-text measurement-unit-suffix">đơn vị</span>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch p-3 bg-white rounded-3 border border-warning border-opacity-25 shadow-sm">
                                <input class="form-check-input ms-0 me-3" type="checkbox" name="detail.IsInverse" value="true" id="isInverseCheck">
                                <label class="form-check-label fw-bold text-dark cursor-pointer" for="isInverseCheck">
                                    <i class="bi bi-arrow-down-circle text-warning me-1"></i> Chỉ tiêu thu nhỏ (Càng thấp càng tốt)
                                </label>
                                <div class="text-muted small ms-5 ps-1 mt-1">Sử dụng cho các chỉ số như tỷ lệ lỗi, chi phí, thời gian chờ...</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Tần suất check-in</label>
                            <div class="input-group">
                                <input type="number" min="1" step="1" name="detail.CheckInFrequencyDays" class="form-control" value="1">
                                <span class="input-group-text">ngày/lần</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Giờ deadline</label>
                            <input type="time" name="detail.CheckInDeadlineTime" class="form-control" value="10:00">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Nhắc trước deadline</label>
                            <div class="input-group">
                                <input type="number" min="0" step="1" name="detail.ReminderBeforeHours" class="form-control" value="24">
                                <span class="input-group-text">giờ</span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn-outline-custom rounded-pill px-4" data-bs-dismiss="modal">Hủy thao tác</button>
                        <button type="submit" class="btn-primary-custom rounded-pill px-4"><i class="bi bi-save me-2"></i>Lưu KPI mới</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


<!-- Modal AI Suggest KPI -->
<div class="modal fade" id="aiKpiSuggestModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0 bg-light rounded-top p-4">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-stars text-primary me-2"></i>AI Gợi ý KPI</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Nhân viên</label>
                        <select id="aiSuggestEmployeeId" class="form-select">
                            <option value="">-- Không chọn nhân viên cụ thể --</option>
                            @foreach (var e in allEmployees)
                            {
                                <option value="@e.Id">@e.FullName (@e.EmployeeCode)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Phòng ban</label>
                        <select id="aiSuggestDepartmentId" class="form-select">
                            <option value="">-- Không chọn phòng ban cụ thể --</option>
                            @foreach (var d in allDepartments)
                            {
                                <option value="@d.Id">@d.DepartmentName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Kỳ đánh giá</label>
                        <select id="aiSuggestPeriodId" class="form-select">
                            <option value="">-- Kỳ được phân công gần nhất --</option>
                            @foreach (var p in periodsDict)
                            {
                                <option value="@p.Key">@p.Value</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">OKR</label>
                        <select id="aiSuggestOkrId" class="form-select">
                            <option value="">-- Không bắt buộc --</option>
                            @foreach (var okr in okrsList)
                            {
                                <option value="@okr.Id">@okr.ObjectiveName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Key Result</label>
                        <select id="aiSuggestKrId" class="form-select">
                            <option value="">-- Không bắt buộc --</option>
                            @foreach (var kr in okrKeyResultsList)
                            {
                                var parentOkrName = kr.OKRId.HasValue && okrNamesDict.ContainsKey(kr.OKRId.Value)
                                    ? okrNamesDict[kr.OKRId.Value]
                                    : "OKR";
                                <option value="@kr.Id" data-okr-id="@kr.OKRId">@parentOkrName - @kr.KeyResultName</option>
                            }
                        </select>
                    </div>
                </div>
                <div id="aiSuggestOptionsStatus" class="text-muted small mb-3"></div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <p class="text-muted small mb-0">AI sẽ tạo bản nháp KPI. Bạn chọn “Áp dụng” rồi kiểm tra lại trước khi lưu.</p>
                    <button type="button" class="btn btn-primary" id="aiRunKpiSuggestBtn">
                        <i class="bi bi-magic me-1"></i> Tạo gợi ý
                    </button>
                </div>
                <div id="aiKpiSuggestResults" class="d-grid gap-2"></div>
            </div>
        </div>
    </div>
</div>


<style>
    .stat-card:hover { transform: translateY(-3px); transition: all 0.3s ease; }
    .employee-item:hover { background-color: rgba(13, 202, 240, 0.05); }
    .cursor-pointer { cursor: pointer; }

    .table-responsive {
        overflow: visible !important;
    }

    @@media (max-width: 991.98px) {
        .table-responsive {
            overflow-x: auto !important;
            padding-bottom: 100px;
        }
    }

    .dropdown-menu {
        z-index: 1060 !important;
    }
</style>

<script>
    // Empty placeholder for script segment if needed

    // Search functionality for employee list
    document.getElementById('employeeSearch')?.addEventListener('input', function(e) {
        const searchText = e.target.value.toLowerCase();
        const items = document.querySelectorAll('.employee-item');

        items.forEach(item => {
            const data = item.getAttribute('data-search');
            if (data.includes(searchText)) {
                item.style.display = 'block';
            } else {
                item.style.display = 'none';
            }
        });
    });

    function setupOkrLinkScope(scope) {
        const okrSelect = scope.querySelector('.js-okr-select');
        const keyResultSelect = scope.querySelector('.js-kr-select');
        if (!okrSelect || !keyResultSelect) return;

        const allKeyResults = Array.from(keyResultSelect.querySelectorAll('option[data-okr-id]')).map(option => ({
            value: option.value,
            text: option.textContent,
            okrId: option.dataset.okrId
        }));

        function filterKeyResults() {
            const selectedOkrId = okrSelect.value;
            const selectedKeyResultId = keyResultSelect.value;
            const matchingKeyResults = allKeyResults.filter(option => option.okrId === selectedOkrId);

            keyResultSelect.innerHTML = '';
            keyResultSelect.disabled = !selectedOkrId;

            const placeholder = document.createElement('option');
            placeholder.value = '';
            placeholder.textContent = !selectedOkrId
                ? '-- Chọn OKR trước --'
                : matchingKeyResults.length
                    ? '-- Không liên kết Key Result --'
                    : '-- OKR này chưa có Key Result --';
            keyResultSelect.appendChild(placeholder);

            matchingKeyResults.forEach(item => {
                const option = document.createElement('option');
                option.value = item.value;
                option.textContent = item.text;
                option.dataset.okrId = item.okrId;
                keyResultSelect.appendChild(option);
            });

            if (matchingKeyResults.some(item => item.value === selectedKeyResultId)) {
                keyResultSelect.value = selectedKeyResultId;
            }
        }

        okrSelect.addEventListener('change', filterKeyResults);
        keyResultSelect.addEventListener('change', function () {
            filterKeyResults();
        });

        filterKeyResults();
    }

    document.querySelectorAll('[data-okr-link-scope]').forEach(setupOkrLinkScope);

    const aiSuggestState = {
        keyResults: [],
        requestId: 0
    };

    function getAiSuggestControls() {
        return {
            employee: document.getElementById('aiSuggestEmployeeId'),
            department: document.getElementById('aiSuggestDepartmentId'),
            period: document.getElementById('aiSuggestPeriodId'),
            okr: document.getElementById('aiSuggestOkrId'),
            kr: document.getElementById('aiSuggestKrId'),
            status: document.getElementById('aiSuggestOptionsStatus')
        };
    }

    function setSelectOptions(select, placeholderText, items, selectedValue, disableWhenEmpty = false) {
        if (!select) return;

        const selected = selectedValue ? String(selectedValue) : '';
        select.innerHTML = '';

        const placeholder = document.createElement('option');
        placeholder.value = '';
        placeholder.textContent = placeholderText;
        select.appendChild(placeholder);

        (items || []).forEach(item => {
            const option = document.createElement('option');
            option.value = item.id;
            option.textContent = item.text;
            if (item.parentId !== null && item.parentId !== undefined) {
                option.dataset.okrId = item.parentId;
            }
            if (item.departmentId !== null && item.departmentId !== undefined) {
                option.dataset.departmentId = item.departmentId;
            }
            select.appendChild(option);
        });

        if ((items || []).some(item => String(item.id) === selected)) {
            select.value = selected;
        }

        select.disabled = disableWhenEmpty && !(items || []).length;
    }

    function renderAiKeyResultOptions(selectedKeyResultId) {
        const controls = getAiSuggestControls();
        if (!controls.kr) return;

        const okrId = controls.okr?.value || '';
        const matchingKeyResults = okrId
            ? aiSuggestState.keyResults.filter(item => String(item.parentId) === okrId)
            : [];

        const placeholder = !okrId
            ? '-- Chọn OKR trước --'
            : matchingKeyResults.length
                ? '-- Không bắt buộc --'
                : '-- OKR này chưa có Key Result --';

        setSelectOptions(controls.kr, placeholder, matchingKeyResults, selectedKeyResultId, true);
        controls.kr.disabled = !okrId || !matchingKeyResults.length;
    }

    function setAiSuggestStatus(message) {
        const status = getAiSuggestControls().status;
        if (status) {
            status.textContent = message || '';
        }
    }

    async function refreshAiSuggestOptions(source) {
        const controls = getAiSuggestControls();
        if (!controls.employee || !controls.department || !controls.period || !controls.okr || !controls.kr) return;

        if (source === 'department') {
            controls.employee.value = '';
        }

        const previous = {
            employeeId: controls.employee.value,
            departmentId: controls.department.value,
            periodId: controls.period.value,
            okrId: controls.okr.value,
            krId: controls.kr.value
        };

        const params = new URLSearchParams();
        if (previous.employeeId) params.set('employeeId', previous.employeeId);
        if (previous.departmentId) params.set('departmentId', previous.departmentId);

        const currentRequestId = ++aiSuggestState.requestId;
        setAiSuggestStatus('Đang lọc dữ liệu theo lựa chọn hiện tại...');

        try {
            const queryString = params.toString();
            const response = await fetch(queryString ? `/AI/SuggestKpiOptions?${queryString}` : '/AI/SuggestKpiOptions');
            const data = await response.json();

            if (currentRequestId !== aiSuggestState.requestId) return;

            if (!response.ok || data.success === false) {
                setAiSuggestStatus('');
                Swal.fire('Không thể tải dữ liệu', data.warnings?.[0] || 'Không thể lọc danh sách cho AI gợi ý KPI.', 'warning');
                return;
            }

            const selectedDepartmentId = data.selectedDepartmentId ? String(data.selectedDepartmentId) : '';
            const selectedEmployeeId = (data.employees || []).some(item => String(item.id) === previous.employeeId)
                ? previous.employeeId
                : '';
            const selectedPeriodId = (data.periods || []).some(item => String(item.id) === previous.periodId)
                ? previous.periodId
                : '';
            const selectedOkrId = (data.okrs || []).some(item => String(item.id) === previous.okrId)
                ? previous.okrId
                : '';

            setSelectOptions(controls.department, '-- Không chọn phòng ban cụ thể --', data.departments || [], selectedDepartmentId);
            setSelectOptions(controls.employee, '-- Không chọn nhân viên cụ thể --', data.employees || [], selectedEmployeeId);
            setSelectOptions(
                controls.period,
                (data.periods || []).length ? '-- Kỳ được phân công gần nhất --' : '-- Chưa có kỳ được phân công --',
                data.periods || [],
                selectedPeriodId,
                true);
            setSelectOptions(
                controls.okr,
                (data.okrs || []).length ? '-- Không bắt buộc --' : '-- Chưa có OKR được phân công --',
                data.okrs || [],
                selectedOkrId,
                true);

            aiSuggestState.keyResults = data.keyResults || [];
            renderAiKeyResultOptions(previous.krId);

            if (data.warnings?.length) {
                setAiSuggestStatus(data.warnings[0]);
            } else if (previous.employeeId || selectedDepartmentId) {
                setAiSuggestStatus('Dữ liệu đang được lọc theo phân công của nhân viên hoặc phòng ban đã chọn.');
            } else {
                setAiSuggestStatus('');
            }
        } catch {
            if (currentRequestId !== aiSuggestState.requestId) return;
            setAiSuggestStatus('');
            Swal.fire('Lỗi', 'Không thể tải danh sách cho AI gợi ý KPI.', 'error');
        }
    }

    function setupAiSuggestControls() {
        const controls = getAiSuggestControls();
        if (!controls.employee || !controls.department || !controls.okr) return;

        controls.employee.addEventListener('change', function () {
            refreshAiSuggestOptions('employee');
        });

        controls.department.addEventListener('change', function () {
            refreshAiSuggestOptions('department');
        });

        controls.okr.addEventListener('change', function () {
            renderAiKeyResultOptions();
        });

        document.getElementById('aiKpiSuggestModal')?.addEventListener('shown.bs.modal', function () {
            refreshAiSuggestOptions('modal');
        });

        renderAiKeyResultOptions();
    }

    setupAiSuggestControls();

    document.getElementById('aiRunKpiSuggestBtn')?.addEventListener('click', async function () {
        const btn = this;
        const results = document.getElementById('aiKpiSuggestResults');
        const originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> AI đang tạo...';
        results.innerHTML = '<div class="text-muted small">Đang phân tích dữ liệu KPI/OKR...</div>';

        const payload = {
            employeeId: numberOrNull(document.getElementById('aiSuggestEmployeeId')?.value),
            departmentId: numberOrNull(document.getElementById('aiSuggestDepartmentId')?.value),
            okrId: numberOrNull(document.getElementById('aiSuggestOkrId')?.value),
            okrKeyResultId: numberOrNull(document.getElementById('aiSuggestKrId')?.value),
            periodId: numberOrNull(document.getElementById('aiSuggestPeriodId')?.value)
        };

        try {
            const response = await fetch('/AI/SuggestKPI', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    ...window.antiForgeryHeaders()
                },
                body: JSON.stringify(payload)
            });
            const data = await response.json();
            if (!response.ok || data.success === false) {
                results.innerHTML = '';
                Swal.fire('AI chưa sẵn sàng', data.warnings?.[0] || 'Không thể tạo gợi ý KPI.', 'warning');
                return;
            }

            renderKpiSuggestions(data.suggestions || []);
        } catch {
            results.innerHTML = '';
            Swal.fire('Lỗi', 'Không thể kết nối AI. Vui lòng thử lại sau.', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        }
    });

    function renderKpiSuggestions(suggestions) {
        const results = document.getElementById('aiKpiSuggestResults');
        if (!suggestions.length) {
            results.innerHTML = '<div class="text-muted small">AI chưa trả về gợi ý phù hợp.</div>';
            return;
        }

        results.innerHTML = suggestions.map((item, index) => `
            <div class="ai-suggestion-item">
                <div class="d-flex justify-content-between gap-2">
                    <div>
                        <div class="fw-bold text-dark">${escapeHtml(item.name || 'KPI đề xuất')}</div>
                        <div class="small text-muted mt-1">${escapeHtml(item.rationale || '')}</div>
                        <div class="small mt-2">
                            <span class="badge bg-primary bg-opacity-10 text-primary">Target: ${escapeHtml(item.targetValue ?? 'N/A')} ${escapeHtml(item.unit || '')}</span>
                            <span class="badge bg-success bg-opacity-10 text-success">Đạt: ${escapeHtml(item.passThreshold ?? 'N/A')}</span>
                            <span class="badge bg-danger bg-opacity-10 text-danger">Trượt: ${escapeHtml(item.failThreshold ?? 'N/A')}</span>
                        </div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-success align-self-start" data-apply-kpi="${index}">Áp dụng</button>
                </div>
            </div>
        `).join('');

        results.querySelectorAll('[data-apply-kpi]').forEach(button => {
            button.addEventListener('click', function () {
                applyKpiSuggestion(suggestions[parseInt(button.dataset.applyKpi, 10)]);
            });
        });
    }

    function applyKpiSuggestion(item) {
        document.getElementById('createKpiName').value = item.name || '';
        document.getElementById('createTarget').value = item.targetValue ?? '';
        document.getElementById('createPass').value = item.passThreshold ?? '';
        document.getElementById('createFail').value = item.failThreshold ?? '';

        if (window.setMeasurementUnitSelectValue) {
            window.setMeasurementUnitSelectValue(document.getElementById('createUnit'), item.unit || '');
        } else {
            document.getElementById('createUnit').value = item.unit || '';
        }

        const periodId = document.getElementById('aiSuggestPeriodId')?.value;
        const okrId = document.getElementById('aiSuggestOkrId')?.value;
        const krId = document.getElementById('aiSuggestKrId')?.value;
        if (periodId) document.getElementById('createPeriodId').value = periodId;
        if (okrId) {
            document.getElementById('createOkrId').value = okrId;
            document.getElementById('createOkrId').dispatchEvent(new Event('change', { bubbles: true }));
        }
        if (krId) document.getElementById('createKrId').value = krId;

        bootstrap.Modal.getOrCreateInstance(document.getElementById('aiKpiSuggestModal')).hide();
        bootstrap.Modal.getOrCreateInstance(document.getElementById('createKpiModal')).show();
    }

    function numberOrNull(value) {
        const n = parseInt(value || '', 10);
        return Number.isFinite(n) ? n : null;
    }
</script>

</div>
