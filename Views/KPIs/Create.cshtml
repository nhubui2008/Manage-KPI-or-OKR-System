@model Manage_KPI_or_OKR_System.Models.KPI

@{
    ViewData["Title"] = "Thêm KPI Mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var periodsDict = ViewBag.Periods as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-dark fw-bold">
                <i class="bi bi-plus-circle me-2"></i>Thêm KPI Mới
            </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-dark text-decoration-none opacity-75">Quản lý KPI</a></li>
                    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Thêm mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="content-card rounded-3">
        <div class="card-body-custom p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <h5 class="fw-bold text-dark mb-4 border-bottom pb-2">Thông tin chung</h5>
                <div class="row g-4 mb-5">
                    <div class="col-md-12">
                        <label class="form-label fw-bold text-dark">Tên KPI <span class="text-danger">*</span></label>
                        <input type="text" name="kpi.KPIName" class="form-control" placeholder="VD: Doanh thu bán hàng tháng" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-dark">Phân loại KPI <span class="text-danger">*</span></label>
                        <select name="kpi.KPITypeId" class="form-select" required>
                            <option value="1">Kết quả</option>
                            <option value="2">Hành vi</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-dark">Kỳ đánh giá <span class="text-danger">*</span></label>
                        <select name="kpi.PeriodId" class="form-select" required>
                            <option value="">-- Chọn kỳ đánh giá --</option>
                            @foreach (var kvp in periodsDict)
                            {
                                <option value="@kvp.Key">@kvp.Value</option>
                            }
                        </select>
                    </div>
                </div>
                
                <h5 class="fw-bold text-dark mb-4 border-bottom pb-2"><i class="bi bi-sliders me-2"></i>Chi tiết Chỉ tiêu</h5>
                <div class="row g-4 mb-4 bg-light p-4 rounded-3 border">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-dark">Chỉ tiêu (Target) <span class="text-danger">*</span></label>
                        <input type="number" step="0.01" name="detail.TargetValue" class="form-control" placeholder="1000000" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-dark">Đơn vị đo lường</label>
                        <input type="text" name="detail.MeasurementUnit" class="form-control" placeholder="VD: VNĐ, Sản phẩm, Khách hàng, Lần...">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-dark">Ngưỡng đạt (Pass Threshold)</label>
                        <input type="number" step="0.01" name="detail.PassThreshold" class="form-control" placeholder="Mức tối thiểu để Đạt">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-dark text-opacity-75">Ngưỡng trượt (Fail Threshold)</label>
                        <input type="number" step="0.01" name="detail.FailThreshold" class="form-control" placeholder="Mức xác định là Không đạt">
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-5 border-top pt-4">
                    <a asp-action="Index" class="btn-outline-custom px-4">
                        <i class="bi bi-x-circle me-1"></i> Hủy bỏ
                    </a>
                    <button type="submit" class="btn-primary-custom px-4">
                        <i class="bi bi-save me-2"></i> Lưu KPI mới
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
