@model Manage_KPI_or_OKR_System.Models.KPI
@using Manage_KPI_or_OKR_System.Helpers
@{
    ViewData["Title"] = "Chi tiết KPI";
    var detail = ViewBag.KPIDetail as Manage_KPI_or_OKR_System.Models.KPIDetail;
    var assignments = ViewBag.Assignments as Dictionary<int, string> ?? new Dictionary<int, string>();
    var recentCheckIns = ViewBag.RecentCheckIns as IEnumerable<dynamic>;
    var statuses = ViewBag.CheckInStatuses as Dictionary<int, string> ?? new Dictionary<int, string>();
    var measurementUnits = new[] {
        new { Value = "%", Text = "% - Tỷ lệ phần trăm" },
        new { Value = "VNĐ", Text = "VNĐ - Tiền tệ" },
        new { Value = "Triệu VNĐ", Text = "Triệu VNĐ - Tiền tệ rút gọn" },
        new { Value = "Điểm", Text = "Điểm - Thang điểm" },
        new { Value = "Người", Text = "Người - Nhân sự" },
        new { Value = "Khách hàng", Text = "Khách hàng" },
        new { Value = "Cơ hội", Text = "Cơ hội bán hàng" },
        new { Value = "Hợp đồng", Text = "Hợp đồng" },
        new { Value = "Sản phẩm", Text = "Sản phẩm" },
        new { Value = "Lần", Text = "Lần" },
        new { Value = "Giờ", Text = "Giờ" },
        new { Value = "Ngày", Text = "Ngày" },
        new { Value = "Dự án", Text = "Dự án" },
        new { Value = "Công việc", Text = "Công việc" }
    };
    var currentMeasurementUnit = detail?.MeasurementUnit ?? "";
    var hasCustomMeasurementUnit = !string.IsNullOrWhiteSpace(currentMeasurementUnit)
        && !measurementUnits.Any(u => string.Equals(u.Value, currentMeasurementUnit, StringComparison.OrdinalIgnoreCase));
}

<div class="container-fluid px-0">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        </div>
    }
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 font-weight-bold mb-1">Chi tiết KPI: @Model.KPIName</h1>
            <div class="page-breadcrumb">
                <a href="/">Trang chủ</a>
                <i class="bi bi-chevron-right separator"></i>
                <a asp-action="Index">Danh sách KPI</a>
                <i class="bi bi-chevron-right separator"></i>
                <span>Chi tiết</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
            @if (!(User.IsInRole("Employee") || User.IsInRole("employee") || User.IsInRole("Sales") || User.IsInRole("sales")))
            {
                <button class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#editKpiModal">
                    <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa
                </button>
            }
        </div>
    </div>

    <div class="row g-4">
        <!-- Thông tin cơ bản -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-info-circle text-primary me-2"></i>Thông tin chỉ tiêu</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="text-muted small text-uppercase fw-bold mb-1">Tên chỉ tiêu</label>
                            <p class="fs-5 fw-medium text-dark">@Model.KPIName</p>
                        </div>
                        <div class="col-md-3">
                            <label class="text-muted small text-uppercase fw-bold mb-1">Chu kỳ</label>
                            <p class="fs-5 fw-medium text-dark">@ViewBag.PeriodName</p>
                        </div>
                        <div class="col-md-3">
                            <label class="text-muted small text-uppercase fw-bold mb-1">Loại KPI</label>
                            <p class="fs-5 fw-medium text-dark">@ViewBag.TypeName</p>
                        </div>

                        <div class="col-12"><hr class="text-muted opacity-25"></div>

                        <div class="col-md-4">
                            <div class="p-3 bg-primary rounded-4 text-center shadow-sm">
                                <label class="text-white text-opacity-75 small text-uppercase fw-bold d-block mb-1">Chỉ tiêu (Target)</label>
                                <span class="fs-4 fw-bold text-white">@String.Format("{0:N0}", detail?.TargetValue ?? 0) @currentMeasurementUnit</span>
                                <div class="text-white text-opacity-50 small">@ViewBag.PropertyName</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-success rounded-4 text-center shadow-sm">
                                <label class="text-white text-opacity-75 small text-uppercase fw-bold d-block mb-1">Ngưỡng đạt</label>
                                <span class="fs-4 fw-bold text-white">@String.Format("{0:N0}", detail?.PassThreshold ?? 0) @currentMeasurementUnit</span>
                                <div class="text-white text-opacity-50 small">Mục tiêu tối thiểu</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-danger rounded-4 text-center shadow-sm">
                                <label class="text-white text-opacity-75 small text-uppercase fw-bold d-block mb-1">Ngưỡng không đạt</label>
                                <span class="fs-4 fw-bold text-white">@String.Format("{0:N0}", detail?.FailThreshold ?? 0) @currentMeasurementUnit</span>
                                <div class="text-white text-opacity-50 small">Mức cảnh báo</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Lịch sử Check-in -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history text-warning me-2"></i>Lịch sử cập nhật tiến độ</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 border-0">Ngày</th>
                                    <th class="border-0">Người cập nhật</th>
                                    <th class="border-0">Giá trị</th>
                                    <th class="border-0">Tiến độ</th>
                                    <th class="border-0">Đánh giá</th>
                                    <th class="border-0">Lý do</th>
                                    <th class="border-0 pe-4 text-end">Ghi chú</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (recentCheckIns != null && recentCheckIns.Any())
                                {
                                    foreach (var ci in recentCheckIns)
                                    {
                                        decimal achievedValue = ci.AchievedValue != null ? (decimal)ci.AchievedValue : 0m;
                                        decimal progress = detail != null ? ProgressHelper.CalculateProgress(achievedValue, detail.TargetValue ?? 0, detail.IsInverse) : 0m;
                                        decimal progressWidth = Math.Min(100, progress);
                                        <tr>
                                            <td class="ps-4 text-muted small">@ci.CheckInDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="fw-bold text-dark">@ci.employeeName</td>
                                            <td class="fw-bold text-dark">@String.Format("{0:N0}", ci.AchievedValue ?? 0) @currentMeasurementUnit</td>
                                            <td>
                                                <div class="d-flex align-items-center gap-2" style="min-width: 120px;">
                                                    <div class="progress flex-grow-1" style="height: 6px;">
                                                        <div class="progress-bar bg-primary" style="width: @progressWidth%"></div>
                                                    </div>
                                                    <span class="small fw-bold">@Math.Round(progress, 1)%</span>
                                                </div>
                                            </td>
                                            <td>
                                                @if (ci.StatusId != null && statuses.ContainsKey(ci.StatusId))
                                                {
                                                    string statusName = statuses[ci.StatusId];
                                                    string badgeClass = statusName == "Đạt" ? "bg-success" : 
                                                                       statusName == "Gần đạt" ? "bg-warning" : "bg-danger";
                                                    <span class="badge @badgeClass text-white rounded-pill px-3">@statusName</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(ci.failReason))
                                                {
                                                    <span class="badge bg-danger text-white border-0">
                                                        <i class="bi bi-exclamation-triangle-fill me-1"></i> @ci.failReason
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">--</span>
                                                }
                                            </td>
                                            <td class="pe-4 text-end text-muted small">@ci.Note</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-4 text-muted italic">Chưa có dữ liệu cập nhật nào.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Nhân viên phụ trách -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-people text-info me-2"></i>Nhân sự phụ trách</h5>
                </div>
                <div class="card-body p-4">
                    @if (assignments.Any())
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var emp in assignments)
                            {
                                <div class="d-flex align-items-center gap-3 p-2 bg-light rounded-3 transition-hover">
                                    <div class="avatar-sm bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                    <div>
                                        <p class="mb-0 fw-bold text-dark">@emp.Value</p>
                                        <span class="text-muted smaller">ID: @emp.Key</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0 italic small text-center py-2">Chưa phân bổ nhân sự.</p>
                    }
                </div>
            </div>

            <!-- Ghi chú / Mô tả -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-card-text text-secondary me-2"></i>Mô tả & Ghi chú</h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-dark mb-0">@(detail?.MeasurementUnit != null ? $"Theo dõi chỉ tiêu tính bằng {detail.MeasurementUnit}." : "Không có mô tả chi tiết cho chỉ tiêu này.")</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-success { 
        background-color: #ecfdf5; 
        border: 1px solid #10b98120;
    }
    .bg-soft-danger { 
        background-color: #fef2f2; 
        border: 1px solid #ef444420;
    }
    .bg-soft-warning { 
        background-color: #fffbeb; 
        border: 1px solid #f59e0b20;
    }
    .bg-soft-primary { 
        background-color: #eff6ff; 
        border: 1px solid #3b82f620;
    }

    .text-success { color: #059669 !important; }
    .text-danger { color: #dc2626 !important; }
    .text-warning { color: #d97706 !important; }
    .text-primary { color: #1d4ed8 !important; }
    
    .transition-hover:hover {
        background-color: #f8fafc !important;
        transform: translateX(4px);
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05);
    }
    
    .smaller { font-size: 0.75rem; }
</style>

<!-- Modal Chỉnh sửa KPI -->
<div class="modal fade" id="editKpiModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0 bg-light rounded-top p-4">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-pencil-square text-primary me-2"></i>Chỉnh sửa KPI</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="kpi.Id" value="@Model.Id" />
                    
                    <h6 class="fw-bold text-primary mb-3">Thông tin chung</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-12">
                            <label class="form-label fw-semibold">Tên KPI <span class="text-danger">*</span></label>
                            <input type="text" name="kpi.KPIName" value="@Model.KPIName" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Phân loại KPI <span class="text-danger">*</span></label>
                            <select name="kpi.KPITypeId" class="form-select" required>
                                @foreach (var t in (ViewBag.KPITypes as List<Manage_KPI_or_OKR_System.Models.KPIType>) ?? new List<Manage_KPI_or_OKR_System.Models.KPIType>())
                                {
                                    @if(Model.KPITypeId == t.Id) {
                                        <option value="@t.Id" selected>@t.TypeName</option>
                                    } else {
                                        <option value="@t.Id">@t.TypeName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Kỳ đánh giá <span class="text-danger">*</span></label>
                            <select name="kpi.PeriodId" class="form-select" required>
                                @foreach (var p in (ViewBag.AllPeriods as List<Manage_KPI_or_OKR_System.Models.EvaluationPeriod>) ?? new List<Manage_KPI_or_OKR_System.Models.EvaluationPeriod>())
                                {
                                    @if(Model.PeriodId == p.Id) {
                                        <option value="@p.Id" selected>@p.PeriodName</option>
                                    } else {
                                        <option value="@p.Id">@p.PeriodName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-semibold">Cấp độ quản lý</label>
                            <select name="kpi.PropertyId" class="form-select">
                                @foreach (var pr in (ViewBag.AllProperties as List<Manage_KPI_or_OKR_System.Models.KPIProperty>) ?? new List<Manage_KPI_or_OKR_System.Models.KPIProperty>())
                                {
                                    @if(Model.PropertyId == pr.Id) {
                                        <option value="@pr.Id" selected>@pr.PropertyName</option>
                                    } else {
                                        <option value="@pr.Id">@pr.PropertyName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    
                    <h6 class="fw-bold text-primary mb-3"><i class="bi bi-sliders me-2"></i>Chi tiết Chỉ tiêu</h6>
                    <div class="row g-3 mb-4 bg-light p-3 rounded-3" data-measurement-scope>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Chỉ tiêu (Target) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="number" step="0.01" name="detail.TargetValue" value="@detail?.TargetValue" class="form-control measurement-value-input" data-measurement-role="target" required>
                                <span class="input-group-text measurement-unit-suffix">đơn vị</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Đơn vị đo lường <span class="text-danger">*</span></label>
                            <select name="detail.MeasurementUnit" class="form-select measurement-unit-select" data-placeholder="-- Chọn đơn vị đo --" required>
                                <option value="">-- Chọn đơn vị đo --</option>
                                @if (hasCustomMeasurementUnit)
                                {
                                    <option value="@currentMeasurementUnit" selected>@currentMeasurementUnit</option>
                                }
                                @foreach (var unit in measurementUnits)
                                {
                                    if (string.Equals(unit.Value, currentMeasurementUnit, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <option value="@unit.Value" selected>@unit.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@unit.Value">@unit.Text</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Ngưỡng đạt (Pass Threshold)</label>
                            <div class="input-group">
                                <input type="number" step="0.01" name="detail.PassThreshold" value="@detail?.PassThreshold" class="form-control measurement-value-input" data-measurement-role="pass">
                                <span class="input-group-text measurement-unit-suffix">đơn vị</span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold text-danger">Ngưỡng trượt (Fail Threshold)</label>
                            <div class="input-group">
                                <input type="number" step="0.01" name="detail.FailThreshold" value="@detail?.FailThreshold" class="form-control measurement-value-input" data-measurement-role="fail">
                                <span class="input-group-text measurement-unit-suffix">đơn vị</span>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch p-3 bg-white rounded-3 border border-warning border-opacity-25 shadow-sm">
                                <input class="form-check-input ms-0 me-3" type="checkbox" name="detail.IsInverse" value="true" id="editIsInverseCheck" @(detail?.IsInverse == true ? "checked" : "")>
                                <label class="form-check-label fw-bold text-dark cursor-pointer" for="editIsInverseCheck">
                                    <i class="bi bi-arrow-down-circle text-warning me-1"></i> Chỉ tiêu thu nhỏ (Càng thấp càng tốt)
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4"><i class="bi bi-save me-2"></i>Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
