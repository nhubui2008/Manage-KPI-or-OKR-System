@model Manage_KPI_or_OKR_System.Helpers.PaginatedList<Manage_KPI_or_OKR_System.Models.AuditLog>
@{
    ViewData["Title"] = "Nhật ký Hệ thống";
    var users = ViewBag.Users as Dictionary<int, string> ?? new Dictionary<int, string>();
    var currentFilter = ViewData["CurrentFilter"] as string;
    var startDate = ViewData["StartDate"] as string;
    var endDate = ViewData["EndDate"] as string;
    var actionFilter = ViewData["ActionFilter"] as string;

    string GetActionBadgeClass(string action)
    {
        return action switch
        {
            "CREATE" => "badge-on-track",
            "UPDATE" => "bg-primary text-white",
            "DELETE" => "badge-late",
            _ => "bg-secondary text-white"
        };
    }

    string GetActionText(string action)
    {
        return action switch
        {
            "CREATE" => "Tạo mới",
            "UPDATE" => "Cập nhật",
            "DELETE" => "Xóa",
            _ => action ?? "N/A"
        };
    }
}

<div class="container-fluid px-0">
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 font-weight-bold mb-1">Nhật ký Hệ thống</h1>
            <div class="page-breadcrumb">
                <a href="/" class="text-primary text-decoration-none">Trang chủ</a>
                <i class="bi bi-chevron-right separator mx-2" style="font-size: 0.7rem; opacity: 0.5;"></i>
                <span class="text-muted">Hệ thống</span>
                <i class="bi bi-chevron-right separator mx-2" style="font-size: 0.7rem; opacity: 0.5;"></i>
                <span class="text-dark fw-bold">Audit Logs</span>
            </div>
        </div>
    </div>

    <div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100">
                <div class="card-body-custom p-4">
                    <!-- SEARCH & FILTER FORM -->
                    <form asp-action="Index" method="get" class="mb-4">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-3">
                                <div class="search-wrapper-premium w-100" style="max-width: 100%;">
                                    <i class="bi bi-search"></i>
                                    <input type="text" name="searchString" value="@currentFilter" class="search-input-premium" 
                                           placeholder="Tên người dùng, action, bảng..." />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="premium-select-wrapper w-100" style="max-width: 100%;">
                                    <span class="select-label">Hành động</span>
                                    <i class="bi bi-lightning-charge lead-icon"></i>
                                    <select name="actionFilter">
                                        <option value="">Tất cả hành động</option>
                                        <option value="CREATE" selected="@(actionFilter == "CREATE")">Tạo mới (CREATE)</option>
                                        <option value="UPDATE" selected="@(actionFilter == "UPDATE")">Cập nhật (UPDATE)</option>
                                        <option value="DELETE" selected="@(actionFilter == "DELETE")">Xóa (DELETE)</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="search-wrapper-premium w-100" style="max-width: 100%;">
                                    <i class="bi bi-calendar-event"></i>
                                    <input type="date" name="startDate" value="@startDate" class="search-input-premium" 
                                           title="Từ ngày" />
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="search-wrapper-premium w-100" style="max-width: 100%;">
                                    <i class="bi bi-calendar-check"></i>
                                    <input type="date" name="endDate" value="@endDate" class="search-input-premium" 
                                           title="Đến ngày" />
                                </div>
                            </div>
                            <div class="col-md-2 d-flex gap-2">
                                <button type="submit" class="btn-filter-premium flex-grow-1">
                                    <i class="bi bi-funnel-fill"></i> Lọc
                                </button>
                                <a asp-action="Index" class="btn-refresh-premium" title="Làm mới">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </a>
                            </div>
                        </div>
                    </form>

                    <div class="table-responsive w-100">
                        <table class="data-table w-100">
                            <thead>
                                <tr>
                                    <th style="width:18%;">Thời gian</th>
                                    <th style="width:15%;">Tài khoản</th>
                                    <th style="width:18%;">Loại</th>
                                    <th style="width:15%;">Bảng tác động</th>
                                    <th style="width:24%;">Tóm tắt</th>
                                    <th class="text-end" style="width:10%;">Hạnh động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var log in Model)
                                    {
                                        var userName = log.SystemUserId.HasValue && users.ContainsKey(log.SystemUserId.Value) ? users[log.SystemUserId.Value] : "System";
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="stat-icon blue shadow-sm" style="width:32px;height:32px;font-size:0.8rem;border-radius:8px; opacity: 0.9;">
                                                        <i class="bi bi-calendar-event"></i>
                                                    </div>
                                                    <div>
                                                        <div class="text-dark fw-bold" style="font-size: 0.85rem;">@(log.LogTime?.ToString("dd/MM/yyyy") ?? "")</div>
                                                        <div class="text-muted" style="font-size: 0.75rem;">@(log.LogTime?.ToString("HH:mm:ss") ?? "")</div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="user-avatar" style="width:28px;height:28px;font-size:0.75rem;">
                                                        @(userName.Length > 0 ? userName[0].ToString().ToUpper() : "?")
                                                    </div>
                                                    <span class="fw-medium text-dark">@userName</span>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="status-badge-soft @GetActionBadgeClass(log.ActionType ?? "")" style="font-size: 0.65rem; padding: 4px 10px; white-space: nowrap;">
                                                    <span class="status-dot"></span>
                                                    @GetActionText(log.ActionType ?? "")
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-primary border fw-bold" style="font-size: 0.7rem; border-radius: 6px;">
                                                    @(log.ImpactedTable ?? "N/A")
                                                </span>
                                            </td>
                                            <td>
                                                <div class="text-muted text-truncate small" style="max-width:300px;" title="@(log.NewData ?? log.OldData)">
                                                    @(string.IsNullOrEmpty(log.NewData) ? (string.IsNullOrEmpty(log.OldData) ? "—" : log.OldData) : log.NewData)
                                                </div>
                                            </td>
                                            <td>
                                                <div class="action-btns justify-content-end">
                                                    <button type="button" class="action-btn" title="Xem chi tiết" 
                                                            onclick="showLogDetails('@log.Id', '@log.ActionType', '@log.ImpactedTable', '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(log.OldData))', '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(log.NewData))')">
                                                        <i class="bi bi-eye"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-5">
                                            <i class="bi bi-inbox display-4 text-light mb-3 d-block"></i>
                                            <p class="mb-0">Không tìm thấy nhật ký phù hợp trong khoảng thời gian này.</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- PAGINATION -->
                    @if (Model != null && Model.TotalPages > 1)
                    {
                        <div class="pagination-custom mt-4 px-2">
                            <div class="text-muted small">
                                Hiển thị trang <strong>@Model.PageIndex</strong> trên tổng số <strong>@Model.TotalPages</strong>
                            </div>
                            <div class="pagination-pages">
                                <a class="page-btn @(!Model.HasPreviousPage ? "disabled" : "")" asp-action="Index" 
                                   asp-route-pageNumber="@(Model.PageIndex - 1)" 
                                   asp-route-searchString="@currentFilter"
                                   asp-route-actionFilter="@actionFilter"
                                   asp-route-startDate="@startDate"
                                   asp-route-endDate="@endDate">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                                
                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    if (i == 1 || i == Model.TotalPages || (i >= Model.PageIndex - 2 && i <= Model.PageIndex + 2))
                                    {
                                        <a class="page-btn @(i == Model.PageIndex ? "active" : "")" asp-action="Index" 
                                           asp-route-pageNumber="@i" 
                                           asp-route-searchString="@currentFilter"
                                           asp-route-actionFilter="@actionFilter"
                                           asp-route-startDate="@startDate"
                                           asp-route-endDate="@endDate">@i</a>
                                    }
                                    else if (i == Model.PageIndex - 3 || i == Model.PageIndex + 3)
                                    {
                                        <span class="px-2 text-muted">...</span>
                                    }
                                }

                                <a class="page-btn @(!Model.HasNextPage ? "disabled" : "")" asp-action="Index" 
                                   asp-route-pageNumber="@(Model.PageIndex + 1)" 
                                   asp-route-searchString="@currentFilter"
                                   asp-route-actionFilter="@actionFilter"
                                   asp-route-startDate="@startDate"
                                   asp-route-endDate="@endDate">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Chi tiết Nhật ký -->
<div class="modal fade" id="logDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">
            <div class="modal-header-soft primary d-flex justify-content-between align-items-center px-4 py-3">
                <h5 class="modal-title-custom mb-0">
                    <i class="bi bi-clock-history text-primary"></i>
                    Chi tiết Nhật ký Hệ thống
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body-soft p-4">
                <div class="soft-tag-indicator mb-3">
                    <i class="bi bi-info-circle-fill"></i>
                    <span>Tóm tắt thông tin hành động hệ thống vừa ghi nhận.</span>
                </div>

                <div class="row mb-4 g-3">
                    <div class="col-md-6">
                        <div class="form-icon-group mb-0">
                            <label>Loại hành động</label>
                            <div class="input-wrapper">
                                <i class="bi bi-lightning-charge"></i>
                                <div id="modalActionText" class="form-control d-flex align-items-center" style="background: #f8fafc; border-style: dashed; font-weight: 700;">—</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-icon-group mb-0">
                            <label>Bảng tác động</label>
                            <div class="input-wrapper">
                                <i class="bi bi-table"></i>
                                <div id="modalTable" class="form-control d-flex align-items-center text-primary fw-bold" style="background: #f8fafc; border-style: dashed;">—</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label class="small text-muted fw-bold text-uppercase" style="letter-spacing: 0.1em;">Dữ liệu chi tiết</label>
                        <button type="button" class="btn-outline-custom" onclick="copyLogData()" style="padding: 4px 12px; font-size: 0.75rem; border-radius: 8px;">
                            <i class="bi bi-clipboard me-1"></i> Sao chép JSON
                        </button>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6" id="oldDataContainer">
                            <div class="small text-muted mb-2 fw-bold text-uppercase" style="font-size: 0.65rem;">Dữ liệu trước khi đổi</div>
                            <pre id="modalOldData" class="bg-dark text-info p-3 rounded-4 small mb-0 shadow-sm" style="max-height: 400px; overflow-y: auto; font-family: 'Cascadia Code', monospace;"></pre>
                        </div>
                        <div class="col-md-6" id="newDataContainer">
                            <div class="small text-muted mb-2 fw-bold text-uppercase" style="font-size: 0.65rem;">Dữ liệu sau khi đổi</div>
                            <pre id="modalNewData" class="bg-dark text-success p-3 rounded-4 small mb-0 shadow-sm" style="max-height: 400px; overflow-y: auto; font-family: 'Cascadia Code', monospace;"></pre>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 p-4 pt-0 gap-2">
                <button type="button" class="btn-light px-4 py-2" style="border-radius: 10px; font-weight: 600;" data-bs-dismiss="modal">Đóng cửa sổ</button>
            </div>
        </div>
    </div>
</div>

<style>
    pre {
        white-space: pre-wrap;
        word-break: break-all;
    }
    .page-btn.disabled {
        pointer-events: none;
        opacity: 0.5;
    }
    /* Mẫu Pre đặc biệt */
    #modalOldData::-webkit-scrollbar, #modalNewData::-webkit-scrollbar {
        width: 6px;
    }
    #modalOldData::-webkit-scrollbar-thumb, #modalNewData::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.1);
        border-radius: 10px;
    }
</style>

@section Scripts {
    <script>
        function showLogDetails(id, action, table, oldData, newData) {
            $('#modalActionText').text(translateAction(action));
            $('#modalTable').text(table);

            try {
                // Try to format JSON for readability
                const oldObj = oldData ? JSON.parse(oldData) : null;
                const newObj = newData ? JSON.parse(newData) : null;
                
                $('#modalOldData').text(oldObj ? JSON.stringify(oldObj, null, 2) : "Không có dữ liệu cũ");
                $('#modalNewData').text(newObj ? JSON.stringify(newObj, null, 2) : "Không có dữ liệu mới");
            } catch (e) {
                // If not JSON, show as plain text
                $('#modalOldData').text(oldData || "Không có dữ liệu cũ");
                $('#modalNewData').text(newData || "Không có dữ liệu mới");
            }

            // Adjust layout based on action
            if (action === "CREATE") {
                $('#oldDataContainer').hide();
                $('#newDataContainer').attr('class', 'col-12');
            } else if (action === "DELETE") {
                $('#newDataContainer').hide();
                $('#oldDataContainer').attr('class', 'col-12');
            } else {
                $('#oldDataContainer').show().attr('class', 'col-md-6');
                $('#newDataContainer').show().attr('class', 'col-md-6');
            }

            const modal = new bootstrap.Modal(document.getElementById('logDetailsModal'));
            modal.show();
        }

        function translateAction(action) {
            switch(action) {
                case "CREATE": return "Tạo mới";
                case "UPDATE": return "Cập nhật";
                case "DELETE": return "Xóa";
                default: return action;
            }
        }

        function copyLogData() {
            const oldData = $('#modalOldData').text();
            const newData = $('#modalNewData').text();
            const textToCopy = `Dữ liệu cũ:\n${oldData}\n\nDữ liệu mới:\n${newData}`;
            
            navigator.clipboard.writeText(textToCopy).then(() => {
                alert("Đã sao chép vào bộ nhớ tạm!");
            });
        }
    </script>
}