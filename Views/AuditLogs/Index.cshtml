@model List<Manage_KPI_or_OKR_System.Models.AuditLog>
@{
    ViewData["Title"] = "Nhật ký Hệ thống (Audit Logs)";
    var users = ViewBag.Users as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="h3 font-weight-bold mb-1">Nhật ký Hệ thống</h1><div class="page-breadcrumb"><a href="/">Trang chủ</a><i class="bi bi-chevron-right separator"></i><span>Hệ thống</span><i class="bi bi-chevron-right separator"></i><span>Audit Logs</span></div></div>
</div>

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100">
    <div class="card-body-custom">
        <div class="table-responsive w-100">
            <table class="data-table w-100">
                <thead><tr><th style="width:15%;">Thời gian</th><th style="width:15%;">Tài khoản</th><th style="width:15%;">Hành động</th><th style="width:15%;">Bảng tác động</th><th style="width:40%;">Chi tiết</th></tr></thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var log in Model)
                        {
                            var userName = log.SystemUserId.HasValue && users.ContainsKey(log.SystemUserId.Value) ? users[log.SystemUserId.Value] : "System";
                            <tr>
                                <td><div class="text-dark fw-medium">@(log.LogTime?.ToString("dd/MM/yyyy") ?? "")</div><div class="text-muted" style="font-size:0.75rem;">@(log.LogTime?.ToString("HH:mm:ss") ?? "")</div></td>
                                <td><div class="d-flex align-items-center gap-2"><div class="user-avatar bg-dark text-white" style="width:20px;height:20px;font-size:0.5rem;">@(userName.Length > 0 ? userName[0].ToString().ToUpper() : "?")</div><span class="fw-semibold text-dark" style="font-size:0.85rem;">@userName</span></div></td>
                                <td><span class="badge @(log.ActionType == "CREATE" ? "bg-success" : log.ActionType == "DELETE" ? "bg-danger" : "bg-warning") text-white">@(log.ActionType ?? "N/A")</span></td>
                                <td><span class="badge bg-light text-dark border">@(log.ImpactedTable ?? "N/A")</span></td>
                                <td style="font-size:0.85rem;">
                                    @if (!string.IsNullOrEmpty(log.NewData))
                                    {<div class="text-dark text-truncate" style="max-width:400px;">@log.NewData</div>}
                                    else
                                    {<span class="text-muted">Không có chi tiết</span>}
                                </td>
                            </tr>
                        }
                    }
                    else
                    {<tr><td colspan="5" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;"></i><p class="mt-2">Chưa có nhật ký nào</p></td></tr>}
                </tbody>
            </table>
        </div>
    </div>
</div>

        </div>
    </div>
</div>