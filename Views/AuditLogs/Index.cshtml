@model Manage_KPI_or_OKR_System.Helpers.PaginatedList<Manage_KPI_or_OKR_System.Models.AuditLog>
@{
    ViewData["Title"] = "Nhật ký Hệ thống (Audit Logs)";
    var users = ViewBag.Users as Dictionary<int, string> ?? new Dictionary<int, string>();
    var currentFilter = ViewData["CurrentFilter"] as string;
    var startDate = ViewData["StartDate"] as string;
    var endDate = ViewData["EndDate"] as string;

    string GetActionClass(string action)
    {
        return action switch
        {
            "CREATE" => "bg-success",
            "UPDATE" => "bg-warning text-dark",
            "DELETE" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    string GetActionText(string action)
    {
        return action switch
        {
            "CREATE" => "Tạo mới",
            "UPDATE" => "Cập nhật",
            "DELETE" => "Xóa",
            _ => action ?? "N/A"
        };
    }
}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 font-weight-bold mb-1">Nhật ký Hệ thống</h1>
            <div class="page-breadcrumb">
                <a href="/">Trang chủ</a><i class="bi bi-chevron-right separator"></i>
                <span>Hệ thống</span><i class="bi bi-chevron-right separator"></i>
                <span>Audit Logs</span>
            </div>
        </div>
    </div>

    <div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100">
                <div class="card-body-custom p-4">
                    <!-- ADVANCED SEARCH FORM -->
                    <form asp-action="Index" method="get" class="mb-4">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-muted">Tìm kiếm từ khóa</label>
                                <div class="position-relative">
                                    <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                                    <input type="text" name="searchString" value="@currentFilter" class="form-control ps-5" placeholder="Tên người dùng, hành động, bảng..." />
                                </div>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small fw-bold text-muted">Từ ngày</label>
                                <input type="date" name="startDate" value="@startDate" class="form-control" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small fw-bold text-muted">Đến ngày</label>
                                <input type="date" name="endDate" value="@endDate" class="form-control" />
                            </div>
                            <div class="col-md-4 d-flex gap-2">
                                <button type="submit" class="btn-primary-custom auditlog-filter-btn flex-grow-1 d-flex align-items-center justify-content-center shadow-none">
                                    <i class="bi bi-filter me-2"></i> Lọc dữ liệu
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary auditlog-refresh-btn d-flex align-items-center justify-content-center px-3" title="Làm mới">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </a>
                            </div>
                        </div>
                    </form>

                    <div class="table-responsive w-100 border rounded">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4" style="width:18%;">Thời gian</th>
                                    <th style="width:15%;">Tài khoản</th>
                                    <th style="width:12%;">Hành động</th>
                                    <th style="width:15%;">Bảng tác động</th>
                                    <th style="width:30%;">Tóm tắt thay đổi</th>
                                    <th class="text-end pe-4" style="width:10%;">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var log in Model)
                                    {
                                        var userName = log.SystemUserId.HasValue && users.ContainsKey(log.SystemUserId.Value) ? users[log.SystemUserId.Value] : "System";
                                        <tr>
                                            <td class="ps-4">
                                                <div class="text-dark fw-medium">@(log.LogTime?.ToString("dd/MM/yyyy") ?? "")</div>
                                                <div class="text-muted small">@(log.LogTime?.ToString("HH:mm:ss") ?? "")</div>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="user-avatar bg-dark text-white rounded-circle d-flex align-items-center justify-content-center" style="width:28px;height:28px;font-size:0.75rem;">
                                                        @(userName.Length > 0 ? userName[0].ToString().ToUpper() : "?")
                                                    </div>
                                                    <span class="fw-medium text-dark">@userName</span>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge @GetActionClass(log.ActionType ?? "") px-2 py-1">
                                                    @GetActionText(log.ActionType ?? "")
                                                </span>
                                            </td>
                                            <td><code class="text-primary fw-bold">@(log.ImpactedTable ?? "N/A")</code></td>
                                            <td>
                                                <div class="text-muted text-truncate mb-0 small" style="max-width:350px;">
                                                    @(string.IsNullOrEmpty(log.NewData) ? (string.IsNullOrEmpty(log.OldData) ? "Không có dữ liệu chi tiết" : log.OldData) : log.NewData)
                                                </div>
                                            </td>
                                            <td class="text-end pe-4">
                                                <button type="button" class="btn btn-sm btn-outline-primary auditlog-detail-btn rounded-pill px-3" 
                                                        data-id="@log.Id"
                                                        data-action="@log.ActionType"
                                                        data-table="@log.ImpactedTable"
                                                        data-old="@log.OldData"
                                                        data-new="@log.NewData">
                                                    Chi tiết
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr class="auditlog-empty-row">
                                        <td colspan="6" class="text-center text-muted py-5">
                                            <i class="bi bi-inbox auditlog-empty-icon mb-3 d-block"></i>
                                            <p class="mb-0">Không tìm thấy nhật ký phù hợp trong khoảng thời gian này.</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- PAGINATION -->
                    @if (Model != null && Model.TotalPages > 1)
                    {
                        <div class="d-flex justify-content-between align-items-center mt-4 px-2">
                            <div class="text-muted small">
                                Hiển thị trang <strong>@Model.PageIndex</strong> trên tổng số <strong>@Model.TotalPages</strong>
                            </div>
                            <nav aria-label="Page navigation">
                                <ul class="pagination pagination-sm mb-0 gap-1">
                                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                                        <a class="page-link border-0 rounded-circle shadow-none text-dark" asp-action="Index" 
                                           asp-route-pageNumber="@(Model.PageIndex - 1)" 
                                           asp-route-searchString="@currentFilter"
                                           asp-route-startDate="@startDate"
                                           asp-route-endDate="@endDate">
                                            <i class="bi bi-chevron-left"></i>
                                        </a>
                                    </li>
                                    
                                    @for (int i = 1; i <= Model.TotalPages; i++)
                                    {
                                        if (i == 1 || i == Model.TotalPages || (i >= Model.PageIndex - 2 && i <= Model.PageIndex + 2))
                                        {
                                            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                                <a class="page-link border-0 rounded-circle shadow-none @(i == Model.PageIndex ? "" : "text-dark")" asp-action="Index" 
                                                   asp-route-pageNumber="@i" 
                                                   asp-route-searchString="@currentFilter"
                                                   asp-route-startDate="@startDate"
                                                   asp-route-endDate="@endDate">@i</a>
                                            </li>
                                        }
                                        else if (i == Model.PageIndex - 3 || i == Model.PageIndex + 3)
                                        {
                                            <li class="page-item disabled"><span class="page-link border-0">...</span></li>
                                        }
                                    }

                                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                                        <a class="page-link border-0 rounded-circle shadow-none text-dark" asp-action="Index" 
                                           asp-route-pageNumber="@(Model.PageIndex + 1)" 
                                           asp-route-searchString="@currentFilter"
                                           asp-route-startDate="@startDate"
                                           asp-route-endDate="@endDate">
                                            <i class="bi bi-chevron-right"></i>
                                        </a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Chi tiết Nhật ký -->
<div class="modal fade" id="logDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark">
                    <i class="bi bi-clock-history text-primary me-2"></i>Chi tiết Nhật ký Hệ thống
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row mb-3 g-3">
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded border-start border-primary border-4">
                            <label class="small text-muted fw-bold d-block mb-1 text-uppercase">Hành động</label>
                            <span id="modalAction" class="badge"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded border-start border-info border-4">
                            <label class="small text-muted fw-bold d-block mb-1 text-uppercase">Bảng dữ liệu</label>
                            <span id="modalTable" class="fw-bold text-dark"></span>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label class="small text-muted fw-bold text-uppercase">Dữ liệu Thay đổi</label>
                        <button type="button" class="btn btn-sm btn-outline-secondary auditlog-copy-btn border-0" onclick="copyLogData()">
                            <i class="bi bi-clipboard me-1"></i> Sao chép
                        </button>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6" id="oldDataContainer">
                            <div class="small text-muted mb-1 fw-bold">DỮ LIỆU CŨ</div>
                            <pre id="modalOldData" class="bg-dark text-light p-3 rounded small mb-0" style="max-height: 300px; overflow-y: auto;"></pre>
                        </div>
                        <div class="col-md-6" id="newDataContainer">
                            <div class="small text-muted mb-1 fw-bold">DỮ LIỆU MỚI</div>
                            <pre id="modalNewData" class="bg-dark text-light p-3 rounded small mb-0" style="max-height: 300px; overflow-y: auto;"></pre>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<style>
    pre {
        white-space: pre-wrap;
        word-break: break-all;
    }

    .page-link:hover {
        background-color: #f8f9fa;
    }

    .bg-warning.text-dark {
        background-color: #ffc107 !important;
    }

    .auditlog-filter-btn i,
    .auditlog-refresh-btn i,
    .auditlog-detail-btn i,
    .auditlog-copy-btn i {
        color: currentColor !important;
        opacity: 1 !important;
    }

    .auditlog-refresh-btn {
        min-width: 48px;
    }

    .auditlog-empty-row:hover > td {
        background-color: transparent !important;
    }

    .auditlog-empty-icon {
        font-size: 3rem;
        color: #9aa8b8;
        opacity: 0.55;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.auditlog-detail-btn').on('click', function () {
                var id = $(this).data('id');
                var action = $(this).data('action');
                var table = $(this).data('table');
                var oldData = $(this).attr('data-old');
                var newData = $(this).attr('data-new');
                
                showLogDetails(id, action, table, oldData, newData);
            });
        });

        function showLogDetails(id, action, table, oldData, newData) {
            $('#modalAction').text(translateAction(action));
            $('#modalAction').attr('class', 'badge ' + getActionBadgeClass(action));
            $('#modalTable').text(table);

            try {
                // Try to format JSON for readability
                const oldObj = oldData ? JSON.parse(oldData) : null;
                const newObj = newData ? JSON.parse(newData) : null;
                
                $('#modalOldData').text(oldObj ? JSON.stringify(oldObj, null, 2) : "Không có dữ liệu");
                $('#modalNewData').text(newObj ? JSON.stringify(newObj, null, 2) : "Không có dữ liệu");
            } catch (e) {
                // If not JSON, show as plain text
                $('#modalOldData').text(oldData || "Không có dữ liệu");
                $('#modalNewData').text(newData || "Không có dữ liệu");
            }

            // Adjust layout based on action
            if (action === "CREATE") {
                $('#oldDataContainer').hide();
                $('#newDataContainer').attr('class', 'col-12');
            } else if (action === "DELETE") {
                $('#newDataContainer').hide();
                $('#oldDataContainer').attr('class', 'col-12');
            } else {
                $('#oldDataContainer').show().attr('class', 'col-md-6');
                $('#newDataContainer').show().attr('class', 'col-md-6');
            }

            const modal = new bootstrap.Modal(document.getElementById('logDetailsModal'));
            modal.show();
        }

        function translateAction(action) {
            switch(action) {
                case "CREATE": return "Tạo mới";
                case "UPDATE": return "Cập nhật";
                case "DELETE": return "Xóa";
                default: return action;
            }
        }

        function getActionBadgeClass(action) {
            switch(action) {
                case "CREATE": return "bg-success";
                case "UPDATE": return "bg-warning text-dark";
                case "DELETE": return "bg-danger";
                default: return "bg-secondary";
            }
        }

        function copyLogData() {
            const oldData = $('#modalOldData').text();
            const newData = $('#modalNewData').text();
            const textToCopy = `Dữ liệu cũ:\n${oldData}\n\nDữ liệu mới:\n${newData}`;
            
            navigator.clipboard.writeText(textToCopy).then(() => {
                alert("Đã sao chép vào bộ nhớ tạm!");
            });
        }
    </script>
}
