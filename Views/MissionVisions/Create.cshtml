@model Manage_KPI_or_OKR_System.Models.MissionVision

@{
    ViewData["Title"] = "Thêm Mục Tiêu Chiến Lược";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-dark fw-bold">
                <i class="bi bi-flag-fill me-2"></i>Thêm Mục Tiêu Chiến Lược
            </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-dark text-decoration-none opacity-75">Sứ mệnh & Tầm nhìn</a></li>
                    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Thêm mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="content-card rounded-3">
        <div class="card-body-custom p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">
                    <div class="col-md-12">
                        <label class="form-label fw-bold text-dark">Nội dung chiến lược / Sứ mệnh <span class="text-danger">*</span></label>
                        <textarea name="Content" class="form-control" rows="5" placeholder="Nhập định hướng kinh doanh cốt lõi của năm nay hoặc tầm nhìn chung..." required></textarea>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-dark">Mục tiêu tài chính (VNĐ)</label>
                        <input type="number" step="1000000" name="FinancialTarget" class="form-control" placeholder="VD: 50000000000 (Không bắt buộc)">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-dark">Năm áp dụng</label>
                        <input type="number" name="TargetYear" class="form-control" placeholder="Để trống nếu đây là Tầm nhìn/Sứ mệnh chung dài hạn" value="@DateTime.Now.Year">
                        <div class="form-text mt-2"><i class="bi bi-info-circle me-1"></i> Xóa trắng trường này nếu muốn thiết lập Sứ mệnh công ty dài hạn.</div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-5 border-top pt-4">
                    <a asp-action="Index" class="btn-outline-custom px-4">
                        <i class="bi bi-x-circle me-1"></i> Hủy bỏ
                    </a>
                    <button type="submit" class="btn-primary-custom px-4">
                        <i class="bi bi-save me-2"></i> Lưu mục tiêu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
