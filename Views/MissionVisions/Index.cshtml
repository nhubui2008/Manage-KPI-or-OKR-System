@{
    ViewData["Title"] = "Sứ mệnh & Tầm nhìn";
}

<div class="page-header">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Định hướng chiến lược</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Sứ mệnh & Tầm nhìn</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn-primary-custom">
            <i class="bi bi-plus-lg"></i> Thêm mục tiêu
        </button>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Tầm nhìn & Sứ mệnh chung -->
    <div class="col-12">
        <div class="content-card bg-primary text-white border-0" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);">
            <div class="card-body-custom px-4 py-5 text-center">
                <i class="bi bi-compass mb-3" style="font-size: 3rem; opacity: 0.9;"></i>
                <h2 class="fw-bold mb-3">Trở thành công ty công nghệ đi đầu trong lĩnh vực quản trị doanh nghiệp tại Đông Nam Á</h2>
                <p class="mb-0 mx-auto" style="max-width: 800px; opacity: 0.9; font-size: 1.1rem;">
                    Sứ mệnh: Cung cấp giải pháp phần mềm tối ưu, dễ sử dụng giúp các doanh nghiệp vừa và nhỏ chuyển đổi số thành công, nâng cao hiệu suất làm việc và tạo ra môi trường làm việc hạnh phúc.
                </p>
            </div>
        </div>
    </div>
</div>

<div class="d-flex align-items-center justify-content-between mb-3 mt-5">
    <h4 class="mb-0 fw-bold text-dark">Mục tiêu chiến lược theo năm</h4>
    <select class="filter-select bg-white">
        <option>Năm 2026</option>
        <option>Năm 2027</option>
        <option>Năm 2025</option>
    </select>
</div>

<div class="row g-4">
    <div class="col-md-6 col-xl-4">
        <div class="content-card h-100">
            <div class="card-body-custom p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 fw-semibold">Giai đoạn 2026</div>
                    <div class="dropdown">
                        <button class="btn btn-sm btn-link text-muted p-0" data-bs-toggle="dropdown"><i class="bi bi-three-dots"></i></button>
                    </div>
                </div>
                <h5 class="fw-bold text-dark mb-3">Đạt doanh thu 50 tỷ VNĐ</h5>
                <p class="text-muted mb-4" style="font-size: 0.9rem;">Mục tiêu tài chính quan trọng nhất trong năm 2026, đánh dấu sự tăng trưởng 50% so với năm trước.</p>
                <div class="d-flex align-items-center justify-content-between mt-auto pt-3 border-top">
                    <div>
                        <div class="text-muted" style="font-size: 0.75rem;">Mục tiêu tài chính</div>
                        <div class="fw-semibold text-dark">50,000,000,000 đ</div>
                    </div>
                    <span class="status-badge active">Đang thực hiện</span>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 col-xl-4">
        <div class="content-card h-100">
            <div class="card-body-custom p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 fw-semibold">Giai đoạn 2026</div>
                    <div class="dropdown">
                        <button class="btn btn-sm btn-link text-muted p-0" data-bs-toggle="dropdown"><i class="bi bi-three-dots"></i></button>
                    </div>
                </div>
                <h5 class="fw-bold text-dark mb-3">Mở rộng thị trường miền Trung</h5>
                <p class="text-muted mb-4" style="font-size: 0.9rem;">Thành lập văn phòng đại diện tại Đà Nẵng và phủ sóng kênh phân phối tại 5 tỉnh miền Trung.</p>
                <div class="d-flex align-items-center justify-content-between mt-auto pt-3 border-top">
                    <div>
                        <div class="text-muted" style="font-size: 0.75rem;">Mục tiêu tài chính</div>
                        <div class="fw-semibold text-dark">15,000,000,000 đ</div>
                    </div>
                    <span class="status-badge active">Đang thực hiện</span>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 col-xl-4">
        <div class="content-card h-100">
            <div class="card-body-custom p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 fw-semibold">Giai đoạn 2026</div>
                    <div class="dropdown">
                        <button class="btn btn-sm btn-link text-muted p-0" data-bs-toggle="dropdown"><i class="bi bi-three-dots"></i></button>
                    </div>
                </div>
                <h5 class="fw-bold text-dark mb-3">Phát triển sản phẩm mới (ERP Mini)</h5>
                <p class="text-muted mb-4" style="font-size: 0.9rem;">Hoàn thiện và ra mắt thành công gói giải pháp ERP dành riêng cho doanh nghiệp dưới 50 nhân sự.</p>
                <div class="d-flex align-items-center justify-content-between mt-auto pt-3 border-top">
                    <div>
                        <div class="text-muted" style="font-size: 0.75rem;">Mục tiêu tài chính</div>
                        <div class="fw-semibold text-dark">10,000,000,000 đ</div>
                    </div>
                    <span class="status-badge active">Đang thực hiện</span>
                </div>
            </div>
        </div>
    </div>
</div>
