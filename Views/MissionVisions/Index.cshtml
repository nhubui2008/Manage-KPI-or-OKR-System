@model IEnumerable<Manage_KPI_or_OKR_System.Models.MissionVision>
@{
    ViewData["Title"] = "Sứ mệnh & Tầm nhìn";
    var longTermStatements = ViewBag.LongTermStatements as List<Manage_KPI_or_OKR_System.Models.MissionVision> ?? new List<Manage_KPI_or_OKR_System.Models.MissionVision>();
    var selectedYear = ViewBag.SelectedYear as int?;
    var availableYears = ViewBag.AvailableYears as List<int> ?? new List<int>();
    var isAdminRole = User.IsInRole("Admin") || User.IsInRole("Administrator");
    var canCreateMission = ViewBag.CanCreateMission is bool canCreateFromDb ? canCreateFromDb : isAdminRole || User.HasClaim("Permission", "MISSIONS_CREATE");
    var canEditMission = ViewBag.CanEditMission is bool canEditFromDb ? canEditFromDb : isAdminRole || User.HasClaim("Permission", "MISSIONS_EDIT");
    var canDeleteMission = ViewBag.CanDeleteMission is bool canDeleteFromDb ? canDeleteFromDb : isAdminRole || User.HasClaim("Permission", "MISSIONS_DELETE");
}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4 animate__animated animate__fadeIn">
    <div>
        <h1 class="h3 font-weight-bold mb-1 text-dark">Định hướng chiến lược</h1>
        <div class="page-breadcrumb">
            <a href="/" class="text-decoration-none opacity-75">Trang chủ</a>
            <i class="bi bi-chevron-right separator mx-2 small opacity-50"></i>
            <span class="text-primary fw-600">Sứ mệnh & Tầm nhìn</span>
        </div>
    </div>
    <div class="d-flex justify-content-end gap-2">
        @if (canCreateMission)
        {
            <a asp-action="Create" class="btn btn-primary shadow-sm d-flex align-items-center px-4 py-2" style="border-radius: 12px; font-weight: 700; background: linear-gradient(135deg, #1a73e8 0%, #1557b0 100%); border: none; transition: all 0.3s;">
                <i class="bi bi-plus-lg me-2"></i> Thêm mục tiêu
            </a>
        }
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success shadow-sm border-0 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
    </div>
}

<div class="row g-4 mb-4">
    <!-- Tầm nhìn & Sứ mệnh chung -->
    @if (longTermStatements.Any())
    {
        foreach (var statement in longTermStatements)
        {
            var iconClass = statement.MissionVisionType == MissionVision.TypeMission ? "bi-bullseye" : "bi-compass";
            var financialLabel = statement.MissionVisionType == MissionVision.TypeMission ? "Mục tiêu tài chính hỗ trợ" : "Mục tiêu tài chính dài hạn";

            <div class="@(longTermStatements.Count == 1 ? "col-12" : "col-lg-6")">
                <div class="content-card bg-primary text-white border-0 position-relative h-100" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);">
                    @if (canEditMission || canDeleteMission)
                    {
                    <div class="position-absolute top-0 end-0 p-3 d-flex gap-2">
                        @if (canEditMission)
                        {
                            <a asp-action="Edit" asp-route-id="@statement.Id" class="btn btn-sm btn-outline-light border-0" title="Chỉnh sửa @statement.TypeDisplayName">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                        }
                        @if (canDeleteMission)
                        {
                            <form asp-action="Delete" asp-route-id="@statement.Id" method="post" class="m-0" onsubmit="return confirm('Bạn có chắc muốn xóa @statement.TypeDisplayName này?');">
                                <button type="submit" class="btn btn-sm btn-outline-light border-0"><i class="bi bi-trash"></i></button>
                            </form>
                        }
                    </div>
                    }
                    <div class="card-body-custom px-4 py-5 text-center">
                        <i class="bi @iconClass mb-3" style="font-size: 3rem; opacity: 0.9;"></i>
                        <div class="badge bg-white bg-opacity-25 text-white rounded-pill px-3 py-2 mb-3">@statement.TypeDisplayName</div>
                        <h2 class="fw-bold mb-3" style="max-width: 900px; margin: 0 auto; line-height: 1.4;">@statement.Content</h2>
                        @if (statement.FinancialTarget.HasValue)
                        {
                            <p class="mb-0 mx-auto" style="opacity: 0.9; font-size: 1.1rem;">
                                @financialLabel: <strong>@String.Format("{0:N0} đ", statement.FinancialTarget.Value)</strong>
                            </p>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="content-card bg-primary text-white border-0 position-relative" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);">
                <div class="card-body-custom px-4 py-5 text-center">
                    <i class="bi bi-compass mb-3" style="font-size: 3rem; opacity: 0.9;"></i>
                    <h2 class="fw-bold mb-3">Chưa thiết lập Tầm nhìn & Sứ mệnh</h2>
                    <p class="mb-0 mx-auto" style="opacity: 0.9; font-size: 1.1rem;">
                        Hãy bấm "Thêm mục tiêu" và chọn loại "Tầm nhìn" hoặc "Sứ mệnh" để cài đặt định hướng dài hạn.
                    </p>
                </div>
            </div>
        </div>
    }
</div>

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3 mt-5">
    <h4 class="mb-0 fw-bold text-dark">Mục tiêu chiến lược theo năm</h4>
    <form method="get" asp-action="Index" class="d-flex flex-wrap align-items-center gap-2 bg-white p-1 rounded shadow-sm border">
        <span class="ps-2 text-muted small fw-bold text-uppercase" style="font-size: 0.7rem; white-space: nowrap;">Năm áp dụng:</span>
        <select name="year" class="form-select form-select-sm border-0 fw-bold text-primary page-filter-select" style="outline: none; box-shadow: none;" data-allow-clear="true">
            <option value="" selected="@(selectedYear == null ? "selected" : null)">Tất cả</option>
            @foreach (var y in availableYears)
            {
                if (y == selectedYear)
                {
                    <option value="@y" selected="selected">Năm @y</option>
                }
                else
                {
                    <option value="@y">Năm @y</option>
                }
            }
        </select>
        <button type="submit" class="btn btn-sm btn-primary-custom rounded px-2" style="padding: 0.25rem 0.6rem;">
            <i class="bi bi-funnel"></i>
        </button>
    </form>
</div>

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="row g-4 w-100">
    @if (Model != null && Model.Any())
    {
        foreach (var goal in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="content-card h-100">
                    <div class="card-body-custom p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 fw-semibold">@goal.TypeDisplayName @goal.TargetYear</div>
                            @if (canEditMission || canDeleteMission)
                            {
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-link text-muted p-0" data-bs-toggle="dropdown"><i class="bi bi-three-dots"></i></button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                        @if (canEditMission)
                                        {
                                            <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@goal.Id"><i class="bi bi-pencil me-2"></i>Chỉnh sửa</a></li>
                                        }
                                        @if (canEditMission && canDeleteMission)
                                        {
                                            <li><hr class="dropdown-divider"></li>
                                        }
                                        @if (canDeleteMission)
                                        {
                                            <li>
                                                <form asp-action="Delete" asp-route-id="@goal.Id" method="post" class="m-0" onsubmit="return confirm('Xóa mục tiêu chiến lược năm @goal.TargetYear?');">
                                                    <button type="submit" class="dropdown-item text-danger"><i class="bi bi-trash me-2"></i>Xóa mục tiêu</button>
                                                </form>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            }
                        </div>
                        <h5 class="fw-bold text-dark mb-3" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">@goal.Content</h5>
                        
                        <div class="d-flex align-items-center justify-content-between mt-auto pt-3 border-top">
                            <div>
                                <div class="text-muted" style="font-size: 0.75rem;">Mục tiêu tài chính</div>
                                @if (goal.FinancialTarget.HasValue)
                                {
                                    <div class="fw-semibold text-dark">@String.Format("{0:N0} đ", goal.FinancialTarget.Value)</div>
                                }
                                else
                                {
                                    <div class="text-muted fst-italic">Không đặt ra</div>
                                }
                            </div>
                            <span class="status-badge active">Đang áp dụng</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info border-0 shadow-sm text-center p-5">
                <i class="bi bi-flag display-4 text-info mb-3 d-block"></i>
                <h5>@(selectedYear.HasValue ? $"Chưa có mục tiêu trong năm {selectedYear}" : "Chưa có mục tiêu chiến lược theo năm")</h5>
                <p class="text-muted mb-0">@(selectedYear.HasValue ? "Bấm \"Thêm mục tiêu\" để hoạch định chiến lược cho năm này." : "Bấm \"Thêm mục tiêu\" để hoạch định chiến lược cho các năm.")</p>
            </div>
        </div>
    }
</div>


        </div>
    </div>
</div>
