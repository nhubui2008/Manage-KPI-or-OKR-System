@using Manage_KPI_or_OKR_System.Models
@{
    ViewData["Title"] = "Dashboard";
    var totalEmployees = (int)(ViewBag.TotalEmployees ?? 0);
    var totalOKRs = (int)(ViewBag.TotalOKRs ?? 0);
    var totalKPIs = (int)(ViewBag.TotalKPIs ?? 0);
    var totalCheckIns = (int)(ViewBag.TotalCheckIns ?? 0);
    var totalDepartments = (int)(ViewBag.TotalDepartments ?? 0);
    var totalPositions = (int)(ViewBag.TotalPositions ?? 0);
    var recentCheckIns = ViewBag.RecentCheckIns as List<KPICheckIn> ?? new List<KPICheckIn>();
    var employeeNames = ViewBag.EmployeeNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var kpiNames = ViewBag.KPINames as Dictionary<int, string> ?? new Dictionary<int, string>();
    
    // DỮ LIỆU THỰC từ Controller
    var kpiAchievementRate = ViewBag.KPIAchievementRate ?? 0.0;
    var okrProgressRate = ViewBag.OKRProgressRate ?? 0.0;
    
    // Selected period
    var selectedPeriod = ViewBag.SelectedPeriod as EvaluationPeriod;
    var allPeriods = ViewBag.AllPeriods as List<EvaluationPeriod> ?? new List<EvaluationPeriod>();

    // Top employees
    var topEmployees = ViewBag.TopEmployees as IEnumerable<dynamic>;

    // Helpers
    string GetKpiStatusColor(double rate) {
        if (rate >= 80) return "success";
        if (rate >= 50) return "warning";
        return "danger";
    }
    string GetKpiStatusText(double rate) {
        if (rate >= 80) return "Tốt";
        if (rate >= 50) return "Trung bình";
        if (rate > 0) return "Cần cải thiện";
        return "Chưa có dữ liệu";
    }
    string GetOkrStatusColor(double rate) {
        if (rate >= 70) return "success";
        if (rate >= 40) return "warning";
        return "danger";
    }
    string GetOkrStatusText(double rate) {
        if (rate >= 70) return "Đúng tiến độ";
        if (rate >= 40) return "Đang bám sát";
        if (rate > 0) return "Chậm tiến độ";
        return "Chưa có dữ liệu";
    }
}

<div class="page-header mb-4 align-items-end">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Tổng quan hệ thống</h1>
        <div class="page-breadcrumb text-muted" style="font-size: 0.85rem;">
            <a href="/" class="text-decoration-none text-primary fw-medium">Trang chủ</a>
            <i class="bi bi-chevron-right separator mx-1"></i>
            <span>Dashboard</span>
        </div>
    </div>
    <div class="ms-auto">
        <form method="get" asp-action="Index" class="d-flex align-items-center gap-2 bg-white p-1 rounded shadow-sm border">
            <span class="ps-2 text-muted small fw-bold text-uppercase" style="font-size: 0.7rem; white-space: nowrap;">Kỳ báo cáo:</span>
            <select name="periodId" class="form-select form-select-sm border-0 fw-bold text-primary" style="width: 320px; outline: none; box-shadow: none;" onchange="this.form.submit()">
                <option value="">-- Tất cả --</option>
                @foreach (var period in allPeriods)
                {
                    var isSelected = selectedPeriod?.Id == period.Id;
                    <option value="@period.Id" selected="@(isSelected ? "selected" : null)">
                        @period.PeriodName
                        @if (period.StartDate.HasValue && period.EndDate.HasValue)
                        {
                            <text> (@period.StartDate.Value.ToString("dd/MM/yy") - @period.EndDate.Value.ToString("dd/MM/yy"))</text>
                        }
                    </option>
                }
            </select>
            <button type="submit" class="btn btn-sm btn-primary-custom rounded px-2" style="padding: 0.25rem 0.6rem;">
                <i class="bi bi-funnel"></i>
            </button>
        </form>
    </div>
</div>

@* ============ STAT CARDS ============ *@
<div class="row g-4 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card p-3 border rounded shadow-sm h-100 bg-white border-start border-primary border-4">
