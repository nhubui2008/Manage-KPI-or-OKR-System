                <div>
                    <div class="stat-label text-muted fw-bold text-uppercase" style="font-size: 0.75rem;">Tỉ lệ KPI đạt</div>
                    <div class="stat-value h4 mb-0 fw-bold text-dark mt-1">@kpiAchievementRate%</div>
                </div>
                <div class="stat-icon text-primary bg-primary bg-opacity-10 p-2 rounded">
                    <i class="bi bi-speedometer2 fs-4"></i>
                </div>
            </div>
            <div class="mt-2">
                <span class="text-@GetKpiStatusColor((double)kpiAchievementRate) fw-bold" style="font-size: 0.75rem;">
                    <i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i> @GetKpiStatusText((double)kpiAchievementRate)
                </span>
                <span class="text-muted ms-1" style="font-size: 0.75rem;">(Tổng: @totalKPIs KPI)</span>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card p-3 border rounded shadow-sm h-100 bg-white border-start border-success border-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label text-muted fw-bold text-uppercase" style="font-size: 0.75rem;">Tiến độ OKR Công Ty</div>
                    <div class="stat-value h4 mb-0 fw-bold text-dark mt-1">@okrProgressRate%</div>
                </div>
                <div class="stat-icon text-success bg-success bg-opacity-10 p-2 rounded">
                    <i class="bi bi-bullseye fs-4"></i>
                </div>
            </div>
            <div class="mt-2">
                <span class="text-@GetOkrStatusColor((double)okrProgressRate) fw-bold" style="font-size: 0.75rem;">
                    <i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i> @GetOkrStatusText((double)okrProgressRate)
                </span>
                <span class="text-muted ms-1" style="font-size: 0.75rem;">(Tổng: @totalOKRs mục tiêu)</span>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card p-3 border rounded shadow-sm h-100 bg-white border-start border-info border-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label text-muted fw-bold text-uppercase" style="font-size: 0.75rem;">Tổng Nhân Viên</div>
                    <div class="stat-value h4 mb-0 fw-bold text-dark mt-1">@totalEmployees</div>
                </div>
                <div class="stat-icon text-info bg-info bg-opacity-10 p-2 rounded">
                    <i class="bi bi-people-fill fs-4"></i>
                </div>
            </div>
            <div class="mt-2">
                <span class="text-muted" style="font-size: 0.75rem;">Đang hoạt động trên hệ thống</span>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card p-3 border rounded shadow-sm h-100 bg-white border-start border-warning border-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label text-muted fw-bold text-uppercase" style="font-size: 0.75rem;">Lượt Check-in</div>
                    <div class="stat-value h4 mb-0 fw-bold text-dark mt-1">@totalCheckIns</div>
                </div>
                <div class="stat-icon text-warning bg-warning bg-opacity-10 p-2 rounded">
                    <i class="bi bi-check2-square fs-4"></i>
                </div>
            </div>
            <div class="mt-2">
                <span class="text-muted" style="font-size: 0.75rem;">
                    @if (selectedPeriod != null) { <text>Trong kỳ @selectedPeriod.PeriodName</text> } else { <text>Toàn hệ thống</text> }
                </span>
            </div>
        </div>
    </div>
</div>

@* ============ AI PERFORMANCE ANALYSIS ============ *@
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h5 class="mb-0 fs-6 fw-bold"><i class="bi bi-stars text-primary"></i> AI Phân tích Hiệu suất</h5>
                <button type="button" class="btn btn-sm btn-outline-primary" id="runAiPerformanceAnalysis" data-period-id="@(selectedPeriod?.Id)">
                    <i class="bi bi-magic me-1"></i> Phân tích
                </button>
            </div>
            <div class="card-body">
                <div id="aiPerformanceAnalysisResult" class="text-muted small">
                    Chọn kỳ báo cáo rồi bấm phân tích để AI tóm tắt xu hướng, rủi ro và hành động cải thiện.
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    #aiPerformanceAnalysisResult,
    #aiPerformanceAnalysisResult .ai-result-card,
    #aiPerformanceAnalysisResult .ai-analysis-content {
        width: 100%;
        max-width: 100%;
        white-space: normal;
        overflow: visible;
        overflow-wrap: anywhere;
        word-break: normal;
        line-height: 1.7;
    }

    #aiPerformanceAnalysisResult .ai-result-card {
        color: var(--text-secondary);
    }

    #aiPerformanceAnalysisResult .ai-analysis-content p {
        margin: 0 0 0.75rem;
    }

    #aiPerformanceAnalysisResult .ai-analysis-content p:last-child,
    #aiPerformanceAnalysisResult .ai-analysis-content ul:last-child {
        margin-bottom: 0;
    }

    #aiPerformanceAnalysisResult .ai-analysis-content ul {
        margin: 0 0 0.75rem;
        padding-left: 1.1rem;
    }

    #aiPerformanceAnalysisResult .ai-analysis-content li {
        margin-bottom: 0.35rem;
    }
</style>

