@{
    ViewData["Title"] = "Dashboard";
    var totalEmployees = (int)(ViewBag.TotalEmployees ?? 0);
    var totalOKRs = (int)(ViewBag.TotalOKRs ?? 0);
    var totalKPIs = (int)(ViewBag.TotalKPIs ?? 0);
    var totalRevenue = (decimal)(ViewBag.TotalRevenue ?? 0m);
    var totalCheckIns = (int)(ViewBag.TotalCheckIns ?? 0);
    var recentCheckIns = ViewBag.RecentCheckIns as List<Manage_KPI_or_OKR_System.Models.KPICheckIn> ?? new List<Manage_KPI_or_OKR_System.Models.KPICheckIn>();
    var employeeNames = ViewBag.EmployeeNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var kpiNames = ViewBag.KPINames as Dictionary<int, string> ?? new Dictionary<int, string>();
    
    // Giả lập dữ liệu % tiến độ (Bạn có thể truyền từ Controller sang bằng ViewBag)
    var kpiAchievementRate = ViewBag.KPIAchievementRate ?? 85.5; 
    var okrProgressRate = ViewBag.OKRProgressRate ?? 68.0;
}

<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h3 font-weight-bold mb-1">Tổng quan hệ thống</h1>
            <div class="page-breadcrumb text-muted" style="font-size: 0.85rem;">
                <a href="/" class="text-decoration-none">Trang chủ</a>
                <i class="bi bi-chevron-right separator mx-1"></i>
                <span>Dashboard</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <select class="form-select form-select-sm" style="width: 150px;">
                <option>Quý 1 - 2026</option>
                <option>Quý 2 - 2026</option>
                <option>Năm 2026</option>
            </select>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card p-3 border rounded shadow-sm h-100 bg-white border-start border-primary border-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label text-muted fw-bold text-uppercase" style="font-size: 0.75rem;">Tổng KPI Đã Đạt</div>
                    <div class="stat-value h4 mb-0 fw-bold text-dark mt-1">@kpiAchievementRate%</div>
                </div>
                <div class="stat-icon text-primary bg-primary bg-opacity-10 p-2 rounded">
                    <i class="bi bi-speedometer2 fs-4"></i>
                </div>
            </div>
            <div class="mt-2">
                <span class="text-success fw-bold" style="font-size: 0.75rem;"><i class="bi bi-arrow-up"></i> Tốt</span>
                <span class="text-muted ms-1" style="font-size: 0.75rem;">(Tổng: @totalKPIs mục tiêu)</span>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card p-3 border rounded shadow-sm h-100 bg-white border-start border-success border-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label text-muted fw-bold text-uppercase" style="font-size: 0.75rem;">Tiến độ OKR Công Ty</div>
                    <div class="stat-value h4 mb-0 fw-bold text-dark mt-1">@okrProgressRate%</div>
                </div>
                <div class="stat-icon text-success bg-success bg-opacity-10 p-2 rounded">
                    <i class="bi bi-bullseye fs-4"></i>
                </div>
            </div>
            <div class="mt-2">
                <span class="text-warning fw-bold" style="font-size: 0.75rem;">Đang bám sát</span>
                <span class="text-muted ms-1" style="font-size: 0.75rem;">(Tổng: @totalOKRs mục tiêu)</span>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card p-3 border rounded shadow-sm h-100 bg-white border-start border-info border-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label text-muted fw-bold text-uppercase" style="font-size: 0.75rem;">Tổng Nhân Viên</div>
                    <div class="stat-value h4 mb-0 fw-bold text-dark mt-1">@totalEmployees</div>
                </div>
                <div class="stat-icon text-info bg-info bg-opacity-10 p-2 rounded">
                    <i class="bi bi-people-fill fs-4"></i>
                </div>
            </div>
            <div class="mt-2">
                <span class="text-muted" style="font-size: 0.75rem;">Đang hoạt động trên hệ thống</span>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card p-3 border rounded shadow-sm h-100 bg-white border-start border-warning border-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label text-muted fw-bold text-uppercase" style="font-size: 0.75rem;">Doanh Thu</div>
                    <div class="stat-value h4 mb-0 fw-bold text-dark mt-1">
                        @(totalRevenue > 1000000000 ? $"{totalRevenue/1000000000:N1} Tỷ" : totalRevenue > 1000000 ? $"{totalRevenue/1000000:N0} Tr" : totalRevenue.ToString("N0"))
                    </div>
                </div>
                <div class="stat-icon text-warning bg-warning bg-opacity-10 p-2 rounded">
                    <i class="bi bi-currency-dollar fs-4"></i>
                </div>
            </div>
            <div class="mt-2">
                <span class="text-muted" style="font-size: 0.75rem;">Đơn hàng hoàn thành</span>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fs-6 fw-bold"><i class="bi bi-bar-chart-fill text-primary"></i> Tiến độ OKR & KPI Khối Doanh Nghiệp</h5>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center p-4">
                <div class="w-100" style="position: relative; height: 350px;">
                    <canvas id="mainDashboardChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fs-6 fw-bold"><i class="bi bi-activity text-danger"></i> Hoạt động Check-in gần đây</h5>
            </div>
            <div class="card-body pt-3" style="max-height: 400px; overflow-y: auto;">
                @if (recentCheckIns.Any())
                {
                    <ul class="list-group list-group-flush">
                    @foreach (var ci in recentCheckIns)
                    {
                        var empName = ci.EmployeeId.HasValue && employeeNames.ContainsKey(ci.EmployeeId.Value) ? employeeNames[ci.EmployeeId.Value] : "N/A";
                        var kpiName = ci.KPIId.HasValue && kpiNames.ContainsKey(ci.KPIId.Value) ? kpiNames[ci.KPIId.Value] : "N/A";
                        
                        <li class="list-group-item px-0 border-bottom">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-2 me-3">
                                        <i class="bi bi-check-lg"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold fs-6" style="font-size: 0.9rem;">@empName</div>
                                        <small class="text-muted">Đã check-in: @kpiName</small>
                                    </div>
                                </div>
                                <small class="text-muted">@(ci.CheckInDate?.ToString("dd/MM HH:mm") ?? "")</small>
                            </div>
                        </li>
                    }
                    </ul>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-inbox opacity-50" style="font-size: 3rem;"></i>
                        <p class="mt-2 mb-0">Chưa có hoạt động check-in nào</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fs-6 fw-bold"><i class="bi bi-lightning-charge-fill text-warning"></i> Truy cập nhanh</h5>
            </div>
            <div class="card-body pt-3">
                <div class="row g-2">
                    <div class="col-6"><a href="/Employees" class="btn btn-outline-primary w-100 py-2"><i class="bi bi-people me-2"></i>Nhân sự</a></div>
                    <div class="col-6"><a href="/KPIs" class="btn btn-outline-success w-100 py-2"><i class="bi bi-speedometer2 me-2"></i>Quản lý KPI</a></div>
                    <div class="col-6"><a href="/OKRs" class="btn btn-outline-info w-100 py-2"><i class="bi bi-bullseye me-2"></i>Quản lý OKR</a></div>
                    <div class="col-6"><a href="/SalesOrders" class="btn btn-outline-warning w-100 py-2"><i class="bi bi-cart me-2"></i>Đơn hàng</a></div>
                    <div class="col-6"><a href="/EvaluationResults" class="btn btn-outline-danger w-100 py-2"><i class="bi bi-award me-2"></i>Đánh giá</a></div>
                    <div class="col-6"><a href="/KPICheckIns" class="btn btn-outline-secondary w-100 py-2"><i class="bi bi-check2-square me-2"></i>Check-in</a></div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fs-6 fw-bold"><i class="bi bi-info-circle-fill text-primary"></i> Chi tiết hệ thống</h5>
            </div>
            <div class="card-body pt-3">
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-diagram-3 me-2"></i>Phòng ban</span>
                    <span class="fw-bold">@(ViewBag.TotalDepartments ?? 0)</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-people me-2"></i>Nhân viên</span>
                    <span class="fw-bold">@totalEmployees</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-bullseye me-2"></i>OKR đang hoạt động</span>
                    <span class="fw-bold">@totalOKRs</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-speedometer2 me-2"></i>KPI đang hoạt động</span>
                    <span class="fw-bold">@totalKPIs</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-person-hearts me-2"></i>Khách hàng</span>
                    <span class="fw-bold">@(ViewBag.TotalCustomers ?? 0)</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2">
                    <span class="text-muted"><i class="bi bi-cart me-2"></i>Đơn hàng</span>
                    <span class="fw-bold">@(ViewBag.TotalOrders ?? 0)</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-2 mb-4">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fs-6 fw-bold"><i class="bi bi-pie-chart-fill text-success"></i> Phân bổ trạng thái OKR</h5>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center p-4">
                <div class="w-100" style="position: relative; height: 320px;">
                    <canvas id="okrStatusChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fs-6 fw-bold"><i class="bi bi-graph-up-arrow text-info"></i> Hiệu suất theo Phòng ban</h5>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center p-4">
                <div class="w-100" style="position: relative; height: 320px;">
                    <canvas id="deptPerformanceChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Lấy dữ liệu từ ViewBag (đã được serialize thành JSON)
        const okrLabels = @Html.Raw(ViewBag.OKRStatusLabels ?? "[]");
        const okrData = @Html.Raw(ViewBag.OKRStatusData ?? "[]");
        const deptLabels = @Html.Raw(ViewBag.DeptLabels ?? "[]");
        const deptProgress = @Html.Raw(ViewBag.DeptProgress ?? "[]");
        const mainLabels = @Html.Raw(ViewBag.MainChartLabels ?? "[]");
        const mainData = @Html.Raw(ViewBag.MainChartData ?? "[]");

        // --- 1. BIỂU ĐỒ CHÍNH (TIẾN ĐỘ TỔNG THỂ) ---
        const ctxMain = document.getElementById('mainDashboardChart').getContext('2d');
        new Chart(ctxMain, {
            type: 'line',
            data: {
                labels: mainLabels,
                datasets: [{
                    label: 'Tiến độ hoàn thành (%)',
                    data: mainData,
                    borderColor: '#4e73df',
                    backgroundColor: 'rgba(78, 115, 223, 0.05)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: '#4e73df'
                }]
            },
            options: {
                maintainAspectRatio: false,
                plugins: { 
                    legend: { display: false },
                    tooltip: { backgroundColor: 'rgba(0,0,0,0.8)', padding: 12 }
                },
                scales: {
                    x: { grid: { display: false } },
                    y: { beginAtZero: true, ticks: { callback: value => value + '%' } }
                }
            }
        });

        // --- 2. BIỂU ĐỒ TRẠNG THÁI OKR ---
        const ctxStatus = document.getElementById('okrStatusChart').getContext('2d');
        new Chart(ctxStatus, {
            type: 'doughnut',
            data: {
                labels: okrLabels,
                datasets: [{
                    data: okrData,
                    backgroundColor: ['#10b981', '#f59e0b', '#3b82f6', '#ef4444', '#6366f1'],
                    borderWidth: 0,
                    hoverOffset: 15
                }]
            },
            options: {
                maintainAspectRatio: false,
                cutout: '72%',
                plugins: {
                    legend: { position: 'bottom', labels: { usePointStyle: true, padding: 25, font: { size: 11 } } }
                }
            }
        });

        // --- 3. BIỂU ĐỒ HIỆU SUẤT PHÒNG BAN ---
        const ctxDept = document.getElementById('deptPerformanceChart').getContext('2d');
        new Chart(ctxDept, {
            type: 'bar',
            data: {
                labels: deptLabels,
                datasets: [{
                    label: 'Hiệu suất TB (%)',
                    data: deptProgress,
                    backgroundColor: '#4e73df',
                    hoverBackgroundColor: '#2e59d9',
                    borderRadius: 10,
                    barThickness: 24
                }]
            },
            options: {
                indexAxis: 'y',
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { grid: { display: false }, ticks: { padding: 10 } },
                    x: { beginAtZero: true, ticks: { callback: value => value + '%' } }
                }
            }
        });
    </script>
