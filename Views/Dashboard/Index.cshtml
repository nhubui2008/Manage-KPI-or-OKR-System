@{
    ViewData["Title"] = "Dashboard";
    var totalEmployees = (int)(ViewBag.TotalEmployees ?? 0);
    var totalOKRs = (int)(ViewBag.TotalOKRs ?? 0);
    var totalKPIs = (int)(ViewBag.TotalKPIs ?? 0);
    var totalRevenue = (decimal)(ViewBag.TotalRevenue ?? 0m);
    var totalCheckIns = (int)(ViewBag.TotalCheckIns ?? 0);
    var recentCheckIns = ViewBag.RecentCheckIns as List<Manage_KPI_or_OKR_System.Models.KPICheckIn> ?? new List<Manage_KPI_or_OKR_System.Models.KPICheckIn>();
    var employeeNames = ViewBag.EmployeeNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var kpiNames = ViewBag.KPINames as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="page-header">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Tổng quan hệ thống</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Dashboard</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <select class="form-select form-select-sm" style="width: 150px;">
            <option>Quý 1 - 2026</option>
            <option>Quý 2 - 2026</option>
            <option>Năm 2026</option>
        </select>
    </div>
</div>

<!-- Stat Cards -->
<div class="row g-4 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Tổng Nhân Viên</div>
                    <div class="stat-value">@totalEmployees</div>
                </div>
                <div class="stat-icon blue">
                    <i class="bi bi-people-fill"></i>
                </div>
            </div>
            <div class="mt-2">
                <span class="text-muted" style="font-size: 0.75rem;">Đang hoạt động</span>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Tổng OKR</div>
                    <div class="stat-value">@totalOKRs</div>
                </div>
                <div class="stat-icon teal">
                    <i class="bi bi-bullseye"></i>
                </div>
            </div>
            <div class="mt-2">
                <span class="text-muted" style="font-size: 0.75rem;">Mục tiêu đang hoạt động</span>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Tổng KPI</div>
                    <div class="stat-value">@totalKPIs</div>
                </div>
                <div class="stat-icon orange">
                    <i class="bi bi-speedometer2"></i>
                </div>
            </div>
            <div class="mt-2">
                <span class="text-muted" style="font-size: 0.75rem;">@totalCheckIns lượt check-in</span>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Doanh Thu</div>
                    <div class="stat-value">@(totalRevenue > 1000000000 ? $"{totalRevenue/1000000000:N1}B" : totalRevenue > 1000000 ? $"{totalRevenue/1000000:N0}M" : totalRevenue.ToString("N0"))</div>
                </div>
                <div class="stat-icon green">
                    <i class="bi bi-currency-dollar"></i>
                </div>
            </div>
            <div class="mt-2">
                <span class="text-muted" style="font-size: 0.75rem;">Đơn hàng hoàn thành</span>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Charts Container -->
    <div class="col-lg-8">
        <div class="row g-4">
            <div class="col-12">
                <div class="content-card">
                    <div class="card-header-custom">
                        <h5><i class="bi bi-bar-chart-fill"></i> Tiến độ OKR Công Ty (Năm Hiện Tại)</h5>
                    </div>
                    <div class="card-body-custom" style="min-height: 300px;">
                        <div id="okrChart"></div>
                    </div>
                </div>
            </div>
            <div class="col-12">
                <div class="content-card">
                    <div class="card-header-custom">
                        <h5><i class="bi bi-graph-up text-success"></i> Xu hướng Hiệu suất KPI</h5>
                    </div>
                    <div class="card-body-custom" style="min-height: 300px;">
                        <div id="kpiTrendChart"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Hoạt động gần đây -->
    <div class="col-lg-4">
        <div class="content-card h-100">
            <div class="card-header-custom">
                <h5><i class="bi bi-activity"></i> Hoạt động Check-in gần đây</h5>
            </div>
            <div class="card-body-custom pt-3">
                @if (recentCheckIns.Any())
                {
                    @foreach (var ci in recentCheckIns)
                    {
                        var empName = ci.EmployeeId.HasValue && employeeNames.ContainsKey(ci.EmployeeId.Value) ? employeeNames[ci.EmployeeId.Value] : "N/A";
                        var kpiName = ci.KPIId.HasValue && kpiNames.ContainsKey(ci.KPIId.Value) ? kpiNames[ci.KPIId.Value] : "N/A";
                        <div class="activity-item">
                            <div class="activity-icon bg-primary text-white"><i class="bi bi-check-lg"></i></div>
                            <div class="activity-content">
                                <div class="activity-text fw-medium">@empName <span class="fw-normal">đã check-in KPI: @kpiName</span></div>
                                <div class="activity-time">@(ci.CheckInDate?.ToString("dd/MM/yyyy HH:mm") ?? "")</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                        <p class="mt-2 mb-0">Chưa có hoạt động check-in nào</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Quick links -->
    <div class="col-lg-6">
        <div class="content-card">
            <div class="card-header-custom border-bottom-0 pb-0">
                <h5><i class="bi bi-lightning-charge-fill text-warning"></i> Truy cập nhanh</h5>
            </div>
            <div class="card-body-custom pt-3">
                <div class="row g-2">
                    <div class="col-6"><a href="/Employees" class="btn btn-outline-primary w-100 py-2"><i class="bi bi-people me-2"></i>Nhân sự</a></div>
                    <div class="col-6"><a href="/KPIs" class="btn btn-outline-success w-100 py-2"><i class="bi bi-speedometer2 me-2"></i>Quản lý KPI</a></div>
                    <div class="col-6"><a href="/OKRs" class="btn btn-outline-info w-100 py-2"><i class="bi bi-bullseye me-2"></i>Quản lý OKR</a></div>
                    <div class="col-6"><a href="/SalesOrders" class="btn btn-outline-warning w-100 py-2"><i class="bi bi-cart me-2"></i>Đơn hàng</a></div>
                    <div class="col-6"><a href="/EvaluationResults" class="btn btn-outline-danger w-100 py-2"><i class="bi bi-award me-2"></i>Đánh giá</a></div>
                    <div class="col-6"><a href="/KPICheckIns" class="btn btn-outline-secondary w-100 py-2"><i class="bi bi-check2-square me-2"></i>Check-in</a></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Cảnh báo / Vấn đề -->
    <div class="col-lg-6">
        <div class="content-card h-100">
            <div class="card-header-custom">
                <h5><i class="bi bi-info-circle-fill text-primary"></i> Thống kê hệ thống</h5>
            </div>
            <div class="card-body-custom pt-3">
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-diagram-3 me-2"></i>Phòng ban</span>
                    <span class="fw-bold">@(ViewBag.TotalDepartments ?? 0)</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-people me-2"></i>Nhân viên</span>
                    <span class="fw-bold">@totalEmployees</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-bullseye me-2"></i>OKR đang hoạt động</span>
                    <span class="fw-bold">@totalOKRs</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-speedometer2 me-2"></i>KPI đang hoạt động</span>
                    <span class="fw-bold">@totalKPIs</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-person-hearts me-2"></i>Khách hàng</span>
                    <span class="fw-bold">@(ViewBag.TotalCustomers ?? 0)</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2">
                    <span class="text-muted"><i class="bi bi-cart me-2"></i>Đơn hàng</span>
                    <span class="fw-bold">@(ViewBag.TotalOrders ?? 0)</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Load OKR Data
            fetch('/Dashboard/GetOKRProgress')
                .then(res => res.json())
                .then(data => {
                    var okrOptions = {
                        series: [{
                            name: '% Hoàn thành',
                            data: data.data
                        }],
                        chart: {
                            type: 'bar',
                            height: 350,
                            toolbar: { show: false }
                        },
                        colors: ['#0d6efd'],
                        plotOptions: {
                            bar: {
                                borderRadius: 4,
                                horizontal: false,
                                columnWidth: '55%',
                            }
                        },
                        dataLabels: {
                            enabled: true,
                            formatter: function (val) { return val + "%"; }
                        },
                        stroke: { show: true, width: 2, colors: ['transparent'] },
                        xaxis: { categories: data.labels },
                        yaxis: {
                            title: { text: '% Tiến độ' },
                            max: 100
                        },
                        fill: { opacity: 1 },
                        tooltip: {
                            y: { formatter: function (val) { return val + "%" } }
                        }
                    };
                    var okrChart = new ApexCharts(document.querySelector("#okrChart"), okrOptions);
                    okrChart.render();
                });

            // Load KPI Trend Data
            fetch('/Dashboard/GetKPITrend')
                .then(res => res.json())
                .then(data => {
                    var kpiOptions = {
                        series: [{
                            name: 'Trung bình KPI',
                            data: data.data
                        }],
                        chart: {
                            height: 350,
                            type: 'line',
                            zoom: { enabled: false },
                            toolbar: { show: false }
                        },
                        colors: ['#198754'],
                        dataLabels: { enabled: true },
                        stroke: { curve: 'smooth' },
                        xaxis: { categories: data.labels },
                        yaxis: {
                            title: { text: '% Hoàn thành trung bình' },
                            max: 100
                        },
                        tooltip: {
                            y: { formatter: function (val) { return val + "%" } }
                        }
                    };
                    var kpiChart = new ApexCharts(document.querySelector("#kpiTrendChart"), kpiOptions);
                    kpiChart.render();
                });
        });
    </script>
}
