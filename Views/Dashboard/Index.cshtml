@* ============ TOP EMPLOYEES ============ *@
@if (topEmployees != null && topEmployees.Any())
{
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fs-6 fw-bold"><i class="bi bi-trophy-fill text-warning"></i> Top 5 nhân viên hiệu suất cao</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4 py-3" style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Xếp hạng</th>
                                <th class="px-4 py-3" style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Nhân viên</th>
                                <th class="px-4 py-3" style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Tiến độ TB (%)</th>
                                <th class="px-4 py-3" style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Lượt Check-in</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int rank = 1; }
                            @foreach (var emp in topEmployees)
                            {
                                var medalIcon = rank switch {
                                    1 => "🥇",
                                    2 => "🥈",
                                    3 => "🥉",
                                    _ => $"#{rank}"
                                };
                                double progress = (double)emp.AvgProgress;
                                var progressColor = progress >= 100 ? "success" : progress >= 70 ? "primary" : progress >= 40 ? "warning" : "danger";
                                <tr>
                                    <td class="px-4 py-3 fw-bold">@medalIcon</td>
                                    <td class="px-4 py-3">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 0.75rem; font-weight: 700;">
                                                @(((string)emp.Name)?[0])
                                            </div>
                                            <span class="fw-medium">@emp.Name</span>
                                        </div>
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height: 8px; border-radius: 4px;">
                                                <div class="progress-bar bg-@progressColor" role="progressbar" style="width: @(Math.Min(progress, 100))%"></div>
                                            </div>
                                            <span class="fw-bold text-@progressColor" style="min-width: 50px; font-size: 0.85rem;">@emp.AvgProgress%</span>
                                        </div>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span class="badge bg-light text-dark border">@emp.CheckInCount lần</span>
                                    </td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
}

@section Scripts {
    <script>
        // Lấy dữ liệu THỰC từ Controller (đã được serialize thành JSON)
        const okrLabels = @Html.Raw(ViewBag.OKRStatusLabels ?? "[]");
        const okrData = @Html.Raw(ViewBag.OKRStatusData ?? "[]");
        const deptLabels = @Html.Raw(ViewBag.DeptLabels ?? "[]");
        const deptProgress = @Html.Raw(ViewBag.DeptProgress ?? "[]");
        const mainLabels = @Html.Raw(ViewBag.MainChartLabels ?? "[]");
        const mainData = @Html.Raw(ViewBag.MainChartData ?? "[]");

        // --- 1. BIỂU ĐỒ XU HƯỚNG 6 THÁNG GẦN NHẤT ---
        const ctxMain = document.getElementById('mainDashboardChart').getContext('2d');
        new Chart(ctxMain, {
            type: 'line',
            data: {
                labels: mainLabels,
                datasets: [{
                    label: 'Tiến độ trung bình (%)',
                    data: mainData,
                    borderColor: '#1a73e8',
                    backgroundColor: 'rgba(26, 115, 232, 0.08)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 5,
                    pointBackgroundColor: '#1a73e8',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    pointHoverRadius: 7
                }]
            },
            options: {
                maintainAspectRatio: false,
                plugins: { 
                    legend: { display: true, position: 'top', labels: { usePointStyle: true, font: { size: 12 } } },
                    tooltip: { 
                        backgroundColor: 'rgba(0,0,0,0.8)', padding: 12,
                        callbacks: { label: ctx => `Tiến độ: ${ctx.parsed.y}%` }
                    }
                },
                scales: {
                    x: { grid: { display: false } },
                    y: { beginAtZero: true, max: 100, ticks: { callback: value => value + '%' } }
                }
            }
        });

        // --- 2. BIỂU ĐỒ TRẠNG THÁI OKR ---
        const ctxStatus = document.getElementById('okrStatusChart').getContext('2d');
        const hasOkrData = okrData.some(v => v > 0);
        new Chart(ctxStatus, {
            type: 'doughnut',
            data: {
                labels: hasOkrData ? okrLabels : ['Chưa có dữ liệu'],
                datasets: [{
                    data: hasOkrData ? okrData : [1],
                    backgroundColor: hasOkrData ? ['#0f9d58', '#f29900', '#1a73e8', '#d93025', '#5e35b1', '#7c4dff'] : ['#e3e8ef'],
                    borderWidth: 0,
                    hoverOffset: 15
                }]
            },
            options: {
                maintainAspectRatio: false,
                cutout: '72%',
                plugins: {
                    legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20, font: { size: 11 } } }
                }
            }
        });

        // --- 3. BIỂU ĐỒ HIỆU SUẤT PHÒNG BAN ---
        const ctxDept = document.getElementById('deptPerformanceChart').getContext('2d');
        const hasDeptData = deptProgress.length > 0 && deptProgress.some(v => v > 0);
        if (hasDeptData) {
            new Chart(ctxDept, {
                type: 'bar',
                data: {
                    labels: deptLabels,
                    datasets: [{
                        label: 'Hiệu suất TB (%)',
                        data: deptProgress,
                        backgroundColor: deptProgress.map(v => v >= 70 ? '#0f9d58' : v >= 40 ? '#f29900' : '#d93025'),
                        hoverBackgroundColor: '#1557b0',
                        borderRadius: 8,
                        barThickness: 24
                    }]
                },
                options: {
                    indexAxis: 'y',
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { grid: { display: false }, ticks: { padding: 10 } },
                        x: { beginAtZero: true, max: 100, ticks: { callback: value => value + '%' } }
                    }
                }
            });
        } else {
            ctxDept.canvas.parentElement.innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-bar-chart opacity-25" style="font-size: 3rem;"></i><p class="mt-2 mb-0">Chưa có dữ liệu hiệu suất phòng ban</p></div>';
        }
    </script>
}
