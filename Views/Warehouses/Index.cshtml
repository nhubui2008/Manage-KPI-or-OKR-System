@model List<Manage_KPI_or_OKR_System.Models.Warehouse>
@{ ViewData["Title"] = "Danh sách Kho"; }
@if (TempData["SuccessMessage"] != null)
{<div class="alert alert-success alert-dismissible fade show" role="alert"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}
@if (TempData["ErrorMessage"] != null)
{<div class="alert alert-danger alert-dismissible fade show" role="alert"><i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="h3 font-weight-bold mb-1">Danh sách Kho</h1><div class="page-breadcrumb"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a><i class="bi bi-chevron-right separator"></i><span class="text-dark opacity-75">Kho</span><i class="bi bi-chevron-right separator"></i><span class="text-dark fw-bold">Danh sách kho</span></div></div>
    <div class="d-flex justify-content-end gap-2"><a asp-action="Create" class="btn-primary-custom d-flex align-items-center text-decoration-none"><i class="bi bi-plus-lg me-1"></i> Thêm kho mới</a></div>
</div>

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100"><div class="card-body-custom">
    <div class="table-responsive w-100"><table class="data-table w-100">
        <thead><tr><th>Mã kho</th><th>Tên kho</th><th>Địa chỉ</th><th>Trạng thái</th><th class="text-end">Thao tác</th></tr></thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var w in Model)
                {
                    <tr>
                        <td class="fw-bold text-dark">@w.WarehouseCode</td>
                        <td class="fw-semibold text-dark">@w.WarehouseName</td>
                        <td class="text-muted">@(w.Address ?? "—")</td>
                        <td><span class="status-badge active"><span class="status-dot"></span> Hoạt động</span></td>
                        <td><div class="action-btns justify-content-end">
                            <button type="button" class="action-btn" title="Sửa" onclick="showComingSoonToast('Chỉnh sửa Kho')"><i class="bi bi-pencil-square"></i></button>
                            <form asp-action="Delete" method="post" style="display:inline;"><input type="hidden" name="id" value="@w.Id" /><button type="submit" class="action-btn danger" title="Xóa" onclick="return confirm('Vô hiệu hóa kho?')"><i class="bi bi-trash"></i></button></form>
                        </div></td>
                    </tr>
                }
            }
            else
            {<tr><td colspan="5" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;"></i><p class="mt-2">Chưa có kho nào</p></td></tr>}
        </tbody>
    </table></div>
</div></div>


        </div>
    </div>
</div>