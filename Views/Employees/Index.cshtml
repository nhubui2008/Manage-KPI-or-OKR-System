@model IEnumerable<Manage_KPI_or_OKR_System.Models.Employee>
@{
    ViewData["Title"] = "Quản lý Nhân sự";
    var assignments = ViewBag.Assignments as Dictionary<int, Manage_KPI_or_OKR_System.Models.EmployeeAssignment> ?? new Dictionary<int, Manage_KPI_or_OKR_System.Models.EmployeeAssignment>();
    var departments = ViewBag.Departments as Dictionary<int, string> ?? new Dictionary<int, string>();
    var positions = ViewBag.Positions as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="page-header">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Quản lý Nhân sự</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Nhân sự</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn-outline-custom">
            <i class="bi bi-file-earmark-excel"></i> Nhập Excel
        </button>
        <button class="btn-primary-custom" data-bs-toggle="modal" data-bs-target="#createEmployeeModal">
            <i class="bi bi-plus-lg"></i> Thêm nhân viên mới
        </button>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success shadow-sm border-0 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
    </div>
}

<div class="content-card">
    <div class="card-body-custom">
        <div class="toolbar">
            <div class="toolbar-left">
                <div class="toolbar-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Tìm kiếm theo mã, tên, SĐT...">
                </div>
                <select class="filter-select">
                    <option value="">Tất cả phòng ban</option>
                    @foreach (var dept in departments)
                    {
                        <option value="@dept.Key">@dept.Value</option>
                    }
                </select>
                <select class="filter-select">
                    <option value="">Trạng thái</option>
                    <option value="active">Đang làm việc</option>
                    <option value="inactive">Đã nghỉ việc</option>
                </select>
            </div>
            <div class="toolbar-right">
                <button class="btn btn-sm btn-outline-secondary border-0"><i class="bi bi-arrow-clockwise"></i></button>
                <button class="btn btn-sm btn-outline-secondary border-0"><i class="bi bi-funnel"></i></button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Thông tin nhân viên</th>
                        <th>Phòng ban</th>
                        <th>Chức vụ</th>
                        <th>Liên hệ</th>
                        <th>Ngày vào làm</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var emp in Model)
                        {
                            var hasAssignment = assignments.TryGetValue(emp.Id, out var assign);
                            var deptName = hasAssignment && assign.DepartmentId.HasValue && departments.ContainsKey(assign.DepartmentId.Value) 
                                           ? departments[assign.DepartmentId.Value] : "Chưa phân bổ";
                            var posName = hasAssignment && assign.PositionId.HasValue && positions.ContainsKey(assign.PositionId.Value) 
                                           ? positions[assign.PositionId.Value] : "Chưa phân bổ";
                            var statusClass = emp.IsActive == true ? "active" : "inactive";
                            var statusDot = emp.IsActive == true ? "" : "text-danger bg-danger";
                            var statusText = emp.IsActive == true ? "Đang làm việc" : "Đã nghỉ việc";
                            var avatarLetter = !string.IsNullOrEmpty(emp.FullName) ? emp.FullName[0].ToString().ToUpper() : "U";

                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="user-avatar bg-primary text-white d-flex justify-content-center align-items-center" style="width: 36px; height: 36px; font-weight: bold;">
                                            @avatarLetter
                                        </div>
                                        <div>
                                            <div class="fw-semibold text-dark">@emp.FullName</div>
                                            <div class="text-muted" style="font-size: 0.75rem;">@emp.EmployeeCode</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@deptName</td>
                                <td>@posName</td>
                                <td>
                                    <div class="text-dark" style="font-size: 0.85rem;"><i class="bi bi-envelope text-muted me-1"></i>@emp.Email</div>
                                    <div class="text-muted" style="font-size: 0.75rem;"><i class="bi bi-telephone text-muted me-1"></i>@emp.Phone</div>
                                </td>
                                <td>@(emp.JoinDate?.ToString("dd/MM/yyyy"))</td>
                                <td><span class="status-badge @statusClass"><span class="status-dot @statusDot"></span> @statusText</span></td>
                                <td>
                                    <div class="action-btns justify-content-end">
                                        <button class="action-btn" title="Xem chi tiết"><i class="bi bi-eye"></i></button>
                                        <button class="action-btn" title="Thay đổi phòng ban/chức vụ"><i class="bi bi-briefcase"></i></button>
                                        @if (emp.IsActive == true)
                                        {
                                            <form asp-action="Delete" asp-route-id="@emp.Id" method="post" class="m-0" onsubmit="return confirm('Xác nhận cho nhân viên này nghỉ việc?');">
                                                <button type="submit" class="action-btn danger" title="Nghỉ việc"><i class="bi bi-person-dash"></i></button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">Chưa có nhân viên nào trong hệ thống.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Thêm Nhân Viên -->
<div class="modal fade" id="createEmployeeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-person-plus text-primary me-2"></i>Thêm Nhân Viên Mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-controller="Employees" asp-action="Create" method="post">
                    <div class="row g-3">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Mã nhân viên <span class="text-danger">*</span></label>
                            <input type="text" name="EmployeeCode" class="form-control" placeholder="VD: NV001" required>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Họ và tên <span class="text-danger">*</span></label>
                            <input type="text" name="FullName" class="form-control" placeholder="Tên đầy đủ" required>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Email <span class="text-danger">*</span></label>
                            <input type="email" name="Email" class="form-control" placeholder="Email công ty" required>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Số điện thoại</label>
                            <input type="text" name="Phone" class="form-control" placeholder="Số điện thoại liên hệ">
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Phòng ban</label>
                            <select name="departmentId" class="form-select">
                                <option value="0">-- Chọn phòng ban --</option>
                                @foreach (var dept in departments)
                                {
                                    <option value="@dept.Key">@dept.Value</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Chức vụ</label>
                            <select name="positionId" class="form-select">
                                <option value="0">-- Chọn chức vụ --</option>
                                @foreach (var pos in positions)
                                {
                                    <option value="@pos.Key">@pos.Value</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ngày vào làm</label>
                            <input type="date" name="JoinDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Mã số thuế</label>
                            <input type="text" name="TaxCode" class="form-control" placeholder="MST Cá nhân">
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-3 pt-3 border-top">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Lưu nhân viên</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
