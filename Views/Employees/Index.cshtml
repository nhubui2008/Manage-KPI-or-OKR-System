@{
    ViewData["Title"] = "Quản lý Nhân sự";
}

<div class="page-header">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Quản lý Nhân sự</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Nhân sự</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn-outline-custom">
            <i class="bi bi-file-earmark-excel"></i> Nhập Excel
        </button>
        <button class="btn-primary-custom">
            <i class="bi bi-plus-lg"></i> Thêm nhân viên mới
        </button>
    </div>
</div>

<div class="content-card">
    <div class="card-body-custom">
        <div class="toolbar">
            <div class="toolbar-left">
                <div class="toolbar-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Tìm kiếm theo mã, tên, SĐT...">
                </div>
                <select class="filter-select">
                    <option value="">Tất cả phòng ban</option>
                    <option value="1">Ban Giám đốc</option>
                    <option value="2">Phòng Kinh doanh</option>
                    <option value="3">Phòng Nhân sự</option>
                    <option value="4">Phòng Kho vận</option>
                </select>
                <select class="filter-select">
                    <option value="">Trạng thái</option>
                    <option value="active">Đang làm việc</option>
                    <option value="inactive">Đã nghỉ việc</option>
                </select>
            </div>
            <div class="toolbar-right">
                <button class="btn btn-sm btn-outline-secondary border-0"><i class="bi bi-arrow-clockwise"></i></button>
                <button class="btn btn-sm btn-outline-secondary border-0"><i class="bi bi-funnel"></i></button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 40px;"><input type="checkbox" class="form-check-input"></th>
                        <th>Thông tin nhân viên</th>
                        <th>Phòng ban</th>
                        <th>Chức vụ</th>
                        <th>Ngày vào làm</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="user-avatar" style="width: 36px; height: 36px;">VA</div>
                                <div>
                                    <div class="fw-semibold text-dark">Nguyễn Văn An</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">NV002 • vana@vietmach.com</div>
                                </div>
                            </div>
                        </td>
                        <td>Phòng Kinh doanh</td>
                        <td>Trưởng phòng</td>
                        <td>01/03/2021</td>
                        <td><span class="status-badge active"><span class="status-dot"></span> Đang làm việc</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="Xem chi tiết"><i class="bi bi-eye"></i></button>
                                <button class="action-btn" title="Chỉnh sửa"><i class="bi bi-pencil"></i></button>
                                <button class="action-btn danger" title="Xóa"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="user-avatar bg-info" style="width: 36px; height: 36px;">TB</div>
                                <div>
                                    <div class="fw-semibold text-dark">Trần Thị Bình</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">NV003 • thib@vietmach.com</div>
                                </div>
                            </div>
                        </td>
                        <td>Phòng Nhân sự</td>
                        <td>Trưởng phòng</td>
                        <td>15/06/2021</td>
                        <td><span class="status-badge active"><span class="status-dot"></span> Đang làm việc</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="Xem chi tiết"><i class="bi bi-eye"></i></button>
                                <button class="action-btn" title="Chỉnh sửa"><i class="bi bi-pencil"></i></button>
                                <button class="action-btn danger" title="Xóa"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="user-avatar bg-success" style="width: 36px; height: 36px;">LC</div>
                                <div>
                                    <div class="fw-semibold text-dark">Lê Văn Cường</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">NV004 • vanc@vietmach.com</div>
                                </div>
                            </div>
                        </td>
                        <td>Phòng Kinh doanh</td>
                        <td>Nhân viên</td>
                        <td>10/01/2022</td>
                        <td><span class="status-badge active"><span class="status-dot"></span> Đang làm việc</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="Xem chi tiết"><i class="bi bi-eye"></i></button>
                                <button class="action-btn" title="Chỉnh sửa"><i class="bi bi-pencil"></i></button>
                                <button class="action-btn danger" title="Xóa"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="user-avatar bg-warning" style="width: 36px; height: 36px;">TD</div>
                                <div>
                                    <div class="fw-semibold text-dark">Phạm Thị Dung</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">NV005 • thid@vietmach.com</div>
                                </div>
                            </div>
                        </td>
                        <td>Phòng Kho vận</td>
                        <td>Nhân viên</td>
                        <td>01/06/2022</td>
                        <td><span class="status-badge active"><span class="status-dot"></span> Đang làm việc</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="action-btn" title="Xem chi tiết"><i class="bi bi-eye"></i></button>
                                <button class="action-btn" title="Chỉnh sửa"><i class="bi bi-pencil"></i></button>
                                <button class="action-btn danger" title="Xóa"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="pagination-custom mt-3">
            <div>Hiển thị 1-4 trong số 124 bản ghi</div>
            <div class="pagination-pages">
                <a href="#" class="page-btn"><i class="bi bi-chevron-left"></i></a>
                <a href="#" class="page-btn active">1</a>
                <a href="#" class="page-btn">2</a>
                <a href="#" class="page-btn">3</a>
                <span class="px-2 text-muted">...</span>
                <a href="#" class="page-btn">13</a>
                <a href="#" class="page-btn"><i class="bi bi-chevron-right"></i></a>
            </div>
        </div>
    </div>
</div>
