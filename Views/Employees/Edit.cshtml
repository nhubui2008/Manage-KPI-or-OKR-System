@model Manage_KPI_or_OKR_System.Controllers.EmployeeViewModel

@{
    ViewData["Title"] = "Cập nhật Nhân viên";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark fw-bold">
                    <h5 class="mb-0"><i class="fas fa-user-edit me-2"></i> Cập Nhật Thông Tin Nhân Viên</h5>
                </div>
                <div class="card-body p-4">
                    
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />

                        <h6 class="text-uppercase text-muted fw-bold mb-3 border-bottom pb-2">1. Thông tin cá nhân</h6>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Mã nhân viên <span class="text-danger">*</span></label>
                                <input asp-for="EmployeeCode" class="form-control" required />
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Họ và tên <span class="text-danger">*</span></label>
                                <input asp-for="FullName" class="form-control" required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Email</label>
                                <input asp-for="Email" type="email" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Số điện thoại</label>
                                <input asp-for="Phone" class="form-control" />
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Ngày sinh</label>
                                <input asp-for="DateOfBirth" type="date" class="form-control" />
                            </div>
                        </div>

                        <h6 class="text-uppercase text-muted fw-bold mb-3 mt-3 border-bottom pb-2">2. Cập nhật Phòng Ban & Chức Danh</h6>
                        <div class="row bg-light p-3 rounded">
                            
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Chọn phòng ban <span class="text-danger">*</span></label>
                                <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.Departments" required>
                                    <option value="">-- Vui lòng chọn --</option>
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Chọn chức danh <span class="text-danger">*</span></label>
                                <select asp-for="PositionId" class="form-select" asp-items="ViewBag.Positions" required>
                                    <option value="">-- Vui lòng chọn --</option>
                                </select>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-1"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-warning px-4 fw-bold">
                                <i class="fas fa-save me-1"></i> Lưu Cập Nhật
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>