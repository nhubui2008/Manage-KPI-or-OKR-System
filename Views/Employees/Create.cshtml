@model Manage_KPI_or_OKR_System.Models.Employee

@{
    ViewData["Title"] = "Thêm Nhân Viên";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-dark fw-bold">
                <i class="bi bi-person-plus-fill me-2"></i>Thêm Nhân Viên Mới
            </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-dark text-decoration-none opacity-75">Danh sách nhân viên</a></li>
                    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Thêm mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="content-card rounded-3">
        <div class="card-body-custom p-4">
            
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-dark alert-dismissible fade show shadow-sm" role="alert">
                    <strong><i class="bi bi-exclamation-triangle-fill me-2"></i> Lỗi!</strong> @ViewBag.ErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="EmployeeCode" class="form-label fw-bold text-dark">Mã nhân viên <span class="badge bg-dark bg-opacity-10 text-dark">Tự động</span></label>
                        <div class="input-group">
                            <input asp-for="EmployeeCode" class="form-control" value="@(ViewData["NextEmployeeCode"] ?? "")" readonly />
                            <span class="input-group-text" title="Mã này được tự động sinh">
                                <i class="bi bi-info-circle"></i>
                            </span>
                        </div>
                        <small class="text-muted d-block mt-1">Hệ thống sẽ tự động gán mã: @ViewData["NextEmployeeCode"]</small>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label fw-bold text-dark">Họ và tên <span class="text-danger">*</span></label>
                        <input asp-for="FullName" class="form-control" placeholder="Nhập đầy đủ họ tên" required />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="DateOfBirth" class="form-label fw-bold text-dark">Ngày sinh</label>
                        <input asp-for="DateOfBirth" type="date" class="form-control" />
                        <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="JoinDate" class="form-label fw-bold text-dark">Ngày vào làm</label>
                        <input asp-for="JoinDate" type="date" class="form-control" />
                        <span asp-validation-for="JoinDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label fw-semibold">Số điện thoại <span class="text-danger">*</span></label>

                        <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại liên hệ" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-semibold">Email công việc <span class="text-danger">*</span></label>

                        <input asp-for="Email" type="email" class="form-control" placeholder="Nhập địa chỉ email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="TaxCode" class="form-label fw-bold text-dark">Mã số thuế</label>
                        <input asp-for="TaxCode" class="form-control" placeholder="Nhập MST (nếu có)" />
                        <span asp-validation-for="TaxCode" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label for="SystemUserId" class="form-label fw-bold text-dark">Tài khoản đăng nhập (Liên kết)</label>
                        <select asp-for="SystemUserId" class="form-select" asp-items="ViewBag.SystemUserId">
                            <option value="">-- Chọn tài khoản (Không bắt buộc) --</option>
                        </select>
                        <span asp-validation-for="SystemUserId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label for="DepartmentId" class="form-label fw-bold text-dark">Phòng ban</label>
                        <select name="departmentId" class="form-select" asp-items="ViewBag.DepartmentId">
                            <option value="">-- Chọn phòng ban (Không bắt buộc) --</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label for="PositionId" class="form-label fw-bold text-dark">Vị trí công việc</label>
                        <select name="positionId" class="form-select" asp-items="ViewBag.PositionId">
                            <option value="">-- Chọn vị trí (Không bắt buộc) --</option>
                        </select>
                    </div>

                    <div class="col-12 mt-4 text-dark fw-bold">
                        <div class="form-check form-switch fs-5">
                            <input type="checkbox" class="form-check-input" id="isActiveSwitch" name="IsActive" value="true" checked />
                            <input type="hidden" name="IsActive" value="false" />
                            <label class="form-check-label fw-semibold ms-2" style="font-size: 1rem; margin-top: 2px;" for="isActiveSwitch">Đang làm việc (Kích hoạt)</label>

                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                    <a asp-action="Index" class="btn-outline-custom px-4 text-decoration-none">
                        <i class="bi bi-x-circle me-1"></i> Hủy bỏ
                    </a>
                    <button type="submit" class="btn-primary-custom px-4">
                        <i class="bi bi-save me-1"></i> Lưu Nhân Viên
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}