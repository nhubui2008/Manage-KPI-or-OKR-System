@model Manage_KPI_or_OKR_System.Models.OKR

@{
    ViewData["Title"] = "Khởi tạo OKR";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-content py-4 container-fluid px-4">
    <!-- HEADER -->
    <div class="page-header d-flex align-items-center justify-content-between mb-4 animate__animated animate__fadeIn">
        <div>
            <h1 class="mb-2 fw-800 text-dark text-gradient">Thiết lập OKR Mới</h1>
            <div class="page-breadcrumb">
                <a href="/" class="text-decoration-none opacity-75">Trang chủ</a>
                <span class="separator mx-2 text-muted">/</span>
                <a asp-action="Index" class="text-decoration-none opacity-75">Quản lý OKR</a>
                <span class="separator mx-2 text-muted">/</span>
                <span class="text-primary fw-bold">Khởi tạo</span>
            </div>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-light shadow-sm border-0 bg-white px-4 py-2" style="border-radius: 12px; font-weight: 600; color: #475569; transition: all 0.3s;">
                <i class="bi bi-arrow-left me-2"></i> Quay lại danh sách
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- FORM COLUMN -->
        <div class="col-xl-8 animate__animated animate__fadeInLeft">
            <div class="content-card border-0 shadow-lg overflow-hidden" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(15px); border-radius: 20px;">
                <div class="card-header-custom border-bottom bg-white bg-opacity-50 py-4 px-4" style="border-radius: 24px 24px 0 0;">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3">
                            <i class="bi bi-bullseye text-primary fs-4"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold fs-5 mb-0 text-dark">Chi tiết Mục tiêu (Objective)</h5>
                            <p class="text-muted small mb-0">Xây dựng mục tiêu tầm nhìn rõ ràng và truyền cảm hứng cho tổ chức</p>
                        </div>
                    </div>
                </div>
                
                <div class="card-body-custom p-4">
                    <form asp-action="Create" method="post" id="createOkrForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <!-- SECTION 1: CẤU HÌNH MỤC TIÊU -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-primary text-white me-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 32px; height: 32px; border-radius: 10px; font-weight: 700;">
                                1
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1 small">Thông tin cơ bản</h6>
                        </div>

                        <div class="row g-4 mb-5 p-4 rounded-4 bg-light bg-opacity-40 border border-white position-relative overflow-hidden">
                            <div class="col-12">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Tên Mục tiêu (Objective) <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-pencil-square"></i>
                                        <input asp-for="ObjectiveName" class="form-control shadow-sm border-0" placeholder="VD: Tăng cường mức độ hài lòng của khách hàng trong Q2" required />
                                    </div>
                                    <span asp-validation-for="ObjectiveName" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="premium-select-wrapper">
                                    <span class="select-label">Loại OKR</span>
                                    <i class="bi bi-tag lead-icon"></i>
                                    <select name="OKRTypeId" required>
                                        <option value="">-- Chọn loại mục tiêu --</option>
                                        @if (ViewBag.OKRTypes != null)
                                        {
                                            foreach (var type in ViewBag.OKRTypes as IEnumerable<Manage_KPI_or_OKR_System.Models.OKRType>)
                                            {
                                                <option value="@type.Id">@type.TypeName</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="premium-select-wrapper">
                                    <span class="select-label">Chu kỳ thực hiện</span>
                                    <i class="bi bi-calendar3 lead-icon"></i>
                                    <select name="Cycle" required>
                                        <option value="Q1-@DateTime.Now.Year">Quý 1 - @DateTime.Now.Year</option>
                                        <option value="Q2-@DateTime.Now.Year">Quý 2 - @DateTime.Now.Year</option>
                                        <option value="Q3-@DateTime.Now.Year">Quý 3 - @DateTime.Now.Year</option>
                                        <option value="Q4-@DateTime.Now.Year">Quý 4 - @DateTime.Now.Year</option>
                                        <option value="Năm @DateTime.Now.Year">Cả năm @DateTime.Now.Year</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- SECTION 2: PHÂN BỔ CHIẾN LƯỢC -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-success text-white me-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 32px; height: 32px; border-radius: 10px; font-weight: 700;">
                                2
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1 small">Gắn kết chiến lược & Phân bổ</h6>
                        </div>

                        <div class="row g-4 p-4 rounded-4 bg-light bg-opacity-40 border border-white mb-4">
                            <div class="col-12">
                                <div class="premium-select-wrapper">
                                    <span class="select-label">Tầm nhìn Chiến lược liên kết</span>
                                    <i class="bi bi-diagram-3 lead-icon"></i>
                                    <select name="missionId">
                                        <option value="">-- Không phân bổ (Cấp độ phòng ban/cá nhân) --</option>
                                        @if (ViewBag.Missions != null)
                                        {
                                            foreach (var m in ViewBag.Missions as IEnumerable<Manage_KPI_or_OKR_System.Models.MissionVision>)
                                            {
                                                <option value="@m.Id">Năm @m.TargetYear: @(m.Content?.Length > 60 ? m.Content.Substring(0, 60) + "..." : m.Content)</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="premium-select-wrapper">
                                    <span class="select-label">Phòng ban phụ trách</span>
                                    <i class="bi bi-building lead-icon"></i>
                                    <select name="departmentId">
                                        <option value="">-- Áp dụng cho toàn tổ chức hoặc cá nhân --</option>
                                        @if (ViewBag.Departments != null)
                                        {
                                            foreach (var d in ViewBag.Departments as IEnumerable<Manage_KPI_or_OKR_System.Models.Department>)
                                            {
                                                <option value="@d.Id">@d.DepartmentName</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="premium-select-wrapper">
                                    <span class="select-label">Nhân viên chịu trách nhiệm</span>
                                    <i class="bi bi-person-check lead-icon"></i>
                                    <select name="employeeId">
                                        <option value="">-- Không phân bổ cá nhân --</option>
                                        @if (ViewBag.Employees != null)
                                        {
                                            foreach (var e in ViewBag.Employees as IEnumerable<Manage_KPI_or_OKR_System.Models.Employee>)
                                            {
                                                <option value="@e.Id">@e.FullName (@e.EmployeeCode)</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                            <a asp-action="Index" class="btn-outline-custom" style="padding: 10px 24px; border-radius: 10px; font-size: 0.95rem;">
                                <i class="bi bi-x-lg me-2"></i> Hủy bỏ
                            </a>
                            <button type="submit" class="btn-primary-custom" style="padding: 10px 30px; border-radius: 10px; font-size: 0.95rem;">
                                <i class="bi bi-rocket-takeoff me-2"></i> Khởi tạo OKR
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- SIDEBAR COLUMN -->
        <div class="col-xl-4 animate__animated animate__fadeInRight">
            <div class="sticky-top" style="top: 100px;">
                <!-- TIPS CARD -->
                <div class="content-card border-0 shadow-lg text-white mb-4 position-relative overflow-hidden" 
                     style="background: linear-gradient(135deg, #0078d4, #005a9e); border-radius: 24px;">
                    <div style="position:absolute;top:-30px;right:-30px;width:120px;height:120px;background:rgba(255,255,255,0.07);border-radius:50%;"></div>
                    <div style="position:absolute;bottom:-20px;left:-20px;width:80px;height:80px;background:rgba(255,255,255,0.05);border-radius:50%;"></div>
                    <div class="card-body-custom p-4 position-relative z-index-1">
                        <div class="d-flex align-items-center mb-4">
                            <div class="me-3 flex-shrink-0" style="width:56px;height:56px;background:linear-gradient(135deg,#f59e0b,#d97706);border-radius:16px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 15px rgba(245,158,11,0.4);">
                                <i class="bi bi-lightbulb-fill fs-3 text-white"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold text-uppercase small" style="opacity:0.8;letter-spacing:0.08em;">Gợi ý thiết lập</h6>
                                <h4 class="mb-0 fw-800">Quy tắc OKR</h4>
                            </div>
                        </div>
                        
                        <div class="mb-4">
                            <h6 class="fw-bold mb-2">Thế nào là một Objective tốt?</h6>
                            <ul class="list-unstyled mb-0 small" style="opacity: 0.9; line-height: 1.6;">
                                <li class="mb-2 d-flex"><i class="bi bi-check2-circle me-2 fs-5"></i> <span><strong>Tham vọng:</strong> Phải đủ thách thức nhưng không bất khả thi.</span></li>
                                <li class="mb-2 d-flex"><i class="bi bi-check2-circle me-2 fs-5"></i> <span><strong>Ngắn gọn:</strong> Dễ nhớ và truyền cảm hứng cho đội ngũ.</span></li>
                                <li class="d-flex"><i class="bi bi-check2-circle me-2 fs-5"></i> <span><strong>Định hướng hành động:</strong> Chứa đựng mục đích rõ ràng.</span></li>
                            </ul>
                        </div>

                        <div class="bg-white bg-opacity-10 p-3 rounded-4 border border-white border-opacity-10">
                            <p class="small mb-0 italic">"Objective trả lời cho câu hỏi: Chúng ta muốn đạt được cái gì?"</p>
                        </div>
                    </div>
                    <!-- Decorative circles -->
                    <div class="position-absolute" style="top: -20px; right: -20px; width: 100px; height: 100px; background: rgba(255,255,255,0.1); border-radius: 50%;"></div>
                    <div class="position-absolute" style="bottom: -10px; left: -10px; width: 60px; height: 60px; background: rgba(255,255,255,0.05); border-radius: 50%;"></div>
                </div>

                <!-- INFO CARD -->
                <div class="content-card border-0 shadow-sm rounded-4 bg-white p-4">
                    <h6 class="fw-bold text-dark mb-3">
                        <i class="bi bi-info-circle text-primary me-2"></i> Liên kết Chiến lược
                    </h6>
                    <div class="d-flex align-items-start mb-3">
                        <div class="text-primary me-3 mt-1"><i class="bi bi-1-circle"></i></div>
                        <p class="small text-muted mb-0">Hãy gắn OKR này với một <strong>Sứ mệnh/Tầm nhìn</strong> nếu nó đóng góp trực tiếp vào mục tiêu năm của công ty.</p>
                    </div>
                    <div class="d-flex align-items-start mb-3">
                        <div class="text-success me-3 mt-1"><i class="bi bi-2-circle"></i></div>
                        <p class="small text-muted mb-0">Việc phân bổ cho <strong>Phòng ban</strong> giúp các nhóm dễ dàng theo dõi chỉ tiêu chung.</p>
                    </div>
                    <div class="d-flex align-items-start">
                        <div class="text-warning me-3 mt-1"><i class="bi bi-3-circle"></i></div>
                        <p class="small text-muted mb-0">Sau khi khởi tạo Mục tiêu, bạn cần thêm các <strong>Key Results</strong> để đo lường tiến độ.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    .text-gradient { background: linear-gradient(135deg, #1e293b 0%, #334155 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .letter-spacing-1 { letter-spacing: 0.1em; }
    .shadow-primary { box-shadow: 0 10px 25px -5px rgba(0, 120, 212, 0.35); }
    
    /* Premium Form Styling */
    .form-icon-group { position: relative; }
    .form-icon-group .input-wrapper {
        position: relative;
        transition: all 0.3s ease;
        background: #fff;
    }
    .form-icon-group .input-wrapper:focus-within {
        border-color: #0078d4 !important;
        box-shadow: 0 8px 15px -5px rgba(0, 120, 212, 0.15) !important;
        transform: translateY(-1px);
    }
    .form-icon-group .input-wrapper i {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: 1.1rem;
        z-index: 10;
        transition: color 0.3s;
        pointer-events: none;
    }
    .form-icon-group .input-wrapper:focus-within i { color: #0078d4; }
    
    .form-control, .form-select {
        padding: 12px 12px 12px 45px !important;
        border: 1.5px solid #f1f5f9 !important;
        background-color: #f8fafc !important;
        border-radius: 12px !important;
        transition: all 0.3s ease;
    }
    
    .form-control:focus, .form-select:focus {
        background-color: #ffffff !important;
        border-color: #0078d4 !important;
        box-shadow: 0 0 0 4px rgba(0, 120, 212, 0.1) !important;
        color: #1e293b;
    }

    /* Page effects */
    .animate__animated { animation-duration: 0.8s; }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
}
