@{
    ViewData["Title"] = "Quản lý OKR";
}

<div class="page-header">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Mục tiêu và Kết quả then chốt (OKR)</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Quản lý OKR</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn-primary-custom">
            <i class="bi bi-plus-lg"></i> Tạo OKR mới
        </button>
    </div>
</div>

<div class="content-card">
    <div class="card-body-custom">
        <div class="toolbar">
            <div class="toolbar-left">
                <div class="toolbar-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Tìm kiếm OKR...">
                </div>
                <select class="filter-select">
                    <option value="">Quý 1 - 2026</option>
                    <option value="">Quý 2 - 2026</option>
                    <option value="">Năm 2026</option>
                </select>
                <select class="filter-select">
                    <option value="">Loại OKR: Tất cả</option>
                    <option value="1">Công ty</option>
                    <option value="2">Phòng ban</option>
                    <option value="3">Cá nhân</option>
                </select>
                <select class="filter-select">
                    <option value="">Trạng thái</option>
                    <option value="active">Đang thực hiện</option>
                    <option value="completed">Hoàn thành</option>
                </select>
            </div>
            <div class="toolbar-right">
                <button class="btn btn-sm btn-outline-secondary border-0"><i class="bi bi-list-task"></i> Xem dạng danh sách</button>
                <button class="btn btn-sm btn-primary border-0 bg-primary bg-opacity-10 text-primary fw-semibold"><i class="bi bi-diagram-3-fill"></i> Sơ đồ liên kết</button>
            </div>
        </div>

        <!-- OKR Items list -->
        <div class="okr-list">
            
            <!-- OKR Item 1 -->
            <div class="border rounded-3 mb-3 hover-shadow-sm transition-base bg-white overflow-hidden">
                <div class="d-flex align-items-center justify-content-between p-3 border-bottom bg-light bg-opacity-50">
                    <div class="d-flex align-items-start gap-3">
                        <button class="btn btn-sm btn-link text-muted p-0" data-bs-toggle="collapse" data-bs-target="#okr1">
                            <i class="bi bi-chevron-down fs-5"></i>
                        </button>
                        <div>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-2">Công ty</span>
                                <h5 class="mb-0 fw-bold fs-6">Tăng doanh thu Q1 20%</h5>
                            </div>
                            <div class="text-muted" style="font-size: 0.8rem;">
                                <i class="bi bi-person"></i> Ban Giám đốc • 
                                <i class="bi bi-calendar3"></i> Q1-2026
                            </div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-4">
                        <div class="text-end" style="width: 150px;">
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <span class="text-muted" style="font-size: 0.75rem;">Tiến độ chung</span>
                                <span class="fw-bold" style="font-size: 0.85rem;">45%</span>
                            </div>
                            <div class="progress-custom">
                                <div class="progress-bar-custom" style="width: 45%;"></div>
                            </div>
                        </div>
                        <div class="badge bg-warning text-dark px-3 py-2 rounded-pill">Đang thực hiện</div>
                        <div class="action-btns">
                            <button class="action-btn"><i class="bi bi-pencil"></i></button>
                            <button class="action-btn"><i class="bi bi-three-dots-vertical"></i></button>
                        </div>
                    </div>
                </div>
                
                <div id="okr1" class="collapse show">
                    <div class="p-3 bg-white">
                        <h6 class="fs-6 fw-semibold text-muted mb-3"><i class="bi bi-key-fill text-warning me-1"></i> Key Results (Kết quả then chốt)</h6>
                        
                        <!-- KR 1 -->
                        <div class="d-flex align-items-center justify-content-between py-2 border-bottom">
                            <div class="ps-4">
                                <div class="fw-medium text-dark">1. Doanh thu đạt 12 tỷ VNĐ</div>
                                <div class="text-muted" style="font-size: 0.75rem;">Mục tiêu: 12,000,000,000 VNĐ • Cập nhật lần cuối: 15/01/2026</div>
                            </div>
                            <div class="d-flex align-items-center gap-4" style="width: 40%;">
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between mb-1" style="font-size: 0.75rem;">
                                        <span class="text-muted">4.5 tỷ</span>
                                        <span class="fw-bold text-success">37.5%</span>
                                    </div>
                                    <div class="progress-custom" style="height: 4px;">
                                        <div class="progress-bar-custom green" style="width: 37.5%;"></div>
                                    </div>
                                </div>
                                <button class="btn btn-sm btn-outline-primary" style="font-size: 0.75rem;">Check-in</button>
                            </div>
                        </div>
                        
                        <!-- KR 2 -->
                        <div class="d-flex align-items-center justify-content-between py-2 border-bottom">
                            <div class="ps-4">
                                <div class="fw-medium text-dark">2. Ký 10 hợp đồng mới với đối tác chiến lược</div>
                                <div class="text-muted" style="font-size: 0.75rem;">Mục tiêu: 10 Hợp đồng • Cập nhật lần cuối: 12/01/2026</div>
                            </div>
                            <div class="d-flex align-items-center gap-4" style="width: 40%;">
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between mb-1" style="font-size: 0.75rem;">
                                        <span class="text-muted">6 hợp đồng</span>
                                        <span class="fw-bold text-success">60%</span>
                                    </div>
                                    <div class="progress-custom" style="height: 4px;">
                                        <div class="progress-bar-custom green" style="width: 60%;"></div>
                                    </div>
                                </div>
                                <button class="btn btn-sm btn-outline-primary" style="font-size: 0.75rem;">Check-in</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- OKR Item 2 -->
            <div class="border rounded-3 mb-3 hover-shadow-sm transition-base bg-white overflow-hidden">
                <div class="d-flex align-items-center justify-content-between p-3 border-bottom bg-light bg-opacity-50">
                    <div class="d-flex align-items-start gap-3">
                        <button class="btn btn-sm btn-link text-muted p-0 collapsed" data-bs-toggle="collapse" data-bs-target="#okr2">
                            <i class="bi bi-chevron-down fs-5"></i>
                        </button>
                        <div>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-2">Phòng ban</span>
                                <h5 class="mb-0 fw-bold fs-6">Nâng cao chất lượng sản phẩm & Dịch vụ</h5>
                            </div>
                            <div class="text-muted" style="font-size: 0.8rem;">
                                <i class="bi bi-diagram-3"></i> Phòng Sản xuất • 
                                <i class="bi bi-calendar3"></i> Q1-2026
                            </div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-4">
                        <div class="text-end" style="width: 150px;">
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <span class="text-muted" style="font-size: 0.75rem;">Tiến độ chung</span>
                                <span class="fw-bold" style="font-size: 0.85rem;">85%</span>
                            </div>
                            <div class="progress-custom">
                                <div class="progress-bar-custom green" style="width: 85%;"></div>
                            </div>
                        </div>
                        <div class="badge bg-success text-white px-3 py-2 rounded-pill">Sắp hoàn thành</div>
                        <div class="action-btns">
                            <button class="action-btn"><i class="bi bi-pencil"></i></button>
                            <button class="action-btn"><i class="bi bi-three-dots-vertical"></i></button>
                        </div>
                    </div>
                </div>
                
                <div id="okr2" class="collapse">
                    <div class="p-3 bg-white">
                        <h6 class="fs-6 fw-semibold text-muted mb-3"><i class="bi bi-key-fill text-warning me-1"></i> Key Results (Kết quả then chốt)</h6>
                        
                        <div class="d-flex align-items-center justify-content-between py-2 border-bottom">
                            <div class="ps-4">
                                <div class="fw-medium text-dark">1. Giảm lỗi sản phẩm trả về xuống dưới 2%</div>
                                <div class="text-muted" style="font-size: 0.75rem;">Mục tiêu: < 2% • Cập nhật lần cuối: Hôm qua</div>
                            </div>
                            <div class="d-flex align-items-center gap-4" style="width: 40%;">
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between mb-1" style="font-size: 0.75rem;">
                                        <span class="text-muted">2.1%</span>
                                        <span class="fw-bold text-success">95%</span>
                                    </div>
                                    <div class="progress-custom" style="height: 4px;">
                                        <div class="progress-bar-custom green" style="width: 95%;"></div>
                                    </div>
                                </div>
                                <button class="btn btn-sm btn-outline-primary" style="font-size: 0.75rem;">Check-in</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="text-center mt-4">
            <button class="btn btn-outline-secondary btn-sm px-4 rounded-pill">Tải thêm OKR</button>
        </div>
    </div>
</div>

<style>
    /* Styling for the accordion arrows */
    .btn-link[data-bs-toggle="collapse"] i {
        display: inline-block;
        transition: transform 0.3s ease;
    }
    .btn-link[data-bs-toggle="collapse"].collapsed i {
        transform: rotate(-90deg);
    }
</style>
