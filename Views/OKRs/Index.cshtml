@model Manage_KPI_or_OKR_System.Helpers.PaginatedList<Manage_KPI_or_OKR_System.Models.OKR>
@using Manage_KPI_or_OKR_System.Helpers
@{
    ViewData["Title"] = "Quản lý OKR";
    var keyResultsDict = ViewBag.KeyResults as Dictionary<int, List<Manage_KPI_or_OKR_System.Models.OKRKeyResult>> ??
                         new Dictionary<int, List<Manage_KPI_or_OKR_System.Models.OKRKeyResult>>();
    var currentFilter = ViewData["CurrentFilter"] as string;
}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 font-weight-bold mb-1">Mục tiêu và Kết quả then chốt (OKR)</h1>
            <div class="page-breadcrumb">
                <a href="/">Trang chủ</a>
                <i class="bi bi-chevron-right separator"></i>
                <span>Quản lý OKR</span>
            </div>
        </div>
        <div class="d-flex justify-content-end gap-2">
            @if (!(User.IsInRole("Employee") || User.IsInRole("employee") || User.IsInRole("Warehouse") || User.IsInRole("warehouse") || User.IsInRole("Sales") || User.IsInRole("sales")))
            {
                <a asp-action="Create" class="text-decoration-none btn-primary-custom d-flex align-items-center">
                    <i class="bi bi-plus-lg me-1"></i> Tạo OKR mới
                </a>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        </div>
    }

    <div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100">
                <div class="card-body-custom">
                    <!-- SEARCH FORM -->
                    <form asp-action="Index" method="get" class="toolbar mb-3">
                        <div class="toolbar-left" style="width: 400px;">
                            <div class="toolbar-search position-relative">
                                <i class="bi bi-search position-absolute" style="left: 15px; top: 50%; transform: translateY(-50%); color: #6c757d;"></i>
                                <input type="text" name="searchString" value="@currentFilter" class="form-control" style="padding-left: 2.5rem;" placeholder="Tìm kiếm tên mục tiêu OKR..." />
                            </div>
                        </div>
                        <div class="toolbar-right d-flex gap-2">
                            <button type="submit" class="btn btn-primary d-flex align-items-center rounded-pill px-3 shadow-none">
                                <i class="bi bi-search me-1"></i> Tìm kiếm
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary border-0 btn-sm d-flex align-items-center" title="Làm mới">
                                <i class="bi bi-arrow-clockwise fs-5"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-secondary border-0" id="toggleAllBtn"><i class="bi bi-list-task"></i> Mở rộng tất cả</button>
                        </div>
                    </form>

                    <div class="accordion" id="accordionOKRs">
                        @if (Model != null && Model.Any())
                        {
                            int index = 0;
                            var currentEmployeeId = ViewBag.CurrentEmployeeId as int?;
                            var allocatedIds = ViewBag.AllocatedOkrIds as List<int> ?? new List<int>();
                            var deptOkrIds = ViewBag.DepartmentOkrIds as List<int> ?? new List<int>();
                            bool isRestrictedRole = User.IsInRole("Employee") || User.IsInRole("employee") || 
                                                   User.IsInRole("Warehouse") || User.IsInRole("warehouse") || 
                                                   User.IsInRole("Sales") || User.IsInRole("sales");

                            foreach (var okr in Model)
                            {
                                index++;
                                string collapseId = $"collapseOkr{index}";
                                var krs = keyResultsDict.ContainsKey(okr.Id) ? keyResultsDict[okr.Id] : new List<Manage_KPI_or_OKR_System.Models.OKRKeyResult>();
                                
                                bool isOwner = okr.CreatedById == currentEmployeeId;
                                bool isAllocated = allocatedIds.Contains(okr.Id) || deptOkrIds.Contains(okr.Id);
                                
                                bool canManageStructure = !isRestrictedRole;
                                bool canUpdateProgress = true; // All visible OKRs for restricted roles are relevant (Personal, Dept, or Strategic)
                                bool canDelete = !isRestrictedRole;

                                // Sử dụng TotalProgress từ model đã được chuẩn hóa
                                int okrProgressInt = (int)okr.TotalProgress;
                                
                                string okrProgressColor = ProgressHelper.GetProgressColorClass(okrProgressInt);
                                string okrTextClass = ProgressHelper.GetProgressTextColorClass(okrProgressInt);

                                <div class="accordion-item mb-3 border-0 shadow-sm rounded" style="overflow: visible;">
                                    <h2 class="accordion-header position-relative" id="heading-@index">
        
                                        <div class="accordion-button collapsed bg-white p-3 d-flex justify-content-between align-items-center w-100" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId" style="cursor: pointer; box-shadow: none;">
                                            
                                            <div class="d-flex flex-column flex-grow-1 pe-4">
                                                <div class="d-flex align-items-center gap-2 mb-2">
                                                    <span class="badge @okrProgressColor bg-opacity-10 @okrTextClass rounded-pill px-2">Objective (O)</span>
                                                    @if(okr.OKRTypeId == 1){<span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-2"><i class="bi bi-star-fill me-1"></i>Chiến lược công ty</span>}
                                                    <h5 class="mb-0 fw-bold fs-6 text-dark">@okr.ObjectiveName</h5>
                                                </div>
                                                
                                                <div class="d-flex align-items-center gap-4">
                                                    <div class="text-muted" style="font-size: 0.8rem;">
                                                        <i class="bi bi-calendar3"></i> @Html.Raw(okr.Cycle ?? "Chưa rõ chu kỳ")
                                                    </div>
                                                    
                                                    <div class="flex-grow-1" style="max-width: 400px;">
                                                        <div class="d-flex justify-content-between mb-1" style="font-size: 0.75rem;">
                                                            <span class="text-muted">Tiến độ chung:</span>
                                                            <span class="fw-bold">@okrProgressInt%</span>
                                                        </div>
                                                        <div class="progress" style="height: 6px; border-radius: 10px;">
                                                            <div class="progress-bar @okrProgressColor" role="progressbar" style="width: @okrProgressInt%" aria-valuenow="@okrProgressInt" aria-valuemin="0" aria-valuemax="100"></div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            @if (canManageStructure || canDelete)
                                            {
                                                <div style="width: 45px;"></div>
                                            }
                                        </div>

                                        @if (canManageStructure || canDelete)
                                        {
                                            <div class="action-btns dropdown position-absolute" style="right: 50px; top: 50%; transform: translateY(-50%); z-index: 10;" onclick="event.stopPropagation();">
                                                <button class="btn btn-sm btn-light rounded-circle" data-bs-toggle="dropdown" aria-expanded="false"><i class="bi bi-three-dots-vertical"></i></button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                                    @if (canManageStructure)
                                                    {
                                                        <li><a class="dropdown-item" href="javascript:void(0)" onclick="openAddKrModal(@okr.Id, '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(okr.ObjectiveName ?? ""))')"><i class="bi bi-plus me-2 text-warning"></i>Thêm KR</a></li>
                                                        <li><a class="dropdown-item" href="javascript:void(0)" onclick="openAllocateModal(@okr.Id)"><i class="bi bi-person-plus me-2 text-primary"></i>Phân bổ nhân viên</a></li>
                                                        <li><hr class="dropdown-divider"></li>
                                                    }
                                                    @if (canDelete)
                                                    {
                                                        <li>
                                                            <form asp-action="Delete" asp-route-id="@okr.Id" method="post" class="m-0" onsubmit="return confirm('Xác nhận xóa OKR này?');">
                                                                <button type="submit" class="dropdown-item text-danger"><i class="bi bi-trash me-2"></i>Xóa OKR</button>
                                                            </form>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        }
                                        
                                    </h2>

                                    <div id="@collapseId" class="accordion-collapse collapse border-top" aria-labelledby="heading-@index">
                                        <div class="accordion-body bg-light bg-opacity-25 p-3">
                                            <h6 class="fs-6 fw-semibold text-muted mb-3"><i class="bi bi-key-fill text-warning me-1"></i> Key Results (Kết quả then chốt)</h6>
                                            
                                            @if (krs.Any())
                                            {
                                                int krIndex = 1;
                                                foreach (var kr in krs)
                                                {
                                                    var krPercent = (int)kr.Progress;
                                                    
                                                    string krColor = ProgressHelper.GetProgressColorClass(krPercent);
                                                    string krTextClass = ProgressHelper.GetProgressTextColorClass(krPercent);

                                                    <div class="d-flex align-items-center justify-content-between py-3 border-bottom border-light">
                                                        <div class="ps-4" style="flex: 1;">
                                                            <div class="fw-medium text-dark mb-1">@krIndex. @kr.KeyResultName</div>
                                                            <div class="text-muted" style="font-size: 0.75rem;">Mục tiêu: @String.Format("{0:N0}", kr.TargetValue) @kr.Unit</div>
                                                        </div>

                                                        <div class="d-flex align-items-center gap-4" style="width: 45%;">
                                                            <div class="flex-grow-1">
                                                                 <div class="d-flex justify-content-between mb-1" style="font-size: 0.75rem;">
                                                                    <span class="text-muted">Tiến độ: <strong>@String.Format("{0:N1}", kr.CurrentValue ?? 0)</strong>/@String.Format("{0:N0}", kr.TargetValue ?? 0) @kr.Unit</span>
                                                                    <span class="fw-bold">@krPercent%</span>
                                                                </div>
                                                                <div class="progress mb-1" style="height: 6px; border-radius: 10px;">
                                                                    <div class="progress-bar @krColor" role="progressbar" style="width: @krPercent%" aria-valuenow="@krPercent" aria-valuemin="0" aria-valuemax="100"></div>
                                                                </div>
                                                                <div class="d-flex justify-content-between" style="font-size: 0.7rem;">
                                                                    <span class="badge badge-pastel-pink px-2 py-1">@ProgressHelper.GetResultStatus(kr.Progress)</span>
                                                                    @if(kr.IsInverse){<span class="text-info"><i class="bi bi-info-circle me-1"></i>Chỉ tiêu giảm thiểu</span>}
                                                                </div>
                                                            </div>

                                                            @if (canManageStructure || canUpdateProgress)
                                                            {
                                                                <div class="d-flex gap-1">
                                                                    @if (canManageStructure)
                                                                    {
                                                                        <button class="btn btn-sm btn-light-primary text-primary border-0 rounded-circle" 
                                                                                onclick="openEditKrModal(@kr.Id, '@kr.KeyResultName', @(kr.TargetValue ?? 0), @(kr.CurrentValue ?? 0), '@kr.Unit', @(kr.IsInverse.ToString().ToLower()))" title="Sửa KR">
                                                                            <i class="bi bi-pencil-square"></i>
                                                                        </button>
                                                                        <form asp-action="DeleteKeyResult" asp-route-id="@kr.Id" method="post" class="m-0" onsubmit="return confirm('Xóa KR này?');">
                                                                            <button type="submit" class="btn btn-sm btn-light-danger text-danger border-0 rounded-circle" title="Xóa KR">
                                                                                <i class="bi bi-trash"></i>
                                                                            </button>
                                                                        </form>
                                                                    }
                                                                </div>
                                                                @if (canUpdateProgress)
                                                                {
                                                                    <button class="btn btn-sm btn-outline-primary rounded-circle" title="Cập nhật tiến độ" onclick="openUpdateProgressModal(@kr.Id, '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(kr.KeyResultName ?? ""))', @(kr.CurrentValue ?? 0), '@kr.Unit')">
                                                                        <i class="bi bi-pencil"></i>
                                                                    </button>
                                                                }
                                                            }
                                                        </div>
                                                    </div>
                                                    krIndex++;
                                                }
                                            }
                                            else
                                            {
                                                <div class="text-muted fst-italic ps-4 py-2">Chưa có kết quả then chốt nào được thiết lập.</div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="alert alert-info border-0 shadow-sm text-center p-5">
                                <h5>Chưa có mục tiêu OKR nào.</h5>
                                <p class="text-muted mb-0">Hãy bấm "Tạo OKR mới" để thiết lập mục tiêu.</p>
                            </div>
                        }
                    </div>

                    <!-- PAGINATION -->
                    @if (Model != null && Model.TotalPages > 1)
                    {
                        <div class="d-flex justify-content-between align-items-center mt-4 px-2">
                            <div class="text-muted small">
                                Hiển thị trang @Model.PageIndex trên tổng số @Model.TotalPages
                            </div>
                            <nav aria-label="Page navigation">
                                <ul class="pagination pagination-sm mb-0 gap-1">
                                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                                        <a class="page-link border-0 rounded-circle text-dark shadow-none" asp-action="Index" 
                                           asp-route-pageNumber="@(Model.PageIndex - 1)" 
                                           asp-route-searchString="@currentFilter">
                                            <i class="bi bi-chevron-left"></i>
                                        </a>
                                    </li>
                                    
                                    @for (int i = 1; i <= Model.TotalPages; i++)
                                    {
                                        if (i == 1 || i == Model.TotalPages || (i >= Model.PageIndex - 1 && i <= Model.PageIndex + 1))
                                        {
                                            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                                <a class="page-link border-0 rounded-circle shadow-none @(i == Model.PageIndex ? "" : "text-dark")" asp-action="Index" 
                                                   asp-route-pageNumber="@i" 
                                                   asp-route-searchString="@currentFilter">@i</a>
                                            </li>
                                        }
                                        else if (i == Model.PageIndex - 2 || i == Model.PageIndex + 2)
                                        {
                                            <li class="page-item disabled"><span class="page-link border-0">...</span></li>
                                        }
                                    }

                                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                                        <a class="page-link border-0 rounded-circle text-dark shadow-none" asp-action="Index" 
                                           asp-route-pageNumber="@(Model.PageIndex + 1)" 
                                           asp-route-searchString="@currentFilter">
                                            <i class="bi bi-chevron-right"></i>
                                        </a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>


<!-- Modal Add Key Result -->
<div class="modal fade" id="addKrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header-soft warning">
                <h5 class="modal-title-custom">
                    <i class="bi bi-key-fill text-warning"></i>
                    Thêm Kết quả then chốt (KR)
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body-soft">
                <div class="soft-tag-indicator">
                    <i class="bi bi-bullseye"></i>
                    <span id="krOkrNameDisplay" class="text-truncate">Objective: </span>
                </div>

                <form asp-controller="OKRs" asp-action="AddKeyResult" method="post">
                    <input type="hidden" name="OKRId" id="krOkrId" />
                    
                    <div class="form-icon-group">
                        <label>Mô tả Kết quả then chốt</label>
                        <div class="input-wrapper">
                            <i class="bi bi-pencil-square"></i>
                            <input type="text" name="KeyResultName" class="form-control" placeholder="VD: Đạt 1000 khách hàng mới trong Q1" required>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <div class="form-icon-group">
                                <label>Chỉ tiêu (Target)</label>
                                <div class="input-wrapper">
                                    <i class="bi bi-flag-fill"></i>
                                    <input type="number" step="0.01" name="TargetValue" class="form-control" placeholder="0.00" required>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-icon-group">
                                <label>Đơn vị tính</label>
                                <div class="input-wrapper">
                                    <i class="bi bi-rulers"></i>
                                    <input type="text" name="Unit" class="form-control" placeholder="VD: VNĐ, %...">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-switch-premium">
                        <div class="label-content">
                            <span class="label-title">Chỉ tiêu thu nhỏ</span>
                            <span class="label-desc">Kích hoạt nếu giá trị càng thấp càng tốt</span>
                        </div>
                        <input class="form-check-input" type="checkbox" name="IsInverse" value="true" id="isInverseCheck">
                    </div>

                    <div class="d-flex justify-content-end gap-3 mt-4">
                        <button type="button" class="btn-outline-custom px-4" data-bs-dismiss="modal">Hủy bỏ</button>
                        <button type="submit" class="btn-primary-custom px-4">Xác nhận tạo KR</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Allocate to Employee -->
<div class="modal fade" id="allocateOkrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header-soft primary">
                <h5 class="modal-title-custom">
                    <i class="bi bi-person-plus-fill text-primary"></i>
                    Phân bổ chỉ tiêu nhân viên
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body-soft">
                <form asp-controller="OKRs" asp-action="AllocateTarget" method="post">
                    <input type="hidden" name="okrId" id="allocOkrId" />
                    
                    <div class="form-icon-group">
                        <label>Chọn nhân viên phụ trách</label>
                        <div class="input-wrapper">
                            <i class="bi bi-person-badge"></i>
                            <select name="employeeId" class="form-select" required>
                                <option value="">-- Chọn nhân viên --</option>
                                @foreach(var e in (ViewBag.AllEmployees as List<Manage_KPI_or_OKR_System.Models.Employee> ?? new List<Manage_KPI_or_OKR_System.Models.Employee>())){
                                    <option value="@e.Id">@e.FullName (@e.EmployeeCode)</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="form-icon-group">
                        <label>Giá trị phân bổ</label>
                        <div class="input-wrapper">
                            <i class="bi bi-calculator"></i>
                            <input type="number" step="0.01" min="0.01" name="allocatedValue" class="form-control" required placeholder="Nhập con số cụ thể...">
                        </div>
                        <div class="form-text text-muted small mt-2">
                            <i class="bi bi-info-circle me-1"></i> Lưu ý: Tổng các chỉ tiêu phân bổ nên bằng chỉ tiêu chung của OKR.
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-3 mt-4">
                        <button type="button" class="btn-outline-custom px-4" data-bs-dismiss="modal">Hủy bỏ</button>
                        <button type="submit" class="btn-primary-custom px-4">Xác nhận phân bổ</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Update KR Progress -->
<div class="modal fade" id="updateKrProgressModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header-soft primary">
                <h5 class="modal-title-custom">
                    <i class="bi bi-graph-up-arrow text-primary"></i>
                    Cập nhật tiến độ KR
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body-soft">
                <div class="soft-tag-indicator">
                    <i class="bi bi-info-circle"></i>
                    <span id="updateKrNameDisplay" class="text-truncate">KR: </span>
                </div>

                <form asp-controller="OKRs" asp-action="UpdateKeyResultProgress" method="post">
                    <input type="hidden" name="krId" id="updateKrId" />
                    
                    <div class="form-icon-group">
                        <label>Thực tế hiện tại</label>
                        <div class="input-wrapper">
                            <i class="bi bi-lightning-charge-fill"></i>
                            <input type="number" step="0.01" name="currentValue" id="updateKrCurrentValue" class="form-control" required>
                            <span class="position-absolute end-0 top-50 translate-middle-y pe-4 fw-bold text-muted" id="updateKrUnitDisplay"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-3 mt-4">
                        <button type="button" class="btn-outline-custom px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn-primary-custom px-4">Cập nhật ngay</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Edit Key Result -->
<div class="modal fade" id="editKrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-pencil-square text-primary me-2"></i>Cập nhật Kết quả then chốt (KR)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-controller="OKRs" asp-action="EditKeyResult" method="post">
                    <input type="hidden" name="Id" id="editKrId" />
                    <div class="mb-3">
                        <label class="form-label">Mô tả Key Result <span class="text-danger">*</span></label>
                        <input type="text" name="KeyResultName" id="editKrName" class="form-control" required>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Hiện tại <span class="text-danger">*</span></label>
                            <input type="number" step="0.01" name="CurrentValue" id="editKrCurrent" class="form-control" required>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label">Chỉ tiêu (Target) <span class="text-danger">*</span></label>
                            <input type="number" step="0.01" name="TargetValue" id="editKrTarget" class="form-control" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Đơn vị đo lường</label>
                        <input type="text" name="Unit" id="editKrUnit" class="form-control">
                    </div>
                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="IsInverse" value="true" id="editKrIsInverse">
                            <label class="form-check-label" for="editKrIsInverse">Chỉ tiêu thu nhỏ (Càng thấp càng tốt)</label>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Cập nhật KR</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openAddKrModal(okrId, okrName) {
            document.getElementById('krOkrId').value = okrId;
            document.getElementById('krOkrNameDisplay').innerText = 'Objective: ' + okrName;
            var modal = new bootstrap.Modal(document.getElementById('addKrModal'));
            modal.show();
        }

        function openAllocateModal(okrId) {
            document.getElementById('allocOkrId').value = okrId;
            var modal = new bootstrap.Modal(document.getElementById('allocateOkrModal'));
            modal.show();
        }

        function openEditKrModal(id, name, target, current, unit, isInverse) {
            document.getElementById('editKrId').value = id;
            document.getElementById('editKrName').value = name;
            document.getElementById('editKrTarget').value = target;
            document.getElementById('editKrCurrent').value = current;
            document.getElementById('editKrUnit').value = unit || '';
            document.getElementById('editKrIsInverse').checked = isInverse;
            new bootstrap.Modal(document.getElementById('editKrModal')).show();
        }

        function openUpdateProgressModal(krId, krName, currentVal, unit) {
            document.getElementById('updateKrId').value = krId;
            document.getElementById('updateKrNameDisplay').innerText = 'KR: ' + krName;
            document.getElementById('updateKrCurrentValue').value = currentVal;
            document.getElementById('updateKrUnitDisplay').innerText = unit;
            var modal = new bootstrap.Modal(document.getElementById('updateKrProgressModal'));
            modal.show();
        }

        // Toggle all accordions functionality
        document.getElementById('toggleAllBtn')?.addEventListener('click', function() {
            const accordions = document.querySelectorAll('#accordionOKRs .accordion-collapse');
            const anyCollapsed = Array.from(accordions).some(a => !a.classList.contains('show'));
            
            accordions.forEach(acc => {
                const bsCollapse = bootstrap.Collapse.getOrCreateInstance(acc);
                if (anyCollapsed) {
                    bsCollapse.show();
                } else {
                    bsCollapse.hide();
                }
            });
            
            // Cập nhật text & icon: Nếu trước đó có ít nhất 1 cái đóng, giờ đã mở hết -> nút thành "Thu gọn". 
            // Nếu trước đó mở hết -> giờ đã đóng hết -> nút thành "Mở rộng".
            if (anyCollapsed) {
                this.innerHTML = '<i class="bi bi-dash-square"></i> Thu gọn tất cả';
            } else {
                this.innerHTML = '<i class="bi bi-list-task"></i> Mở rộng tất cả';
            }
        });
    </script>
}
