@model IEnumerable<Manage_KPI_or_OKR_System.Models.OKR>
@{
    ViewData["Title"] = "Quản lý OKR";
}

<div class="page-header">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Mục tiêu và Kết quả then chốt (OKR)</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Quản lý OKR</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn-primary-custom" data-bs-toggle="modal" data-bs-target="#createOkrModal">
            <i class="bi bi-plus-lg"></i> Tạo OKR mới
        </button>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success shadow-sm border-0 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
    </div>
}

<div class="content-card">
    <div class="card-body-custom">
        <div class="toolbar">
            <div class="toolbar-left">
                <div class="toolbar-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Tìm kiếm OKR...">
                </div>
            </div>
            <div class="toolbar-right">
                <button class="btn btn-sm btn-outline-secondary border-0"><i class="bi bi-list-task"></i> Xem dạng danh sách</button>
            </div>
        </div>

        <!-- OKR Items list -->
        <div class="okr-list">
            @if (Model != null && Model.Any())
            {
                int index = 0;
                foreach (var okr in Model)
                {
                    index++;
                    string collapseId = $"okr{index}";
                    var krs = okr.KeyResults ?? new List<Manage_KPI_or_OKR_System.Models.OKRKeyResult>();
                    var totalProgress = okr.TotalProgress;
                    string progressColor = totalProgress >= 100 ? "success" : totalProgress > 0 ? "primary" : "secondary";
                    
                    <div class="border rounded-3 mb-3 hover-shadow-sm transition-base bg-white overflow-hidden">
                        <div class="d-flex align-items-center justify-content-between p-3 border-bottom bg-light bg-opacity-50">
                            <div class="d-flex align-items-start gap-3">
                                <button class="btn btn-sm btn-link text-muted p-0" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                                    <i class="bi bi-chevron-down fs-5"></i>
                                </button>
                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-2">Mục tiêu (O)</span>
                                        <h5 class="mb-0 fw-bold fs-6">@okr.ObjectiveName</h5>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.8rem;">
                                        <i class="bi bi-calendar3"></i> @Html.Raw(okr.Cycle ?? "Chưa rõ chu kỳ")
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-4">
                                <div class="text-end me-2" style="min-width: 120px;">
                                    <div class="d-flex justify-content-between mb-1" style="font-size: 0.75rem;">
                                        <span class="text-muted fw-bold" id="okr-text-@okr.Id">Tiến độ: @totalProgress%</span>
                                    </div>
                                    <div class="progress" style="height: 6px; width: 100px;">
                                        <div class="progress-bar bg-@progressColor" id="okr-bar-@okr.Id" role="progressbar" style="width: @totalProgress%;" aria-valuenow="@totalProgress" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                </div>
                                <div class="badge bg-warning text-dark px-3 py-2 rounded-pill">Đang thực hiện</div>
                                <div class="action-btns dropdown">
                                    <button class="action-btn" data-bs-toggle="dropdown"><i class="bi bi-three-dots-vertical"></i></button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                        <li><a class="dropdown-item" href="#" onclick="openAddKrModal(@okr.Id, '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(okr.ObjectiveName ?? ""))')"><i class="bi bi-plus me-2"></i>Thêm KR</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form asp-action="Delete" asp-route-id="@okr.Id" method="post" class="m-0" onsubmit="return confirm('Xác nhận xóa OKR này?');">
                                                <button type="submit" class="dropdown-item text-danger"><i class="bi bi-trash me-2"></i>Xóa OKR</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                        
                        <div id="@collapseId" class="collapse show">
                            <div class="p-3 bg-white">
                                <h6 class="fs-6 fw-semibold text-muted mb-3"><i class="bi bi-key-fill text-warning me-1"></i> Key Results (Kết quả then chốt)</h6>
                                
                                @if (krs.Any())
                                {
                                    int krIndex = 1;
                                    foreach (var kr in krs)
                                    {
                                        decimal krProgress = 0;
                                        if (kr.TargetValue.HasValue && kr.TargetValue.Value > 0)
                                        {
                                            krProgress = Math.Min(100, (kr.CurrentValue ?? 0) / kr.TargetValue.Value * 100);
                                        }
                                        string krProgressColor = krProgress >= 100 ? "success" : krProgress > 0 ? "primary" : "secondary";

                                        <div class="d-flex align-items-center justify-content-between py-2 border-bottom">
                                            <div class="ps-4">
                                                <div class="fw-medium text-dark">@krIndex. @kr.KeyResultName</div>
                                                <div class="text-muted" style="font-size: 0.75rem;">
                                                    Hiện tại: <span class="fw-bold text-primary" id="kr-current-@kr.Id">@String.Format("{0:N0}", kr.CurrentValue ?? 0)</span> / 
                                                    Mục tiêu: <span id="kr-target-@kr.Id">@String.Format("{0:N0}", kr.TargetValue)</span> <span id="kr-unit-@kr.Id">@kr.Unit</span>
                                                </div>
                                            </div>
                                            <div class="d-flex align-items-center gap-4" style="width: 45%;">
                                                <div class="flex-grow-1">
                                                    <div class="d-flex justify-content-between mb-1" style="font-size: 0.75rem;">
                                                        <span class="text-muted" id="kr-pct-@kr.Id">Hoàn thành: @krProgress.ToString("N1")%</span>
                                                    </div>
                                                    <div class="progress" style="height: 5px;">
                                                        <div class="progress-bar bg-@krProgressColor" id="kr-bar-@kr.Id" role="progressbar" style="width: @krProgress%;" aria-valuenow="@krProgress" aria-valuemin="0" aria-valuemax="100"></div>
                                                    </div>
                                                </div>
                                                <div class="d-flex gap-1">
                                                    <button class="btn btn-sm btn-light-primary text-primary border-0 rounded-circle" 
                                                            onclick="openEditKrModal(@kr.Id, @okr.Id, '@kr.KeyResultName', @kr.TargetValue, @(kr.CurrentValue ?? 0), '@kr.Unit')" title="Sửa KR">
                                                        <i class="bi bi-pencil-square"></i>
                                                    </button>
                                                    <form asp-action="DeleteKeyResult" asp-route-id="@kr.Id" method="post" class="m-0" onsubmit="return confirm('Xóa KR này?');">
                                                        <button type="submit" class="btn btn-sm btn-light-danger text-danger border-0 rounded-circle" title="Xóa KR">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                        krIndex++;
                                    }
                                }
                                else
                                {
                                    <div class="text-muted fst-italic ps-4 py-2">Chưa có kết quả then chốt nào được thiết lập.</div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info border-0 shadow-sm text-center p-5">
                    <h5>Chưa có mục tiêu OKR nào.</h5>
                    <p class="text-muted mb-0">Hãy bấm "Tạo OKR mới" để thiết lập mục tiêu.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal Create OKR -->
<div class="modal fade" id="createOkrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-target text-primary me-2"></i>Tạo Objective mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-controller="OKRs" asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label">Tên Objective (Mục tiêu) <span class="text-danger">*</span></label>
                        <input type="text" name="ObjectiveName" class="form-control" placeholder="VD: Tăng cường mức độ hài lòng của khách hàng" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Loại OKR <span class="text-danger">*</span></label>
                        <select name="OKRTypeId" class="form-select" required>
                            <option value="">-- Chọn loại --</option>
                            @if (ViewBag.OKRTypes != null)
                            {
                                foreach (var type in ViewBag.OKRTypes as IEnumerable<Manage_KPI_or_OKR_System.Models.OKRType>)
                                {
                                    <option value="@type.Id">@type.TypeName</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Chu kỳ <span class="text-danger">*</span></label>
                        <select name="Cycle" class="form-select" required>
                            <option value="Q1-@DateTime.Now.Year">Quý 1 - @DateTime.Now.Year</option>
                            <option value="Q2-@DateTime.Now.Year">Quý 2 - @DateTime.Now.Year</option>
                            <option value="Q3-@DateTime.Now.Year">Quý 3 - @DateTime.Now.Year</option>
                            <option value="Q4-@DateTime.Now.Year">Quý 4 - @DateTime.Now.Year</option>
                            <option value="Năm @DateTime.Now.Year">Cả năm @DateTime.Now.Year</option>
                        </select>
                    </div>
                    <hr class="my-4 text-muted">
                    <h6 class="text-muted fw-bold mb-3" style="font-size: 0.8rem; letter-spacing: 0.5px; text-transform: uppercase;">Phân bổ mục tiêu (Tùy chọn)</h6>
                    <div class="mb-3">
                        <label class="form-label">Sứ mệnh / Tầm nhìn</label>
                        <select name="missionId" class="form-select">
                            <option value="">-- Không phân bổ --</option>
                            @if (ViewBag.Missions != null)
                            {
                                foreach (var m in ViewBag.Missions as IEnumerable<Manage_KPI_or_OKR_System.Models.MissionVision>)
                                {
                                    <option value="@m.Id">Năm @m.TargetYear: @(m.Content?.Length > 50 ? m.Content.Substring(0, 50) + "..." : m.Content)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phòng ban</label>
                        <select name="departmentId" class="form-select">
                            <option value="">-- Không phân bổ --</option>
                            @if (ViewBag.Departments != null)
                            {
                                foreach (var d in ViewBag.Departments as IEnumerable<Manage_KPI_or_OKR_System.Models.Department>)
                                {
                                    <option value="@d.Id">@d.DepartmentName</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Nhân viên</label>
                        <select name="employeeId" class="form-select">
                            <option value="">-- Không phân bổ --</option>
                            @if (ViewBag.Employees != null)
                            {
                                foreach (var e in ViewBag.Employees as IEnumerable<Manage_KPI_or_OKR_System.Models.Employee>)
                                {
                                    <option value="@e.Id">@e.FullName (@e.EmployeeCode)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Tạo OKR</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Add Key Result -->
<div class="modal fade" id="addKrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-key text-warning me-2"></i>Thêm Kết quả then chốt (KR)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="alert alert-light border border-warning" id="krOkrNameDisplay">Objective: </div>
                <form asp-controller="OKRs" asp-action="AddKeyResult" method="post">
                    <input type="hidden" name="OKRId" id="krOkrId" />
                    <div class="mb-3">
                        <label class="form-label">Mô tả Key Result <span class="text-danger">*</span></label>
                        <input type="text" name="KeyResultName" class="form-control" placeholder="VD: Giảm thời gian phản hồi hỗ trợ xuống còn 5 phút" required>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-4">
                            <label class="form-label">Chỉ tiêu (Target) <span class="text-danger">*</span></label>
                            <input type="number" step="0.01" name="TargetValue" class="form-control" placeholder="VD: 5" required>
                        </div>
                        <div class="col-6 mb-4">
                            <label class="form-label">Đơn vị đo lường</label>
                            <input type="text" name="Unit" class="form-control" placeholder="VD: Phút, Khách hàng, VNĐ...">
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Lưu KR</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Edit Key Result -->
<div class="modal fade" id="editKrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-pencil-square text-primary me-2"></i>Cập nhật Kết quả then chốt (KR)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-controller="OKRs" asp-action="EditKeyResult" method="post" id="editKrForm">
                    <input type="hidden" name="Id" id="editKrId" />
                    <input type="hidden" name="OKRId" id="editParentOkrId" />
                    <div class="mb-3">
                        <label class="form-label">Mô tả Key Result <span class="text-danger">*</span></label>
                        <input type="text" name="KeyResultName" id="editKrName" class="form-control" required>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Hiện tại <span class="text-danger">*</span></label>
                            <input type="number" step="0.01" name="CurrentValue" id="editKrCurrent" class="form-control" required>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label">Chỉ tiêu (Target) <span class="text-danger">*</span></label>
                            <input type="number" step="0.01" name="TargetValue" id="editKrTarget" class="form-control" required>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Đơn vị đo lường</label>
                        <input type="text" name="Unit" id="editKrUnit" class="form-control">
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Cập nhật KR</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function openAddKrModal(okrId, okrName) {
        document.getElementById('krOkrId').value = okrId;
        document.getElementById('krOkrNameDisplay').innerText = "Objective: " + okrName;
        new bootstrap.Modal(document.getElementById('addKrModal')).show();
    }

    function openEditKrModal(id, selectedOkrId, name, target, current, unit) {
        document.getElementById('editKrId').value = id;
        document.getElementById('editParentOkrId').value = selectedOkrId || '';
        document.getElementById('editKrName').value = name;
        document.getElementById('editKrTarget').value = target;
        document.getElementById('editKrCurrent').value = current;
        document.getElementById('editKrUnit').value = unit || '';
        new bootstrap.Modal(document.getElementById('editKrModal')).show();
    }

    document.addEventListener("DOMContentLoaded", function () {
        var editForm = document.getElementById('editKrForm');
        if(editForm) {
            editForm.addEventListener("submit", function (e) {
                e.preventDefault();
                var formData = new FormData(editForm);
                
                fetch(editForm.action, {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        var krId = document.getElementById('editKrId').value;
                        var okrId = document.getElementById('editParentOkrId').value;

                        // Cập nhật DOM của KR
                        var krBar = document.getElementById('kr-bar-' + krId);
                        var krPct = document.getElementById('kr-pct-' + krId);
                        var krCurrent = document.getElementById('kr-current-' + krId);
                        var krTarget = document.getElementById('kr-target-' + krId);
                        var krUnit = document.getElementById('kr-unit-' + krId);

                        if(krBar) {
                            krBar.style.width = data.krProgress + '%';
                            krBar.setAttribute('aria-valuenow', data.krProgress);
                            krBar.className = 'progress-bar bg-' + (data.krProgress >= 100 ? 'success' : (data.krProgress > 0 ? 'primary' : 'secondary'));
                        }
                        if(krPct) krPct.innerText = 'Hoàn thành: ' + parseFloat(data.krProgress).toFixed(1) + '%';
                        if(krCurrent) krCurrent.innerText = Number(data.current).toLocaleString('en-US');
                        if(krTarget) krTarget.innerText = Number(data.target).toLocaleString('en-US');
                        if(krUnit) krUnit.innerText = data.unit || '';

                        // Cập nhật DOM của OKR
                        if (okrId) {
                            var okrBar = document.getElementById('okr-bar-' + okrId);
                            var okrText = document.getElementById('okr-text-' + okrId);
                            if(okrBar) {
                                okrBar.style.width = data.okrProgress + '%';
                                okrBar.setAttribute('aria-valuenow', data.okrProgress);
                                okrBar.className = 'progress-bar bg-' + (data.okrProgress >= 100 ? 'success' : (data.okrProgress > 0 ? 'primary' : 'secondary'));
                            }
                            if(okrText) okrText.innerText = 'Tiến độ: ' + data.okrProgress + '%';
                        }

                        // Đóng modal Modal thủ công do thẻ button data-bs-dismiss đôi khi k hoạt động với fetch
                        var myModalEl = document.getElementById('editKrModal');
                        var modal = bootstrap.Modal.getInstance(myModalEl);
                        modal.hide();

                        // Create alert success
                        var alertNode = document.createElement('div');
                        alertNode.className = 'alert alert-success shadow-sm border-0 mb-4 alert-dismissible fade show';
                        alertNode.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i>Đã lưu và cập nhật trực tiếp tiến độ!<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
                        document.querySelector('.page-header').insertAdjacentElement('afterend', alertNode);
                        setTimeout(() => { alertNode.remove(); }, 3000);
                    }
                })
                .catch(err => console.error(err));
            });
        }
    });
</script>

<style>
    .btn-link[data-bs-toggle="collapse"] i {
        display: inline-block;
        transition: transform 0.3s ease;
    }
    .btn-link[data-bs-toggle="collapse"].collapsed i {
        transform: rotate(-90deg);
    }
</style>
