@model IEnumerable<Manage_KPI_or_OKR_System.Models.OKR>
@{
    ViewData["Title"] = "Quản lý OKR";
    var keyResultsDict = ViewBag.KeyResults as Dictionary<int, List<Manage_KPI_or_OKR_System.Models.OKRKeyResult>> ?? new Dictionary<int, List<Manage_KPI_or_OKR_System.Models.OKRKeyResult>>();
}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Mục tiêu và Kết quả then chốt (OKR)</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Quản lý OKR</span>
        </div>
    </div>
    <div class="d-flex justify-content-end gap-2">
        <button class="btn-primary-custom d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#createOkrModal">
            <i class="bi bi-plus-lg me-1"></i> Tạo OKR mới
        </button>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success shadow-sm border-0 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
    </div>
}

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100">
    <div class="card-body-custom">
        <div class="toolbar">
            <div class="toolbar-left">
                <div class="toolbar-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Tìm kiếm OKR...">
                </div>
            </div>
            <div class="toolbar-right">
                <button class="btn btn-sm btn-outline-secondary border-0"><i class="bi bi-list-task"></i> Xem dạng danh sách</button>
            </div>
        </div>

        <!-- OKR Items list -->
        <div class="okr-list">
            @if (Model != null && Model.Any())
            {
                int index = 0;
                foreach (var okr in Model)
                {
                    index++;
                    string collapseId = $"okr{index}";
                    var krs = keyResultsDict.ContainsKey(okr.Id) ? keyResultsDict[okr.Id] : new List<Manage_KPI_or_OKR_System.Models.OKRKeyResult>();
                    
                    <div class="border rounded-3 mb-3 hover-shadow-sm transition-base bg-white overflow-hidden">
                        <div class="d-flex align-items-center justify-content-between p-3 border-bottom bg-light bg-opacity-50">
                            <div class="d-flex align-items-start gap-3">
                                <button class="btn btn-sm btn-link text-muted p-0" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                                    <i class="bi bi-chevron-down fs-5"></i>
                                </button>
                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-2">Mục tiêu (O)</span>
                                        <h5 class="mb-0 fw-bold fs-6">@okr.ObjectiveName</h5>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.8rem;">
                                        <i class="bi bi-calendar3"></i> @Html.Raw(okr.Cycle ?? "Chưa rõ chu kỳ")
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-4">
                                <div class="badge bg-warning text-dark px-3 py-2 rounded-pill">Đang thực hiện</div>
                                <div class="action-btns dropdown">
                                    <button class="action-btn" data-bs-toggle="dropdown"><i class="bi bi-three-dots-vertical"></i></button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                        <li><a class="dropdown-item" href="#" onclick="openAddKrModal(@okr.Id, '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(okr.ObjectiveName ?? ""))')"><i class="bi bi-plus me-2 text-warning"></i>Thêm KR</a></li>
                                        <li><a class="dropdown-item" href="#" onclick="openAllocateModal(@okr.Id)"><i class="bi bi-person-plus me-2 text-primary"></i>Phân bổ nhân viên</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form asp-action="Delete" asp-route-id="@okr.Id" method="post" class="m-0" onsubmit="return confirm('Xác nhận xóa OKR này?');">
                                                <button type="submit" class="dropdown-item text-danger"><i class="bi bi-trash me-2"></i>Xóa OKR</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                        
                        <div id="@collapseId" class="collapse show">
                            <div class="p-3 bg-white">
                                <h6 class="fs-6 fw-semibold text-muted mb-3"><i class="bi bi-key-fill text-warning me-1"></i> Key Results (Kết quả then chốt)</h6>
                                
                                @if (krs.Any())
                                {
                                    int krIndex = 1;
                                    foreach (var kr in krs)
                                    {
                                        <div class="d-flex align-items-center justify-content-between py-2 border-bottom">
                                            <div class="ps-4">
                                                <div class="fw-medium text-dark">@krIndex. @kr.KeyResultName</div>
                                                <div class="text-muted" style="font-size: 0.75rem;">Mục tiêu: @String.Format("{0:N0}", kr.TargetValue) @kr.Unit</div>
                                            </div>
                                            <div class="d-flex align-items-center gap-4" style="width: 40%;">
                                                <div class="flex-grow-1">
                                                    @{
                                                        var currentVal = kr.CurrentValue ?? 0;
                                                        var targetVal = kr.TargetValue ?? 1;
                                                        var progressPercent = Math.Min(100, (int)(currentVal / targetVal * 100));
                                                        string progressColor = progressPercent >= 100 ? "bg-success" : (progressPercent >= 70 ? "bg-info" : (progressPercent >= 30 ? "bg-warning" : "bg-danger"));
                                                    }
                                                    <div class="d-flex justify-content-between mb-1" style="font-size: 0.75rem;">
                                                        <span class="text-muted">Tiến độ: <strong>@String.Format("{0:N1}", currentVal)</strong>/@String.Format("{0:N0}", targetVal) @kr.Unit</span>
                                                        <span class="fw-bold">@progressPercent%</span>
                                                    </div>
                                                    <div class="progress mb-1" style="height: 6px; border-radius: 10px;">
                                                        <div class="progress-bar @progressColor" role="progressbar" style="width: @progressPercent%" aria-valuenow="@progressPercent" aria-valuemin="0" aria-valuemax="100"></div>
                                                    </div>
                                                    <div class="d-flex justify-content-between" style="font-size: 0.7rem;">
                                                        <span class="badge @(kr.ResultStatus == "Đạt" ? "bg-success" : (kr.ResultStatus == "Gần đạt" ? "bg-info" : "bg-danger")) bg-opacity-10 @(kr.ResultStatus == "Đạt" ? "text-success" : (kr.ResultStatus == "Gần đạt" ? "text-info" : "text-danger")) px-2 py-1">@Html.Raw(kr.ResultStatus ?? "Chưa đánh giá")</span>
                                                        @if(kr.IsInverse){<span class="text-info"><i class="bi bi-info-circle me-1"></i>Chỉ tiêu giảm thiểu</span>}
                                                    </div>
                                                </div>
                                                <button class="btn btn-sm btn-outline-primary border-0 rounded-circle" title="Cập nhật tiến độ" onclick="openUpdateProgressModal(@kr.Id, '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(kr.KeyResultName ?? ""))', @currentVal, '@kr.Unit')">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                            </div>
                                        </div>
                                        krIndex++;
                                    }
                                }
                                else
                                {
                                    <div class="text-muted fst-italic ps-4 py-2">Chưa có kết quả then chốt nào được thiết lập.</div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info border-0 shadow-sm text-center p-5">
                    <h5>Chưa có mục tiêu OKR nào.</h5>
                    <p class="text-muted mb-0">Hãy bấm "Tạo OKR mới" để thiết lập mục tiêu.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal Create OKR -->
<div class="modal fade" id="createOkrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-target text-primary me-2"></i>Tạo Objective mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-controller="OKRs" asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label">Tên Objective (Mục tiêu) <span class="text-danger">*</span></label>
                        <input type="text" name="ObjectiveName" class="form-control" placeholder="VD: Tăng cường mức độ hài lòng của khách hàng" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Chu kỳ <span class="text-danger">*</span></label>
                        <select name="Cycle" class="form-select" required>
                            <option value="Q1-@DateTime.Now.Year">Quý 1 - @DateTime.Now.Year</option>
                            <option value="Q2-@DateTime.Now.Year">Quý 2 - @DateTime.Now.Year</option>
                            <option value="Q3-@DateTime.Now.Year">Quý 3 - @DateTime.Now.Year</option>
                            <option value="Q4-@DateTime.Now.Year">Quý 4 - @DateTime.Now.Year</option>
                            <option value="Năm @DateTime.Now.Year">Cả năm @DateTime.Now.Year</option>
                        </select>
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn-outline-custom rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn-primary-custom rounded-pill px-4">Tạo OKR</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Add Key Result -->
<div class="modal fade" id="addKrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-key text-warning me-2"></i>Thêm Kết quả then chốt (KR)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="alert alert-light border border-warning" id="krOkrNameDisplay">Objective: </div>
                <form asp-controller="OKRs" asp-action="AddKeyResult" method="post">
                    <input type="hidden" name="OKRId" id="krOkrId" />
                    <div class="mb-3">
                        <label class="form-label">Mô tả Key Result <span class="text-danger">*</span></label>
                        <input type="text" name="KeyResultName" class="form-control" placeholder="VD: Giảm thời gian phản hồi hỗ trợ xuống còn 5 phút" required>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-4">
                            <label class="form-label">Chỉ tiêu (Target) <span class="text-danger">*</span></label>
                            <input type="number" step="0.01" name="TargetValue" class="form-control" placeholder="VD: 5" required>
                        </div>
                        <div class="col-6 mb-4">
                            <label class="form-label">Đơn vị đo lường</label>
                            <input type="text" name="Unit" class="form-control" placeholder="VD: Phút, Khách hàng, VNĐ...">
                        </div>
                    </div>
                    <div class="form-check mb-4">
                        <input class="form-check-input" type="checkbox" name="IsInverse" value="true" id="isInverseCheck">
                        <label class="form-check-label" for="isInverseCheck">
                            Chỉ tiêu thu nhỏ (Càng thấp càng tốt - VD: Giảm lỗi, Giảm thời gian chờ)
                        </label>
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn-outline-custom rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn-primary-custom rounded-pill px-4">Lưu KR</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Allocate to Employee -->
<div class="modal fade" id="allocateOkrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-person-plus text-primary me-2"></i>Phân bổ chỉ tiêu cho nhân viên</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-controller="OKRs" asp-action="AllocateTarget" method="post">
                    <input type="hidden" name="okrId" id="allocOkrId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nhân viên <span class="text-danger">*</span></label>
                        <select name="employeeId" class="form-select" required>
                            @foreach(var e in (ViewBag.AllEmployees as List<Manage_KPI_or_OKR_System.Models.Employee> ?? new List<Manage_KPI_or_OKR_System.Models.Employee>())){
                                <option value="@e.Id">@e.FullName (@e.EmployeeCode)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Chỉ tiêu phân bổ (Số lượng/Giá trị) <span class="text-danger">*</span></label>
                        <input type="number" step="0.01" name="allocatedValue" class="form-control form-control-lg" required placeholder="VD: 30">
                        <div class="form-text text-muted">Lưu ý: Tổng các chỉ tiêu phân bổ phải bằng chỉ tiêu chung của OKR.</div>
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn-outline-custom rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn-primary-custom rounded-pill px-4">Lưu phân bổ</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Update KR Progress -->
<div class="modal fade" id="updateKrProgressModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-graph-up text-info me-2"></i>Cập nhật tiến độ KR</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="alert alert-light border border-info mb-3" id="updateKrNameDisplay">KR: </div>
                <form asp-controller="OKRs" asp-action="UpdateKeyResultProgress" method="post">
                    <input type="hidden" name="krId" id="updateKrId" />
                    <div class="mb-4">
                        <label class="form-label fw-bold">Kết quả thực tế hiện tại</label>
                        <div class="input-group">
                            <input type="number" step="0.01" name="currentValue" id="updateKrCurrentValue" class="form-control form-control-lg" required>
                            <span class="input-group-text" id="updateKrUnitDisplay"></span>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn-outline-custom rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn-primary-custom rounded-pill px-4">Cập nhật</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function openAddKrModal(okrId, okrName) {
        document.getElementById('krOkrId').value = okrId;
        document.getElementById('krOkrNameDisplay').innerText = "Objective: " + okrName;
        new bootstrap.Modal(document.getElementById('addKrModal')).show();
    }

    function openUpdateProgressModal(krId, krName, currentValue, unit) {
        document.getElementById('updateKrId').value = krId;
        document.getElementById('updateKrNameDisplay').innerText = "Key Result: " + krName;
        document.getElementById('updateKrCurrentValue').value = currentValue;
        document.getElementById('updateKrUnitDisplay').innerText = unit;
        new bootstrap.Modal(document.getElementById('updateKrProgressModal')).show();
    }

    function openAllocateModal(okrId) {
        document.getElementById('allocOkrId').value = okrId;
        new bootstrap.Modal(document.getElementById('allocateOkrModal')).show();
    }
</script>

<style>
    .btn-link[data-bs-toggle="collapse"] i {
        display: inline-block;
        transition: transform 0.3s ease;
    }
    .btn-link[data-bs-toggle="collapse"].collapsed i {
        transform: rotate(-90deg);
    }
</style>

        </div>
    </div>
</div>