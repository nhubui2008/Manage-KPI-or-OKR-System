<!-- Modal AI History -->
<div class="modal fade" id="aiHistoryModal" tabindex="-1" aria-hidden="true" style="z-index: 1065;">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 12px; overflow: hidden;">
            <div class="modal-header border-bottom-0 pb-0 bg-light p-4">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-clock-history text-primary me-2"></i>Lịch sử đề xuất AI</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-light">
                <div id="aiHistoryLoading" class="text-center py-4 d-none">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="text-muted mt-2">Đang tải lịch sử...</p>
                </div>
                
                <div id="aiHistoryEmpty" class="text-center py-5 d-none">
                    <i class="bi bi-inbox fs-1 text-muted opacity-50"></i>
                    <h6 class="mt-3 text-muted">Chưa có lịch sử đề xuất nào.</h6>
                </div>

                <div id="aiHistoryList" class="d-flex flex-column gap-3">
                    <!-- History items will be injected here -->
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let _aiHistoryCallback = null;

    function openAiHistoryModal(featureName, targetId, callback) {
        _aiHistoryCallback = callback;
        const modalEl = document.getElementById('aiHistoryModal');
        const modal = new bootstrap.Modal(modalEl);
        
        document.getElementById('aiHistoryLoading').classList.remove('d-none');
        document.getElementById('aiHistoryEmpty').classList.add('d-none');
        document.getElementById('aiHistoryList').innerHTML = '';
        
        modal.show();

        let url = `/AI/History?featureName=${featureName}`;
        if (targetId) url += `&targetId=${targetId}`;

        fetch(url)
            .then(res => res.json())
            .then(data => {
                document.getElementById('aiHistoryLoading').classList.add('d-none');
                
                if (!data.success || !data.history || data.history.length === 0) {
                    document.getElementById('aiHistoryEmpty').classList.remove('d-none');
                    return;
                }

                const listEl = document.getElementById('aiHistoryList');
                data.history.forEach(item => {
                    const date = new Date(item.createdAt).toLocaleString('vi-VN');
                    
                    const card = document.createElement('div');
                    card.className = 'card border-0 shadow-sm rounded-3';
                    
                    let previewText = item.response || '';
                    if (previewText.length > 150) {
                        previewText = previewText.substring(0, 150) + '...';
                    }
                    
                    card.innerHTML = `
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <strong class="text-dark"><i class="bi bi-person-circle me-1"></i> ${escapeHtml(item.creatorName)}</strong>
                                <span class="badge bg-secondary bg-opacity-10 text-secondary">${date}</span>
                            </div>
                            <p class="text-muted small mb-2 fst-italic preview-text">${escapeHtml(previewText)}</p>
                            <div class="text-end mt-2">
                                <button type="button" class="btn btn-sm btn-outline-primary px-3 rounded-pill btn-reuse-ai">
                                    <i class="bi bi-arrow-return-left me-1"></i> Sử dụng lại kết quả này
                                </button>
                            </div>
                        </div>
                    `;
                    
                    card.querySelector('.btn-reuse-ai').addEventListener('click', function() {
                        if (_aiHistoryCallback) {
                            try {
                                let parsed = item.response;
                                // Attempt to parse if it looks like JSON
                                if (parsed.trim().startsWith('[') || parsed.trim().startsWith('{')) {
                                    parsed = JSON.parse(parsed);
                                }
                                _aiHistoryCallback(parsed);
                                modal.hide();
                            } catch (e) {
                                console.error('Error parsing AI history response:', e);
                                _aiHistoryCallback(item.response); 
                                modal.hide();
                            }
                        }
                    });

                    listEl.appendChild(card);
                });
            })
            .catch(err => {
                document.getElementById('aiHistoryLoading').classList.add('d-none');
                document.getElementById('aiHistoryEmpty').classList.remove('d-none');
                console.error(err);
            });
    }

    if (typeof escapeHtml !== 'function') {
        function escapeHtml(unsafe) {
            if (!unsafe) return '';
            return unsafe
                 .toString()
                 .replace(/&/g, "&amp;")
                 .replace(/</g, "&lt;")
                 .replace(/>/g, "&gt;")
                 .replace(/"/g, "&quot;")
                 .replace(/'/g, "&#039;");
        }
    }
</script>
