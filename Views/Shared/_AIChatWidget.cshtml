@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <div class="ai-chat-widget" id="aiChatWidget">
        <button type="button" class="ai-chat-toggle" id="aiChatToggle" aria-label="Mo VietMach AI Assistant">
            <i class="bi bi-stars"></i>
        </button>
        <section class="ai-chat-panel" id="aiChatPanel" aria-live="polite">
            <div class="ai-chat-header">
                <div>
                    <div class="ai-chat-title">VietMach AI Assistant</div>
                    <div class="ai-chat-subtitle">KPI, OKR, tiến độ và gợi ý cải thiện</div>
                </div>
                <button type="button" class="ai-chat-close" id="aiChatClose" aria-label="Dong AI chat">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="ai-chat-messages" id="aiChatMessages">
                <div class="ai-message ai-message-bot">
                    <div class="ai-message-bubble">Xin chào, tôi có thể hỗ trợ bạn xem tiến độ KPI/OKR, phân tích rủi ro hoặc gợi ý bước cải thiện tiếp theo.</div>
                </div>
            </div>
            <div class="ai-chat-actions">
                <button type="button" data-ai-prompt="Tóm tắt tiến độ KPI hiện tại của tôi">Tiến độ KPI</button>
                <button type="button" data-ai-prompt="KPI nào đang có rủi ro không đạt?">KPI rủi ro</button>
                <button type="button" data-ai-prompt="Gợi ý 3 hành động cải thiện hiệu suất tuần này">Gợi ý cải thiện</button>
            </div>
            <form class="ai-chat-form" id="aiChatForm">
                <textarea id="aiChatInput" rows="1" placeholder="Hỏi AI về KPI/OKR..." maxlength="1000"></textarea>
                <button type="submit" aria-label="Gui cau hoi"><i class="bi bi-send-fill"></i></button>
            </form>
        </section>
    </div>

    <script>
        (function () {
            const widget = document.getElementById('aiChatWidget');
            const toggle = document.getElementById('aiChatToggle');
            const panel = document.getElementById('aiChatPanel');
            const close = document.getElementById('aiChatClose');
            const form = document.getElementById('aiChatForm');
            const input = document.getElementById('aiChatInput');
            const messages = document.getElementById('aiChatMessages');
            const history = [];

            if (!widget || !toggle || !panel || !form || !input || !messages) return;

            function setOpen(open) {
                widget.classList.toggle('is-open', open);
                if (open) setTimeout(() => input.focus(), 100);
            }

            function renderMessage(role, text, pending) {
                const row = document.createElement('div');
                row.className = `ai-message ai-message-${role}`;
                const bubble = document.createElement('div');
                bubble.className = 'ai-message-bubble';
                if (pending) {
                    bubble.innerHTML = '<span class="ai-typing-dot"></span><span class="ai-typing-dot"></span><span class="ai-typing-dot"></span>';
                } else {
                    bubble.innerHTML = formatAiText(text);
                }
                row.appendChild(bubble);
                messages.appendChild(row);
                messages.scrollTop = messages.scrollHeight;
                return bubble;
            }

            function formatAiText(text) {
                const safe = window.escapeHtml ? window.escapeHtml(text || '') : String(text || '');
                return safe
                    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                    .replace(/\n/g, '<br>');
            }

            async function sendPrompt(prompt) {
                const cleanPrompt = (prompt || '').trim();
                if (!cleanPrompt) return;

                renderMessage('user', cleanPrompt);
                history.push({ role: 'user', text: cleanPrompt });
                input.value = '';

                const pendingBubble = renderMessage('bot', '', true);
                try {
                    const response = await fetch('/AI/Chat', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            ...window.antiForgeryHeaders()
                        },
                        body: JSON.stringify({ message: cleanPrompt, history: history.slice(-8) })
                    });
                    const data = await response.json();
                    if (!response.ok || data.success === false) {
                        pendingBubble.innerHTML = formatAiText(data.warnings?.[0] || 'AI chưa sẵn sàng. Vui lòng thử lại sau.');
                        return;
                    }
                    pendingBubble.innerHTML = formatAiText(data.text || '');
                    history.push({ role: 'model', text: data.text || '' });
                } catch {
                    pendingBubble.innerHTML = 'Không thể kết nối AI. Vui lòng thử lại sau.';
                } finally {
                    messages.scrollTop = messages.scrollHeight;
                }
            }

            toggle.addEventListener('click', () => setOpen(!widget.classList.contains('is-open')));
            close?.addEventListener('click', () => setOpen(false));
            form.addEventListener('submit', function (event) {
                event.preventDefault();
                sendPrompt(input.value);
            });
            widget.querySelectorAll('[data-ai-prompt]').forEach(button => {
                button.addEventListener('click', () => sendPrompt(button.dataset.aiPrompt));
            });
        })();
    </script>
}
