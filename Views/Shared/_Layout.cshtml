<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@SeoHelper.GetTitle(ViewContext)</title>
    
    <!-- Primary Meta Tags -->
    <meta name="title" content="@SeoHelper.GetTitle(ViewContext)" />
    <meta name="description" content="@SeoHelper.GetDescription(ViewContext)" />
    <meta name="keywords" content="@SeoHelper.GetKeywords(ViewContext)" />
    <meta name="author" content="VietMach" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="@SeoHelper.GetCanonicalUrl(ViewContext)" />

    <!-- Open Graph / Facebook / Zalo -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@SeoHelper.GetCanonicalUrl(ViewContext)" />
    <meta property="og:title" content="@SeoHelper.GetTitle(ViewContext)" />
    <meta property="og:description" content="@SeoHelper.GetDescription(ViewContext)" />
    <meta property="og:image" content="@SeoHelper.GetCanonicalUrl(ViewContext, "")/images/seo-banner.png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="@SeoHelper.GetCanonicalUrl(ViewContext)" />
    <meta property="twitter:title" content="@SeoHelper.GetTitle(ViewContext)" />
    <meta property="twitter:description" content="@SeoHelper.GetDescription(ViewContext)" />
    <meta property="twitter:image" content="@SeoHelper.GetCanonicalUrl(ViewContext, "")/images/seo-banner.png" />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "SoftwareApplication",
      "name": "VietMach KPI/OKR System",
      "operatingSystem": "Web-based",
      "applicationCategory": "BusinessApplication",
      "offers": {
        "@@type": "Offer",
        "price": "0",
        "priceCurrency": "VND"
      },
      "description": "Hệ thống quản lý KPI/OKR hiện đại tích hợp AI"
    }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Manage-KPI-or-OKR-System.styles.css" asp-append-version="true" />
    
    <!-- Restore sidebar state immediately to prevent layout shift -->
    <script>
        (function() {
            const sidebarState = localStorage.getItem('sidebarState');
            if (sidebarState === 'expanded' || sidebarState === null) {
                document.documentElement.classList.add('sidebar-expanded');
            } else {
                document.documentElement.classList.remove('sidebar-expanded');
            }
        })();
    </script>
</head>
<body>
    <div class="app-blob-container">
        <div class="app-blob app-blob-1"></div>
        <div class="app-blob app-blob-2"></div>
        <div class="app-blob app-blob-3"></div>
    </div>
    @if (ViewData["IsLoginPage"] is true || ViewData["IsLandingPage"] is true)
    {
        @RenderBody()
    }
    else
    {
        <form id="globalAntiForgeryForm" class="d-none">
            @Html.AntiForgeryToken()
        </form>
        <div class="app-wrapper">
            <nav id="sidebar" class="sidebar">
                <div class="sidebar-brand">
                    <div class="brand-icon"><i class="bi bi-hexagon-fill"></i></div>
                    <div class="brand-info">
                        <div class="brand-text">VietMach System</div>
                        <div class="brand-sub">Manage KPI & OKR</div>
                    </div>
                </div>

                <div class="sidebar-nav">
                    @{
                        // TÁCH RÕ RÀNG CÁC QUYỀN ĐỂ FRONTEND DỄ KIỂM SOÁT
                        bool isAdmin = User.IsInRole("Admin") || User.IsInRole("Administrator");
                        
                        // Permission claims are loaded per request by PermissionClaimsTransformation.
                        var userPermissions = User.Claims
                            .Where(c => c.Type == Manage_KPI_or_OKR_System.Services.PermissionClaimsTransformation.PermissionClaimType)
                            .Select(c => c.Value)
                            .ToHashSet(StringComparer.OrdinalIgnoreCase);

                        if (isAdmin)
                        {
                            // Admin có toàn quyền
                            userPermissions = new HashSet<string> {
                                "MISSIONS_VIEW", "OKRS_VIEW", "EVALPERIODS_VIEW", "KPIS_VIEW",
                                "KPICHECKINS_VIEW", "EVALRESULTS_VIEW", "EVALREPORTS_VIEW",
                                "BONUSRULES_VIEW", "EMPLOYEES_VIEW", "DEPARTMENTS_VIEW",
                                "POSITIONS_VIEW", "SYSUSERS_VIEW", "ROLES_VIEW", "AUDITLOGS_VIEW"
                            };
                        }

                        // Helper: kiểm tra user có permission không
                        bool HasPerm(string code) => isAdmin || userPermissions.Contains(code);
                    }

                    <div class="sidebar-group">
                        <div class="sidebar-group-label">Overview</div>
                        <a href="/" class="sidebar-link">
                            <i class="bi bi-grid-1x2-fill"></i> <span>Dashboard</span>
                        </a>
                    </div>

                    @if (HasPerm("MISSIONS_VIEW") || HasPerm("OKRS_VIEW"))
                    {
                        <div class="sidebar-group">
                            <div class="sidebar-group-label">Mục tiêu chiến lược</div>
                            @if (HasPerm("MISSIONS_VIEW"))
                            {
                                <a href="/MissionVisions" class="sidebar-link">
                                    <i class="bi bi-compass-fill"></i> <span>Thiết lập tầm nhìn & sứ mệnh</span>
                                </a>
                            }
                            @if (HasPerm("OKRS_VIEW"))
                            {
                                <a href="/OKRs" class="sidebar-link">
                                    <i class="bi bi-bullseye"></i> <span>Quản lý OKR / Mục tiêu</span>
                                </a>
                            }
                        </div>
                    }

                    @if (HasPerm("EVALPERIODS_VIEW") || HasPerm("KPIS_VIEW") || HasPerm("KPICHECKINS_VIEW") || HasPerm("KPICHECKINS_REVIEW"))
                    {
                        <div class="sidebar-group">
                            <div class="sidebar-group-label">Đo lường hiệu suất</div>
                            @if (HasPerm("EVALPERIODS_VIEW"))
                            {
                                <a href="/EvaluationPeriods" class="sidebar-link">
                                    <i class="bi bi-calendar3"></i> <span>Kỳ đánh giá</span>
                                </a>
                            }
                            @if (HasPerm("KPIS_VIEW"))
                            {
                                <a href="/KPIs" class="sidebar-link">
                                    <i class="bi bi-speedometer2"></i> <span>Giao & Xem KPI cá nhân</span>
                                </a>
                            }
                            @if (HasPerm("KPICHECKINS_VIEW"))
                            {
                                <a href="/KPICheckIns" class="sidebar-link">
                                    <i class="bi bi-check2-square"></i> <span>Cập nhật tiến độ KPI</span>
                                </a>
                                <a href="/KPICheckIns/EmployeeTracking" class="sidebar-link">
                                    <i class="bi bi-person-lines-fill"></i> <span>Theo dõi KPI nhân viên</span>
                                </a>
                            }
                            @if (HasPerm("KPICHECKINS_REVIEW"))
                            {
                                <a href="/KPICheckIns/ReviewQueue" class="sidebar-link">
                                    <i class="bi bi-patch-check-fill"></i> <span>Xác nhận check-in KPI</span>
                                </a>
                            }
                        </div>
                    }

                    @if (HasPerm("EVALRESULTS_VIEW") || HasPerm("EVALRESULTS_REVIEW") || HasPerm("EVALREPORTS_VIEW") || HasPerm("BONUSRULES_VIEW"))
                    {
                        <div class="sidebar-group">
                            <div class="sidebar-group-label">Đánh giá & Thưởng</div>
                            @if (HasPerm("EVALRESULTS_VIEW"))
                            {
                                <a href="/EvaluationResults" class="sidebar-link">
                                    <i class="bi bi-award-fill"></i> <span>Đánh giá 1-1 / Kết quả</span>
                                </a>
                            }
                            @if (HasPerm("EVALRESULTS_REVIEW"))
                            {
                                <a href="/EvaluationResults/ReviewBoard" class="sidebar-link">
                                    <i class="bi bi-clipboard-check-fill"></i> <span>Duyệt đánh giá & kết quả</span>
                                </a>
                            }
                            @if (HasPerm("EVALREPORTS_VIEW"))
                            {
                                <a href="/EvaluationReports" class="sidebar-link">
                                    <i class="bi bi-file-earmark-bar-graph-fill text-info"></i> <span>Báo cáo Đánh giá (V.Director)</span>
                                </a>
                            }
                            @if (HasPerm("BONUSRULES_VIEW"))
                            {
                                <a href="/BonusRules" class="sidebar-link">
                                    <i class="bi bi-cash-coin"></i> <span>Quy tắc thưởng</span>
                                </a>
                            }
                        </div>
                    }

                    @if (HasPerm("EMPLOYEES_VIEW") || HasPerm("DEPARTMENTS_VIEW") || HasPerm("POSITIONS_VIEW"))
                    {
                        <div class="sidebar-group">
                            <div class="sidebar-group-label">Nhân sự</div>
                            @if (HasPerm("EMPLOYEES_VIEW"))
                            {
                                <a href="/Employees" class="sidebar-link">
                                    <i class="bi bi-people-fill"></i> <span>Nhân sự</span>
                                </a>
                            }
                            @if (HasPerm("DEPARTMENTS_VIEW"))
                            {
                                <a href="/Departments" class="sidebar-link">
                                    <i class="bi bi-diagram-3-fill"></i> <span>Phòng ban</span>
                                </a>
                            }
                            @if (HasPerm("POSITIONS_VIEW"))
                            {
                                <a href="/Positions" class="sidebar-link">
                                    <i class="bi bi-person-badge-fill"></i> <span>Chức vụ</span>
                                </a>
                            }
                        </div>
                    }

                    @* HỆ THỐNG: Dựa trên permission *@
                    @if (HasPerm("SYSUSERS_VIEW") || HasPerm("ROLES_VIEW") || HasPerm("AUDITLOGS_VIEW"))
                    {
                        <div class="sidebar-group mt-2">
                            <div class="sidebar-group-label">Hệ thống</div>
                            @if (HasPerm("SYSUSERS_VIEW"))
                            {
                                <a href="/SystemUsers" class="sidebar-link">
                                    <i class="bi bi-shield-lock-fill"></i> <span>Người dùng</span>
                                </a>
                            }
                            @if (HasPerm("ROLES_VIEW"))
                            {
                                <a href="/Roles" class="sidebar-link">
                                    <i class="bi bi-person-lines-fill"></i> <span>Phân quyền</span>
                                </a>
                            }
                            @if (HasPerm("AUDITLOGS_VIEW"))
                            {
                                <a href="/AuditLogs" class="sidebar-link">
                                    <i class="bi bi-journal-text"></i> <span>Lịch sử hệ thống</span>
                                </a>
                            }
                            @if (User.IsInRole("Admin") || User.IsInRole("Administrator") || User.IsInRole("HR"))
                            {
                                <a href="/SystemParameters" class="sidebar-link">
                                    <i class="bi bi-sliders"></i> <span>Cài đặt tham số</span>
                                </a>
                            }
                            @if (isAdmin)
                            {
                                <a href="/Catalog" class="sidebar-link">
                                    <i class="bi bi-collection-fill"></i> <span>Quản lý danh mục</span>
                                </a>
                            }
                        </div>
                    }

                </div>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    var userName = User.Identity.Name;
                    var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "User";
                    <div class="sidebar-footer dropup">
                        <div class="sidebar-user" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer;">
                            <div class="user-avatar">
                                <span>@(userName?[0].ToString().ToUpper() ?? "U")</span>
                            </div>
                            <div class="user-info">
                                <div class="user-name">@userName</div>
                                <div class="user-role">@userRole</div>
                            </div>
                            <i class="bi bi-three-dots-vertical ms-auto user-dots" style="color: rgba(255,255,255,0.4);"></i>
                        </div>
                        
                        <ul class="dropdown-menu shadow-sm border-0 mb-2" style="min-width: 220px; border-radius: 12px; background: #fff;">
                            <li><a class="dropdown-item py-2 fw-medium" href="/Auth/MyProfile"><i class="bi bi-person me-2 text-muted"></i> Hồ sơ cá nhân</a></li>
                            <li><a class="dropdown-item py-2 fw-medium" href="#"><i class="bi bi-gear me-2 text-muted"></i> Cài đặt</a></li>
                            <li><a class="dropdown-item py-2 fw-medium" href="/Auth/ChangePassword"><i class="bi bi-shield-lock me-2 text-muted"></i> Đổi mật khẩu</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item py-2 text-danger fw-medium" href="/Auth/Logout"><i class="bi bi-box-arrow-right me-2 text-danger"></i> Đăng xuất</a></li>
                        </ul>
                    </div>
                }
            </nav>

            <div id="sidebarOverlay" class="sidebar-overlay"></div>

            <div class="main-content">
                <header class="top-header">
                    <div class="header-left">
                        <button id="sidebarToggle" class="sidebar-toggle">
                            <i class="bi bi-list"></i>
                        </button>
                        <div class="header-search">
                            <i class="bi bi-search"></i>
                            <input type="text" placeholder="Tìm kiếm nhanh nhân viên, KPI, OKR, phòng ban...">
                        </div>
                    </div>

                    <div class="header-right">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <div class="dropdown notification-dropdown"
                                 data-notification-center
                                 data-notification-endpoint="/Notifications/Center"
                                 data-notification-read-endpoint="/Notifications/MarkAsRead"
                                 data-notification-read-all-endpoint="/Notifications/MarkAllAsRead"
                                 data-notification-ai-refresh-endpoint="/AI/RefreshSmartAlerts">
                                <button class="header-icon-btn notification-bell-btn" title="Trung tâm thông báo" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                    <i class="bi bi-bell"></i>
                                    <span class="badge-dot d-none" data-notification-dot></span>
                                    <span class="notification-count-pill d-none" data-notification-pill></span>
                                </button>

                                <div class="dropdown-menu dropdown-menu-end shadow border-0 py-0 notification-menu">
                                    <div class="notification-menu__header">
                                        <div class="notification-menu__intro">
                                            <div class="notification-menu__eyebrow">
                                                <span class="notification-menu__eyebrow-icon">
                                                    <i class="bi bi-broadcast-pin"></i>
                                                </span>
                                                Notification Center
                                            </div>
                                            <div class="notification-menu__title-row">
                                                <div class="notification-menu__title">Thông báo đẩy</div>
                                                <span class="notification-menu__live-pill">
                                                    <span class="notification-menu__live-dot"></span>
                                                    Live
                                                </span>
                                            </div>
                                            <div class="notification-menu__subtitle" data-notification-subtitle>Đang đồng bộ thông báo...</div>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-link notification-menu__action d-none" data-notification-mark-all>
                                            Đánh dấu tab đã đọc
                                        </button>
                                    </div>

                                    <div class="notification-menu__metrics">
                                        <div class="notification-metric notification-metric--all">
                                            <span class="notification-metric__label">Tổng mới</span>
                                            <span class="notification-metric__value" data-notification-metric="all">0</span>
                                        </div>
                                        <div class="notification-metric notification-metric--system">
                                            <span class="notification-metric__label">Hệ thống</span>
                                            <span class="notification-metric__value" data-notification-metric="system">0</span>
                                        </div>
                                        <div class="notification-metric notification-metric--ai">
                                            <span class="notification-metric__label">AI insights</span>
                                            <span class="notification-metric__value" data-notification-metric="ai">0</span>
                                        </div>
                                    </div>

                                    <div class="notification-menu__tabs">
                                        <ul class="nav nav-pills nav-fill gap-2 small" id="notificationTabs" role="tablist">
                                            <li class="nav-item" role="presentation">
                                                <button class="nav-link active py-1" data-bs-toggle="pill" data-bs-target="#systemAlertsPane" type="button" role="tab" data-notification-tab="system">
                                                    Hệ thống
                                                    <span class="badge bg-primary-subtle text-primary ms-1 d-none" data-notification-tab-badge="system"></span>
                                                </button>
                                            </li>
                                            <li class="nav-item" role="presentation">
                                                <button class="nav-link py-1" data-bs-toggle="pill" data-bs-target="#aiAlertsPane" type="button" role="tab" data-notification-tab="ai">
                                                    AI Insights
                                                    <span class="badge bg-warning-subtle text-warning-emphasis ms-1 d-none" data-notification-tab-badge="ai"></span>
                                                </button>
                                            </li>
                                        </ul>
                                    </div>

                                    <div class="tab-content notification-menu__content">
                                        <div class="tab-pane fade show active" id="systemAlertsPane" role="tabpanel">
                                            <div class="notification-list" data-notification-list="system">
                                                <div class="notification-loading">
                                                    <span class="spinner-border spinner-border-sm text-primary" aria-hidden="true"></span>
                                                    <span>Đang tải thông báo hệ thống...</span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="tab-pane fade" id="aiAlertsPane" role="tabpanel">
                                            <div class="notification-pane__toolbar">
                                                <span class="notification-pane__hint">Cảnh báo tự động từ dữ liệu KPI/OKR</span>
                                                <button type="button" class="notification-refresh-btn" data-notification-refresh-ai>
                                                    <i class="bi bi-arrow-repeat"></i> Làm mới
                                                </button>
                                            </div>
                                            <div class="notification-list" data-notification-list="ai">
                                                <div class="notification-loading">
                                                    <span class="spinner-border spinner-border-sm text-primary" aria-hidden="true"></span>
                                                    <span>Đang tải AI insights...</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="notification-menu__footer">
                                        <div class="notification-menu__footer-note">
                                            <i class="bi bi-hand-index-thumb"></i>
                                            <span>Chạm vào từng mục để đánh dấu đã đọc</span>
                                        </div>
                                        <button type="button" class="notification-menu__reload" data-notification-reload>
                                            <i class="bi bi-arrow-clockwise"></i>
                                            Tải lại
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                        
                        @if (User.Identity == null || !User.Identity.IsAuthenticated)
                        {
                            <div class="ms-2">
                                <a href="/Auth/Login" class="btn shadow-sm text-decoration-none" style="background: linear-gradient(135deg, #1a73e8, #4285f4); color: #ffffff; border: none; border-radius: 12px; padding: 8px 22px; font-size: 0.875rem; font-weight: 600; transition: all 0.2s; box-shadow: 0 4px 12px rgba(26, 115, 232, 0.3);" onmouseover="this.style.opacity='0.9'; this.style.transform='translateY(-1px)'" onmouseout="this.style.opacity='1'; this.style.transform='translateY(0)'">Đăng Nhập</a>
                            </div>
                        }
                    </div>
                </header>

                <main class="page-content" role="main">
                    @RenderBody()
                </main>

                <footer class="app-footer">
                    <div>&copy; @DateTime.Now.Year VietMach - KPI & OKR Management System. All rights reserved.</div>
                </footer>
            </div>
        </div>
        @await Html.PartialAsync("_AIChatWidget")
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (TempData["ToastErrorMessage"] != null || TempData["ToastSuccessMessage"] != null || TempData["ToastWarningMessage"] != null || TempData["ToastInfoMessage"] != null || TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const toastQueue = [
                    {
                        message: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastErrorMessage"] ?? TempData["ErrorMessage"])),
                        tone: 'error',
                        eyebrow: 'Tài khoản hệ thống',
                        title: 'Không thể thực hiện'
                    },
                    {
                        message: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastSuccessMessage"] ?? TempData["SuccessMessage"])),
                        tone: 'success',
                        eyebrow: 'Hoàn tất',
                        title: 'Thành công'
                    },
                    {
                        message: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastWarningMessage"])),
                        tone: 'warning',
                        eyebrow: 'Cảnh báo',
                        title: 'Cần chú ý'
                    },
                    {
                        message: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastInfoMessage"])),
                        tone: 'info',
                        eyebrow: 'Thông báo hệ thống',
                        title: 'Thông báo'
                    }
                ].filter(item => item.message);

                toastQueue.forEach(item => {
                    if (typeof window.showAppToast === 'function') {
                        window.showAppToast(item);
                    }
                });
            });
        </script>
    }
    
    @if (TempData["RestoreEntityName"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                Swal.fire({
                    title: 'Thông báo!',
                    text: "Mã '@TempData["RestoreCode"]' đã từng tồn tại và bị xóa. Bạn có muốn khôi phục lại không?",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Khôi phục ngay',
                    cancelButtonText: 'Bỏ qua'
                }).then((result) => {
                    if (result.isConfirmed) {
                        const form = document.createElement('form');
                        form.method = 'post';
                        form.action = '/@(@TempData["RestoreEntityName"])/Restore';
                        
                        const inputId = document.createElement('input');
                        inputId.type = 'hidden';
                        inputId.name = 'id';
                        inputId.value = '@TempData["RestoreId"]';
                        form.appendChild(inputId);

                        const antiForgeryToken = window.getAntiForgeryToken ? window.getAntiForgeryToken() : document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                        if (antiForgeryToken) {
                            const tokenInput = document.createElement('input');
                            tokenInput.type = 'hidden';
                            tokenInput.name = '__RequestVerificationToken';
                            tokenInput.value = antiForgeryToken;
                            form.appendChild(tokenInput);
                        }
                        
                        document.body.appendChild(form);
                        form.submit();
                    }
                });
            });
        </script>
    }

    @if (User.Identity != null && User.Identity.IsAuthenticated && ViewData["IsLoginPage"] is not true)
    {
        <script>
            // ==========================================
            // SESSION TIMEOUT - Phát hiện không hoạt động
            // ==========================================
            (function() {
                const IDLE_LIMIT = 25 * 60 * 1000;    // 25 phút không hoạt động → cảnh báo
                const COUNTDOWN_SECS = 300;            // 5 phút đếm ngược trước khi logout
                const KEEP_ALIVE_INTERVAL = 5 * 60 * 1000;
                let idleTimer = null;
                let countdownTimer = null;
                let warningShown = false;
                let continuedByActivity = false;
                let lastKeepAliveAt = 0;

                function touchServerSession(force) {
                    const now = Date.now();
                    if (!force && now - lastKeepAliveAt < KEEP_ALIVE_INTERVAL) return;
                    lastKeepAliveAt = now;

                    fetch('/Auth/KeepAlive', {
                        method: 'GET',
                        credentials: 'same-origin',
                        cache: 'no-store',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    }).then(function(response) {
                        if (response.status === 401 || response.redirected) {
                            window.location.href = '/Auth/Login';
                        }
                    }).catch(function() {
                        // Không chuyển trang khi mạng chập chờn; request thật kế tiếp sẽ tự kiểm tra cookie.
                    });
                }

                function resetIdleTimer() {
                    if (warningShown) {
                        continuedByActivity = true;
                        Swal.close();
                        return;
                    }
                    clearTimeout(idleTimer);
                    idleTimer = setTimeout(showWarning, IDLE_LIMIT);
                    touchServerSession(false);
                }

                function showWarning() {
                    if (warningShown) return;
                    warningShown = true;
                    continuedByActivity = false;

                    let remaining = COUNTDOWN_SECS;

                    Swal.fire({
                        title: 'Phiên đăng nhập sắp hết hạn',
                        html: `<p>Bạn đã không hoạt động trong một thời gian dài.</p>
                               <p>Hệ thống sẽ tự động đăng xuất sau <b id="swal-countdown">${remaining}</b> giây.</p>`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Tiếp tục làm việc',
                        cancelButtonText: 'Đăng xuất ngay',
                        confirmButtonColor: '#1a73e8',
                        cancelButtonColor: '#dc3545',
                        allowOutsideClick: false,
                        allowEscapeKey: false,
                        didOpen: function() {
                            countdownTimer = setInterval(function() {
                                remaining--;
                                var el = document.getElementById('swal-countdown');
                                if (el) el.textContent = remaining;
                                if (remaining <= 0) {
                                    clearInterval(countdownTimer);
                                    Swal.close();
                                    window.location.href = '/Auth/Logout';
                                }
                            }, 1000);
                        }
                    }).then(function(result) {
                        clearInterval(countdownTimer);
                        warningShown = false;
                        if (continuedByActivity) {
                            continuedByActivity = false;
                            touchServerSession(true);
                            resetIdleTimer();
                            return;
                        }

                        if (result.isConfirmed) {
                            touchServerSession(true);
                            resetIdleTimer();
                        } else {
                            window.location.href = '/Auth/Logout';
                        }
                    });
                }

                // Lắng nghe tất cả hoạt động của người dùng
                ['mousemove', 'mousedown', 'keydown', 'scroll', 'touchstart', 'click'].forEach(function(evt) {
                    document.addEventListener(evt, resetIdleTimer, { passive: true });
                });

                // Bắt đầu đếm
                touchServerSession(true);
                resetIdleTimer();
            })();
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
    <partial name="_AiHistoryModal" />
</body>
</html>
