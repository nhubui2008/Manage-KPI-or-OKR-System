<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VietMach KPI/OKR System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Manage_KPI_or_OKR_System.styles.css" asp-append-version="true" />
    
    <!-- Restore sidebar state immediately to prevent layout shift -->
    <script>
        (function() {
            const sidebarState = localStorage.getItem('sidebarState');
            if (sidebarState === 'expanded' || sidebarState === null) {
                document.documentElement.classList.add('sidebar-expanded');
            } else {
                document.documentElement.classList.remove('sidebar-expanded');
            }
        })();
    </script>
</head>
<body>
    <div class="app-blob-container">
        <div class="app-blob app-blob-1"></div>
        <div class="app-blob app-blob-2"></div>
        <div class="app-blob app-blob-3"></div>
    </div>
    @if (ViewData["IsLoginPage"] is true)
    {
        @RenderBody()
    }
    else
    {
        <form id="globalAntiForgeryForm" class="d-none">
            @Html.AntiForgeryToken()
        </form>
        <div class="app-wrapper">
            <nav id="sidebar" class="sidebar">
                <div class="sidebar-brand">
                    <div class="brand-icon"><i class="bi bi-hexagon-fill"></i></div>
                    <div class="brand-info">
                        <div class="brand-text">VietMach System</div>
                        <div class="brand-sub">Manage KPI & OKR</div>
                    </div>
                </div>

                <div class="sidebar-nav">
                    @{
                        // TÁCH RÕ RÀNG CÁC QUYỀN ĐỂ FRONTEND DỄ KIỂM SOÁT
                        bool isAdmin = User.IsInRole("Admin") || User.IsInRole("Administrator");
                        
                        // === KIỂM TRA PERMISSION TỪ DATABASE ===
                        var userRoles = User.Claims
                            .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role)
                            .Select(c => c.Value).ToList();

                        var userPermissions = new HashSet<string>();
                        var dbContext = Context.RequestServices.GetService(typeof(Manage_KPI_or_OKR_System.Data.MiniERPDbContext)) as Manage_KPI_or_OKR_System.Data.MiniERPDbContext;
                        
                        if (isAdmin)
                        {
                            // Admin có toàn quyền
                            userPermissions = new HashSet<string> {
                                "MISSIONS_VIEW", "OKRS_VIEW", "EVALPERIODS_VIEW", "KPIS_VIEW",
                                "KPICHECKINS_VIEW", "EVALRESULTS_VIEW", "EVALREPORTS_VIEW",
                                "BONUSRULES_VIEW", "EMPLOYEES_VIEW", "DEPARTMENTS_VIEW",
                                "POSITIONS_VIEW", "SYSUSERS_VIEW", "ROLES_VIEW", "AUDITLOGS_VIEW"
                            };
                        }
                        else if (userRoles.Any())
                        {
                            if (dbContext != null)
                            {
                                userPermissions = new HashSet<string>(
                                    dbContext.Role_Permissions
                                        .Join(dbContext.Permissions, rp => rp.PermissionId, p => p.Id, (rp, p) => new { rp, p })
                                        .Join(dbContext.Roles, x => x.rp.RoleId, r => r.Id, (x, r) => new { x.p.PermissionCode, r.RoleName })
                                        .Where(x => x.RoleName != null && userRoles.Contains(x.RoleName) && x.PermissionCode != null)
                                        .Select(x => x.PermissionCode!)
                                        .ToList()
                                );
                            }
                        }

                        // Helper: kiểm tra user có permission không
                        bool HasPerm(string code) => isAdmin || userPermissions.Contains(code);
                        
                        List<Manage_KPI_or_OKR_System.Models.SystemAlert> userAlerts = new List<Manage_KPI_or_OKR_System.Models.SystemAlert>();
                        List<Manage_KPI_or_OKR_System.Models.SystemAlert> normalAlerts = new List<Manage_KPI_or_OKR_System.Models.SystemAlert>();
                        List<Manage_KPI_or_OKR_System.Models.SystemAlert> aiAlerts = new List<Manage_KPI_or_OKR_System.Models.SystemAlert>();
                        int unreadAlerts = 0;
                        int unreadAiAlerts = 0;
                        if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            var currentUserIdValue = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                            if (dbContext != null && int.TryParse(currentUserIdValue, out var currentSystemUserId))
                            {
                                var currentEmployee = dbContext.Employees.FirstOrDefault(e => e.SystemUserId == currentSystemUserId && e.IsActive == true);
                                if (currentEmployee != null)
                                {
                                    userAlerts = dbContext.SystemAlerts
                                        .Where(a => a.ReceiverId == currentEmployee.Id && (a.ExpiresAt == null || a.ExpiresAt > DateTime.Now))
                                        .OrderByDescending(a => a.CreateDate)
                                        .Take(10)
                                        .ToList();

                                    normalAlerts = userAlerts.Where(a => a.AlertType != "AI Insight").Take(5).ToList();
                                    aiAlerts = userAlerts.Where(a => a.AlertType == "AI Insight").Take(5).ToList();
                                    unreadAlerts = dbContext.SystemAlerts.Count(a => a.ReceiverId == currentEmployee.Id && a.IsRead == false && a.AlertType != "AI Insight" && (a.ExpiresAt == null || a.ExpiresAt > DateTime.Now));
                                    unreadAiAlerts = dbContext.SystemAlerts.Count(a => a.ReceiverId == currentEmployee.Id && a.IsRead == false && a.AlertType == "AI Insight" && (a.ExpiresAt == null || a.ExpiresAt > DateTime.Now));
                                }
                            }
                        }
                    }

                    <div class="sidebar-group">
                        <div class="sidebar-group-label">Overview</div>
                        <a href="/" class="sidebar-link">
                            <i class="bi bi-grid-1x2-fill"></i> <span>Dashboard</span>
                        </a>
                    </div>

                    @if (HasPerm("MISSIONS_VIEW") || HasPerm("OKRS_VIEW"))
                    {
                        <div class="sidebar-group">
                            <div class="sidebar-group-label">Mục tiêu chiến lược</div>
                            @if (HasPerm("MISSIONS_VIEW"))
                            {
                                <a href="/MissionVisions" class="sidebar-link">
                                    <i class="bi bi-compass-fill"></i> <span>Thiết lập tầm nhìn & sứ mệnh</span>
                                </a>
                            }
                            @if (HasPerm("OKRS_VIEW"))
                            {
                                <a href="/OKRs" class="sidebar-link">
                                    <i class="bi bi-bullseye"></i> <span>Quản lý OKR / Mục tiêu</span>
                                </a>
                            }
                        </div>
                    }

                    @if (HasPerm("EVALPERIODS_VIEW") || HasPerm("KPIS_VIEW") || HasPerm("KPICHECKINS_VIEW"))
                    {
                        <div class="sidebar-group">
                            <div class="sidebar-group-label">Đo lường hiệu suất</div>
                            @if (HasPerm("EVALPERIODS_VIEW"))
                            {
                                <a href="/EvaluationPeriods" class="sidebar-link">
                                    <i class="bi bi-calendar3"></i> <span>Kỳ đánh giá</span>
                                </a>
                            }
                            @if (HasPerm("KPIS_VIEW"))
                            {
                                <a href="/KPIs" class="sidebar-link">
                                    <i class="bi bi-speedometer2"></i> <span>Giao & Xem KPI cá nhân</span>
                                </a>
                            }
                            @if (HasPerm("KPICHECKINS_VIEW"))
                            {
                                <a href="/KPICheckIns" class="sidebar-link">
                                    <i class="bi bi-check2-square"></i> <span>Cập nhật tiến độ KPI</span>
                                </a>
                            }
                        </div>
                    }

                    @if (HasPerm("EVALRESULTS_VIEW") || HasPerm("EVALREPORTS_VIEW") || HasPerm("BONUSRULES_VIEW"))
                    {
                        <div class="sidebar-group">
                            <div class="sidebar-group-label">Đánh giá & Thưởng</div>
                            @if (HasPerm("EVALRESULTS_VIEW"))
                            {
                                <a href="/EvaluationResults" class="sidebar-link">
                                    <i class="bi bi-award-fill"></i> <span>Đánh giá 1-1 / Kết quả</span>
                                </a>
                            }
                            @if (HasPerm("EVALREPORTS_VIEW"))
                            {
                                <a href="/EvaluationReports" class="sidebar-link">
                                    <i class="bi bi-file-earmark-bar-graph-fill text-info"></i> <span>Báo cáo Đánh giá (V.Director)</span>
                                </a>
                            }
                            @if (HasPerm("BONUSRULES_VIEW"))
                            {
                                <a href="/BonusRules" class="sidebar-link">
                                    <i class="bi bi-cash-coin"></i> <span>Quy tắc thưởng</span>
                                </a>
                            }
                        </div>
                    }

                    @if (HasPerm("EMPLOYEES_VIEW") || HasPerm("DEPARTMENTS_VIEW") || HasPerm("POSITIONS_VIEW"))
                    {
                        <div class="sidebar-group">
                            <div class="sidebar-group-label">Nhân sự</div>
                            @if (HasPerm("EMPLOYEES_VIEW"))
                            {
                                <a href="/Employees" class="sidebar-link">
                                    <i class="bi bi-people-fill"></i> <span>Nhân sự</span>
                                </a>
                            }
                            @if (HasPerm("DEPARTMENTS_VIEW"))
                            {
                                <a href="/Departments" class="sidebar-link">
                                    <i class="bi bi-diagram-3-fill"></i> <span>Phòng ban</span>
                                </a>
                            }
                            @if (HasPerm("POSITIONS_VIEW"))
                            {
                                <a href="/Positions" class="sidebar-link">
                                    <i class="bi bi-person-badge-fill"></i> <span>Chức vụ</span>
                                </a>
                            }
                        </div>
                    }

                    @* HỆ THỐNG: Dựa trên permission *@
                    @if (HasPerm("SYSUSERS_VIEW") || HasPerm("ROLES_VIEW") || HasPerm("AUDITLOGS_VIEW"))
                    {
                        <div class="sidebar-group mt-2">
                            <div class="sidebar-group-label">Hệ thống</div>
                            @if (HasPerm("SYSUSERS_VIEW"))
                            {
                                <a href="/SystemUsers" class="sidebar-link">
                                    <i class="bi bi-shield-lock-fill"></i> <span>Người dùng</span>
                                </a>
                            }
                            @if (HasPerm("ROLES_VIEW"))
                            {
                                <a href="/Roles" class="sidebar-link">
                                    <i class="bi bi-person-lines-fill"></i> <span>Phân quyền</span>
                                </a>
                            }
                            @if (HasPerm("AUDITLOGS_VIEW"))
                            {
                                <a href="/AuditLogs" class="sidebar-link">
                                    <i class="bi bi-journal-text"></i> <span>Lịch sử hệ thống</span>
                                </a>
                            }
                            @if (isAdmin)
                            {
                                <a href="/Catalog" class="sidebar-link">
                                    <i class="bi bi-collection-fill"></i> <span>Quản lý danh mục</span>
                                </a>
                            }
                        </div>
                    }

                </div>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    var userName = User.Identity.Name;
                    var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "User";
                    <div class="sidebar-footer dropup">
                        <div class="sidebar-user" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer;">
                            <div class="user-avatar">
                                <span>@(userName?[0].ToString().ToUpper() ?? "U")</span>
                            </div>
                            <div class="user-info">
                                <div class="user-name">@userName</div>
                                <div class="user-role">@userRole</div>
                            </div>
                            <i class="bi bi-three-dots-vertical ms-auto user-dots" style="color: rgba(255,255,255,0.4);"></i>
                        </div>
                        
                        <ul class="dropdown-menu shadow-sm border-0 mb-2" style="min-width: 220px; border-radius: 12px; background: #fff;">
                            <li><a class="dropdown-item py-2 fw-medium" href="/Auth/MyProfile"><i class="bi bi-person me-2 text-muted"></i> Hồ sơ cá nhân</a></li>
                            <li><a class="dropdown-item py-2 fw-medium" href="#"><i class="bi bi-gear me-2 text-muted"></i> Cài đặt</a></li>
                            <li><a class="dropdown-item py-2 fw-medium" href="/Auth/ChangePassword"><i class="bi bi-shield-lock me-2 text-muted"></i> Đổi mật khẩu</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item py-2 text-danger fw-medium" href="/Auth/Logout"><i class="bi bi-box-arrow-right me-2 text-danger"></i> Đăng xuất</a></li>
                        </ul>
                    </div>
                }
            </nav>

            <div id="sidebarOverlay" class="sidebar-overlay"></div>

            <div class="main-content">
                <header class="top-header">
                    <div class="header-left">
                        <button id="sidebarToggle" class="sidebar-toggle">
                            <i class="bi bi-list"></i>
                        </button>
                        <div class="header-search">
                            <i class="bi bi-search"></i>
                            <input type="text" placeholder="Tìm kiếm nhanh nhân viên, KPI, thiết bị...">
                        </div>
                    </div>

                    <div class="header-right">
                        <div class="dropdown">
                            <button class="header-icon-btn" title="Thông báo hệ thống" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-bell"></i>
                                @if(unreadAlerts + unreadAiAlerts > 0)
                                {
                                    <span class="badge-dot"></span>
                                }
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 py-0" data-bs-auto-close="outside" style="width: 360px; border-radius: 12px; overflow: hidden; margin-top: 10px;">
                                <li class="p-3 bg-light border-bottom d-flex justify-content-between align-items-center">
                                    <span class="fw-bold fs-6">Thông báo</span>
                                    @if(unreadAlerts + unreadAiAlerts > 0) { <span class="badge bg-danger rounded-pill">@(unreadAlerts + unreadAiAlerts) mới</span> }
                                </li>
                                <li class="px-3 pt-2">
                                    <ul class="nav nav-pills nav-fill gap-2 small" id="notificationTabs" role="tablist">
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link active py-1" data-bs-toggle="pill" data-bs-target="#systemAlertsPane" type="button" role="tab">Hệ thống</button>
                                        </li>
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link py-1" data-bs-toggle="pill" data-bs-target="#aiAlertsPane" type="button" role="tab">
                                                AI Insights
                                                @if (unreadAiAlerts > 0) { <span class="badge bg-danger ms-1">@unreadAiAlerts</span> }
                                            </button>
                                        </li>
                                    </ul>
                                </li>
                                <li>
                                    <div class="tab-content" style="max-height: 360px; overflow-y: auto;">
                                        <div class="tab-pane fade show active" id="systemAlertsPane" role="tabpanel">
                                            @if (normalAlerts.Any())
                                            {
                                                foreach (var alert in normalAlerts)
                                                {
                                                    <div class="border-bottom list-group-item-action p-3" style="cursor: pointer; background-color: @(alert.IsRead == true ? "transparent" : "#f0f7ff")">
                                                        <div class="d-flex w-100 justify-content-between">
                                                            <h6 class="mb-1 text-primary fw-bold" style="font-size: 0.85rem;"><i class="bi bi-info-circle me-1"></i> @alert.AlertType</h6>
                                                            <small class="text-muted" style="font-size: 0.7rem;">@alert.CreateDate?.ToString("dd/MM HH:mm")</small>
                                                        </div>
                                                        <p class="mb-1 text-dark" style="font-size: 0.8rem;">@alert.Content</p>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <div class="p-4 text-center text-muted">
                                                    <i class="bi bi-bell-slash fs-4 d-block mb-2 opacity-50"></i>
                                                    <span class="small">Không có thông báo hệ thống</span>
                                                </div>
                                            }
                                        </div>
                                        <div class="tab-pane fade" id="aiAlertsPane" role="tabpanel">
                                            <div class="p-2 border-bottom bg-light d-flex justify-content-between align-items-center">
                                                <span class="small text-muted">Cảnh báo từ dữ liệu KPI/OKR</span>
                                                <button type="button" class="btn btn-sm btn-outline-primary py-0" id="refreshAiAlertsBtn">
                                                    <i class="bi bi-arrow-repeat"></i> Làm mới
                                                </button>
                                            </div>
                                            @if (aiAlerts.Any())
                                            {
                                                foreach (var alert in aiAlerts)
                                                {
                                                    var severityClass = alert.Severity == "high" ? "danger" : alert.Severity == "medium" ? "warning" : "info";
                                                    <div class="border-bottom list-group-item-action p-3" style="cursor: pointer; background-color: @(alert.IsRead == true ? "transparent" : "#fff8e6")">
                                                        <div class="d-flex w-100 justify-content-between">
                                                            <h6 class="mb-1 text-@severityClass fw-bold" style="font-size: 0.85rem;"><i class="bi bi-stars me-1"></i> AI Insight</h6>
                                                            <small class="text-muted" style="font-size: 0.7rem;">@alert.CreateDate?.ToString("dd/MM HH:mm")</small>
                                                        </div>
                                                        <p class="mb-1 text-dark" style="font-size: 0.8rem;">@alert.Content</p>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <div class="p-4 text-center text-muted">
                                                    <i class="bi bi-stars fs-4 d-block mb-2 opacity-50"></i>
                                                    <span class="small">Chưa có AI Insight. Bấm làm mới để phân tích.</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </li>
                            </ul>
                        </div>
                        
                        @if (User.Identity == null || !User.Identity.IsAuthenticated)
                        {
                            <div class="ms-2">
                                <a href="/Auth/Login" class="btn shadow-sm text-decoration-none" style="background: linear-gradient(135deg, #1a73e8, #4285f4); color: #ffffff; border: none; border-radius: 12px; padding: 8px 22px; font-size: 0.875rem; font-weight: 600; transition: all 0.2s; box-shadow: 0 4px 12px rgba(26, 115, 232, 0.3);" onmouseover="this.style.opacity='0.9'; this.style.transform='translateY(-1px)'" onmouseout="this.style.opacity='1'; this.style.transform='translateY(0)'">Đăng Nhập</a>
                            </div>
                        }
                    </div>
                </header>

                <main class="page-content" role="main">
                    @RenderBody()
                </main>

                <footer class="app-footer">
                    <div>&copy; @DateTime.Now.Year VietMach - KPI & OKR Management System. All rights reserved.</div>
                </footer>
            </div>
        </div>
        @await Html.PartialAsync("_AIChatWidget")
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @if (TempData["RestoreEntityName"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                Swal.fire({
                    title: 'Thông báo!',
                    text: "Mã '@TempData["RestoreCode"]' đã từng tồn tại và bị xóa. Bạn có muốn khôi phục lại không?",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Khôi phục ngay',
                    cancelButtonText: 'Bỏ qua'
                }).then((result) => {
                    if (result.isConfirmed) {
                        const form = document.createElement('form');
                        form.method = 'post';
                        form.action = '/@(@TempData["RestoreEntityName"])/Restore';
                        
                        const inputId = document.createElement('input');
                        inputId.type = 'hidden';
                        inputId.name = 'id';
                        inputId.value = '@TempData["RestoreId"]';
                        form.appendChild(inputId);

                        const antiForgeryToken = window.getAntiForgeryToken ? window.getAntiForgeryToken() : document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                        if (antiForgeryToken) {
                            const tokenInput = document.createElement('input');
                            tokenInput.type = 'hidden';
                            tokenInput.name = '__RequestVerificationToken';
                            tokenInput.value = antiForgeryToken;
                            form.appendChild(tokenInput);
                        }
                        
                        document.body.appendChild(form);
                        form.submit();
                    }
                });
            });
        </script>
    }

    @if (User.Identity != null && User.Identity.IsAuthenticated && ViewData["IsLoginPage"] is not true)
    {
        <script>
            document.getElementById('refreshAiAlertsBtn')?.addEventListener('click', async function(event) {
                event.preventDefault();
                event.stopPropagation();
                const btn = this;
                const originalHtml = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
                try {
                    const response = await fetch('/AI/RefreshSmartAlerts', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            ...window.antiForgeryHeaders()
                        },
                        body: JSON.stringify({})
                    });
                    const data = await response.json();
                    if (!response.ok || data.success === false) {
                        Swal.fire('AI Insights', data.warnings?.[0] || 'Không thể làm mới AI Insights.', 'warning');
                        return;
                    }
                    window.location.reload();
                } catch {
                    Swal.fire('AI Insights', 'Không thể kết nối AI. Vui lòng thử lại sau.', 'error');
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                }
            });

            // ==========================================
            // SESSION TIMEOUT - Phát hiện không hoạt động
            // ==========================================
            (function() {
                const IDLE_LIMIT = 25 * 60 * 1000;    // 25 phút không hoạt động → cảnh báo
                const COUNTDOWN_SECS = 300;            // 5 phút đếm ngược trước khi logout
                let idleTimer = null;
                let countdownTimer = null;
                let warningShown = false;

                function resetIdleTimer() {
                    if (warningShown) return; // Đang hiện cảnh báo thì không reset
                    clearTimeout(idleTimer);
                    idleTimer = setTimeout(showWarning, IDLE_LIMIT);
                }

                function showWarning() {
                    if (warningShown) return;
                    warningShown = true;

                    let remaining = COUNTDOWN_SECS;

                    Swal.fire({
                        title: 'Phiên đăng nhập sắp hết hạn',
                        html: `<p>Bạn đã không hoạt động trong một thời gian dài.</p>
                               <p>Hệ thống sẽ tự động đăng xuất sau <b id="swal-countdown">${remaining}</b> giây.</p>`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Tiếp tục làm việc',
                        cancelButtonText: 'Đăng xuất ngay',
                        confirmButtonColor: '#1a73e8',
                        cancelButtonColor: '#dc3545',
                        allowOutsideClick: false,
                        allowEscapeKey: false,
                        didOpen: function() {
                            countdownTimer = setInterval(function() {
                                remaining--;
                                var el = document.getElementById('swal-countdown');
                                if (el) el.textContent = remaining;
                                if (remaining <= 0) {
                                    clearInterval(countdownTimer);
                                    Swal.close();
                                    window.location.href = '/Auth/Logout';
                                }
                            }, 1000);
                        }
                    }).then(function(result) {
                        clearInterval(countdownTimer);
                        warningShown = false;
                        if (result.isConfirmed) {
                            // Gọi 1 request nhẹ để reset SlidingExpiration server-side
                            fetch('/', { method: 'GET', credentials: 'same-origin' });
                            resetIdleTimer();
                        } else {
                            window.location.href = '/Auth/Logout';
                        }
                    });
                }

                // Lắng nghe tất cả hoạt động của người dùng
                ['mousemove', 'mousedown', 'keydown', 'scroll', 'touchstart', 'click'].forEach(function(evt) {
                    document.addEventListener(evt, resetIdleTimer, { passive: true });
                });

                // Bắt đầu đếm
                resetIdleTimer();
            })();
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
