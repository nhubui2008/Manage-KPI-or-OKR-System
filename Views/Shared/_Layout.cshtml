<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VietMach KPI/OKR System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Manage_KPI_or_OKR_System.styles.css" asp-append-version="true" />
</head>
<body>
    @if (ViewData["IsLoginPage"] != null && (bool)ViewData["IsLoginPage"])
    {
        @RenderBody()
    }
    else
    {
        <div class="app-wrapper">
            <nav id="sidebar" class="sidebar">
                <div class="sidebar-brand">
                    <div class="brand-icon"><i class="bi bi-hexagon-fill"></i></div>
                    <div class="brand-info">
                        <div class="brand-text">VietMach System</div>
                        <div class="brand-sub">Manage KPI & OKR</div>
                    </div>
                </div>

                <div class="sidebar-nav">
                    @{
                        // TÁCH RÕ RÀNG CÁC QUYỀN ĐỂ FRONTEND DỄ KIỂM SOÁT
                        bool isAdmin = User.IsInRole("Admin") || User.IsInRole("Administrator");
                        bool isManager = User.IsInRole("Manager");
                        bool isHR = User.IsInRole("HR");
                        bool isEmployee = User.IsInRole("Employee");
                        bool isSales = User.IsInRole("Sales");
                        bool isWarehouse = User.IsInRole("Warehouse");
                        bool isDelivery = User.IsInRole("Delivery") || User.IsInRole("Shipping");
                        bool isCustomer = User.IsInRole("Customer");
                        
                        // Nhóm quyền quản trị chung
                        bool isManagementOrHR = isAdmin || isManager || isHR;
                    }

                    <div class="sidebar-group">
                        <div class="sidebar-group-label">Overview</div>
                        <a href="/" class="sidebar-link">
                            <i class="bi bi-grid-1x2-fill"></i> Dashboard
                        </a>
                    </div>

                    @if (isManagementOrHR)
                    {
                        <div class="sidebar-group">
                            <div class="sidebar-group-label">Nhân sự</div>
                            <a href="/Employees" class="sidebar-link">
                                <i class="bi bi-people-fill"></i> Nhân sự
                            </a>
                            <a href="/Departments" class="sidebar-link">
                                <i class="bi bi-diagram-3-fill"></i> Phòng ban
                            </a>
                            <a href="/Positions" class="sidebar-link">
                                <i class="bi bi-person-badge-fill"></i> Chức vụ
                            </a>
                        </div>
                    }

                    @if (isAdmin || isManager || isEmployee)
                    {
                        <div class="sidebar-group">
                            <div class="sidebar-group-label">Mục tiêu chiến lược</div>
                            @if (isAdmin || isManager)
                            {
                                <a href="/MissionVisions" class="sidebar-link">
                                    <i class="bi bi-compass-fill"></i> Thiết lập tầm nhìn & sứ mệnh
                                </a>
                            }
                            <a href="/OKRs" class="sidebar-link">
                                <i class="bi bi-bullseye"></i> Quản lý OKR / Mục tiêu
                            </a>
                        </div>
                    }

                    @if (isAdmin || isManager || isHR || isEmployee)
                    {
                        <div class="sidebar-group">
                            <div class="sidebar-group-label">Đo lường hiệu suất</div>
                            @if (isManagementOrHR)
                            {
                                <a href="/EvaluationPeriods" class="sidebar-link">
                                    <i class="bi bi-calendar3"></i> Kỳ đánh giá
                                </a>
                            }
                            @if (isAdmin || isManager || isEmployee)
                            {
                                <a href="/KPIs" class="sidebar-link">
                                    <i class="bi bi-speedometer2"></i> Giao & Xem KPI cá nhân
                                </a>
                                <a href="/KPICheckIns" class="sidebar-link">
                                    <i class="bi bi-check2-square"></i> Cập nhật tiến độ KPI
                                </a>
                            }
                        </div>
                    }

                    @if (isAdmin || isManager || isHR || isEmployee)
                    {
                        <div class="sidebar-group">
                            <div class="sidebar-group-label">Đánh giá & Thưởng</div>
                            <a href="/EvaluationResults" class="sidebar-link">
                                <i class="bi bi-award-fill"></i> Đánh giá 1-1 / Kết quả
                            </a>
                            @if (isManagementOrHR)
                            {
                                <a href="/EvaluationReports" class="sidebar-link">
                                    <i class="bi bi-file-earmark-bar-graph-fill text-info"></i> Báo cáo Đánh giá (V.Director)
                                </a>
                                <a href="/BonusRules" class="sidebar-link">
                                    <i class="bi bi-cash-coin"></i> Quy tắc thưởng
                                </a>
                            }
                        </div>
                    }

                    @if (isAdmin || isSales || isWarehouse || isDelivery)
                    {
                        <div class="sidebar-group">
                            <div class="sidebar-group-label">Phân hệ nghiệp vụ</div>
                            
                            @if (isAdmin || isSales)
                            {
                                <a href="#salesSubMenu" class="sidebar-link" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="salesSubMenu">
                                    <i class="bi bi-cart-fill"></i> Bán hàng
                                    <i class="bi bi-chevron-right menu-arrow"></i>
                                </a>
                                <ul class="collapse sidebar-submenu" id="salesSubMenu">
                                    <li><a href="/Customers" class="sidebar-link">Quản lý khách hàng</a></li>
                                    <li><a href="/SalesOrders" class="sidebar-link">Tạo đơn hàng bán</a></li>
                                    <li><a href="/Invoices" class="sidebar-link">Lập hóa đơn</a></li>
                                </ul>
                            }

                            @if (isAdmin || isWarehouse)
                            {
                                <a href="#inventorySubMenu" class="sidebar-link" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="inventorySubMenu">
                                    <i class="bi bi-box-seam-fill"></i> Kho hàng
                                    <i class="bi bi-chevron-right menu-arrow"></i>
                                </a>
                                <ul class="collapse sidebar-submenu" id="inventorySubMenu">
                                    <li><a href="/Products" class="sidebar-link">Quản lý sản phẩm</a></li>
                                    <li><a href="/InventoryReceipts" class="sidebar-link">Nhập kho hàng hóa</a></li>
                                    <li><a href="/Warehouses" class="sidebar-link">Đóng gói đơn hàng</a></li>
                                </ul>
                            }

                            @if (isAdmin || isDelivery)
                            {
                                <a href="#shippingSubMenu" class="sidebar-link" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="shippingSubMenu">
                                    <i class="bi bi-truck"></i> Vận chuyển
                                    <i class="bi bi-chevron-right menu-arrow"></i>
                                </a>
                                <ul class="collapse sidebar-submenu" id="shippingSubMenu">
                                    <li><a href="/DeliveryNotes" class="sidebar-link">Tạo phiếu giao hàng</a></li>
                                    <li><a href="/ShippingPartners" class="sidebar-link">Cập nhật trạng thái</a></li>
                                </ul>
                            }
                        </div>
                    }

                    @if (isAdmin || isCustomer)
                    {
                        <div class="sidebar-group">
                            <div class="sidebar-group-label">Khách hàng</div>
                            <a href="/Shop" class="sidebar-link">
                                <i class="bi bi-shop"></i> Đặt hàng
                            </a>
                            <a href="/MyOrders" class="sidebar-link">
                                <i class="bi bi-box-seam"></i> Quản lý nhận sản phẩm
                            </a>
                        </div>
                    }

                    @* HỆ THỐNG: Chỉ Admin *@
                    @if (isAdmin)
                    {
                        <div class="sidebar-group mt-2">
                            <div class="sidebar-group-label">Hệ thống</div>
                            <a href="/SystemUsers" class="sidebar-link">
                                <i class="bi bi-shield-lock-fill"></i> Người dùng
                            </a>
                            <a href="/Roles" class="sidebar-link">
                                <i class="bi bi-person-lines-fill"></i> Phân quyền
                            </a>
                            <a href="/AuditLogs" class="sidebar-link">
                                <i class="bi bi-journal-text"></i> Lịch sử hệ thống
                            </a>
                        </div>
                    }
                </div>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    var userName = User.Identity.Name;
                    var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "User";
                    <div class="sidebar-footer dropup">
                        <div class="sidebar-user" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer;">
                            <div class="user-avatar">
                                <span>@(userName?[0].ToString().ToUpper() ?? "U")</span>
                            </div>
                            <div class="user-info">
                                <div class="user-name">@userName</div>
                                <div class="user-role">@userRole</div>
                            </div>
                            <i class="bi bi-three-dots-vertical ms-auto text-muted"></i>
                        </div>
                        
                        <ul class="dropdown-menu shadow-sm border-0 mb-2" style="min-width: 220px; border-radius: 12px; background: #fff;">
                            <li><a class="dropdown-item py-2 fw-medium" href="/Auth/MyProfile"><i class="bi bi-person me-2 text-muted"></i> Hồ sơ cá nhân</a></li>
                            <li><a class="dropdown-item py-2 fw-medium" href="#"><i class="bi bi-gear me-2 text-muted"></i> Cài đặt</a></li>
                            <li><a class="dropdown-item py-2 fw-medium" href="/Auth/ChangePassword"><i class="bi bi-shield-lock me-2 text-muted"></i> Đổi mật khẩu</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item py-2 text-danger fw-medium" href="/Auth/Logout"><i class="bi bi-box-arrow-right me-2 text-danger"></i> Đăng xuất</a></li>
                        </ul>
                    </div>
                }
            </nav>

            <div id="sidebarOverlay" class="sidebar-overlay"></div>

            <div class="main-content">
                <header class="top-header">
                    <div class="header-left">
                        <button id="sidebarToggle" class="sidebar-toggle">
                            <i class="bi bi-list"></i>
                        </button>
                        <div class="header-search">
                            <i class="bi bi-search"></i>
                            <input type="text" placeholder="Tìm kiếm nhanh nhân viên, KPI, thiết bị...">
                        </div>
                    </div>

                    <div class="header-right">
                        <button class="header-icon-btn" title="Thông báo hệ thống">
                            <i class="bi bi-bell"></i>
                            <span class="badge-dot"></span>
                        </button>
                        
                        @if (User.Identity == null || !User.Identity.IsAuthenticated)
                        {
                            <div class="ms-2">
                                <a href="/Auth/Login" class="btn shadow-sm text-decoration-none" style="background: linear-gradient(90deg, #a3c9f9, #fbe7a2); color: #2d3559; border: none; border-radius: 12px; padding: 6px 18px; font-size: 0.875rem; font-weight: 600; transition: all 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Đăng Nhập</a>
                            </div>
                        }
                    </div>
                </header>

                <main class="page-content" role="main">
                    @RenderBody()
                </main>

                <footer class="app-footer">
                    <div>&copy; @DateTime.Now.Year VietMach - KPI & OKR Management System. All rights reserved.</div>
                </footer>
            </div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>