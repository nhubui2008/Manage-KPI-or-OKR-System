@model List<Manage_KPI_or_OKR_System.Models.EvaluationResult>
@{
    ViewData["Title"] = "Duyệt đánh giá & kết quả";
    var employees = ViewBag.Employees as Dictionary<int, string> ?? new Dictionary<int, string>();
    var periods = ViewBag.Periods as Dictionary<int, string> ?? new Dictionary<int, string>();
    var ranks = ViewBag.Ranks as Dictionary<int, string> ?? new Dictionary<int, string>();
    bool canDirectorReview = ViewBag.CanDirectorReview == true;
    string returnUrl = Context.Request.Path + Context.Request.QueryString;

    string StatusText(string? status) => status switch
    {
        "PendingDirectorReview" => "Chờ giám đốc review",
        "Approved" => "Đã duyệt",
        "Rejected" => "Từ chối",
        _ => "Bản nháp"
    };

    int totalPending = Model.Count;
    int approved = Model.Count(r => r.SubmissionStatus == "Approved");
    int rejected = Model.Count(r => r.SubmissionStatus == "Rejected");
}

<style>
    /* ===== REVIEW BOARD CUSTOM STYLES ===== */
    .rq-stat-card {
        background: #ffffff;
        border: 1px solid var(--card-border, #e1e8f0);
        border-radius: 14px;
        padding: 20px 24px;
        box-shadow: 0 1px 4px rgba(26, 115, 232, 0.06);
        transition: all 0.25s ease;
        position: relative;
        overflow: hidden;
    }
    .rq-stat-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
    }
    .rq-stat-card.card-pending::before { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
    .rq-stat-card.card-good::before   { background: linear-gradient(90deg, #10b981, #34d399); }
    .rq-stat-card.card-risk::before   { background: linear-gradient(90deg, #ef4444, #f87171); }
    .rq-stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(26, 115, 232, 0.10);
    }
    .rq-stat-icon {
        width: 44px; height: 44px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }
    .rq-stat-card.card-pending .rq-stat-icon { background: #fef3c7; color: #d97706; }
    .rq-stat-card.card-good   .rq-stat-icon { background: #d1fae5; color: #059669; }
    .rq-stat-card.card-risk   .rq-stat-icon { background: #fee2e2; color: #dc2626; }
    .rq-stat-value {
        font-size: 2rem; font-weight: 800;
        line-height: 1; color: #1a2940;
        margin-top: 14px;
    }
    .rq-stat-label {
        font-size: 0.8rem; color: #6b7c93;
        margin-top: 4px; font-weight: 500;
    }

    /* ===== TABLE ROWS ===== */
    .rq-table thead th {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #6b7c93;
        background: #f8fafd;
        border-bottom: 1px solid #e1e8f0;
        padding: 12px 14px;
        white-space: nowrap;
    }
    .rq-table thead th:first-child { padding-left: 24px; border-radius: 0; }
    .rq-table thead th:last-child  { padding-right: 24px; }

    .rq-table tbody tr {
        border-bottom: 1px solid #f0f4f8;
        transition: background 0.15s ease;
    }
    .rq-table tbody tr:hover { background: #f5f9ff; }
    .rq-table tbody tr:last-child { border-bottom: none; }
    .rq-table tbody td {
        padding: 16px 14px;
        vertical-align: top;
    }
    .rq-table tbody td:first-child { padding-left: 24px; }
    .rq-table tbody td:last-child  { padding-right: 24px; }

    /* Avatar chip */
    .emp-avatar {
        width: 38px; height: 38px;
        border-radius: 10px;
        background: linear-gradient(135deg, #1a73e8, #4285f4);
        color: #fff;
        font-size: 0.78rem;
        font-weight: 700;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 4px 10px rgba(26, 115, 232, 0.25);
    }

    /* Review form in table */
    .rq-review-form {
        min-width: 260px;
    }
    .rq-review-form .form-control-sm {
        border-color: #e1e8f0;
        border-radius: 8px;
        font-size: 0.8rem;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    .rq-review-form .form-control-sm:focus {
        border-color: #1a73e8;
        box-shadow: 0 0 0 3px rgba(26, 115, 232, 0.1);
    }
    .rq-btn-approve {
        background: linear-gradient(135deg, #10b981, #059669);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex; align-items: center; gap: 5px;
    }
    .rq-btn-approve:hover {
        background: linear-gradient(135deg, #059669, #047857);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
        transform: translateY(-1px);
    }
    .rq-btn-reject {
        background: transparent;
        color: #dc2626;
        border: 1.5px solid #fca5a5;
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex; align-items: center; gap: 5px;
    }
    .rq-btn-reject:hover {
        background: #fee2e2;
        border-color: #ef4444;
        transform: translateY(-1px);
    }

    /* Score badge */
    .score-badge {
        background: #eff6ff; color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 999px;
        padding: 3px 10px;
        font-size: 0.75rem; font-weight: 700;
    }

    /* Rank badge */
    .rank-badge {
        background: #1e293b; color: #fff;
        border-radius: 6px;
        padding: 3px 8px;
        font-size: 0.72rem; font-weight: 700;
        letter-spacing: 0.04em;
    }

    /* Status badge */
    .status-badge {
        border-radius: 999px;
        padding: 4px 12px;
        font-size: 0.72rem; font-weight: 700;
        letter-spacing: 0.03em;
        border: 1px solid transparent;
    }
    .status-pending { background: #fef3c7; color: #b45309; border-color: #fde68a; }

    /* Empty state */
    .rq-empty {
        padding: 72px 24px;
        text-align: center;
    }
    .rq-empty-icon {
        width: 80px; height: 80px;
        background: linear-gradient(135deg, #d1fae5, #a7f3d0);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 20px;
        font-size: 2.2rem; color: #059669;
        animation: rqPulse 2.5s ease-in-out infinite;
    }
    @@keyframes rqPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(16,185,129,0.25); }
        50%       { box-shadow: 0 0 0 14px rgba(16,185,129,0); }
    }
    .rq-empty-title { font-size: 1.15rem; font-weight: 700; color: #1a2940; margin-bottom: 6px; }
    .rq-empty-sub   { font-size: 0.88rem; color: #6b7c93; }

    /* Alert styles */
    .rq-alert {
        display: flex; align-items: flex-start; gap: 12px;
        border-radius: 12px;
        padding: 14px 18px;
        margin-bottom: 20px;
        border: none;
        font-size: 0.875rem;
        font-weight: 500;
    }
    .rq-alert.success { background: #d1fae5; color: #065f46; }
    .rq-alert.danger  { background: #fee2e2; color: #7f1d1d; }
    .rq-alert-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 1px; }
    .rq-alert .btn-close { margin-left: auto; }
</style>

<div class="container-fluid px-0">

    <!-- Page Header -->
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 font-weight-bold mb-1">Duyệt đánh giá & kết quả</h1>
            <div class="page-breadcrumb">
                <a href="/">Trang chủ</a>
                <i class="bi bi-chevron-right separator"></i>
                <a asp-action="Index">Kết quả đánh giá</a>
                <i class="bi bi-chevron-right separator"></i>
                <span>Duyệt đánh giá</span>
            </div>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 d-flex align-items-center gap-2">
            <i class="bi bi-arrow-left"></i>
            <span>Quay lại</span>
        </a>
    </div>

    <!-- Stat Cards Row -->
    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="rq-stat-card card-pending">
                <div class="rq-stat-icon"><i class="bi bi-hourglass-split"></i></div>
                <div class="rq-stat-value">@totalPending</div>
                <div class="rq-stat-label">Tổng hồ sơ chờ xử lý</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="rq-stat-card card-good">
                <div class="rq-stat-icon"><i class="bi bi-patch-check"></i></div>
                <div class="rq-stat-value">@approved</div>
                <div class="rq-stat-label">Đã duyệt</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="rq-stat-card card-risk">
                <div class="rq-stat-icon"><i class="bi bi-x-octagon"></i></div>
                <div class="rq-stat-value">@rejected</div>
                <div class="rq-stat-label">Từ chối</div>
            </div>
        </div>
    </div>

    <!-- Main Card -->
    <div class="content-card w-100">
        <div class="card-header-custom border-bottom p-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fs-6 fw-bold d-flex align-items-center gap-2">
                <span style="width:32px;height:32px;border-radius:9px;background:linear-gradient(135deg,#1a73e8,#4285f4);display:inline-flex;align-items:center;justify-content:center;box-shadow:0 4px 10px rgba(26,115,232,0.3);flex-shrink:0;">
                    <i class="bi bi-clipboard-check" style="color:#fff;font-size:1rem;"></i>
                </span>
                Hồ sơ đang chờ giám đốc duyệt
            </h5>
            @if (totalPending > 0)
            {
                <span class="badge rounded-pill" style="background: linear-gradient(135deg,#f59e0b,#fbbf24); color: #fff; font-size: 0.78rem; padding: 5px 14px;">
                    @totalPending hồ sơ chờ duyệt
                </span>
            }
        </div>

        <div class="card-body-custom p-0">
            <div class="table-responsive">
                <table class="rq-table w-100 mb-0" style="border-collapse: collapse;">
                    <thead>
                        <tr>
                            <th>Nhân viên</th>
                            <th>Kỳ đánh giá</th>
                            <th>Tổng điểm</th>
                            <th>Xếp hạng</th>
                            <th>Nhận xét trưởng phòng</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Review giám đốc</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var result in Model)
                            {
                                var empName = result.EmployeeId.HasValue && employees.ContainsKey(result.EmployeeId.Value) ? employees[result.EmployeeId.Value] : "N/A";
                                var periodName = result.PeriodId.HasValue && periods.ContainsKey(result.PeriodId.Value) ? periods[result.PeriodId.Value] : "N/A";
                                var rankCode = result.RankId.HasValue && ranks.ContainsKey(result.RankId.Value) ? ranks[result.RankId.Value] : "N/A";

                                string initials = string.Join("", empName.Split(' ').Select(n => n.Length > 0 ? n[0].ToString() : "")).ToUpper();
                                if (initials.Length > 2) initials = initials.Substring(0, 2);

                                <tr>
                                    <!-- Nhân viên -->
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="emp-avatar">@initials</div>
                                            <div>
                                                <div class="fw-semibold text-dark" style="font-size:.88rem;">@empName</div>
                                                <div class="text-muted" style="font-size:.75rem;">@result.Classification</div>
                                            </div>
                                        </div>
                                    </td>

                                    <!-- Kỳ đánh giá -->
                                    <td>
                                        <div class="d-flex align-items-center gap-1 text-muted" style="font-size:.82rem; white-space:nowrap;">
                                            <i class="bi bi-calendar3 text-primary opacity-75"></i>
                                            @periodName
                                        </div>
                                        @if (result.SubmittedAt.HasValue)
                                        {
                                            <div class="text-muted" style="font-size:.72rem; padding-left:1.2rem;">Gửi lúc @result.SubmittedAt.Value.ToString("dd/MM/yyyy HH:mm")</div>
                                        }
                                    </td>

                                    <!-- Tổng điểm -->
                                    <td>
                                        <span class="score-badge">@result.TotalScore?.ToString("0.##") điểm</span>
                                    </td>

                                    <!-- Xếp hạng -->
                                    <td>
                                        <span class="rank-badge">@rankCode</span>
                                    </td>

                                    <!-- Nhận xét -->
                                    <td style="max-width: 300px;">
                                        <div class="text-muted" style="font-size:.78rem; word-break:break-word;">
                                            @(string.IsNullOrWhiteSpace(result.ReviewComment) ? "Chưa có nhận xét" : result.ReviewComment)
                                        </div>
                                    </td>

                                    <!-- Trạng thái -->
                                    <td>
                                        <span class="status-badge status-pending">@StatusText(result.SubmissionStatus)</span>
                                    </td>

                                    <!-- Review Form -->
                                    <td>
                                        @if (canDirectorReview)
                                        {
                                            <form asp-action="DirectorReview" method="post" class="rq-review-form">
                                                <input type="hidden" name="id" value="@result.Id" />
                                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                <textarea name="directorReviewComment" class="form-control form-control-sm mb-2"
                                                          rows="2" placeholder="Nhận xét của giám đốc…"></textarea>
                                                <div class="d-flex gap-2 justify-content-end">
                                                    <button type="submit" name="decision" value="Approved" class="rq-btn-approve">
                                                        <i class="bi bi-check2-circle"></i>Duyệt
                                                    </button>
                                                    <button type="submit" name="decision" value="Rejected" class="rq-btn-reject">
                                                        <i class="bi bi-x-circle"></i>Từ chối
                                                    </button>
                                                </div>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted" style="font-size:.82rem;">Đang chờ giám đốc review</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="p-0">
                                    <div class="rq-empty">
                                        <div class="rq-empty-icon">
                                            <i class="bi bi-clipboard-check"></i>
                                        </div>
                                        <div class="rq-empty-title">Tất cả đã được xử lý!</div>
                                        <div class="rq-empty-sub">Không có đánh giá nào đang chờ duyệt lúc này.</div>
                                        <a asp-action="Index" class="btn btn-outline-primary rounded-pill mt-3 px-4" style="font-size:.85rem;">
                                            <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
