@model Manage_KPI_or_OKR_System.Models.EvaluationResult
@{
    ViewData["Title"] = "Thêm Kết quả Đánh giá";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var allEmployees = ViewBag.AllEmployees as List<Manage_KPI_or_OKR_System.Models.Employee> ?? new List<Manage_KPI_or_OKR_System.Models.Employee>();
    var allPeriods = ViewBag.AllPeriods as List<Manage_KPI_or_OKR_System.Models.EvaluationPeriod> ?? new List<Manage_KPI_or_OKR_System.Models.EvaluationPeriod>();
    var allRanks = ViewBag.AllRanks as List<Manage_KPI_or_OKR_System.Models.GradingRank> ?? new List<Manage_KPI_or_OKR_System.Models.GradingRank>();
    var classificationsList = ViewBag.Classifications as List<string> ?? new List<string> { "Xuất sắc", "Giỏi", "Khá", "Trung bình", "Yếu" };
}

<div class="page-content">
    <div class="page-header d-flex align-items-center justify-content-between mb-4 animate__animated animate__fadeIn">
        <div>
            <h1 class="mb-2 fw-800">Thêm Kết quả Đánh giá</h1>
            <div class="page-breadcrumb">
                <a href="/">Trang chủ</a>
                <span class="separator">/</span>
                <a asp-action="Index">Kết quả Đánh giá</a>
                <span class="separator">/</span>
                <span class="text-muted">Thêm mới</span>
            </div>
        </div>
        <div>
            <a asp-action="Index" class="btn-outline-custom shadow-sm">
                <i class="bi bi-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-8 animate__animated animate__fadeInLeft">
            <div class="content-card border-0 shadow-lg" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">
                <div class="card-header-custom border-bottom bg-transparent py-4">
                    <h5 class="fw-bold fs-5 mb-0"><i class="bi bi-award me-2"></i> Thông tin Đánh giá</h5>
                </div>

                <div class="card-body-custom p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <!-- SECTION 1 -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-primary text-white me-3 d-flex align-items-center justify-content-center shadow" style="width: 38px; height: 38px; border-radius: 12px;">
                                <span class="fw-bold">1</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Đối tượng đánh giá</h6>
                        </div>

                        <div class="row g-4 mb-5 p-3 rounded-4 bg-light bg-opacity-50 border border-white">
                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Nhân viên <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-person-badge"></i>
                                        <select asp-for="EmployeeId" class="form-select shadow-sm" required>
                                            <option value="">-- Chọn nhân viên --</option>
                                            @foreach (var e in allEmployees)
                                            {
                                                <option value="@e.Id">@e.FullName (@e.EmployeeCode)</option>
                                            }
                                        </select>
                                    </div>
                                    <span asp-validation-for="EmployeeId" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Kỳ đánh giá <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-calendar3"></i>
                                        <select asp-for="PeriodId" class="form-select shadow-sm" required>
                                            <option value="">-- Chọn kỳ --</option>
                                            @foreach (var p in allPeriods)
                                            {
                                                <option value="@p.Id">@p.PeriodName</option>
                                            }
                                        </select>
                                    </div>
                                    <span asp-validation-for="PeriodId" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <!-- SECTION 2 -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-success text-white me-3 d-flex align-items-center justify-content-center shadow" style="width: 38px; height: 38px; border-radius: 12px;">
                                <span class="fw-bold">2</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Kết quả đánh giá</h6>
                        </div>

                        <div class="row g-4 p-3 rounded-4 bg-light bg-opacity-50 border border-white mb-4">
                            <div class="col-md-4">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Tổng điểm <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-123"></i>
                                        <input asp-for="TotalScore" type="number" class="form-control shadow-sm" step="0.01" min="0" max="100" required />
                                    </div>
                                    <span asp-validation-for="TotalScore" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Xếp hạng</label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-trophy"></i>
                                        <select asp-for="RankId" class="form-select shadow-sm">
                                            <option value="">-- Chọn hạng --</option>
                                            @foreach (var rk in allRanks)
                                            {
                                                <option value="@rk.Id">@rk.RankCode - @rk.Description</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Phân loại</label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-bar-chart-steps"></i>
                                        <select asp-for="Classification" class="form-select shadow-sm">
                                            <option value="">-- Chọn phân loại --</option>
                                            @foreach (var cls in classificationsList)
                                            {
                                                <option value="@cls">@cls</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                            <a asp-action="Index" class="btn-outline-custom">
                                <i class="bi bi-x-lg me-2"></i> Hủy thao tác
                            </a>
                            <button type="submit" class="btn-primary-custom" style="padding: 12px 40px; border-radius: 12px;">
                                <i class="bi bi-check-lg fs-5 me-2"></i> Lưu Kết quả
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-xl-4 animate__animated animate__fadeInRight">
            <div class="sticky-top" style="top: 100px;">
                <div class="content-card border-0 shadow-lg text-white mb-4" style="background: linear-gradient(135deg, #1a73e8, #1557b0); border-radius: 24px;">
                    <div class="card-body-custom p-4">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-white bg-opacity-20 p-3 rounded-4 me-3">
                                <i class="bi bi-award fs-3 text-white"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 opacity-75 fw-bold text-uppercase small">Tổng điểm</h6>
                                <h2 class="mb-0 fw-800" id="previewScore">--</h2>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="bg-white bg-opacity-10 p-3 rounded-4 d-flex align-items-center">
                                    <i class="bi bi-trophy fs-4 me-3 opacity-75"></i>
                                    <div>
                                        <div class="small opacity-75 mb-1">Xếp hạng</div>
                                        <div class="fw-bold small" id="previewRank">--</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-white bg-opacity-10 p-3 rounded-4 d-flex align-items-center">
                                    <i class="bi bi-bar-chart-steps fs-4 me-3 opacity-75"></i>
                                    <div>
                                        <div class="small opacity-75 mb-1">Phân loại</div>
                                        <div class="fw-bold small" id="previewClass">--</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="content-card border-0 shadow-sm rounded-4 bg-white p-4">
                    <h6 class="fw-bold text-dark mb-3"><i class="bi bi-info-circle text-primary me-2"></i> Lưu ý</h6>
                    <ul class="list-unstyled mb-0 small text-muted" style="line-height: 1.8;">
                        <li class="mb-2"><i class="bi bi-patch-check-fill text-success me-2"></i> Tổng điểm thang 100, không âm.</li>
                        <li class="mb-2"><i class="bi bi-patch-check-fill text-success me-2"></i> Xếp hạng quyết định mức thưởng áp dụng.</li>
                        <li><i class="bi bi-patch-check-fill text-success me-2"></i> Mỗi nhân viên có một kết quả/kỳ.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    .letter-spacing-1 { letter-spacing: 0.1em; }
    .form-select, .form-control { border: 1.5px solid #edf2f7; padding-top: 12px; padding-bottom: 12px; }
    .form-select:focus, .form-control:focus { border-color: #a3c9f9; box-shadow: 0 0 0 4px rgba(163, 201, 249, 0.1); }
    .animate__animated { animation-duration: 0.8s; }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <script>
        const scoreInput = document.getElementById('TotalScore');
        const rankSelect = document.getElementById('RankId');
        const classSelect = document.getElementById('Classification');
        function updatePreview() {
            document.getElementById('previewScore').textContent = scoreInput.value ? scoreInput.value + ' đ' : '--';
            const rankOpt = rankSelect.options[rankSelect.selectedIndex];
            document.getElementById('previewRank').textContent = rankOpt && rankOpt.value ? rankOpt.text : '--';
            document.getElementById('previewClass').textContent = classSelect.value || '--';
        }
        scoreInput.addEventListener('input', updatePreview);
        rankSelect.addEventListener('change', updatePreview);
        classSelect.addEventListener('change', updatePreview);
        window.addEventListener('DOMContentLoaded', updatePreview);
    </script>
}
