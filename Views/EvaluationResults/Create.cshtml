@model Manage_KPI_or_OKR_System.Models.EvaluationResult

@{
    ViewData["Title"] = "Thêm Kết quả Đánh giá";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    var allEmployees = ViewBag.AllEmployees as List<Manage_KPI_or_OKR_System.Models.Employee> ?? new List<Manage_KPI_or_OKR_System.Models.Employee>();
    var allPeriods = ViewBag.AllPeriods as List<Manage_KPI_or_OKR_System.Models.EvaluationPeriod> ?? new List<Manage_KPI_or_OKR_System.Models.EvaluationPeriod>();
    var allRanks = ViewBag.AllRanks as List<Manage_KPI_or_OKR_System.Models.GradingRank> ?? new List<Manage_KPI_or_OKR_System.Models.GradingRank>();
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-dark fw-bold">
                <i class="bi bi-award me-2"></i>Thêm Kết quả Đánh giá
            </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-dark text-decoration-none opacity-75">Kết quả Đánh giá</a></li>
                    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Thêm mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="content-card rounded-3">
        <div class="card-body-custom p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label asp-for="EmployeeId" class="form-label fw-bold text-dark">Nhân viên được đánh giá <span class="text-danger">*</span></label>
                        <select asp-for="EmployeeId" class="form-select" required>
                            <option value="">-- Chọn nhân viên --</option>
                            @foreach (var e in allEmployees)
                            {
                                <option value="@e.Id">@e.FullName (@e.EmployeeCode)</option>
                            }
                        </select>
                        <span asp-validation-for="EmployeeId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="PeriodId" class="form-label fw-bold text-dark">Kỳ đánh giá <span class="text-danger">*</span></label>
                        <select asp-for="PeriodId" class="form-select" required>
                            <option value="">-- Chọn kỳ --</option>
                            @foreach (var p in allPeriods)
                            {
                                <option value="@p.Id">@p.PeriodName</option>
                            }
                        </select>
                        <span asp-validation-for="PeriodId" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="TotalScore" class="form-label fw-bold text-dark">Tổng điểm <span class="text-danger">*</span></label>
                        <input asp-for="TotalScore" type="number" class="form-control" step="0.01" min="0" max="100" required />
                        <span asp-validation-for="TotalScore" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="RankId" class="form-label fw-bold text-dark">Xếp hạng</label>
                        <select asp-for="RankId" class="form-select">
                            <option value="">-- Chọn hạng --</option>
                            @foreach (var rk in allRanks)
                            {
                                <option value="@rk.Id">@rk.RankCode - @rk.Description</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Classification" class="form-label fw-bold text-dark">Phân loại Đánh giá</label>
                        <select asp-for="Classification" class="form-select">
                            <option value="Xuất sắc">Xuất sắc</option>
                            <option value="Giỏi">Giỏi</option>
                            <option value="Khá">Khá</option>
                            <option value="Trung bình">Trung bình</option>
                            <option value="Yếu">Yếu</option>
                        </select>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-5 border-top pt-4">
                    <a asp-action="Index" class="btn-outline-custom px-4">
                        <i class="bi bi-x-circle me-1"></i> Hủy bỏ
                    </a>
                    <button type="submit" class="btn-primary-custom px-4">
                        <i class="bi bi-save me-2"></i> Lưu kết quả
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
