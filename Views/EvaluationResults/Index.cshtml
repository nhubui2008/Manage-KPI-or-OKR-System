@{
    ViewData["Title"] = "Kết quả đánh giá";
}

<div class="page-header">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Kết quả đánh giá KPI & OKR</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Kết quả Đánh giá</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn-outline-custom">
            <i class="bi bi-file-earmark-pdf text-danger"></i> Xuất PDF
        </button>
        <button class="btn-primary-custom">
            <i class="bi bi-graph-up-arrow"></i> Chạy đánh giá kỳ
        </button>
    </div>
</div>

<div class="content-card">
    <div class="card-body-custom">
        <div class="toolbar">
            <div class="toolbar-left">
                <div class="toolbar-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Tìm kiếm nhân viên...">
                </div>
                <select class="filter-select">
                    <option value="">Kỳ: Tháng 1/2026</option>
                    <option value="">Kỳ: Q4/2025</option>
                    <option value="">Kỳ: Năm 2025</option>
                </select>
                <select class="filter-select">
                    <option value="">Phòng ban: Tất cả</option>
                    <option value="1">Kinh doanh</option>
                    <option value="2">Nhân sự</option>
                </select>
                <select class="filter-select">
                    <option value="">Xếp loại: Tất cả</option>
                    <option value="A">Xuất sắc (A)</option>
                    <option value="B">Tốt (B)</option>
                    <option value="C">Khá (C)</option>
                    <option value="D">Cần cố gắng (D)</option>
                </select>
            </div>
        </div>

        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 40px;"><input type="checkbox" class="form-check-input"></th>
                        <th>Nhân viên</th>
                        <th>Phòng ban</th>
                        <th>Điểm hệ số</th>
                        <th>Điểm đạt</th>
                        <th>Xếp loại</th>
                        <th class="text-end">Chi tiết</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="user-avatar bg-info" style="width: 32px; height: 32px; font-size: 0.8rem;">LC</div>
                                <div>
                                    <div class="fw-medium text-dark">Lê Văn Cường</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">NV004</div>
                                </div>
                            </div>
                        </td>
                        <td>Kinh doanh</td>
                        <td>100 / 100</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <span class="fw-bold text-success" style="font-size: 1.1rem;">95.5</span>
                            </div>
                        </td>
                        <td><span class="badge bg-success text-white px-3 py-1 rounded-pill fs-6">A</span> <span class="text-muted ms-1" style="font-size: 0.8rem;">(Xuất sắc)</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="btn btn-sm btn-outline-primary py-1 px-3 rounded-pill" style="font-size: 0.8rem;">Xem chi tiết</button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="user-avatar bg-warning" style="width: 32px; height: 32px; font-size: 0.8rem;">TD</div>
                                <div>
                                    <div class="fw-medium text-dark">Phạm Thị Dung</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">NV005</div>
                                </div>
                            </div>
                        </td>
                        <td>Kho vận</td>
                        <td>100 / 100</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <span class="fw-bold text-primary" style="font-size: 1.1rem;">82.0</span>
                            </div>
                        </td>
                        <td><span class="badge bg-primary text-white px-3 py-1 rounded-pill fs-6">B</span> <span class="text-muted ms-1" style="font-size: 0.8rem;">(Tốt)</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="btn btn-sm btn-outline-primary py-1 px-3 rounded-pill" style="font-size: 0.8rem;">Xem chi tiết</button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="user-avatar" style="width: 32px; height: 32px; font-size: 0.8rem;">VA</div>
                                <div>
                                    <div class="fw-medium text-dark">Nguyễn Văn An</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">NV002</div>
                                </div>
                            </div>
                        </td>
                        <td>Kinh doanh</td>
                        <td>100 / 100</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <span class="fw-bold text-warning" style="font-size: 1.1rem;">68.5</span>
                            </div>
                        </td>
                        <td><span class="badge bg-warning text-dark px-3 py-1 rounded-pill fs-6">C</span> <span class="text-muted ms-1" style="font-size: 0.8rem;">(Khá)</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="btn btn-sm btn-outline-primary py-1 px-3 rounded-pill" style="font-size: 0.8rem;">Xem chi tiết</button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><input type="checkbox" class="form-check-input"></td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="user-avatar bg-danger" style="width: 32px; height: 32px; font-size: 0.8rem;">M</div>
                                <div>
                                    <div class="fw-medium text-dark">Trần Văn Mạnh</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">NV012</div>
                                </div>
                            </div>
                        </td>
                        <td>Sản xuất</td>
                        <td>100 / 100</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <span class="fw-bold text-danger" style="font-size: 1.1rem;">45.0</span>
                            </div>
                        </td>
                        <td><span class="badge bg-danger text-white px-3 py-1 rounded-pill fs-6">D</span> <span class="text-muted ms-1" style="font-size: 0.8rem;">(Cần cố gắng)</span></td>
                        <td>
                            <div class="action-btns justify-content-end">
                                <button class="btn btn-sm btn-outline-primary py-1 px-3 rounded-pill" style="font-size: 0.8rem;">Xem chi tiết</button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        
        <div class="pagination-custom mt-3">
            <div class="text-muted" style="font-size: 0.875rem;">Hiển thị 1-4 trong số 120 kết quả</div>
            <div class="pagination-pages">
                <a href="#" class="page-btn"><i class="bi bi-chevron-left"></i></a>
                <a href="#" class="page-btn active">1</a>
                <a href="#" class="page-btn">2</a>
                <a href="#" class="page-btn">3</a>
                <a href="#" class="page-btn"><i class="bi bi-chevron-right"></i></a>
            </div>
        </div>
    </div>
</div>
