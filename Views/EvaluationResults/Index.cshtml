@model List<Manage_KPI_or_OKR_System.Models.EvaluationResult>
@{
    ViewData["Title"] = "Kết quả Đánh giá";
    var employees = ViewBag.Employees as Dictionary<int, string> ?? new Dictionary<int, string>();
    var periods = ViewBag.Periods as Dictionary<int, string> ?? new Dictionary<int, string>();
    var ranks = ViewBag.Ranks as Dictionary<int, string> ?? new Dictionary<int, string>();
    var workflowEmployees = ViewBag.WorkflowEmployees as Dictionary<int, string> ?? new Dictionary<int, string>();
    var allEmployees = ViewBag.AllEmployees as List<Manage_KPI_or_OKR_System.Models.Employee> ?? new List<Manage_KPI_or_OKR_System.Models.Employee>();
    var allPeriods = ViewBag.AllPeriods as List<Manage_KPI_or_OKR_System.Models.EvaluationPeriod> ?? new List<Manage_KPI_or_OKR_System.Models.EvaluationPeriod>();
    var allRanks = ViewBag.AllRanks as List<Manage_KPI_or_OKR_System.Models.GradingRank> ?? new List<Manage_KPI_or_OKR_System.Models.GradingRank>();
    var classificationsList = ViewBag.Classifications as List<string> ?? new List<string> { "Xuất sắc", "Giỏi", "Khá", "Trung bình", "Yếu" };
    
    bool canManage = User.IsInRole("Admin") || User.IsInRole("Administrator") || User.IsInRole("Manager") || User.IsInRole("HR");
    bool canSubmitEvaluation = ViewBag.CanSubmitEvaluation == true;
    bool canReviewEvaluation = ViewBag.CanReviewEvaluation == true;
    string returnUrl = Context.Request.Path + Context.Request.QueryString;

    string SubmissionText(string? status) => status switch
    {
        "PendingDirectorReview" => "Chờ giám đốc duyệt",
        "Approved" => "Giám đốc đã duyệt",
        "Rejected" => "Giám đốc từ chối",
        _ => "Bản nháp"
    };

    string SubmissionBadge(string? status) => status switch
    {
        "PendingDirectorReview" => "bg-warning bg-opacity-10 text-warning border-warning",
        "Approved" => "bg-success bg-opacity-10 text-success border-success",
        "Rejected" => "bg-danger bg-opacity-10 text-danger border-danger",
        _ => "bg-secondary bg-opacity-10 text-secondary border-secondary"
    };
}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="h3 font-weight-bold mb-1">Kết quả Đánh giá</h1><div class="page-breadcrumb"><a href="/">Trang chủ</a><i class="bi bi-chevron-right separator"></i><span>Kết quả Đánh giá</span></div></div>
    <div class="d-flex justify-content-end gap-2">
        @if (canManage)
        {
            <a asp-action="Create" class="btn-primary-custom d-flex align-items-center"><i class="bi bi-plus-lg me-1"></i> Thêm kết quả</a>
        }
        @if (canSubmitEvaluation || canReviewEvaluation)
        {
            <a asp-action="ReviewBoard" class="btn btn-outline-primary rounded-pill px-4 d-flex align-items-center">
                <i class="bi bi-clipboard-check me-1"></i> Duyệt đánh giá & kết quả
            </a>
        }
    </div>
</div>

<div class="row justify-content-center w-100 m-0">
    <div class="col-12 px-0">
        <div class="content-card w-100">
            <div class="card-body-custom">
                <div class="table-responsive w-100">
                    <table class="data-table w-100">
                        <thead><tr><th>Nhân viên</th><th>Kỳ đánh giá</th><th>Tổng điểm</th><th>Xếp hạng</th><th>Phân loại</th><th>Trạng thái duyệt</th><th>Nhận xét</th>@if(canManage || canSubmitEvaluation || canReviewEvaluation){<th class="text-end">Thao tác</th>}</tr></thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var r in Model)
                                {
                                    var empName = r.EmployeeId.HasValue && employees.ContainsKey(r.EmployeeId.Value) ? employees[r.EmployeeId.Value] : "N/A";
                                    var periodName = r.PeriodId.HasValue && periods.ContainsKey(r.PeriodId.Value) ? periods[r.PeriodId.Value] : "N/A";
                                    var rankCode = r.RankId.HasValue && ranks.ContainsKey(r.RankId.Value) ? ranks[r.RankId.Value] : "N/A";
                                    var scoreColor = r.TotalScore >= 90 ? "success" : r.TotalScore >= 70 ? "primary" : r.TotalScore >= 50 ? "warning" : "danger";
                                    var safeClassification = System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(r.Classification ?? "");
                                    var safeReviewComment = System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(r.ReviewComment ?? "");
                                    var submitterName = r.SubmittedById.HasValue && workflowEmployees.ContainsKey(r.SubmittedById.Value) ? workflowEmployees[r.SubmittedById.Value] : "";
                                    <tr>
                                        <td><div class="d-flex align-items-center gap-2"><div class="user-avatar" style="width:28px;height:28px;font-size:0.7rem;">@(empName.Length > 0 ? empName[0].ToString() : "?")</div><span class="fw-medium text-dark">@empName</span></div></td>
                                        <td class="text-muted">@periodName</td>
                                        <td><span class="badge bg-@scoreColor bg-opacity-10 text-@scoreColor rounded-pill px-2">@(r.TotalScore % 1 == 0 ? r.TotalScore?.ToString("0") : r.TotalScore?.ToString("0.#"))đ</span></td>
                                        <td><span class="badge bg-dark text-white px-2">@rankCode</span></td>
                                        <td>@(r.Classification ?? "Chưa phân loại")</td>
                                        <td>
                                            <span class="badge border rounded-pill px-3 py-2 @SubmissionBadge(r.SubmissionStatus)">
                                                @SubmissionText(r.SubmissionStatus)
                                            </span>
                                            @if (!string.IsNullOrWhiteSpace(submitterName))
                                            {
                                                <div class="text-muted small mt-1">Gửi bởi: @submitterName</div>
                                            }
                                        </td>
                                        <td class="text-muted" style="max-width:260px;">
                                            <span class="d-inline-block text-truncate" style="max-width:250px;" title="@(r.ReviewComment ?? "Chưa có nhận xét")">@(string.IsNullOrWhiteSpace(r.ReviewComment) ? "Chưa có nhận xét" : r.ReviewComment)</span>
                                        </td>
                                        @if(canManage || canSubmitEvaluation || canReviewEvaluation){
                                        <td><div class="action-btns justify-content-end">
                                            @if (canManage)
                                            {
                                                <button type="button" class="action-btn" title="Sửa" onclick="editResult('@r.Id', '@r.EmployeeId', '@r.PeriodId', '@(r.TotalScore?.ToString() ?? "0")', '@r.RankId', '@safeClassification', '@safeReviewComment')"><i class="bi bi-pencil-square"></i></button>
                                                <form asp-action="Delete" method="post" style="display:inline;"><input type="hidden" name="id" value="@r.Id" /><button type="submit" class="action-btn danger" title="Xóa" onclick="return confirm('Xóa kết quả này?')"><i class="bi bi-trash"></i></button></form>
                                            }
                                            @if (canSubmitEvaluation && (string.IsNullOrWhiteSpace(r.SubmissionStatus) || r.SubmissionStatus == "Draft" || r.SubmissionStatus == "Rejected"))
                                            {
                                                <form asp-action="SubmitForDirectorReview" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@r.Id" />
                                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                    <button type="submit" class="action-btn text-primary" title="Gửi giám đốc duyệt"><i class="bi bi-send-check"></i></button>
                                                </form>
                                            }
                                        </div></td>
                                        }
                                    </tr>
                                }
                            }
                            else
                            {<tr><td colspan="@(canManage || canSubmitEvaluation || canReviewEvaluation ? "8" : "7")" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;"></i><p class="mt-2">Chưa có kết quả đánh giá</p></td></tr>}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Create Modal -->
        <div class="modal fade" id="createModal" tabindex="-1">
            <div class="modal-dialog"><div class="modal-content border-0 shadow">
                <div class="modal-header border-0"><h5 class="modal-title fw-bold"><i class="bi bi-award me-2"></i>Thêm Kết quả Đánh giá</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <form asp-action="Create" method="post"><div class="modal-body">
                    <div class="mb-3"><label class="form-label fw-semibold">Nhân viên</label><select name="EmployeeId" class="form-select" required>
                        <option value="">-- Chọn nhân viên --</option>@foreach (var e in allEmployees){<option value="@e.Id">@e.FullName (@e.EmployeeCode)</option>}</select></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Kỳ đánh giá</label><select name="PeriodId" class="form-select" required>
                        <option value="">-- Chọn kỳ --</option>@foreach (var p in allPeriods){<option value="@p.Id">@p.PeriodName</option>}</select></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Tổng điểm</label><input type="number" name="TotalScore" class="form-control" step="0.01" min="0" max="100" required /></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Xếp hạng</label><select name="RankId" class="form-select">
                        <option value="">-- Chọn hạng --</option>@foreach (var rk in allRanks){<option value="@rk.Id">@rk.RankCode - @rk.Description</option>}</select></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Phân loại</label><select name="Classification" class="form-select">
                        <option value="">-- Chọn phân loại --</option>
                        @foreach (var cls in classificationsList)
                        {
                            <option value="@cls">@cls</option>
                        }
                        </select></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Nhận xét đánh giá</label><textarea name="ReviewComment" class="form-control" rows="4" maxlength="2000" placeholder="Nhập nhận xét hoặc để trống để bổ sung sau"></textarea></div>
                </div>
                <div class="modal-footer border-0"><button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn-primary-custom d-flex align-items-center">Lưu kết quả</button></div></form>
            </div></div>
        </div>

        <!-- Edit Modal -->
        <div class="modal fade" id="editModal" tabindex="-1">
            <div class="modal-dialog"><div class="modal-content border-0 shadow">
                <div class="modal-header border-0"><h5 class="modal-title fw-bold"><i class="bi bi-pencil-square me-2"></i>Sửa Kết quả Đánh giá (<span id="editModalScoreHeader">0</span>đ)</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <form asp-action="Edit" method="post"><div class="modal-body">
                    <input type="hidden" name="Id" id="editId" />
                    <div class="mb-3"><label class="form-label fw-semibold">Nhân viên</label><select name="EmployeeId" id="editEmployeeId" class="form-select" required>
                        <option value="">-- Chọn nhân viên --</option>@foreach (var e in allEmployees){<option value="@e.Id">@e.FullName (@e.EmployeeCode)</option>}</select></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Kỳ đánh giá</label><select name="PeriodId" id="editPeriodId" class="form-select" required>
                        <option value="">-- Chọn kỳ --</option>@foreach (var p in allPeriods){<option value="@p.Id">@p.PeriodName</option>}</select></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Tổng điểm</label><input type="number" name="TotalScore" id="editTotalScore" class="form-control" step="0.01" min="0" max="100" required /></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Xếp hạng</label><select name="RankId" id="editRankId" class="form-select">
                        <option value="">-- Chọn hạng --</option>@foreach (var rk in allRanks){<option value="@rk.Id">@rk.RankCode - @rk.Description</option>}</select></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Phân loại</label><select name="Classification" id="editClassification" class="form-select">
                        <option value="">-- Chọn phân loại --</option>
                        @foreach (var cls in classificationsList)
                        {
                            <option value="@cls">@cls</option>
                        }
                        </select></div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label fw-semibold mb-0">Nhận xét đánh giá</label>
                            <button type="button" class="btn btn-sm btn-outline-primary" id="aiGenerateReviewBtn"><i class="bi bi-magic me-1"></i> AI Viết nhận xét</button>
                        </div>
                        <textarea name="ReviewComment" id="editReviewComment" class="form-control" rows="5" maxlength="2000" placeholder="AI sẽ tạo bản nháp, quản lý có thể chỉnh sửa trước khi lưu"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0"><button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn-primary-custom d-flex align-items-center">Cập nhật kết quả</button></div></form>
            </div></div>
        </div>

    </div>
</div>
</div>

<script>
    function editResult(id, empId, periodId, score, rankId, classification, reviewComment) {
        document.getElementById('editId').value = id;
        document.getElementById('editEmployeeId').value = empId;
        document.getElementById('editPeriodId').value = periodId;
        document.getElementById('editTotalScore').value = score;
        document.getElementById('editRankId').value = rankId;
        document.getElementById('editClassification').value = classification || "Trung bình";
        document.getElementById('editReviewComment').value = reviewComment || "";
        document.getElementById('editModalScoreHeader').innerText = parseFloat(score);
        
        var editModal = new bootstrap.Modal(document.getElementById('editModal'));
        editModal.show();
    }

    document.getElementById('aiGenerateReviewBtn')?.addEventListener('click', async function () {
        const resultId = parseInt(document.getElementById('editId').value || '0', 10);
        if (!resultId) return;

        const btn = this;
        const originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> AI đang viết...';

        try {
            const response = await fetch('/AI/GenerateReview', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    ...window.antiForgeryHeaders()
                },
                body: JSON.stringify({ evaluationResultId: resultId })
            });
            const data = await response.json();
            if (!response.ok || data.success === false) {
                const message = data.warnings?.[0] || 'Không thể sinh nhận xét AI.';
                window.showAppToast({ tone: 'warning', eyebrow: 'AI Nhận xét', title: 'AI chưa sẵn sàng', message });
                return;
            }
            document.getElementById('editReviewComment').value = data.text || '';
        } catch {
            window.showAppToast({ tone: 'error', eyebrow: 'Kết nối AI', title: 'Lỗi kết nối', message: 'Không thể kết nối AI. Vui lòng thử lại sau.' });
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        }
    });
</script>
