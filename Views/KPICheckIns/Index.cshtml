@model IEnumerable<Manage_KPI_or_OKR_System.Models.KPICheckIn>
@using Manage_KPI_or_OKR_System.Helpers
@using System.Text.Json
@{
    ViewData["Title"] = "Lịch sử Check-in KPI";
    
    var detailsDict = ViewBag.Details as Dictionary<int, Manage_KPI_or_OKR_System.Models.CheckInDetail> ?? new Dictionary<int, Manage_KPI_or_OKR_System.Models.CheckInDetail>();
    var employeesDict = ViewBag.Employees as Dictionary<int, Manage_KPI_or_OKR_System.Models.Employee> ?? new Dictionary<int, Manage_KPI_or_OKR_System.Models.Employee>();
    var kpisDict = ViewBag.KPIs as Dictionary<int, Manage_KPI_or_OKR_System.Models.KPI> ?? new Dictionary<int, Manage_KPI_or_OKR_System.Models.KPI>();
    var statusesDict = ViewBag.CheckInStatuses as Dictionary<int, string> ?? new Dictionary<int, string>();
    var commentsByCheckIn = ViewBag.CheckInComments as Dictionary<int, List<Manage_KPI_or_OKR_System.Models.GoalComment>> ?? new Dictionary<int, List<Manage_KPI_or_OKR_System.Models.GoalComment>>();
    bool canReviewCheckIns = ViewBag.CanReviewCheckIns == true;
    string returnUrl = ViewBag.ReturnUrl as string ?? "/KPICheckIns";
    var failReasonsDict = (ViewBag.FailReasons as List<Manage_KPI_or_OKR_System.Models.FailReason> ?? new List<Manage_KPI_or_OKR_System.Models.FailReason>()).ToDictionary(r => r.Id, r => r.ReasonName ?? "Chưa rõ");
    var kpiData = ViewBag.KPIData as Dictionary<int, Manage_KPI_or_OKR_System.Models.KPIDetail> ?? new Dictionary<int, Manage_KPI_or_OKR_System.Models.KPIDetail>();
    var kpiPeriods = ViewBag.KPIPeriods as Dictionary<int, Manage_KPI_or_OKR_System.Models.EvaluationPeriod> ?? new Dictionary<int, Manage_KPI_or_OKR_System.Models.EvaluationPeriod>();
    var kpisForSchedule = (ViewBag.AllKPIs as List<Manage_KPI_or_OKR_System.Models.KPI> ?? new List<Manage_KPI_or_OKR_System.Models.KPI>())
        .Concat(kpisDict.Values)
        .GroupBy(k => k.Id)
        .ToDictionary(g => g.Key, g => g.First());
    var kpiDataJson = JsonSerializer.Serialize(kpiData.ToDictionary(k => k.Key, v => new {
        target = v.Value.TargetValue,
        unit = v.Value.MeasurementUnit,
        isInverse = v.Value.IsInverse,
        frequencyDays = v.Value.CheckInFrequencyDays ?? 1,
        deadlineTime = (v.Value.CheckInDeadlineTime ?? new TimeSpan(10, 0, 0)).ToString(@"hh\:mm"),
        reminderBeforeHours = v.Value.ReminderBeforeHours ?? 24,
        periodStart = kpisForSchedule.ContainsKey(v.Key) && kpisForSchedule[v.Key].PeriodId.HasValue && kpiPeriods.ContainsKey(kpisForSchedule[v.Key].PeriodId!.Value)
            ? kpiPeriods[kpisForSchedule[v.Key].PeriodId!.Value].StartDate
            : null,
        periodEnd = kpisForSchedule.ContainsKey(v.Key) && kpisForSchedule[v.Key].PeriodId.HasValue && kpiPeriods.ContainsKey(kpisForSchedule[v.Key].PeriodId!.Value)
            ? kpiPeriods[kpisForSchedule[v.Key].PeriodId!.Value].EndDate
            : null
    }));

    int inTimeCount = Model.Count(c => c.StatusId == 1 || c.StatusId == null);
    int riskCount = Model.Count(c => c.StatusId == 2);
    int lateCount = Model.Count(c => c.StatusId == 3);
    int totalCount = Model.Count();
    
    int inTimePct = totalCount > 0 ? (inTimeCount * 100) / totalCount : 0;
    int riskPct = totalCount > 0 ? (riskCount * 100) / totalCount : 0;
    int latePct = totalCount > 0 ? (lateCount * 100) / totalCount : 0;

    string GetReviewText(string? status) => status switch
    {
        "Pending" => "Chờ quản lý xác nhận",
        "Rejected" => "Từ chối",
        _ => "Đã xác nhận"
    };

    string GetReviewBadgeClass(string? status) => status switch
    {
        "Pending" => "bg-warning bg-opacity-10 text-warning border-warning",
        "Rejected" => "bg-danger bg-opacity-10 text-danger border-danger",
        _ => "bg-success bg-opacity-10 text-success border-success"
    };
}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Check-in KPI</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <a href="/KPIs">KPI</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Check-in</span>
        </div>
    </div>
    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Create" class="btn-primary-custom d-flex align-items-center">
            <i class="bi bi-calendar-check text-white me-1"></i> Thực hiện Check-in
        </a>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Phân tích Check-in -->
    <div class="col-lg-4">
        <div class="content-card h-100 shadow-sm border-0">
            <div class="card-header-custom border-bottom p-3">
                <h5 class="mb-0 fs-6 fw-bold"><i class="bi bi-pie-chart-fill me-2"></i> Trạng thái (Tuần này)</h5>
            </div>
            <div class="card-body-custom p-4 text-center">
                <div class="position-relative d-inline-block mx-auto mb-4" style="width: 140px; height: 140px;">
                    <!-- Placeholder for Doughnut Chart -->
                    <svg viewBox="0 0 36 36" class="circular-chart w-100 h-100">
                        <path class="circle-bg" stroke="#f1f5f9" stroke-width="3" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                        <!-- Green section -->
                        <path class="circle" stroke="#10b981" stroke-dasharray="@inTimePct, 100" stroke-width="3" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                        <!-- Yellow section -->
                        <path class="circle" stroke="#f59e0b" stroke-dasharray="@riskPct, 100" stroke-dashoffset="-@inTimePct" stroke-width="3" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                        <!-- Red section -->
                        <path class="circle" stroke="#ef4444" stroke-dasharray="@latePct, 100" stroke-dashoffset="-@(inTimePct + riskPct)" stroke-width="3" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                        <text x="18" y="20.35" class="percentage" font-size="7.5" text-anchor="middle" fill="#1e293b" font-weight="700">@((inTimePct + riskPct).ToString())%</text>
                    </svg>
                </div>
                <div class="d-flex flex-column gap-2 mt-2 px-3">
                    <div class="status-badge-soft badge-on-track w-100 justify-content-between">
                        <span><i class="bi bi-check-circle-fill me-2"></i>Tốt (On Track)</span>
                        <span>@inTimePct%</span>
                    </div>
                    <div class="status-badge-soft badge-at-risk w-100 justify-content-between">
                        <span><i class="bi bi-exclamation-triangle-fill me-2"></i>Nguy cơ (At Risk)</span>
                        <span>@riskPct%</span>
                    </div>
                    <div class="status-badge-soft badge-late w-100 justify-content-between">
                        <span><i class="bi bi-x-circle-fill me-2"></i>Trễ (Late)</span>
                        <span>@latePct%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Checklist -->
    <div class="col-lg-8">
        <div class="content-card h-100 shadow-sm border-0">
            <div class="card-header-custom border-bottom p-3 d-flex justify-content-between align-items-center bg-light bg-opacity-50">
                <h5 class="mb-0 fs-6 fw-bold"><i class="bi bi-card-checklist me-2"></i> Lịch sử Check-in</h5>
            </div>
            <div class="card-body-custom p-0">
                <div class="table-responsive w-100">
                    <table class="data-table w-100 mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4 fw-medium border-0">Người cập nhật</th>
                                <th class="fw-medium border-0">Thực tế KPI</th>
                                <th class="fw-medium border-0">Ngày Checkin</th>
                                <th class="fw-medium border-0">Deadline</th>
                                <th class="fw-medium border-0">Lý do chưa đạt</th>
                                <th class="fw-medium border-0">Tiến độ</th>
                                <th class="fw-medium border-0">Xác nhận</th>
                                <th class="fw-medium border-0">Đánh giá QL</th>
                                <th class="fw-medium border-0 text-end pe-4">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var ci in Model)
                                {
                                    var detail = detailsDict.ContainsKey(ci.Id) ? detailsDict[ci.Id] : new Manage_KPI_or_OKR_System.Models.CheckInDetail();
                                    var employee = (ci.EmployeeId.HasValue && employeesDict.ContainsKey(ci.EmployeeId.Value)) ? employeesDict[ci.EmployeeId.Value] : null;
                                    string empName = employee?.FullName ?? "Chưa gán";
                                    string initials = string.Join("", empName.Split(' ').Select(n => n.Length > 0 ? n[0].ToString() : "")).ToUpper();
                                    if (initials.Length > 2) initials = initials.Substring(0, 2);

                                    var kpi = (ci.KPIId.HasValue && kpisDict.ContainsKey(ci.KPIId.Value)) ? kpisDict[ci.KPIId.Value] : null;
                                    string kpiName = kpi?.KPIName ?? "KPI Đã xóa";

                                    decimal progressVal = detail.ProgressPercentage ?? 0;
                                    decimal progressWidth = Math.Min(100, progressVal);
                                    string colorClass = ProgressHelper.GetProgressTextColorClass(progressVal);
                                    string barColor = ProgressHelper.GetProgressColorClass(progressVal);

                                    <tr class="bg-white">
                                        <td class="ps-4 py-3 border-bottom-0">
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="user-avatar bg-primary text-white flex-shrink-0 d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width: 36px; height: 36px; font-size: 0.85rem; border-radius: 10px;">@initials</div>
                                                <div class="fw-bold text-dark">@empName</div>
                                            </div>
                                        </td>
                                        <td class="py-3 border-bottom-0">
                                            <div class="fw-bold text-dark mb-1">@kpiName</div>
                                            <div class="text-muted d-flex align-items-center gap-1" style="font-size: 0.8rem;">
                                                <i class="bi bi-arrow-right-short"></i> @String.Format("{0:N0}", detail.AchievedValue)
                                                @if (!string.IsNullOrEmpty(detail.Note))
                                                {
                                                    <span class="ms-2" title="@detail.Note"><i class="bi bi-info-circle text-info"></i></span>
                                                }
                                            </div>
                                        </td>
                                        <td class="py-3 border-bottom-0">
                                            <div class="text-muted" style="font-size: 0.85rem;"><i class="bi bi-clock me-1"></i> @(ci.CheckInDate?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</div>
                                        </td>
                                        <td class="py-3 border-bottom-0">
                                            <div class="fw-semibold @(ci.IsLate == true ? "text-danger" : "text-success")" style="font-size: 0.82rem;">
                                                <i class="bi bi-alarm me-1"></i>@(ci.DeadlineAt?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa đặt")
                                            </div>
                                            @if (detail.ExpectedValueAtDeadline.HasValue)
                                            {
                                                <div class="text-muted" style="font-size: 0.72rem;">
                                                    Cần đạt: @String.Format("{0:N0}", detail.ExpectedValueAtDeadline)
                                                </div>
                                            }
                                        </td>
                                        <td class="py-3 border-bottom-0">
                                            @if (ci.FailReasonId.HasValue && failReasonsDict.ContainsKey(ci.FailReasonId.Value))
                                            {
                                                <div class="status-badge-soft bg-danger bg-opacity-10 text-danger border-0" style="font-size: 0.75rem; white-space: nowrap;">
                                                    <i class="bi bi-exclamation-triangle-fill me-1"></i> @failReasonsDict[ci.FailReasonId.Value]
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="text-muted" style="font-size: 0.75rem;">--</div>
                                            }
                                        </td>
                                        <td class="py-3 border-bottom-0" style="min-width: 140px;">
                                            <div class="d-flex align-items-center justify-content-between mb-2">
                                                <span class="@colorClass fw-bold" style="font-size: 0.85rem;">@progressVal%</span>
                                                @{
                                                    var statusName = ci.StatusId.HasValue && statusesDict.ContainsKey(ci.StatusId.Value) ? statusesDict[ci.StatusId.Value] : "Đúng tiến độ";
                                                    string badgeClass = ci.IsLate == true || statusName.Contains("Chậm") ? "badge-late" :
                                                        statusName.Contains("Vượt") ? "badge-at-risk" : "badge-on-track";
                                                    string badgeText = ci.IsLate == true || statusName.Contains("Chậm") ? "Late" :
                                                        statusName.Contains("Vượt") ? "Ahead" : "On Track";
                                                }
                                                <span class="status-badge-soft @badgeClass" style="font-size: 0.65rem; padding: 2px 8px;">
                                                    <span class="status-dot"></span> @badgeText
                                                </span>
                                            </div>
                                            <div class="progress shadow-sm" style="height: 6px;">
                                                <div class="progress-bar @barColor" style="width: @progressWidth%;"></div>
                                            </div>
                                        </td>
                                        <td class="py-3 border-bottom-0">
                                            @{
                                                var reviewStatus = string.IsNullOrWhiteSpace(ci.ReviewStatus) ? "Approved" : ci.ReviewStatus;
                                                var reviewer = (ci.ReviewedById.HasValue && employeesDict.ContainsKey(ci.ReviewedById.Value)) ? employeesDict[ci.ReviewedById.Value] : null;
                                            }
                                            <span class="badge border rounded-pill px-3 py-2 @GetReviewBadgeClass(reviewStatus)">
                                                @GetReviewText(reviewStatus)
                                            </span>
                                            @if (ci.ReviewedAt.HasValue)
                                            {
                                                <div class="text-muted mt-1" style="font-size: 0.72rem;">
                                                    @reviewer?.FullName - @ci.ReviewedAt.Value.ToString("dd/MM/yyyy HH:mm")
                                                </div>
                                            }
                                        </td>
                                        <td class="py-3 border-bottom-0" style="min-width: 170px;">
                                            @if (ci.ReviewScore.HasValue)
                                            {
                                                <div class="fw-bold text-primary">@ci.ReviewScore.Value.ToString("0.##")/100</div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(ci.ReviewComment))
                                            {
                                                <div class="text-muted small" title="@ci.ReviewComment">
                                                    @(ci.ReviewComment.Length > 70 ? ci.ReviewComment.Substring(0, 70) + "..." : ci.ReviewComment)
                                                </div>
                                            }
                                            @if (!ci.ReviewScore.HasValue && string.IsNullOrWhiteSpace(ci.ReviewComment))
                                            {
                                                <span class="text-muted small">--</span>
                                            }
                                        </td>
                                        <td class="py-3 border-bottom-0 pe-4 text-end" style="min-width: 260px;">
                                            @if (canReviewCheckIns && reviewStatus == "Pending")
                                            {
                                                <form asp-action="Review" method="post" class="review-inline-form text-start">
                                                    <input type="hidden" name="id" value="@ci.Id" />
                                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                    <div class="d-flex gap-2 mb-2">
                                                        <input type="number" min="0" max="100" step="0.01" name="reviewScore" class="form-control form-control-sm" placeholder="Điểm 0-100" />
                                                    </div>
                                                    <textarea name="reviewComment" class="form-control form-control-sm mb-2" rows="2" placeholder="Nhận xét của quản lý..."></textarea>
                                                    <div class="d-flex gap-2 justify-content-end">
                                                        <button type="submit" name="decision" value="Approved" class="btn btn-sm btn-success">
                                                            <i class="bi bi-check2-circle me-1"></i>Xác nhận
                                                        </button>
                                                        <button type="submit" name="decision" value="Rejected" class="btn btn-sm btn-outline-danger">
                                                            <i class="bi bi-x-circle me-1"></i>Từ chối
                                                        </button>
                                                    </div>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">--</span>
                                            }
                                        </td>
                                    </tr>
                                    <tr class="bg-white">
                                        <td colspan="8" class="px-4 pb-4 pt-0">
                                            @{
                                                var comments = commentsByCheckIn.ContainsKey(ci.Id) ? commentsByCheckIn[ci.Id] : new List<Manage_KPI_or_OKR_System.Models.GoalComment>();
                                            }
                                            <div class="checkin-comments border rounded-3 p-3 bg-light bg-opacity-50">
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <div class="fw-bold small text-dark">
                                                        <i class="bi bi-chat-left-text me-1 text-primary"></i>Trao đổi & đánh giá bổ sung
                                                    </div>
                                                    <span class="text-muted small">@comments.Count bình luận</span>
                                                </div>
                                                @if (comments.Any())
                                                {
                                                    <div class="d-flex flex-column gap-2 mb-3">
                                                        @foreach (var comment in comments)
                                                        {
                                                            var commenter = comment.CommenterId.HasValue && employeesDict.ContainsKey(comment.CommenterId.Value)
                                                                ? employeesDict[comment.CommenterId.Value].FullName
                                                                : "Hệ thống";
                                                            <div class="bg-white border rounded-3 p-2">
                                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                                    <span class="fw-semibold small">@commenter</span>
                                                                    <span class="text-muted" style="font-size: 0.72rem;">@comment.CommentTime?.ToString("dd/MM/yyyy HH:mm")</span>
                                                                </div>
                                                                @if (comment.Rating.HasValue)
                                                                {
                                                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 mb-1">
                                                                        Đánh giá: @comment.Rating.Value.ToString("0.##")/100
                                                                    </span>
                                                                }
                                                                <div class="text-muted small">@comment.Content</div>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                <form asp-action="AddComment" method="post" class="row g-2 align-items-start">
                                                    <input type="hidden" name="checkInId" value="@ci.Id" />
                                                    <input type="hidden" name="kpiId" value="@ci.KPIId" />
                                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                    <div class="col-lg-8">
                                                        <textarea name="content" class="form-control form-control-sm" rows="2" placeholder="Thêm bình luận về lần check-in này..." required></textarea>
                                                    </div>
                                                    <div class="col-lg-2">
                                                        <input type="number" min="0" max="100" step="0.01" name="rating" class="form-control form-control-sm" placeholder="Điểm" />
                                                    </div>
                                                    <div class="col-lg-2 d-grid">
                                                        <button type="submit" class="btn btn-sm btn-outline-primary">
                                                            <i class="bi bi-send me-1"></i>Gửi
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center py-5 text-muted bg-white">
                                        <i class="bi bi-journal-x fs-2 opacity-50 mb-2 d-block"></i>
                                        Chưa có bản ghi Check-in nào
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@{
    var allEmployeesList = ViewBag.AllEmployees as List<Manage_KPI_or_OKR_System.Models.Employee> ?? new List<Manage_KPI_or_OKR_System.Models.Employee>();
    var allKPIsList = ViewBag.AllKPIs as List<Manage_KPI_or_OKR_System.Models.KPI> ?? new List<Manage_KPI_or_OKR_System.Models.KPI>();
    var allStatusesList = ViewBag.AllStatuses as List<Manage_KPI_or_OKR_System.Models.CheckInStatus> ?? new List<Manage_KPI_or_OKR_System.Models.CheckInStatus>();
}

@if (TempData["SuccessMessage"] != null)
{<div class="alert alert-success alert-dismissible fade show" role="alert"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

@if (TempData["ErrorMessage"] != null)
{<div class="alert alert-danger alert-dismissible fade show" role="alert"><i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<!-- Create Check-in Modal -->
<div class="modal fade" id="createCheckinModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header-soft primary">
                <h5 class="modal-title-custom">
                    <i class="bi bi-calendar-check-fill text-white shadow-sm" style="background: linear-gradient(135deg, #1a73e8, #4285f4); width: 42px; height: 42px; display: flex; align-items: center; justify-content: center; border-radius: 12px;"></i>
                    Thực hiện Check-in KPI
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" asp-controller="KPICheckIns" method="post">
                <div class="modal-body-soft">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-icon-group">
                                <label>Nhân viên</label>
                                <div class="input-wrapper">
                                    <i class="bi bi-person"></i>
                                    @if (allEmployeesList.Count == 1)
                                    {
                                        var e = allEmployeesList[0];
                                        <input type="hidden" name="EmployeeId" value="@e.Id" />
                                        <input type="text" class="form-control bg-light" value="@e.FullName (@e.EmployeeCode)" readonly style="padding-left: 45px;" />
                                    }
                                    else
                                    {
                                        <select name="EmployeeId" class="form-select" required style="padding-left: 45px;">
                                            <option value="">-- Chọn nhân viên --</option>
                                            @foreach(var e in allEmployeesList)
                                            {
                                                <option value="@e.Id">@e.FullName (@e.EmployeeCode)</option>
                                            }
                                        </select>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-icon-group">
                                <label>KPI Mục tiêu</label>
                                <div class="input-wrapper">
                                    <i class="bi bi-speedometer2"></i>
                                    <select name="KPIId" id="quickKpiSelect" class="form-select" required>
                                        @if (allKPIsList.Count != 1)
                                        {
                                            <option value="">-- Chọn KPI --</option>
                                        }
                                        @foreach(var k in allKPIsList)
                                        {
                                            <option value="@k.Id" selected="@(allKPIsList.Count == 1 ? "selected" : null)">@k.KPIName</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-icon-group">
                                <label>Trạng thái tiến độ</label>
                                <div class="input-wrapper">
                                    <i class="bi bi-flag-fill"></i>
                                    <select name="StatusId" class="form-select">
                                        @foreach(var s in allStatusesList)
                                        {
                                            <option value="@s.Id">@s.StatusName</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-icon-group">
                                <label>Kết quả thực tế</label>
                                <div class="input-wrapper input-group">
                                    <i class="bi bi-graph-up-arrow"></i>
                                    <input type="number" step="0.01" min="0" name="AchievedValue" id="quickAchievedInput" class="form-control measurement-value-input" data-measurement-role="achieved" data-measurement-suffix-target="quickAchievedUnitSuffix" placeholder="0.00" required>
                                    <span class="input-group-text measurement-unit-suffix" id="quickAchievedUnitSuffix">đơn vị</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-info bg-info bg-opacity-10 border-0 rounded-3 py-2 px-3 mb-3">
                        <div class="fw-semibold small"><i class="bi bi-alarm me-1"></i> Deadline: <span id="quickDeadlineDisplay">--</span></div>
                        <div class="text-muted small">Mục tiêu tới hạn: <span id="quickDeadlineTargetDisplay">--</span></div>
                    </div>

                    <div class="form-icon-group">
                        <label>Ghi chú / Trở ngại</label>
                        <div class="input-wrapper">
                            <i class="bi bi-chat-left-dots"></i>
                            <textarea name="Note" class="form-control" placeholder="Nhập ghi chú hoặc các khó khăn gặp phải..." rows="2" style="padding-top: 12px;"></textarea>
                        </div>
                    </div>

                    <div class="form-icon-group mb-0">
                        <label>Lý do (Nếu chưa đạt)</label>
                        <div class="input-wrapper">
                            <i class="bi bi-exclamation-triangle"></i>
                            <select name="FailReasonId" class="form-select">
                                <option value="">-- Không có / Đã đạt --</option>
                                @foreach(var r in (ViewBag.FailReasons as List<Manage_KPI_or_OKR_System.Models.FailReason> ?? new List<Manage_KPI_or_OKR_System.Models.FailReason>())){
                                    <option value="@r.Id">@r.ReasonName</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-3 mt-4">
                        <button type="button" class="btn btn-outline-secondary px-4 py-2" data-bs-dismiss="modal">Hủy bỏ</button>
                        <button type="submit" class="btn-primary-custom px-4">Xác nhận Check-in</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* Styling adjustments for KPI checkins */
    .status-dot {
        width: 10px;
        height: 10px;
    }

    .review-inline-form {
        max-width: 280px;
        margin-left: auto;
    }

    .checkin-comments {
        border-color: #e5e7eb !important;
    }
</style>

<script>
    const quickCheckInKpiMap = @Html.Raw(kpiDataJson);

    function resolveQuickDeadline(data) {
        const now = new Date();
        const frequencyDays = Math.max(1, parseInt(data?.frequencyDays || 1, 10));
        const periodStart = data?.periodStart ? new Date(data.periodStart) : new Date(now);
        const periodEnd = data?.periodEnd ? new Date(data.periodEnd) : null;
        const startDate = new Date(periodStart.getFullYear(), periodStart.getMonth(), periodStart.getDate());
        let targetDate = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        if (targetDate < startDate) targetDate = startDate;
        if (periodEnd) {
            const endDate = new Date(periodEnd.getFullYear(), periodEnd.getMonth(), periodEnd.getDate());
            if (targetDate > endDate) targetDate = endDate;
        }
        const offsetDays = Math.max(0, Math.floor((targetDate - startDate) / 86400000));
        const due = new Date(startDate);
        due.setDate(startDate.getDate() + Math.floor(offsetDays / frequencyDays) * frequencyDays);
        const [hour, minute] = String(data?.deadlineTime || '10:00').split(':').map(Number);
        due.setHours(hour || 0, minute || 0, 0, 0);
        return due;
    }

    function calculateQuickExpected(data, deadline) {
        const target = data?.target || 0;
        if (!data?.periodStart || !data?.periodEnd || !target) return target;
        const periodStart = new Date(data.periodStart);
        const periodEnd = new Date(data.periodEnd);
        const startDate = new Date(periodStart.getFullYear(), periodStart.getMonth(), periodStart.getDate());
        const endDate = new Date(periodEnd.getFullYear(), periodEnd.getMonth(), periodEnd.getDate());
        const dueDate = new Date(deadline.getFullYear(), deadline.getMonth(), deadline.getDate());
        const totalDays = Math.max(1, Math.floor((endDate - startDate) / 86400000) + 1);
        const elapsedDays = Math.min(totalDays, Math.max(1, Math.floor((dueDate - startDate) / 86400000) + 1));
        return target * (elapsedDays / totalDays);
    }

    function updateQuickCheckInInput() {
        const kpiSelect = document.getElementById('quickKpiSelect');
        const achievedInput = document.getElementById('quickAchievedInput');
        if (!kpiSelect || !achievedInput) return;

        const selectedKpi = quickCheckInKpiMap[kpiSelect.value];
        const unit = selectedKpi?.unit || '';
        const config = window.applyMeasurementUnitConfigToInputs
            ? window.applyMeasurementUnitConfigToInputs(unit, [achievedInput])
            : { suffix: unit || 'đơn vị' };

        const suffix = document.getElementById('quickAchievedUnitSuffix');
        if (suffix) suffix.textContent = config.suffix || unit || 'đơn vị';

        const deadlineDisplay = document.getElementById('quickDeadlineDisplay');
        const deadlineTargetDisplay = document.getElementById('quickDeadlineTargetDisplay');
        if (selectedKpi && deadlineDisplay && deadlineTargetDisplay) {
            const deadline = resolveQuickDeadline(selectedKpi);
            const expected = calculateQuickExpected(selectedKpi, deadline);
            deadlineDisplay.textContent = deadline.toLocaleString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
            deadlineTargetDisplay.textContent = new Intl.NumberFormat('vi-VN').format(expected) + (unit ? ` ${unit}` : '');
        } else {
            if (deadlineDisplay) deadlineDisplay.textContent = '--';
            if (deadlineTargetDisplay) deadlineTargetDisplay.textContent = '--';
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        document.getElementById('quickKpiSelect')?.addEventListener('change', updateQuickCheckInInput);
        updateQuickCheckInInput();
    });
</script>

</div>
