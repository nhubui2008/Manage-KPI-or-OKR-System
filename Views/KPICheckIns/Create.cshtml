@model Manage_KPI_or_OKR_System.Models.KPICheckIn
@using System.Text.Json

@{
    ViewData["Title"] = "Thực hiện Check-in KPI";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    var employees = ViewBag.AllEmployees as List<Manage_KPI_or_OKR_System.Models.Employee> ?? new List<Manage_KPI_or_OKR_System.Models.Employee>();
    var kpis = ViewBag.AllKPIs as List<Manage_KPI_or_OKR_System.Models.KPI> ?? new List<Manage_KPI_or_OKR_System.Models.KPI>();
    var statuses = ViewBag.AllStatuses as List<Manage_KPI_or_OKR_System.Models.CheckInStatus> ?? new List<Manage_KPI_or_OKR_System.Models.CheckInStatus>();
    var failReasons = ViewBag.FailReasons as List<Manage_KPI_or_OKR_System.Models.FailReason> ?? new List<Manage_KPI_or_OKR_System.Models.FailReason>();
    var kpiData = ViewBag.KPIData as Dictionary<int, Manage_KPI_or_OKR_System.Models.KPIDetail> ?? new Dictionary<int, Manage_KPI_or_OKR_System.Models.KPIDetail>();
    var kpiPeriods = ViewBag.KPIPeriods as Dictionary<int, Manage_KPI_or_OKR_System.Models.EvaluationPeriod> ?? new Dictionary<int, Manage_KPI_or_OKR_System.Models.EvaluationPeriod>();
    var assignmentWeights = ViewBag.AssignmentWeights as Dictionary<int, Dictionary<int, decimal>> ?? new Dictionary<int, Dictionary<int, decimal>>();
    var employeeKpiIds = ViewBag.EmployeeKPIIds as Dictionary<int, List<int>> ?? new Dictionary<int, List<int>>();
    var kpisById = kpis.ToDictionary(k => k.Id);
    
    // Serialize data for JS use
    var kpiDataJson = JsonSerializer.Serialize(kpiData.ToDictionary(kvp => kvp.Key, kvp => new {
        target = kvp.Value.TargetValue,
        unit = kvp.Value.MeasurementUnit,
        isInverse = kvp.Value.IsInverse,
        frequencyDays = kvp.Value.CheckInFrequencyDays ?? 1,
        deadlineTime = (kvp.Value.CheckInDeadlineTime ?? new TimeSpan(10, 0, 0)).ToString(@"hh\:mm"),
        reminderBeforeHours = kvp.Value.ReminderBeforeHours ?? 24,
        periodStart = kpisById.ContainsKey(kvp.Key) && kpisById[kvp.Key].PeriodId.HasValue && kpiPeriods.ContainsKey(kpisById[kvp.Key].PeriodId!.Value)
            ? kpiPeriods[kpisById[kvp.Key].PeriodId!.Value].StartDate
            : null,
        periodEnd = kpisById.ContainsKey(kvp.Key) && kpisById[kvp.Key].PeriodId.HasValue && kpiPeriods.ContainsKey(kpisById[kvp.Key].PeriodId!.Value)
            ? kpiPeriods[kpisById[kvp.Key].PeriodId!.Value].EndDate
            : null
    }));
    var assignmentWeightsJson = JsonSerializer.Serialize(assignmentWeights);
    var employeeKpiIdsJson = JsonSerializer.Serialize(employeeKpiIds);
    var kpiOptionsJson = JsonSerializer.Serialize(kpis.Select(k => new {
        id = k.Id,
        name = k.KPIName ?? $"KPI #{k.Id}"
    }));
}

<div class="page-content">
    <div class="page-header d-flex align-items-center justify-content-between mb-4 animate__animated animate__fadeIn">
        <div>
            <h1 class="mb-2 fw-800">Thực hiện Check-in KPI</h1>
            <div class="page-breadcrumb">
                <a href="/">Trang chủ</a>
                <span class="separator">/</span>
                <a asp-action="Index">Lịch sử Check-in</a>
                <span class="separator">/</span>
                <span class="text-muted">Thực hiện mới</span>
            </div>
        </div>
        <div>
            <a asp-action="Index" class="btn-outline-custom shadow-sm">
                <i class="bi bi-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- FORM COLUMN -->
        <div class="col-xl-8 animate__animated animate__fadeInLeft">
            <div class="content-card border-0 shadow-lg" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">
                <div class="card-header-custom border-bottom bg-transparent py-4">
                    <h5 class="fw-bold fs-5 mb-0"><i class="bi bi-calendar-check me-2"></i> Chi tiết báo cáo tiến độ</h5>
                </div>
                
                <div class="card-body-custom p-4">
                    <form id="checkinForm" asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <!-- SECTION 1: THÔNG TIN CHUNG -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-primary text-white me-3 d-flex align-items-center justify-content-center shadow" style="width: 38px; height: 38px; border-radius: 12px;">
                                <span class="fw-bold">1</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Cấu hình Báo cáo</h6>
                        </div>

                        <div class="row g-4 mb-5 p-3 rounded-4 bg-light bg-opacity-50 border border-white">
                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Nhân viên <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-person-badge"></i>
                                        <select asp-for="EmployeeId" id="employeeSelect" class="form-select shadow-sm" required>
                                            @if(employees.Count != 1) { <option value="">-- Chọn nhân viên --</option> }
                                            @foreach(var e in employees)
                                            {
                                                <option value="@e.Id" selected="@((Model.EmployeeId == e.Id || employees.Count == 1) ? "selected" : null)">@e.FullName (@e.EmployeeCode)</option>
                                            }
                                        </select>
                                    </div>
                                    <span asp-validation-for="EmployeeId" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">KPI Mục tiêu <span class="text-danger">*</span></label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-bullseye"></i>
                                        <select asp-for="KPIId" id="kpiSelect" class="form-select shadow-sm" required>
                                            @if (kpis.Count != 1)
                                            {
                                                <option value="">-- Chọn KPI cần báo cáo --</option>
                                            }
                                            @foreach(var k in kpis)
                                            {
                                                <option value="@k.Id" selected="@((Model.KPIId == k.Id || kpis.Count == 1) ? "selected" : null)">@k.KPIName</option>
                                            }
                                        </select>
                                    </div>
                                    <span asp-validation-for="KPIId" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <!-- SECTION 2: KẾT QUẢ THỰC TẾ -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle bg-success text-white me-3 d-flex align-items-center justify-content-center shadow" style="width: 38px; height: 38px; border-radius: 12px;">
                                <span class="fw-bold">2</span>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark text-uppercase letter-spacing-1">Kết quả thực hiện</h6>
                        </div>

                        <div class="row g-4 p-3 rounded-4 bg-light bg-opacity-50 border border-white mb-4">
                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Kết quả đạt được <span class="text-danger">*</span></label>
                                    <div class="input-wrapper input-group">
                                        <i class="bi bi-pencil-square"></i>
                                        <input type="number" step="0.01" min="0" name="AchievedValue" id="achievedInput" class="form-control shadow-sm measurement-value-input" data-measurement-role="achieved" data-measurement-suffix-target="achievedUnitSuffix" placeholder="Nhập số liệu..." required data-val="true" data-val-required="Vui lòng nhập kết quả đạt được." data-val-number="Kết quả đạt được phải là số hợp lệ." data-msg-required="Vui lòng nhập kết quả đạt được." data-msg-min="Kết quả đạt được không thể là số âm." value="@ViewBag.AchievedValue">
                                        <span class="input-group-text measurement-unit-suffix" id="achievedUnitSuffix">đơn vị</span>
                                    </div>
                                    @Html.ValidationMessage("AchievedValue", null, new { @class = "text-danger small mt-1 d-block" })
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Trạng thái tự đánh giá</label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-speedometer2"></i>
                                        <select asp-for="StatusId" class="form-select shadow-sm">
                                            @foreach(var s in statuses) { <option value="@s.Id">@s.StatusName</option> }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-12">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Chi tiết phân tích / Ghi chú</label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-textarea-t" style="top: 25px;"></i>
                                        <textarea name="Note" class="form-control shadow-sm" placeholder="Mô tả các khó khăn hoặc thuận lợi trong quá trình thực hiện..." rows="4" style="padding-left: 48px; border-radius: 12px;">@ViewBag.Note</textarea>
                                    </div>
                                    <span class="text-danger small mt-1 d-block">@Html.ValidationMessage("Note")</span>
                                </div>
                            </div>

                            <div class="col-md-12">
                                <div class="form-icon-group mb-0">
                                    <label class="form-label small text-muted text-uppercase fw-800">Lý do chính (Nếu chưa đạt mục tiêu)</label>
                                    <div class="input-wrapper">
                                        <i class="bi bi-question-diamond"></i>
                                        <select asp-for="FailReasonId" class="form-select shadow-sm">
                                            <option value="">-- Không có / Đã hoàn thành tốt --</option>
                                            @foreach(var r in failReasons) { <option value="@r.Id">@r.ReasonName</option> }
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                            <a asp-action="Index" class="btn-outline-custom">
                                <i class="bi bi-x-lg me-2"></i> Hủy thao tác
                            </a>
                            <button type="submit" class="btn-primary-custom" style="padding: 12px 40px; border-radius: 12px;">
                                <i class="bi bi-check-lg fs-5 me-2"></i> Hoàn tất Check-in
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- STATS COLUMN -->
        <div class="col-xl-4 animate__animated animate__fadeInRight">
            <div class="sticky-top" style="top: 100px;">
                <div class="content-card border-0 shadow-lg text-white mb-4" style="background: linear-gradient(135deg, #1a73e8, #1557b0); border-radius: 24px;">
                    <div class="card-body-custom p-4">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-white bg-opacity-20 p-3 rounded-4 me-3">
                                <i class="bi bi-graph-up-arrow fs-3 text-white"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 opacity-75 fw-bold text-uppercase small">Tổng chỉ tiêu</h6>
                                <h4 class="mb-0 fw-800" id="targetDisplay">--</h4>
                            </div>
                        </div>

                        <div class="bg-white bg-opacity-10 p-3 rounded-4 mb-4 border border-white border-opacity-20 shadow-sm" id="individualTargetContainer">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="small opacity-75 text-uppercase fw-bold" style="font-size: 0.7rem;">Chỉ tiêu cá nhân (<span id="weightLabel">100%</span>)</div>
                                    <div class="h3 mb-0 fw-bold" id="individualTargetDisplay">--</div>
                                </div>
                                <div class="bg-white bg-opacity-20 p-2 rounded-3">
                                    <i class="bi bi-person-check fs-4"></i>
                                </div>
                            </div>
                        </div>

                        <div class="bg-white bg-opacity-10 p-3 rounded-4 mb-4 border border-white border-opacity-20 shadow-sm">
                            <div class="small opacity-75 text-uppercase fw-bold mb-1" style="font-size: 0.7rem;">Deadline check-in kỳ này</div>
                            <div class="h5 mb-1 fw-bold" id="deadlineDisplay">--</div>
                            <div class="small opacity-75">Mục tiêu cần đạt tới hạn: <strong id="deadlineTargetDisplay">--</strong></div>
                            <div class="small opacity-75">Nhắc trước: <strong id="reminderDisplay">--</strong></div>
                        </div>
                         
                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-end mb-2">
                                <span class="small fw-bold opacity-75 text-uppercase">Tiến độ ước tính</span>
                                <h2 class="mb-0 fw-800" id="progressPercentage">0%</h2>
                            </div>
                            <div class="progress" style="height: 12px; background: rgba(255,255,255,0.15); border-radius: 20px;">
                                <div id="liveProgressBar" class="progress-bar bg-white transition-all shadow-sm" style="width: 0%; border-radius: 20px;"></div>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-6">
                                <div class="bg-white bg-opacity-10 p-3 rounded-4 d-flex align-items-center">
                                    <i class="bi bi-rulers fs-4 me-3 opacity-75"></i>
                                    <div>
                                        <div class="small opacity-75 mb-1">Đơn vị</div>
                                        <div class="fw-bold" id="unitDisplay">--</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-white bg-opacity-10 p-3 rounded-4 d-flex align-items-center">
                                    <i class="bi bi-gear-wide-connected fs-4 me-3 opacity-75"></i>
                                    <div>
                                        <div class="small opacity-75 mb-1">Loại đo lường</div>
                                        <div class="fw-bold" id="modeDisplay">--</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="content-card border-0 shadow-sm rounded-4 bg-white p-4">
                    <h6 class="fw-bold text-dark mb-3"><i class="bi bi-info-circle text-primary me-2"></i> Lưu ý báo cáo</h6>
                    <ul class="list-unstyled mb-0 small text-muted" style="line-height: 1.8;">
                        <li class="mb-2"><i class="bi bi-patch-check-fill text-success me-2"></i> Nhập số liệu chính xác từ báo cáo thực tế.</li>
                        <li class="mb-2"><i class="bi bi-patch-check-fill text-success me-2"></i> Giải trình chi tiết nếu tiến độ dưới 80%.</li>
                        <li><i class="bi bi-patch-check-fill text-success me-2"></i> Hệ thống tự động tính điểm xếp loại dựa trên kết quả.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    .letter-spacing-1 { letter-spacing: 0.1em; }
    .transition-all { transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
    
    .form-select, .form-control {
        border: 1.5px solid #edf2f7;
        padding-top: 12px;
        padding-bottom: 12px;
    }
    
    .form-select:focus, .form-control:focus {
        border-color: #a3c9f9;
        box-shadow: 0 0 0 4px rgba(163, 201, 249, 0.1);
    }

    #checkinForm .form-icon-group label.error {
        color: #dc3545;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0;
        margin: 0.35rem 0 0;
        text-transform: none;
    }

    #checkinForm .input-group label.error {
        flex: 0 0 100%;
        order: 20;
        width: 100%;
    }

    /* Animation effects */
    .animate__animated { animation-duration: 0.8s; }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <script>
        const kpiMap = @Html.Raw(kpiDataJson);
        const assignmentWeights = @Html.Raw(assignmentWeightsJson);
        const employeeKpiIds = @Html.Raw(employeeKpiIdsJson);
        const allKpiOptions = @Html.Raw(kpiOptionsJson);
        const kpiSelect = document.getElementById('kpiSelect');
        const employeeSelect = document.getElementById('employeeSelect');
        const achievedInput = document.getElementById('achievedInput');
        const targetDisplay = document.getElementById('targetDisplay');
        const unitDisplay = document.getElementById('unitDisplay');
        const modeDisplay = document.getElementById('modeDisplay');
        const progressPercentage = document.getElementById('progressPercentage');
        const liveProgressBar = document.getElementById('liveProgressBar');
        const deadlineDisplay = document.getElementById('deadlineDisplay');
        const deadlineTargetDisplay = document.getElementById('deadlineTargetDisplay');
        const reminderDisplay = document.getElementById('reminderDisplay');

        function resolveCurrentDeadline(data) {
            const now = new Date();
            const frequencyDays = Math.max(1, parseInt(data.frequencyDays || 1, 10));
            const periodStart = data.periodStart ? new Date(data.periodStart) : new Date(now);
            const periodEnd = data.periodEnd ? new Date(data.periodEnd) : null;
            const baseDate = new Date(now.getFullYear(), now.getMonth(), now.getDate());
            const startDate = new Date(periodStart.getFullYear(), periodStart.getMonth(), periodStart.getDate());
            let targetDate = baseDate < startDate ? startDate : baseDate;

            if (periodEnd) {
                const endDate = new Date(periodEnd.getFullYear(), periodEnd.getMonth(), periodEnd.getDate());
                if (targetDate > endDate) targetDate = endDate;
            }

            const offsetDays = Math.max(0, Math.floor((targetDate - startDate) / 86400000));
            const slotDate = new Date(startDate);
            slotDate.setDate(startDate.getDate() + Math.floor(offsetDays / frequencyDays) * frequencyDays);
            const [hour, minute] = String(data.deadlineTime || '10:00').split(':').map(Number);
            slotDate.setHours(hour || 0, minute || 0, 0, 0);
            return slotDate;
        }

        function calculateExpectedAtDeadline(individualTarget, data, deadline) {
            if (!data.periodStart || !data.periodEnd || !individualTarget) return individualTarget;
            const periodStart = new Date(data.periodStart);
            const periodEnd = new Date(data.periodEnd);
            const startDate = new Date(periodStart.getFullYear(), periodStart.getMonth(), periodStart.getDate());
            const endDate = new Date(periodEnd.getFullYear(), periodEnd.getMonth(), periodEnd.getDate());
            const dueDate = new Date(deadline.getFullYear(), deadline.getMonth(), deadline.getDate());
            const totalDays = Math.max(1, Math.floor((endDate - startDate) / 86400000) + 1);
            const elapsedDays = Math.min(totalDays, Math.max(1, Math.floor((dueDate - startDate) / 86400000) + 1));
            return individualTarget * (elapsedDays / totalDays);
        }

        function filterKpisByEmployee() {
            const employeeId = employeeSelect.value;
            const previousKpiId = kpiSelect.value;
            const allowedKpiIds = new Set((employeeKpiIds[employeeId] || []).map(String));
            const filteredKpis = employeeId
                ? allKpiOptions.filter(kpi => allowedKpiIds.has(String(kpi.id)))
                : [];

            kpiSelect.innerHTML = '';
            const placeholderText = employeeId
                ? (filteredKpis.length ? '-- Chọn KPI cần báo cáo --' : 'Nhân viên này chưa có KPI được phân bổ')
                : '-- Chọn nhân viên trước --';
            kpiSelect.add(new Option(placeholderText, ''));

            filteredKpis.forEach(kpi => {
                kpiSelect.add(new Option(kpi.name, kpi.id));
            });

            if (previousKpiId && filteredKpis.some(kpi => String(kpi.id) === String(previousKpiId))) {
                kpiSelect.value = previousKpiId;
            } else if (filteredKpis.length === 1) {
                kpiSelect.value = filteredKpis[0].id;
            }
        }

        function updateStats() {
            const kpiId = kpiSelect.value;
            const value = parseFloat(achievedInput.value) || 0;
            
            if (kpiId && kpiMap[kpiId]) {
                const data = kpiMap[kpiId];
                const target = data.target || 0;
                const employeeId = employeeSelect.value;
                const employeeWeights = assignmentWeights[employeeId] || {};
                const weight = employeeWeights[kpiId] || 100;
                const individualTarget = target * (weight / 100);
                const unit = data.unit || 'đơn vị';
                const isInverse = data.isInverse;
                const deadline = resolveCurrentDeadline(data);
                const expectedAtDeadline = calculateExpectedAtDeadline(individualTarget, data, deadline);
                const unitConfig = window.applyMeasurementUnitConfigToInputs
                    ? window.applyMeasurementUnitConfigToInputs(unit, [achievedInput])
                    : { suffix: unit };

                targetDisplay.textContent = new Intl.NumberFormat().format(target);
                document.getElementById('individualTargetDisplay').textContent = new Intl.NumberFormat().format(individualTarget);
                document.getElementById('weightLabel').textContent = weight + '%';
                unitDisplay.textContent = unit;
                document.getElementById('achievedUnitSuffix').textContent = unitConfig.suffix || unit;
                modeDisplay.textContent = isInverse ? "Càng thấp càng tốt" : "Càng cao càng tốt";
                deadlineDisplay.textContent = deadline.toLocaleString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
                deadlineTargetDisplay.textContent = new Intl.NumberFormat('vi-VN').format(expectedAtDeadline) + ' ' + unit;
                reminderDisplay.textContent = (data.reminderBeforeHours || 24) + ' giờ trước deadline';

                let progress = 0;
                if (individualTarget > 0) {
                    if (isInverse) {
                        if (value <= individualTarget) {
                            progress = 100;
                        } else {
                            const excess = value - individualTarget;
                            const penalty = (excess / individualTarget) * 100;
                            progress = Math.max(0, 100 - penalty);
                        }
                    } else {
                        progress = (value / individualTarget) * 100;
                    }
                }

                const displayProgress = Math.min(200, Math.round(progress * 100) / 100);
                progressPercentage.textContent = displayProgress + '%';
                liveProgressBar.style.width = Math.min(100, displayProgress) + '%';

                // Update bar color based on progress
                if (displayProgress < 50) {
                    liveProgressBar.className = "progress-bar bg-danger transition-all shadow-sm";
                } else if (displayProgress < 90) {
                    liveProgressBar.className = "progress-bar bg-warning transition-all shadow-sm";
                } else {
                    liveProgressBar.className = "progress-bar bg-white transition-all shadow-sm";
                }
            } else {
                targetDisplay.textContent = "--";
                document.getElementById('individualTargetDisplay').textContent = "--";
                document.getElementById('weightLabel').textContent = "100%";
                unitDisplay.textContent = "--";
                deadlineDisplay.textContent = "--";
                deadlineTargetDisplay.textContent = "--";
                reminderDisplay.textContent = "--";
                if (window.applyMeasurementUnitConfigToInputs) {
                    window.applyMeasurementUnitConfigToInputs('', [achievedInput]);
                }
                document.getElementById('achievedUnitSuffix').textContent = "đơn vị";
                modeDisplay.textContent = "--";
                progressPercentage.textContent = "0%";
                liveProgressBar.style.width = "0%";
                liveProgressBar.className = "progress-bar bg-white transition-all shadow-sm";
            }
        }

        kpiSelect.addEventListener('change', updateStats);
        employeeSelect.addEventListener('change', function () {
            filterKpisByEmployee();
            updateStats();
        });
        achievedInput.addEventListener('input', updateStats);

        // Initial check if pre-filled
        window.addEventListener('DOMContentLoaded', function () {
            filterKpisByEmployee();
            updateStats();
        });
    </script>
}
