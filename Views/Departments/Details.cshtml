@model Manage_KPI_or_OKR_System.Models.Department

@{
    ViewData["Title"] = "Chi tiết Phòng ban";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var subDepartments = ViewBag.SubDepartments as List<Manage_KPI_or_OKR_System.Models.Department>;
    var subDeptCounts = ViewBag.SubDeptEmployeeCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
    var allManagers = ViewBag.AllManagers as Dictionary<int, string> ?? new Dictionary<int, string>();
    var managerName = ViewBag.ManagerName as string ?? "Chưa phân công";
    var avatarLetter = managerName != "Chưa phân công" && managerName.Length > 0 ? managerName[0].ToString().ToUpper() : "?";
}

<div class="container-fluid px-0 h-100">
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 font-weight-bold mb-1">Chi tiết Phòng ban</h1>
            <div class="page-breadcrumb">
                <a href="/">Trang chủ</a>
                <i class="bi bi-chevron-right separator"></i>
                <a asp-action="Index">Phòng ban</a>
                <i class="bi bi-chevron-right separator"></i>
                <span>@Model.DepartmentName</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn-outline-custom d-flex align-items-center">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-custom d-flex align-items-center">
                <i class="bi bi-pencil me-1"></i> Chỉnh sửa
            </a>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card p-3 h-100 border">
                <div class="d-flex align-items-center gap-2">
                    <div class="stat-icon blue mb-0 rounded" style="width: 40px; height: 40px; flex-shrink: 0; font-size: 1.2rem;">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div class="min-w-0">
                        <div class="stat-label mb-0 text-truncate" style="font-size: 0.75rem;">Tổng Nhân Sự</div>
                        <div class="stat-value text-primary fs-4 mb-0">@ViewBag.EmployeeCount</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card p-3 h-100 border">
                <div class="d-flex align-items-center gap-2">
                    <div class="stat-icon purple mb-0 rounded" style="width: 40px; height: 40px; flex-shrink: 0; font-size: 1.2rem;">
                        <i class="bi bi-diagram-2-fill"></i>
                    </div>
                    <div class="min-w-0">
                        <div class="stat-label mb-0 text-truncate" style="font-size: 0.75rem;">Đơn Vị Trực Thuộc</div>
                        <div class="stat-value text-dark fs-4 mb-0">@(subDepartments?.Count ?? 0)</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card p-3 h-100 border">
                <div class="d-flex align-items-center gap-2">
                    <div class="stat-icon orange mb-0 rounded" style="width: 40px; height: 40px; flex-shrink: 0; font-size: 1.2rem;">
                        <i class="bi bi-diagram-3-fill"></i>
                    </div>
                    <div class="min-w-0" style="flex: 1; overflow: hidden;">
                        <div class="stat-label mb-0 text-truncate" style="font-size: 0.75rem;">Đơn Vị Cấp Trên</div>
                        @if(ViewBag.ParentDeptName == "Không có (Cấp cao nhất)"){
                            <div class="stat-value text-dark mb-0 text-truncate text-uppercase" style="font-size: 0.9rem;">Cấp cao nhất</div>
                        } else {
                            <div class="stat-value text-dark mb-0 text-truncate" style="font-size: 0.9rem;" title="@ViewBag.ParentDeptName">@ViewBag.ParentDeptName</div>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card p-3 h-100 border">
                <div class="d-flex align-items-center gap-2">
                    <div class="stat-icon @(Model.IsActive == true ? "green" : "red") mb-0 rounded" style="width: 40px; height: 40px; flex-shrink: 0; font-size: 1.2rem;">
                        <i class="bi @(Model.IsActive == true ? "bi-check-circle-fill" : "bi-pause-circle-fill")"></i>
                    </div>
                    <div class="min-w-0">
                        <div class="stat-label mb-0 text-truncate" style="font-size: 0.75rem;">Trạng Thái</div>
                        <div class="stat-value @(Model.IsActive == true ? "text-success" : "text-danger") mb-0 fw-bold" style="font-size: 1.1rem;">@(Model.IsActive == true ? "Đang hoạt động" : "Tạm ngưng")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <!-- Main details -->
        <div class="col-lg-7">
            <div class="content-card h-100 border shadow-sm">
                <div class="card-header-custom border-bottom py-3 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-card-checklist me-2"></i>Hồ sơ phòng ban</h6>
                    <div class="fw-bold text-primary font-monospace bg-primary bg-opacity-10 px-2 py-1 rounded" style="font-size: 0.85rem;">@Model.DepartmentCode</div>
                </div>
                <div class="card-body-custom pt-3 pb-3">
                    <div class="d-flex align-items-center gap-3 mb-3 pb-3 border-bottom">
                        <div class="d-flex align-items-center justify-content-center bg-primary text-white rounded-3 shadow-sm" style="width: 55px; height: 55px; font-size: 1.8rem; flex-shrink: 0;">
                            <i class="bi bi-building"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark mb-1">@Model.DepartmentName</h5>
                            <div class="text-muted d-flex align-items-center gap-2" style="font-size: 0.85rem;">
                                <i class="bi bi-geo-alt"></i> Trụ sở chính / Trực thuộc: <strong>@(ViewBag.ParentDeptName == "Không có (Cấp cao nhất)" ? "Toàn công ty" : ViewBag.ParentDeptName)</strong>
                            </div>
                        </div>
                    </div>

                    <h6 class="fw-bold text-dark text-uppercase mb-2 text-muted" style="letter-spacing: 0.5px; font-size: 0.75rem;">Thông tin Trưởng phòng quản lý</h6>
                    <div class="p-2 bg-light rounded border d-flex align-items-center gap-3 mb-3 shadow-sm">
                        @if(managerName != "Chưa phân công"){
                            <div class="user-avatar bg-primary text-white fw-bold d-flex justify-content-center align-items-center shadow-sm" style="width: 45px; height: 45px; font-size: 1.2rem;">
                                @avatarLetter
                            </div>
                            <div>
                                <h6 class="fw-bold text-dark mb-1">@managerName</h6>
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25" style="font-size: 0.7rem;">Trưởng Phòng</span>
                            </div>
                        } else {
                            <div class="user-avatar bg-primary text-white fw-bold d-flex justify-content-center align-items-center shadow-sm" style="width: 45px; height: 45px; font-size: 1.2rem;">
                                <i class="bi bi-person-x"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold text-muted fst-italic mb-1">Chưa có người quản lý</h6>
                                <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25" style="font-size: 0.7rem;">Trống</span>
                            </div>
                        }
                    </div>

                     <div class="row g-2">
                        <div class="col-sm-6">
                             <div class="p-2 bg-light rounded border h-100 shadow-sm">
                                <label class="text-muted fw-semibold mb-1 small text-uppercase" style="font-size: 0.7rem;"><i class="bi bi-calendar-check me-1"></i>Trạng thái dữ liệu</label>
                                <div class="fw-bold text-dark mt-0" style="font-size: 0.85rem;">Sẵn sàng</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                             <div class="p-2 bg-light rounded border h-100 shadow-sm">
                                <label class="text-muted fw-semibold mb-1 small text-uppercase" style="font-size: 0.7rem;"><i class="bi bi-hash me-1"></i>Định danh hệ thống</label>
                                <div class="fw-bold text-dark mt-0" style="font-size: 0.85rem;">ID: @Model.Id</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sub Departments List -->
        <div class="col-lg-5">
            <div class="content-card h-100 d-flex flex-column border shadow-sm">
                <div class="card-header-custom border-bottom bg-light bg-opacity-50 py-3">
                    <div class="d-flex align-items-center justify-content-between w-100">
                        <h6 class="mb-0 fw-bold"><i class="bi bi-diagram-2 me-2"></i>Phân nhánh trực thuộc</h6>
                        <span class="badge bg-primary rounded-pill badge-sm" style="font-size: 0.75rem;">@(subDepartments?.Count ?? 0) nhánh</span>
                    </div>
                </div>
                <div class="card-body-custom p-0 flex-grow-1" style="max-height: 400px; overflow-y: auto;">
                    @if (subDepartments != null && subDepartments.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var sub in subDepartments)
                            {
                                var subManager = sub.ManagerId.HasValue && allManagers.ContainsKey(sub.ManagerId.Value) ? allManagers[sub.ManagerId.Value] : "Chưa phân công";
                                var subInitial = subManager != "Chưa phân công" && subManager.Length > 0 ? subManager[0].ToString().ToUpper() : "?";
                                var deptCount = subDeptCounts.ContainsKey(sub.Id) ? subDeptCounts[sub.Id] : 0;

                                <a href="@Url.Action("Details", "Departments", new { id = sub.Id })" class="list-group-item list-group-item-action p-3 border-bottom text-decoration-none transition-all" style="cursor: pointer; transition: background-color 0.2s;">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <div class="fw-bold text-dark mb-1 d-flex align-items-center" style="font-size: 0.9rem;">
                                                <i class="bi bi-folder-fill text-warning me-2"></i>
                                                @sub.DepartmentName
                                            </div>
                                            <div class="text-secondary font-monospace bg-light px-1 py-0.5 rounded border d-inline-block" style="font-size: 0.7rem;">Mã: @sub.DepartmentCode</div>
                                        </div>
                                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 shadow-sm" style="font-size: 0.75rem;">
                                            <i class="bi bi-people me-1"></i> @deptCount <span class="d-none d-sm-inline">NV</span>
                                        </span>
                                    </div>
                                    <div class="d-flex align-items-center gap-2 mt-2 pt-2 border-top border-light">
                                        @if(subManager != "Chưa phân công") {
                                            <div class="user-avatar bg-primary text-white fw-bold d-flex justify-content-center align-items-center shadow-sm" style="width: 20px; height: 20px; font-size: 0.6rem;">
                                                @subInitial
                                            </div>
                                        } else {
                                            <i class="bi bi-person-x text-muted border rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 20px; height: 20px; font-size: 0.75rem;"></i>
                                        }
                                        <div class="text-muted @(subManager == "Chưa phân công" ? "fst-italic" : "fw-medium")" style="font-size: 0.75rem;">
                                            @subManager
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted h-100 d-flex flex-column justify-content-center align-items-center bg-light bg-opacity-50">
                            <i class="bi bi-diagram-2 text-secondary opacity-25 mb-2" style="font-size: 2.5rem;"></i>
                            <div class="text-dark fw-bold opacity-75" style="font-size: 0.9rem;">Không có chi nhánh</div>
                            <div class="small text-muted mt-1" style="font-size: 0.8rem;">Phòng ban này hiện chưa có đơn vị trực thuộc nào.</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>