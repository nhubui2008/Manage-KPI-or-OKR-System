@model Manage_KPI_or_OKR_System.Models.Department

@{
    ViewData["Title"] = "Chi tiết Phòng ban";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-primary fw-bold"><i class="bi bi-card-list me-2"></i>Chi tiết Phòng ban</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/Dashboard" class="text-decoration-none">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Danh sách phòng ban</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Chi tiết</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="content-card rounded-3">
        <div class="card-body-custom p-4">
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <strong>Mã phòng ban:</strong>
                    <p>@Model.DepartmentCode</p>
                </div>
                <div class="col-md-6">
                    <strong>Tên phòng ban:</strong>
                    <p>@Model.DepartmentName</p>
                </div>
                <div class="col-md-6">
                    <strong>Phòng ban cấp trên:</strong>
                    <p>@ViewBag.ParentDeptName</p>
                </div>
                <div class="col-md-6">
                    <strong>Trưởng phòng:</strong>
                    <p>@ViewBag.ManagerName</p>
                </div>
                <div class="col-md-6">
                    <strong>Trạng thái:</strong>
                    <p>@(Model.IsActive == true ? "Hoạt động" : "Tạm dừng")</p>
                </div>
                <div class="col-md-6">
                    <strong>Số nhân viên:</strong>
                    <p>@ViewBag.EmployeeCount</p>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn-outline-custom rounded-pill px-4">Quay lại</a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-custom rounded-pill px-4">Chỉnh sửa</a>
            </div>
        </div>
    </div>
</div>