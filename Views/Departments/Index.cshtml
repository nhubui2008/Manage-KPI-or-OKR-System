@model IEnumerable<Manage_KPI_or_OKR_System.Models.Department>
@{
    ViewData["Title"] = "Quản lý Phòng ban";
    var employees = ViewBag.Employees as Dictionary<int, string> ?? new Dictionary<int, string>();
    var employeeCounts = ViewBag.EmployeeCounts as Dictionary<int, int> ?? new Dictionary<int, int>();

    // SỬ DỤNG LOCAL FUNCTION THAY CHO @functions
    void RenderDeptTree(IEnumerable<Manage_KPI_or_OKR_System.Models.Department> allDepts, int? parentId, int depth, Dictionary<int, int> counts)
    {
        var children = allDepts.Where(d => d.ParentDepartmentId == parentId).ToList();
        if (!children.Any()) return;
        
        string indent = depth > 0 ? "ps-3 ms-1 border-start" : "";
        <div class="@indent">
            @foreach (var child in children)
            {
                var icon = depth == 0 ? "bi-folder-fill text-warning" : "bi-files text-secondary";
                var count = counts.ContainsKey(child.Id) ? counts[child.Id] : 0;
                <div class="d-flex justify-content-between align-items-center mb-2 py-1 px-2 rounded hover-bg-light" style="margin-left: -5px; cursor: pointer;">
                    <span class="d-flex align-items-center gap-2"><i class="bi @icon"></i> @child.DepartmentName</span>
                    <span class="badge bg-secondary rounded-pill">@count</span>
                </div>
                
                // Gọi đệ quy trực tiếp, không dùng await
                RenderDeptTree(allDepts, child.Id, depth + 1, counts);
            }
        </div>
    }
}

<div class="page-header">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Cơ cấu tổ chức</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Phòng ban</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn-primary-custom" asp-action="Create" asp-controller="Departments">
            <i class="bi bi-plus-lg"></i> Thêm phòng ban mới
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success shadow-sm border-0 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
    </div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="content-card h-100">
            <div class="card-header-custom border-bottom">
                <h5 class="mb-0 fw-bold"><i class="bi bi-diagram-3 me-2"></i> Cây tổ chức</h5>
            </div>
            <div class="card-body-custom pt-3">
                <div class="d-flex align-items-center gap-2 mb-3 px-2 py-2 rounded bg-primary bg-opacity-10 border border-primary border-opacity-25">
                    <i class="bi bi-building text-primary fs-5"></i>
                    <span class="fw-bold text-dark">Tổ Chức / Công Ty</span>
                </div>
                
                <div class="ps-3 ms-2 border-start">
                    @{
                        if (Model != null && Model.Any())
                        {
                            // Gọi hàm in cây đa cấp không cần await
                            RenderDeptTree(Model, null, 0, employeeCounts);
                        }
                        else
                        {
                            <div class="text-muted fst-italic py-2">Chưa có phòng ban nào trong hệ thống</div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="content-card h-100">
            <div class="card-body-custom">
                <form asp-action="Index" method="get" class="toolbar">
                    <div class="toolbar-left">
                        <div class="toolbar-search">
                            <i class="bi bi-search"></i>
                            <input type="text" name="searchString" value="@(ViewData["CurrentFilter"] ?? "")" class="form-control" placeholder="Tìm kiếm mã hoặc tên phòng ban..." />
                        </div>

                        <select name="isActive" class="filter-select">
                            @if (string.IsNullOrEmpty(ViewBag.CurrentStatus))
                            {
                                <option value="" selected>Tất cả trạng thái</option>
                            }
                            else
                            {
                                <option value="">Tất cả trạng thái</option>
                            }

                            @if (ViewBag.CurrentStatus == "true")
                            {
                                <option value="true" selected>Hoạt động</option>
                            }
                            else
                            {
                                <option value="true">Hoạt động</option>
                            }

                            @if (ViewBag.CurrentStatus == "false")
                            {
                                <option value="false" selected>Ngừng HĐ</option>
                            }
                            else
                            {
                                <option value="false">Ngừng HĐ</option>
                            }
                        </select>
                    </div>
                    <div class="toolbar-right">
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary border-0" title="Làm mới">
                            <i class="bi bi-arrow-clockwise"></i>
                        </a>
                        <button type="submit" class="btn btn-sm btn-outline-secondary border-0" title="Lọc kết quả">
                            <i class="bi bi-funnel"></i>
                        </button>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Mã PB</th>
                                <th>Tên phòng ban</th>
                                <th>Trưởng phòng</th>
                                <th>Số lượng NV</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var dept in Model)
                                {
                                    var managerName = dept.ManagerId.HasValue && employees.ContainsKey(dept.ManagerId.Value) 
                                                      ? employees[dept.ManagerId.Value] : "Chưa cập nhật";
                                    var count = employeeCounts.ContainsKey(dept.Id) ? employeeCounts[dept.Id] : 0;
                                    var statusClass = dept.IsActive == true ? "active" : "inactive";
                                    var statusDot = dept.IsActive == true ? "" : "text-danger bg-danger";
                                    var statusText = dept.IsActive == true ? "Hoạt động" : "Ngừng HĐ";
                                    var avatarLetter = managerName != "Chưa cập nhật" ? managerName[0].ToString().ToUpper() : "?";

                                    <tr>
                                        <td class="fw-semibold text-muted">@dept.DepartmentCode</td>
                                        <td class="fw-bold text-dark">@dept.DepartmentName</td>
                                        <td>
                                            @if (managerName != "Chưa cập nhật")
                                            {
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="user-avatar bg-secondary text-white fw-bold d-flex justify-content-center align-items-center" style="width: 24px; height: 24px; font-size: 0.7rem;">
                                                        @avatarLetter
                                                    </div>
                                                    <span>@managerName</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted fst-italic">@managerName</span>
                                            }
                                        </td>
                                        <td><span class="badge bg-light text-dark border">@count</span></td>
                                        <td><span class="status-badge @statusClass"><span class="status-dot @statusDot"></span> @statusText</span></td>
                                        <td>
                                            <div class="action-btns justify-content-end">
                                            <a asp-action="Details" asp-route-id="@dept.Id" class="action-btn" title="Xem chi tiết"><i class="bi bi-eye"></i></a>
                                            <a asp-action="Edit" asp-route-id="@dept.Id" class="action-btn" title="Chỉnh sửa"><i class="bi bi-pencil"></i></a>

                                            @if (dept.IsActive == true)
                                            {
                                                <button class="action-btn danger" title="Ngưng hoạt động" data-bs-toggle="modal" data-bs-target="#deleteModal-@dept.Id">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <form asp-action="Activate" asp-route-id="@dept.Id" method="post" class="m-0">
                                                    <button type="submit" class="action-btn success" title="Kích hoạt lại"><i class="bi bi-arrow-clockwise"></i></button>
                                                </form>
                                            }
                                        </div>
                                        </td>
                                    </tr>

                                    @if (dept.IsActive == true)
                                    {
                                        <div class="modal fade" id="deleteModal-@dept.Id" tabindex="-1" aria-labelledby="deleteModalLabel-@dept.Id" aria-hidden="true">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content">
                                                    <div class="modal-header bg-danger text-white">
                                                        <h5 class="modal-title" id="deleteModalLabel-@dept.Id">Xác nhận ngưng hoạt động</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        Bạn có chắc muốn ngưng hoạt động phòng ban <strong>@dept.DepartmentName</strong>?
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                                        <form asp-action="Delete" asp-route-id="@dept.Id" method="post" class="m-0">
                                                            <button type="submit" class="btn btn-danger">Xác nhận</button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">Chưa có phòng ban nào trong hệ thống.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
