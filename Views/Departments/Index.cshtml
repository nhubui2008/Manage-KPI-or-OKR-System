@model IEnumerable<Manage_KPI_or_OKR_System.Models.Department>
@{
    ViewData["Title"] = "Quản lý Phòng ban";
    var employees = ViewBag.Employees as Dictionary<int, string> ?? new Dictionary<int, string>();
    var employeeCounts = ViewBag.EmployeeCounts as Dictionary<int, int> ?? new Dictionary<int, int>();

    // SỬ DỤNG LOCAL FUNCTION THAY CHO @functions
    void RenderDeptTree(IEnumerable<Manage_KPI_or_OKR_System.Models.Department> allDepts, int? parentId, int depth, Dictionary<int, int> counts)
    {
        var children = allDepts.Where(d => d.ParentDepartmentId == parentId).ToList();
        if (!children.Any()) return;
        
        string indent = depth > 0 ? "ps-3 ms-1 border-start" : "";
        <div class="@indent">
            @foreach (var child in children)
            {
                var icon = depth == 0 ? "bi-folder-fill text-warning" : "bi-files text-secondary";
                var count = counts.ContainsKey(child.Id) ? counts[child.Id] : 0;
                <div class="d-flex justify-content-between align-items-center mb-1 py-1 px-2 rounded hover-bg-light" style="margin-left: -5px; cursor: pointer; font-size: 1rem;" onclick="window.location.href='@Url.Action("Details", "Departments", new { id = child.Id })'">
                    <span class="d-flex align-items-center gap-1"><i class="bi @icon"></i> @child.DepartmentName</span>
                    <span class="badge bg-secondary rounded-pill" style="font-size: 0.875rem;">@count</span>
                </div>
                
                // Gọi đệ quy trực tiếp, không dùng await
                RenderDeptTree(allDepts, child.Id, depth + 1, counts);
            }
        </div>
    }
}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Cơ cấu tổ chức</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Phòng ban</span>
        </div>
    </div>
    <div class="d-flex justify-content-end gap-2">
        <a class="btn-primary-custom d-flex align-items-center" asp-action="Create" asp-controller="Departments">
            <i class="bi bi-plus-lg me-1"></i> Thêm phòng ban mới
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert" style="background-color: var(--success-bg); color: var(--text-primary); border-radius: var(--radius-md); border-left: 4px solid var(--success) !important;">
        <div class="d-flex align-items-center">
            <i class="bi bi-check-circle-fill me-3 fs-5" style="color: var(--success);"></i>
            <div class="fw-medium">@TempData["SuccessMessage"]</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mb-4" role="alert" style="background-color: var(--danger-bg); color: var(--text-primary); border-radius: var(--radius-md); border-left: 4px solid var(--danger) !important;">
        <div class="d-flex align-items-center">
            <i class="bi bi-exclamation-triangle-fill me-3 fs-5" style="color: var(--danger);"></i>
            <div class="fw-medium">@TempData["ErrorMessage"]</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-3">
    <div class="col-xl-3 col-12">
        <div class="content-card h-100">
            <div class="card-header-custom border-bottom py-2 px-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-diagram-3 me-2"></i> Cây tổ chức</h5>
            </div>
            <div class="card-body-custom pt-2 px-3 pb-2">
                <div class="d-flex align-items-center gap-2 mb-2 px-2 py-1 rounded bg-primary bg-opacity-10 border border-primary border-opacity-25">
                    <i class="bi bi-building text-primary"></i>
                    <span class="fw-semibold text-dark">Tổ Chức / Công Ty</span>
                </div>
                
                <div class="ps-2 ms-1 border-start">
                    @{
                        if (Model != null && Model.Any())
                        {
                            // Gọi hàm in cây đa cấp không cần await
                            RenderDeptTree(Model, null, 0, employeeCounts);
                        }
                        else
                        {
                            <div class="text-muted fst-italic py-1 small">Chưa có phòng ban nào trong hệ thống</div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-9 col-12">
        <div class="content-card h-100">
            <div class="card-body-custom px-3 py-2">
                <form asp-action="Index" method="get" class="toolbar mb-2" style="padding: 6px 0;">
                    <div class="toolbar-left">
                        <div class="search-wrapper-premium" style="max-width: 350px;">
                            <i class="bi bi-search"></i>
                            <input type="text" name="searchString" value="@(ViewData["CurrentFilter"] ?? "")" class="search-input-premium" placeholder="Tìm kiếm mã hoặc tên phòng ban..." />
                        </div>
                    </div>
                    <div class="toolbar-right">
                        <div class="premium-select-wrapper" style="min-width: 170px;">
                            <span class="select-label">Trạng thái</span>
                            <i class="bi bi-toggle-on lead-icon"></i>
                            <select name="isActive" onchange="this.form.submit()">
                                <option value="" selected="@(string.IsNullOrEmpty(ViewBag.CurrentStatus))">Mọi trạng thái</option>
                                <option value="true" selected="@(ViewBag.CurrentStatus == "true")">Hoạt động</option>
                                <option value="false" selected="@(ViewBag.CurrentStatus == "false")">Ngừng HĐ</option>
                            </select>
                        </div>
                        <a asp-action="Index" class="btn-refresh-premium" title="Làm mới (Xóa bộ lọc)">
                            <i class="bi bi-arrow-clockwise fs-5"></i>
                        </a>
                        <button type="submit" class="btn-filter-premium" title="Lọc kết quả">
                            <i class="bi bi-funnel-fill"></i> Lọc
                        </button>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="data-table" style="font-size: 1rem;">
                        <thead>
                            <tr>
                                <th class="text-nowrap py-2" style="width: 80px;">Mã PB</th>
                                <th class="py-2" style="min-width: 150px;">Tên phòng ban</th>
                                <th class="text-nowrap py-2" style="min-width: 130px;">Trưởng phòng</th>
                                <th class="text-nowrap text-center py-2">Số NV</th>
                                <th class="text-nowrap py-2">Trạng thái</th>
                                <th class="text-end text-nowrap py-2">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var dept in Model)
                                {
                                    var managerName = dept.ManagerId.HasValue && employees.ContainsKey(dept.ManagerId.Value) 
                                                      ? employees[dept.ManagerId.Value] : "Chưa cập nhật";
                                    var count = employeeCounts.ContainsKey(dept.Id) ? employeeCounts[dept.Id] : 0;
                                    var statusClass = dept.IsActive == true ? "active" : "inactive";
                                    var statusDot = dept.IsActive == true ? "" : "text-danger bg-danger";
                                    var statusText = dept.IsActive == true ? "Hoạt động" : "Ngừng HĐ";
                                    var avatarLetter = managerName != "Chưa cập nhật" ? managerName[0].ToString().ToUpper() : "?";

                                    <tr class="hover-bg-light">
                                        <td class="fw-semibold text-muted py-1">@dept.DepartmentCode</td>
                                        <td class="fw-semibold text-dark py-1">@dept.DepartmentName</td>
                                        @if (managerName != "Chưa cập nhật")
                                        {
                                            <td class="py-1">
                                                <div class="d-flex align-items-center gap-1">
                                                    <div class="user-avatar bg-primary text-white fw-bold d-flex justify-content-center align-items-center" style="width: 20px; height: 20px; font-size: 0.65rem; flex-shrink:0;">
                                                        @avatarLetter
                                                    </div>
                                                    <span class="text-nowrap">@managerName</span>
                                                </div>
                                            </td>
                                        }
                                        else
                                        {
                                            <td class="py-1"><span class="text-muted fst-italic">@managerName</span></td>
                                        }
                                        <td class="text-center py-1"><span class="badge bg-light text-dark border" style="font-size: 0.9rem;">@count</span></td>
                                        <td class="text-nowrap py-1"><span class="status-badge @statusClass"><span class="status-dot @statusDot"></span> @statusText</span></td>
                                        <td onclick="event.stopPropagation();" class="py-1">
                                            <div class="action-btns justify-content-end">
                                            <a asp-action="Details" asp-route-id="@dept.Id" class="action-btn" title="Xem chi tiết"><i class="bi bi-eye"></i></a>
                                            <a asp-action="Edit" asp-route-id="@dept.Id" class="action-btn" title="Chỉnh sửa"><i class="bi bi-pencil"></i></a>

                                            @if (dept.IsActive == true)
                                            {
                                                <button class="action-btn danger" title="Ngưng hoạt động" data-bs-toggle="modal" data-bs-target="#deleteModal-@dept.Id">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <form asp-action="Activate" asp-route-id="@dept.Id" method="post" class="m-0">
                                                    <button type="submit" class="action-btn success" title="Kích hoạt lại"><i class="bi bi-arrow-clockwise"></i></button>
                                                </form>
                                            }
                                        </div>
                                        </td>
                                    </tr>

                                    @if (dept.IsActive == true)
                                    {
                                        <div class="modal fade" id="deleteModal-@dept.Id" tabindex="-1" aria-labelledby="deleteModalLabel-@dept.Id" aria-hidden="true">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content">
                                                    <div class="modal-header bg-danger text-white">
                                                        <h5 class="modal-title" id="deleteModalLabel-@dept.Id">Xác nhận ngưng hoạt động</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        Bạn có chắc muốn ngưng hoạt động phòng ban <strong>@dept.DepartmentName</strong>?
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                                        <form asp-action="Delete" asp-route-id="@dept.Id" method="post" class="m-0">
                                                            <button type="submit" class="btn btn-danger">Xác nhận</button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">Chưa có phòng ban nào trong hệ thống.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    </div>
</div>