@model IEnumerable<Manage_KPI_or_OKR_System.Models.Department>
@{
    ViewData["Title"] = "Quản lý Phòng ban";
    var employees = ViewBag.Employees as Dictionary<int, string> ?? new Dictionary<int, string>();
    var employeeCounts = ViewBag.EmployeeCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

@functions {
    public async Task RenderDeptTree(IEnumerable<Manage_KPI_or_OKR_System.Models.Department> allDepts, int? parentId, int depth, Dictionary<int, int> counts)
    {
        var children = allDepts.Where(d => d.ParentDepartmentId == parentId).ToList();
        if (!children.Any()) return;
        
        string indent = depth > 0 ? "ps-3 ms-1 border-start" : "";
        <div class="@indent">
            @foreach (var child in children)
            {
                var icon = depth == 0 ? "bi-folder-fill text-warning" : "bi-files text-secondary";
                var count = counts.ContainsKey(child.Id) ? counts[child.Id] : 0;
                <div class="d-flex justify-content-between align-items-center mb-2 py-1 px-2 rounded hover-bg-light" style="margin-left: -5px; cursor: pointer;">
                    <span class="d-flex align-items-center gap-2"><i class="bi @icon"></i> @child.DepartmentName</span>
                    <span class="badge bg-secondary rounded-pill">@count</span>
                </div>
                await RenderDeptTree(allDepts, child.Id, depth + 1, counts);
            }
        </div>
    }
}

<div class="page-header">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Cơ cấu tổ chức</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Phòng ban</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn-primary-custom" data-bs-toggle="modal" data-bs-target="#createDepartmentModal">
            <i class="bi bi-plus-lg"></i> Thêm phòng ban mới
        </button>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success shadow-sm border-0 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
    </div>
}

<div class="row g-4">
    <!-- Tree View (Left) -->
    <div class="col-lg-4">
        <div class="content-card h-100">
            <div class="card-header-custom border-bottom">
                <h5 class="mb-0 fw-bold"><i class="bi bi-diagram-3 me-2"></i> Cây tổ chức</h5>
            </div>
            <div class="card-body-custom pt-3">
                <div class="d-flex align-items-center gap-2 mb-3 px-2 py-2 rounded bg-primary bg-opacity-10 border border-primary border-opacity-25">
                    <i class="bi bi-building text-primary fs-5"></i>
                    <span class="fw-bold text-dark">Tổ Chức / Công Ty</span>
                </div>
                
                <div class="ps-3 ms-2 border-start">
                    @{
                        if (Model != null && Model.Any())
                        {
                            await RenderDeptTree(Model, null, 0, employeeCounts);
                        }
                        else
                        {
                            <div class="text-muted fst-italic py-2">Chưa có phòng ban nào trong hệ thống</div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Data Table (Right) -->
    <div class="col-lg-8">
        <div class="content-card h-100">
            <div class="card-body-custom">
                <div class="toolbar">
                    <div class="toolbar-search w-100" style="max-width: 300px;">
                        <i class="bi bi-search"></i>
                        <input type="text" placeholder="Tìm kiếm phòng ban...">
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Mã PB</th>
                                <th>Tên phòng ban</th>
                                <th>Trưởng phòng</th>
                                <th>Số lượng NV</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var dept in Model)
                                {
                                    var managerName = dept.ManagerId.HasValue && employees.ContainsKey(dept.ManagerId.Value) 
                                                      ? employees[dept.ManagerId.Value] : "Chưa cập nhật";
                                    var count = employeeCounts.ContainsKey(dept.Id) ? employeeCounts[dept.Id] : 0;
                                    var statusClass = dept.IsActive == true ? "active" : "inactive";
                                    var statusDot = dept.IsActive == true ? "" : "text-danger bg-danger";
                                    var statusText = dept.IsActive == true ? "Hoạt động" : "Ngừng HĐ";
                                    var avatarLetter = managerName != "Chưa cập nhật" ? managerName[0].ToString().ToUpper() : "?";

                                    <tr>
                                        <td class="fw-semibold text-muted">@dept.DepartmentCode</td>
                                        <td class="fw-bold text-dark">@dept.DepartmentName</td>
                                        <td>
                                            @if (managerName != "Chưa cập nhật")
                                            {
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="user-avatar bg-secondary text-white fw-bold d-flex justify-content-center align-items-center" style="width: 24px; height: 24px; font-size: 0.7rem;">
                                                        @avatarLetter
                                                    </div>
                                                    <span>@managerName</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted fst-italic">@managerName</span>
                                            }
                                        </td>
                                        <td><span class="badge bg-light text-dark border">@count</span></td>
                                        <td><span class="status-badge @statusClass"><span class="status-dot @statusDot"></span> @statusText</span></td>
                                        <td>
                                            <div class="action-btns justify-content-end">
                                                <button class="action-btn" title="Chỉnh sửa"><i class="bi bi-pencil"></i></button>
                                                @if (dept.IsActive == true)
                                                {
                                                    <form asp-action="Delete" asp-route-id="@dept.Id" method="post" class="m-0" onsubmit="return confirm('Xác nhận vô hiệu hóa phòng ban này?');">
                                                        <button type="submit" class="action-btn danger" title="Xóa"><i class="bi bi-trash"></i></button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">Chưa có phòng ban nào trong hệ thống.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Thêm Phòng Ban -->
<div class="modal fade" id="createDepartmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-building-add text-primary me-2"></i>Thêm Phòng Ban Mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-controller="Departments" asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label">Mã phòng ban <span class="text-danger">*</span></label>
                        <input type="text" name="DepartmentCode" class="form-control" placeholder="VD: PKD, HR" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tên phòng ban <span class="text-danger">*</span></label>
                        <input type="text" name="DepartmentName" class="form-control" placeholder="VD: Phòng Kinh doanh" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phòng ban cấp trên</label>
                        <select name="ParentDepartmentId" class="form-select">
                            <option value="">-- Không có (Phòng ban gốc) --</option>
                            @if (Model != null)
                            {
                                foreach (var d in Model.Where(m => m.IsActive == true))
                                {
                                    <option value="@d.Id">@d.DepartmentName</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Trưởng phòng</label>
                        <select name="ManagerId" class="form-select">
                            <option value="">-- Chọn trưởng phòng --</option>
                            @foreach (var emp in employees)
                            {
                                <option value="@emp.Key">@emp.Value</option>
                            }
                        </select>
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Lưu phòng ban</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
