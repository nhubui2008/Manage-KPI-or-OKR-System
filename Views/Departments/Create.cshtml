@model Manage_KPI_or_OKR_System.Models.Department

@{
    ViewData["Title"] = "Thêm mới Phòng ban";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var employees = ViewBag.Employees as Dictionary<int, string> ?? new Dictionary<int, string>();
    var departments = ViewBag.Departments as List<Manage_KPI_or_OKR_System.Models.Department> ?? new List<Manage_KPI_or_OKR_System.Models.Department>();
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-dark fw-bold">
                <i class="bi bi-diagram-3-fill me-2"></i>Thêm Phòng Ban Mới
            </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-dark text-decoration-none opacity-75">Hệ thống phòng ban</a></li>
                    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Thêm mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="content-card rounded-3">
        <div class="card-body-custom p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="mb-3">
                        <label asp-for="DepartmentCode" class="form-label fw-bold text-dark">Mã phòng ban <span class="text-danger">*</span></label>
                        <input asp-for="DepartmentCode" class="form-control" placeholder="VD: PKT, PNS, PBH..." required />
                        <span asp-validation-for="DepartmentCode" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DepartmentName" class="form-label fw-bold text-dark">Tên phòng ban <span class="text-danger">*</span></label>
                        <input asp-for="DepartmentName" class="form-control" placeholder="VD: Phòng Kinh doanh" required />
                        <span asp-validation-for="DepartmentName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ParentDepartmentId" class="form-label fw-bold text-dark">Phòng ban cấp trên</label>
                        <select asp-for="ParentDepartmentId" class="form-select">
                            <option value="">-- Là phòng ban cấp cao nhất --</option>
                            @foreach (var d in departments)
                            {
                                <option value="@d.Id">@d.DepartmentName (@d.DepartmentCode)</option>
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ManagerId" class="form-label fw-bold text-dark">Người quản lý (Trưởng bộ phận)</label>
                        <select asp-for="ManagerId" class="form-select">
                            <option value="">-- Chưa chỉ định --</option>
                            @foreach (var emp in employees)
                            {
                                <option value="@emp.Key">@emp.Value</option>
                            }
                        </select>
                    </div>

                    <div class="col-12">
                        <div class="d-flex justify-content-end gap-2 pt-3">
                            <a asp-action="Index" class="btn-outline-custom rounded-pill px-4">Hủy</a>
                            <button type="submit" class="btn-primary-custom rounded-pill px-4">Lưu phòng ban</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>