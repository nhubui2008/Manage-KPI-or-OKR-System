@model Manage_KPI_or_OKR_System.Models.EvaluationPeriod

@{
    ViewData["Title"] = "Thêm Kỳ Đánh giá";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var statuses = ViewBag.Statuses as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="text-dark fw-bold">
                <i class="bi bi-calendar-plus me-2"></i>Thêm Kỳ Đánh giá Mới
            </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none opacity-75">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-dark text-decoration-none opacity-75">Kỳ Đánh giá</a></li>
                    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Thêm mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="content-card rounded-3">
        <div class="card-body-custom p-4">
            
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="PeriodName" class="form-label fw-semibold">Tên kỳ đánh giá <span class="text-danger">*</span></label>
                        <input asp-for="PeriodName" class="form-control" placeholder="VD: Quý 1 - 2026" required />
                        <span asp-validation-for="PeriodName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="PeriodType" class="form-label fw-semibold">Loại kỳ <span class="text-danger">*</span></label>
                        <select asp-for="PeriodType" class="form-select">
                            <option value="MONTH">Hàng tháng</option>
                            <option value="QUARTER">Hàng quý</option>
                            <option value="YEAR">Hàng năm</option>
                        </select>
                        <span asp-validation-for="PeriodType" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="StartDate" class="form-label fw-semibold">Ngày bắt đầu <span class="text-danger">*</span></label>
                        <input asp-for="StartDate" type="date" class="form-control" required />
                        <span asp-validation-for="StartDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="EndDate" class="form-label fw-semibold">Ngày kết thúc <span class="text-danger">*</span></label>
                        <input asp-for="EndDate" type="date" class="form-control" required />
                        <span asp-validation-for="EndDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="StatusId" class="form-label fw-semibold">Trạng thái <span class="text-danger">*</span></label>
                        <select asp-for="StatusId" class="form-select">
                            @foreach (var s in statuses)
                            {
                                <option value="@s.Key">@s.Value</option>
                            }
                        </select>
                        <span asp-validation-for="StatusId" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                    <a asp-action="Index" class="btn-outline-custom px-4">
                        <i class="bi bi-x-circle me-1"></i> Hủy bỏ
                    </a>
                    <button type="submit" class="btn-primary-custom px-4">
                        <i class="bi bi-save me-1"></i> Tạo mới
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
