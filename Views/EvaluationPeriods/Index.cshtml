@model List<Manage_KPI_or_OKR_System.Models.EvaluationPeriod>
@{
    ViewData["Title"] = "Quản lý Kỳ Đánh giá";
    var statuses = ViewBag.Statuses as Dictionary<int, string> ?? new Dictionary<int, string>();
    var kpiCounts = ViewBag.KPICounts as Dictionary<int, int> ?? new Dictionary<int, int>();
    var isAdminRole = User.IsInRole("Admin") || User.IsInRole("Administrator");
    var canCreatePeriod = ViewBag.CanCreatePeriod is bool canCreateFromDb ? canCreateFromDb : isAdminRole || User.HasClaim("Permission", "EVALPERIODS_CREATE");
    var canEditPeriod = ViewBag.CanEditPeriod is bool canEditFromDb ? canEditFromDb : isAdminRole || User.HasClaim("Permission", "EVALPERIODS_EDIT");
    var canDeletePeriod = ViewBag.CanDeletePeriod is bool canDeleteFromDb ? canDeleteFromDb : isAdminRole || User.HasClaim("Permission", "EVALPERIODS_DELETE");
}

@functions {
    private static string NormalizePeriodTypeForView(string? periodType)
    {
        var value = periodType?.Trim().ToUpperInvariant();
        return value switch
        {
            "MONTH" or "THANG" or "THÁNG" or "HANG THANG" or "HÀNG THÁNG" => "MONTH",
            "QUARTER" or "QUY" or "QUÝ" or "HANG QUY" or "HÀNG QUÝ" => "QUARTER",
            "YEAR" or "NAM" or "NĂM" or "HANG NAM" or "HÀNG NĂM" => "YEAR",
            _ => value ?? string.Empty
        };
    }

    private static string GetPeriodTypeLabel(string? periodType)
    {
        return NormalizePeriodTypeForView(periodType) switch
        {
            "MONTH" => "Hàng tháng",
            "QUARTER" => "Hàng quý",
            "YEAR" => "Hàng năm",
            _ => string.IsNullOrWhiteSpace(periodType) ? "N/A" : periodType
        };
    }
}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Kỳ Đánh giá</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Kỳ Đánh giá</span>
        </div>
    </div>
    <div class="d-flex justify-content-end gap-2">
        @if (canCreatePeriod)
        {
            <a asp-action="Create" class="btn-primary-custom d-flex align-items-center">
                <i class="bi bi-plus-lg me-1"></i> Thêm kỳ đánh giá
            </a>
        }
    </div>
</div>

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100">
    <div class="card-body-custom">
        <div class="table-responsive w-100">
            <table class="data-table w-100">
                <thead>
                    <tr>
                        <th>Tên kỳ đánh giá</th>
                        <th>Loại kỳ</th>
                        <th>Thời gian</th>
                        <th>Tổng KPI</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var p in Model)
                        {
                            var statusName = p.StatusId.HasValue && statuses.ContainsKey(p.StatusId.Value) ? statuses[p.StatusId.Value] : "N/A";
                            var kpiCount = kpiCounts.ContainsKey(p.Id) ? kpiCounts[p.Id] : 0;
                            var normalizedPeriodType = NormalizePeriodTypeForView(p.PeriodType);
                            var periodTypeLabel = GetPeriodTypeLabel(p.PeriodType);
                            var badgeClass = normalizedPeriodType == "QUARTER" ? "bg-info bg-opacity-10 text-info border border-info border-opacity-25" : normalizedPeriodType == "YEAR" ? "bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25" : "bg-light text-dark border";
                            <tr>
                                <td class="fw-bold">
                                    <span class="text-primary-custom"><i class="bi bi-calendar-check me-2"></i>@p.PeriodName</span>
                                </td>
                                <td><span class="badge @badgeClass">@periodTypeLabel</span></td>
                                <td class="text-muted">@(p.StartDate?.ToString("dd/MM/yyyy") ?? "") - @(p.EndDate?.ToString("dd/MM/yyyy") ?? "")</td>
                                <td>@kpiCount KPI</td>
                                <td>
                                    @if (statusName == "Active" || statusName == "In Progress")
                                    {<span class="status-badge active"><span class="status-dot"></span> Đang mở</span>}
                                    else if (statusName == "Closed" || statusName == "Completed")
                                    {<span class="status-badge inactive"><span class="status-dot"></span> Đã đóng</span>}
                                    else
                                    {<span class="status-badge pending"><span class="status-dot"></span> @statusName</span>}
                                </td>
                                <td>
                                    <div class="action-btns justify-content-end">
                                        @if (canEditPeriod)
                                        {
                                            <button type="button" class="action-btn" title="Sửa" 
                                                    onclick="openEditModal(@p.Id, '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(p.PeriodName ?? ""))', '@normalizedPeriodType', '@p.StartDate?.ToString("yyyy-MM-dd")', '@p.EndDate?.ToString("yyyy-MM-dd")', @(p.StatusId ?? 0))">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                        }
                                        @if (canDeletePeriod)
                                        {
                                            <form asp-action="Delete" method="post" style="display:inline;">
                                                <input type="hidden" name="id" value="@p.Id" />
                                                <button type="submit" class="action-btn danger" title="Xóa" onclick="return confirm('Bạn có chắc muốn vô hiệu hóa kỳ đánh giá này?')"><i class="bi bi-trash"></i></button>
                                            </form>
                                        }
                                        @if (!canEditPeriod && !canDeletePeriod)
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size: 2rem;"></i><p class="mt-2">Chưa có kỳ đánh giá nào</p></td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


@if (canEditPeriod)
{
<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0"><h5 class="modal-title fw-bold"><i class="bi bi-pencil-square me-2"></i>Chỉnh sửa Kỳ Đánh giá</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form id="editPeriodForm" asp-action="Edit" method="post">
                <input type="hidden" id="editId" name="Id" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên kỳ đánh giá <span class="nameWarning text-danger small ms-2" style="display:none;">(Không khớp với Loại kỳ)</span></label>
                        <input type="text" id="editPeriodName" name="PeriodName" class="periodName form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Loại kỳ</label>
                        <select id="editPeriodType" name="PeriodType" class="periodType form-select no-select2">
                            <option value="MONTH">Hàng tháng</option>
                            <option value="QUARTER">Hàng quý</option>
                            <option value="YEAR">Hàng năm</option>
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-semibold">Ngày bắt đầu</label>
                            <input type="date" id="editStartDate" name="StartDate" class="startDate form-control" required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-semibold">Ngày kết thúc</label>
                            <input type="date" id="editEndDate" name="EndDate" class="endDate form-control" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Trạng thái</label>
                        <select id="editStatusId" name="StatusId" class="form-select no-select2">
                            @foreach (var s in statuses)
                            {<option value="@s.Key">@s.Value</option>}
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn-primary-custom d-flex align-items-center">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function normalizePeriodType(type) {
        const value = (type || '').trim().toUpperCase();
        if (['MONTH', 'THANG', 'THÁNG', 'HANG THANG', 'HÀNG THÁNG'].includes(value)) return 'MONTH';
        if (['QUARTER', 'QUY', 'QUÝ', 'HANG QUY', 'HÀNG QUÝ'].includes(value)) return 'QUARTER';
        if (['YEAR', 'NAM', 'NĂM', 'HANG NAM', 'HÀNG NĂM'].includes(value)) return 'YEAR';
        return value;
    }

    function openEditModal(id, name, type, start, end, statusId) {
        document.getElementById('editId').value = id;
        document.getElementById('editPeriodName').value = name;
        document.getElementById('editPeriodType').value = normalizePeriodType(type);
        document.getElementById('editStartDate').value = start;
        document.getElementById('editEndDate').value = end;
        document.getElementById('editStatusId').value = statusId;
        
        const modal = new bootstrap.Modal(document.getElementById('editModal'));
        modal.show();
    }

    document.addEventListener('DOMContentLoaded', function () {
        // Shared logic for both modals
        const forms = ['createPeriodForm', 'editPeriodForm'];
        
        forms.forEach(formId => {
            const form = document.getElementById(formId);
            if (!form) return;

            const pName = form.querySelector('.periodName');
            const pType = form.querySelector('.periodType');
            const sDate = form.querySelector('.startDate');
            const eDate = form.querySelector('.endDate');
            const warning = form.querySelector('.nameWarning');

            function suggestName() {
                if (!sDate.value) return;
                const date = new Date(sDate.value);
                const month = date.getMonth() + 1;
                const year = date.getFullYear();

                if (pType.value === 'MONTH') {
                    pName.value = `Tháng ${month < 10 ? '0' + month : month}/${year}`;
                } else if (pType.value === 'QUARTER') {
                    const quarter = Math.floor((month - 1) / 3) + 1;
                    pName.value = `Quý ${quarter} - ${year}`;
                } else if (pType.value === 'YEAR') {
                    pName.value = `Năm ${year}`;
                }
                checkConsistency();
            }

            function checkConsistency() {
                const name = pName.value.toLowerCase();
                const type = pType.value;
                let inconsistent = false;

                if (type === 'QUARTER' && name.includes('tháng')) inconsistent = true;
                if (type === 'MONTH' && name.includes('quý')) inconsistent = true;

                warning.style.display = inconsistent ? 'inline' : 'none';
            }

            pType.addEventListener('change', suggestName);
            sDate.addEventListener('change', suggestName);
            pName.addEventListener('input', checkConsistency);

            form.onsubmit = function (e) {
                const start = new Date(sDate.value);
                const end = new Date(eDate.value);
                
                if (end < start) {
                    alert('Ngày kết thúc không thể trước ngày bắt đầu.');
                    return false;
                }

                const diffTime = Math.abs(end - start);
                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;

                if (pType.value === 'QUARTER' && diffDays < 80) {
                    if (!confirm(`Kỳ đánh giá Hàng quý thông thường phải dài 3 tháng, nhưng bạn chỉ chọn ${diffDays} ngày. Tiếp tục?`)) {
                        return false;
                    }
                }
                
                if (pType.value === 'MONTH' && diffDays > 32) {
                    if (!confirm(`Kỳ đánh giá Hàng tháng thông thường dài 1 tháng, nhưng bạn chọn ${diffDays} ngày. Tiếp tục?`)) {
                        return false;
                    }
                }

                return true;
            };
        });
    });
</script>
}

        </div>
    </div>
</div>
