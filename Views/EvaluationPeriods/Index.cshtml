@model List<Manage_KPI_or_OKR_System.Models.EvaluationPeriod>
@{
    ViewData["Title"] = "Quản lý Kỳ Đánh giá";
    var statuses = ViewBag.Statuses as Dictionary<int, string> ?? new Dictionary<int, string>();
    var kpiCounts = ViewBag.KPICounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container-fluid px-0">
    
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 font-weight-bold mb-1">Kỳ Đánh giá</h1>
        <div class="page-breadcrumb">
            <a href="/">Trang chủ</a>
            <i class="bi bi-chevron-right separator"></i>
            <span>Kỳ Đánh giá</span>
        </div>
    </div>
    <div class="d-flex justify-content-end gap-2">
        <button class="btn-primary-custom d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#createModal">
            <i class="bi bi-plus-lg me-1"></i> Thêm kỳ đánh giá
        </button>
    </div>
</div>

<div class="row justify-content-center w-100 m-0">
        <div class="col-12 px-0">
            <div class="content-card w-100">
    <div class="card-body-custom">
        <div class="table-responsive w-100">
            <table class="data-table w-100">
                <thead>
                    <tr>
                        <th>Tên kỳ đánh giá</th>
                        <th>Loại kỳ</th>
                        <th>Thời gian</th>
                        <th>Tổng KPI</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var p in Model)
                        {
                            var statusName = p.StatusId.HasValue && statuses.ContainsKey(p.StatusId.Value) ? statuses[p.StatusId.Value] : "N/A";
                            var kpiCount = kpiCounts.ContainsKey(p.Id) ? kpiCounts[p.Id] : 0;
                            var badgeClass = p.PeriodType == "QUARTER" ? "bg-info bg-opacity-10 text-info border border-info border-opacity-25" : p.PeriodType == "YEAR" ? "bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25" : "bg-light text-dark border";
                            <tr>
                                <td class="fw-bold">
                                    <span class="text-primary-custom"><i class="bi bi-calendar-check me-2"></i>@p.PeriodName</span>
                                </td>
                                <td><span class="badge @badgeClass">@(p.PeriodType ?? "N/A")</span></td>
                                <td class="text-muted">@(p.StartDate?.ToString("dd/MM/yyyy") ?? "") - @(p.EndDate?.ToString("dd/MM/yyyy") ?? "")</td>
                                <td>@kpiCount KPI</td>
                                <td>
                                    @if (statusName == "Active" || statusName == "In Progress")
                                    {<span class="status-badge active"><span class="status-dot"></span> Đang mở</span>}
                                    else if (statusName == "Closed" || statusName == "Completed")
                                    {<span class="status-badge inactive"><span class="status-dot"></span> Đã đóng</span>}
                                    else
                                    {<span class="status-badge pending"><span class="status-dot"></span> @statusName</span>}
                                </td>
                                <td>
                                    <div class="action-btns justify-content-end">
                                        <button type="button" class="action-btn" title="Sửa" onclick="showComingSoonToast('Chỉnh sửa Kỳ Đánh giá')"><i class="bi bi-pencil-square"></i></button>
                                        <form asp-action="Delete" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@p.Id" />
                                            <button type="submit" class="action-btn danger" title="Xóa" onclick="return confirm('Bạn có chắc muốn vô hiệu hóa kỳ đánh giá này?')"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size: 2rem;"></i><p class="mt-2">Chưa có kỳ đánh giá nào</p></td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0"><h5 class="modal-title fw-bold"><i class="bi bi-calendar-plus me-2"></i>Thêm Kỳ Đánh giá</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form asp-action="Create" method="post">
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label fw-semibold">Tên kỳ đánh giá</label><input type="text" name="PeriodName" class="form-control" required placeholder="VD: Quý 1 - 2026" /></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Loại kỳ</label>
                        <select name="PeriodType" class="form-select"><option value="MONTH">Hàng tháng</option><option value="QUARTER">Hàng quý</option><option value="YEAR">Hàng năm</option></select></div>
                    <div class="row"><div class="col-6 mb-3"><label class="form-label fw-semibold">Ngày bắt đầu</label><input type="date" name="StartDate" class="form-control" required /></div>
                    <div class="col-6 mb-3"><label class="form-label fw-semibold">Ngày kết thúc</label><input type="date" name="EndDate" class="form-control" required /></div></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Trạng thái</label>
                        <select name="StatusId" class="form-select">
                            @foreach (var s in statuses)
                            {<option value="@s.Key">@s.Value</option>}
                        </select></div>
                </div>
                <div class="modal-footer border-0"><button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn-primary-custom d-flex align-items-center">Tạo mới</button></div>
            </form>
        </div>
    </div>
</div>

        </div>
    </div>
</div>