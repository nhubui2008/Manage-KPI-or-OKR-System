{
  "DetailedErrors": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "ForwardedHeaders": {
    "Enabled": false,
    "KnownProxies": [],
    "TrustAllProxies": false,
    "ForwardLimit": 1
  },
  "Database": {
    "RunMigrationsOnStartup": true
  }
}
